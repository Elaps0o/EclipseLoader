local function _espDrawArrow(data, root)
    local arrow = ensureESPArrow(data)
    if not arrow then return end
    local cf  = Camera.CFrame
    local rel = cf:PointToObjectSpace(root.Position)
    local ang
    if rel.Z > 0 then
        ang = math.atan2(-rel.X, rel.Z)
    else
        ang = math.atan2(rel.X, -rel.Z)
    end
    local vs = Camera.ViewportSize
    local cx2, cy2 = vs.X/2, vs.Y/2
    local rad = math.min(cx2, cy2) - 80
    local tipX = cx2 + math.sin(ang) * rad
    local tipY = cy2 - math.cos(ang) * rad
    local size = 12
    local dx, dy = math.sin(ang), -math.cos(ang)
    local perpX, perpY = -dy, dx
    local baseX = tipX - dx * size * 1.8
    local baseY = tipY - dy * size * 1.8
    arrow.PointA = Vector2.new(tipX, tipY)
    arrow.PointB = Vector2.new(baseX + perpX*size, baseY + perpY*size)
    arrow.PointC = Vector2.new(baseX - perpX*size, baseY - perpY*size)
    arrow.Color = Config.ESP.ArrowsColor
    arrow.Filled = true
    arrow.Transparency = 1
    arrow.Visible = true
end

local function _espDrawCornerBox(data, plr, L, R, T, B, cW, cH)
    local col = IsAlly(plr) and Config.ESP.AllyBoxColor or Config.ESP.BoxColor
    local ln = data.CornerLines
    ln[1].From=Vector2.new(L,T); ln[1].To=Vector2.new(L+cW,T); ln[1].Color=col; ln[1].Visible=true
    ln[2].From=Vector2.new(L,T); ln[2].To=Vector2.new(L,T+cH); ln[2].Color=col; ln[2].Visible=true
    ln[3].From=Vector2.new(R,T); ln[3].To=Vector2.new(R-cW,T); ln[3].Color=col; ln[3].Visible=true
    ln[4].From=Vector2.new(R,T); ln[4].To=Vector2.new(R,T+cH); ln[4].Color=col; ln[4].Visible=true
    ln[5].From=Vector2.new(L,B); ln[5].To=Vector2.new(L+cW,B); ln[5].Color=col; ln[5].Visible=true
    ln[6].From=Vector2.new(L,B); ln[6].To=Vector2.new(L,B-cH); ln[6].Color=col; ln[6].Visible=true
    ln[7].From=Vector2.new(R,B); ln[7].To=Vector2.new(R-cW,B); ln[7].Color=col; ln[7].Visible=true
    ln[8].From=Vector2.new(R,B); ln[8].To=Vector2.new(R,B-cH); ln[8].Color=col; ln[8].Visible=true
end

local function _espDrawHealth(data, hum, L, T, B, height)
    local pct = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
    local bx = L - 10
    data.HealthBg.From = Vector2.new(bx, T); data.HealthBg.To = Vector2.new(bx, B); data.HealthBg.Visible = true
    data.HealthFill.Visible = false
    local maxSegs = #data.HealthSegments
    local segments = math.clamp(math.floor(height / 4), 6, maxSegs)
    for i = 1, maxSegs do
        local seg = data.HealthSegments[i]
        if i <= segments then
            local a = (i - 1) / segments
            local b = i / segments
            seg.From = Vector2.new(bx, B - (height * a))
            seg.To = Vector2.new(bx, B - (height * b) + 1)
            seg.Color = GetHealthColor((a + b) * 0.5)
            seg.Thickness = (height < 40) and 2 or 3
            seg.Transparency = 1
            seg.Visible = b <= pct + (1 / segments)
        else
            seg.Visible = false
        end
    end
    if data.HealthTicks then
        local showTicks = height >= 48
        local tickX1, tickX2 = bx - 4, bx + 4
        for i, tick in ipairs(data.HealthTicks) do
            if showTicks then
                local frac = (i == 1) and (1/3) or (2/3)
                local ty = B - (height * frac)
                tick.From = Vector2.new(tickX1, ty)
                tick.To   = Vector2.new(tickX2, ty)
                tick.Transparency = 1
                tick.Visible = true
            else
                tick.Visible = false
            end
        end
    end
    data.HealthText.Visible = false
end

local function _espDrawSkeleton(data, char)
    local col = Config.ESP.SkeletonColor
    local shown = {}
    for i, bone in ipairs(SkeletonBones) do
        local ln = data.Skeleton[i]
        local a = char:FindFirstChild(bone[1])
        local b = char:FindFirstChild(bone[2])
        if a and b and a:IsA("BasePart") and b:IsA("BasePart") then
            local pa, oa = Camera:WorldToViewportPoint(a.Position)
            local pb, ob = Camera:WorldToViewportPoint(b.Position)
            if oa and ob then
                ln.From = Vector2.new(pa.X, pa.Y)
                ln.To   = Vector2.new(pb.X, pb.Y)
                ln.Color = col; ln.Visible = true
                shown[i] = true
            end
        end
    end
    for i, ln in ipairs(data.Skeleton) do if not shown[i] then ln.Visible = false end end
end

