-- text while dead). When alive again, the existing apply loop replays.
task.spawn(function()
    local wasAlive = false
    while scriptRunning do
        local alive = IsAlive()
        if wasAlive and not alive then
            for slotFrame, rec in pairs(HUDSkin.slots) do
                if slotFrame and slotFrame.Parent then
                    local nameLbl, iconLbl, iconViewport = _slotParts(slotFrame)
                    if nameLbl then pcall(_restoreHUDName, rec, nameLbl) end
                    if iconLbl or iconViewport then pcall(_restoreOriginalHUDIcon, rec, iconLbl, iconViewport) end
                end
            end
        elseif not wasAlive and alive and Config.Skins.SkinChangerEnabled then
            -- Force-restore native icons/names first so any transient hidden
            -- state from death frame doesn't leave the knife icon invisible.
            for slotFrame, rec in pairs(HUDSkin.slots) do
                if slotFrame and slotFrame.Parent then
                    local nameLbl, iconLbl, iconViewport = _slotParts(slotFrame)
                    if nameLbl then pcall(_restoreHUDName, rec, nameLbl) end
                    if iconLbl or iconViewport then pcall(_restoreOriginalHUDIcon, rec, iconLbl, iconViewport) end
                end
            end
            for slotFrame in pairs(HUDSkin.slots) do
                if slotFrame and slotFrame.Parent then pcall(_queueHUDSlotApply, slotFrame) end
            end
        end
        wasAlive = alive
        task.wait(0.25)
    end
end)



