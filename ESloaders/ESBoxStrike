function _applyGloveSideDirect(glove, side, gloveSkin, gsr, directSurfaceApps, sourceKey)
    if glove:GetAttribute("EclipseSkinSource") == sourceKey and glove:GetAttribute("SkinApplied") == gloveSkin then return end
    _restoreGloveSurfaceOnly(glove, side)
    _cacheSkinTarget(glove)
    for _, old in ipairs(glove:GetChildren()) do
        if old:IsA("SurfaceAppearance") then old:Destroy() end
    end
    if #directSurfaceApps > 0 then
        for _, sa in ipairs(directSurfaceApps) do
            local c = sa:Clone()
            c.Name = "SurfaceAppearance"
            c:SetAttribute("EclipseSkinSurface", true)
            c:SetAttribute("EclipseSurfaceSource", sourceKey)
            c.Parent = glove
        end
        glove:SetAttribute("EclipseSkinSource", sourceKey)
        glove:SetAttribute("SkinApplied", gloveSkin)
        return
    end
    local sideSource = gsr:FindFirstChild(side)
    if sideSource then
        _applySkinSourceToPart(glove, sideSource)
        glove:SetAttribute("SkinApplied", gloveSkin)
    end
end

function _applyGloveSkinCore(gloveSkin)
    local gf = SkinsFolder:FindFirstChild("Sports Gloves"); if not gf then return end
    local gs = gf:FindFirstChild(gloveSkin)
    local gsr = gs and gs:FindFirstChild("Camera") and gs.Camera:FindFirstChild("Factory New")
    if not gsr then return end
    local directSurfaceApps = {}
    for _, sa in ipairs(gsr:GetChildren()) do
        if sa:IsA("SurfaceAppearance") then table.insert(directSurfaceApps, sa) end
    end
    local sourceKey = "Sports Gloves/" .. tostring(gloveSkin)
    _forEachCameraGlove(function(glove, side)
        pcall(_applyGloveSideDirect, glove, side, gloveSkin, gsr, directSurfaceApps, sourceKey)
    end)
end

function _applySelectedGloveSkin()
