local _wcEffect
local function _ensureWCEffect()
    if _wcEffect and _wcEffect.Parent then return _wcEffect end
    _wcEffect = Instance.new("ColorCorrectionEffect")
    _wcEffect.Name = "EclipseWorldColor"
    _wcEffect.Saturation = 0
    _wcEffect.Enabled = false
    _wcEffect.Parent = _Lighting
    return _wcEffect
end
