local _PEN_LAST = 0
function updatePenetrationCrosshair()
    local on = Config.GlobalEnable and Config.Crosshair.PenetrationEnabled
    if not on or not Camera then _pen3dHide(); return end
    local t = tick()
    if t - _PEN_LAST < 0.05 then return end
    _PEN_LAST = t
    local st = _pen3dEnsure()
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    pcall(function() params.CollisionGroup = "Bullet" end)
    params.FilterDescendantsInstances = { LocalPlayer.Character, Camera, st.part }
    local origin = Camera.CFrame.Position
    local dir = Camera.CFrame.LookVector
    local res = Workspace:Raycast(origin, dir * 4500, params)
    if not res then _pen3dHide(); return end
    local stats = GetPenetrationStats(origin, dir, tonumber(Config.Aimbot and Config.Aimbot.WallDepth) or 1.0, { LocalPlayer.Character, Camera, st.part }, nil)
    local col = stats.Success and (Config.Crosshair.PenetrationOkColor or Color3.fromRGB(0,255,0))
                              or (Config.Crosshair.PenetrationNoColor or Color3.fromRGB(255,60,60))
    local pos = res.Position + (res.Normal or Vector3.new(0,1,0)) * 0.05
    local dist = (pos - origin).Magnitude
    -- Calibrated: tighter base size, gentler distance scaling, softer alpha
    local scale = math.clamp(0.55 + dist * 0.006, 0.7, 3.2)
    st.part.Color = col
    st.part.Transparency = 0.35
    st.part.Size = Vector3.new(0.55 * scale, 0.55 * scale, 0.04)
    local cf = CFrame.lookAt(pos, pos + (res.Normal or Vector3.new(0,1,0)))
    pcall(function() st.part.CFrame = cf end)

end




