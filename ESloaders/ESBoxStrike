-- ESP PREVIEW PANEL: a keybind-list-styled side panel that snaps next to the
-- main GUI while the Visuals tab is active. Shows a demo enemy silhouette
-- with the currently-enabled ESP overlays (box, chams, name/distance text)
-- so the user can preview colors and styles before enabling them in game.
;(function() if true then return end -- ESP PREVIEW disabled (removed per user request)
local ESPPreview = { gui=nil, frame=nil, viewport=nil, cam=nil, dummy=nil, visible=false }
-- Cached preview source model. Filled the first time ANY player (including
-- LocalPlayer) is alive, then reused forever so the preview keeps working
-- when the round is empty / everyone is dead. Refreshed opportunistically
-- whenever a live enemy character becomes available.
local _cachedPreviewSrc = nil -- Model (clone, parked off-workspace)

function _snapshotPlayerModel(ch)
    if not ch then return nil end
    local ok, clone = pcall(function() return ch:Clone() end)
    if not ok or not clone then return nil end
    for _, d in ipairs(clone:GetDescendants()) do
        if d:IsA("BasePart") then
            d.Anchored = true; d.CanCollide = false
        elseif d:IsA("Script") or d:IsA("LocalScript") then
            d:Destroy()
        end
    end
    return clone
end

function _refreshCachedPreviewSrc()
    -- Prefer a RANDOM other player who has a Character (alive OR ragdoll).
    -- If no other player has one, fall back to LocalPlayer's Character
    -- (also alive OR ragdoll). Only bail when literally no rig exists —
    -- keeps the preview usable even when everyone is dead / waiting.
    local pool = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChildWhichIsA("BasePart") then
            table.insert(pool, p.Character)
        end
    end
    local ch = (#pool > 0 and pool[math.random(1, #pool)])
        or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("BasePart")
            and LocalPlayer.Character)
    if not ch then return end
    local snap = _snapshotPlayerModel(ch)
    if snap then
        if _cachedPreviewSrc then pcall(function() _cachedPreviewSrc:Destroy() end) end
        _cachedPreviewSrc = snap
    end
end

function _cloneLocalCharacter()
    -- Return a fresh clone of the cached source (build it if we don't have
    -- one yet). This guarantees the preview works even when NO player is
    -- alive right now — including when the localplayer is dead.
    if not _cachedPreviewSrc then _refreshCachedPreviewSrc() end
    if not _cachedPreviewSrc then return nil end
    local ok, clone = pcall(function() return _cachedPreviewSrc:Clone() end)
    if not ok or not clone then return nil end
    return clone
end

-- Kick off an initial snapshot as soon as the script loads.
task.spawn(function()
    for _ = 1, 40 do
        _refreshCachedPreviewSrc()
        if _cachedPreviewSrc then break end
        task.wait(0.5)
    end
end)
-- Refresh the cache whenever a new alive enemy shows up.
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(1); _refreshCachedPreviewSrc() end)
end)
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        p.CharacterAdded:Connect(function() task.wait(1); _refreshCachedPreviewSrc() end)
    end
end

