        end
    end)

    local function _hookHumanoidDied(plr, char)
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if hum:GetAttribute("EclipseKillHooked") then return end
        hum:SetAttribute("EclipseKillHooked", true)
        local hConn, dConn
        hConn = hum.HealthChanged:Connect(function(hp)
            if tonumber(hp) and hp <= 0 then
                if hConn then pcall(function() hConn:Disconnect() end) end
                pcall(_tryKillEffectFromHealth, plr, char)
            end
        end)
        dConn = hum.Died:Connect(function()
            if dConn then pcall(function() dConn:Disconnect() end) end
            if hConn then pcall(function() hConn:Disconnect() end) end
            pcall(_tryKillEffectFromHealth, plr, char)
        end)
        table.insert(UnloadConnections, hConn)
        table.insert(UnloadConnections, dConn)
    end

    local function _bindPlayer(plr)
        if plr.Character then _hookHumanoidDied(plr, plr.Character) end
        table.insert(UnloadConnections, plr.CharacterAdded:Connect(function(c)
            task.wait(0.2); _hookHumanoidDied(plr, c)
        end))
    end
    for _, plr in ipairs(Players:GetPlayers()) do _bindPlayer(plr) end
    table.insert(UnloadConnections, Players.PlayerAdded:Connect(_bindPlayer))

    -- Fallback: watch LocalPlayer leaderstats.Kills / Score. On increment, trigger the effect
    -- on the nearest recently-dead enemy. Bypasses damage/attribution heuristics that can miss.
    local function _forceKillEffectOnNearestDead()
        if not (Config.GlobalEnable and Config.Visuals.KillEffect) then return end
        if not _localIsAlive() then return end
        local myChar = LocalPlayer.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Torso"))
        if not myRoot then return end
        local best, bd
        for _, plr in ipairs(Players:GetPlayers()) do
            if _isEnemyPlayer(plr) and plr.Character then
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                local r = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
                if hum and r and hum.Health <= 0 and not _killEffectDone[plr.Character] and _killCharVisible(plr.Character) then
                    local d = (r.Position - myRoot.Position).Magnitude
                    if not bd or d < bd then bd = d; best = plr.Character end
                end
            end
        end
        if best then
            _killEffectDone[best] = tick()
            task.spawn(function() pcall(_spawnKillEffect, best) end)
        end
    end
    local function _bindKillsWatcher()
        pcall(function()
            local ls = LocalPlayer:FindFirstChild("leaderstats")
            if not ls then return end
            for _, stat in ipairs(ls:GetChildren()) do
                local n = tostring(stat.Name or ""):lower()
                if (n == "kills" or n == "score" or n == "frags") and stat:IsA("ValueBase") and not stat:GetAttribute("EclipseKillWatch") then
                    stat:SetAttribute("EclipseKillWatch", true)
                    local last = tonumber(stat.Value) or 0
                    local conn = stat.Changed:Connect(function(v)
                        local cur = tonumber(v) or 0
                        if cur > last then
                            last = cur
                            task.defer(_forceKillEffectOnNearestDead)
                            task.delay(0.25, _forceKillEffectOnNearestDead)
                        else
                            last = cur
                        end
                    end)
                    table.insert(UnloadConnections, conn)
                end
            end
        end)
    end
    _bindKillsWatcher()
    table.insert(UnloadConnections, LocalPlayer.ChildAdded:Connect(function(c)
        if c.Name == "leaderstats" then
            task.wait(0.3); _bindKillsWatcher()
            table.insert(UnloadConnections, c.ChildAdded:Connect(function() task.wait(0.1); _bindKillsWatcher() end))
        end
    end))
    do
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            table.insert(UnloadConnections, ls.ChildAdded:Connect(function() task.wait(0.1); _bindKillsWatcher() end))
        end
    end

    -- === HvH-style kill detection via Workspace.Debris ChildAdded ===
    -- Fires for every death (unattributable to killer here), but only for
    -- corpses currently VISIBLE from the local camera (raycast unobstructed
    -- or on-screen with short ray) to save FPS/RAM.
    local function _corpseIsVisible(model)
        local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso") or model:FindFirstChild("Head")
        if not hrp then return false, math.huge end
        local cam = workspace.CurrentCamera
        if not cam then return false, math.huge end
        local dist = (cam.CFrame.Position - hrp.Position).Magnitude
        if dist > 500 then return false, dist end
        local _, onScreen = cam:WorldToViewportPoint(hrp.Position)
        if not onScreen then return false, dist end
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local ex = { model }
        if LocalPlayer.Character then table.insert(ex, LocalPlayer.Character) end
        rp.FilterDescendantsInstances = ex
        rp.IgnoreWater = true
        local dir = hrp.Position - cam.CFrame.Position
        local hit = Workspace:Raycast(cam.CFrame.Position, dir, rp)
        if hit and (hit.Position - cam.CFrame.Position).Magnitude < (dist - 2) then
            return false, dist
        end
        return true, dist
    end

    local function _watchDebrisFolder(folder)
        if not folder or folder:GetAttribute("EclipseKFXHooked") then return end
        folder:SetAttribute("EclipseKFXHooked", true)
        local conn = folder.ChildAdded:Connect(function(child)
            if not (Config.GlobalEnable and Config.Visuals.KillEffect) then return end
            task.wait(0.05)
            if not (child:IsA("Model") and child:FindFirstChildOfClass("Humanoid") and (child:FindFirstChild("Head") or child:FindFirstChild("UpperTorso"))) then return end
            if _killEffectDone[child] then return end
            if not _localIsAlive() then return end
            -- Filtra: nao aplicar em aliados, no LocalPlayer, ou vitima sem attribution ao LP.
            local vplr = Players:GetPlayerByUserId(tonumber(child:GetAttribute("UserId")) or -1)
                       or Players:FindFirstChild(child.Name)
            if vplr == LocalPlayer then return end
            if vplr and IsAlly and IsAlly(vplr) then return end
            local lethalAt = vplr and (_lastLethalByLP[vplr] or _lastLethalByUid[tonumber(vplr.UserId)])
            local dmgAt    = vplr and _lastDamagedByLP[vplr]
            local killedByLP = (lethalAt and (tick()-lethalAt) < 5.0)
                            or (dmgAt and (tick()-dmgAt) < 2.0)
            if not killedByLP then return end
            local vis, dist = _corpseIsVisible(child)
            if not vis then
                pcall(function() print(string.format("[Eclipse KillFX] Skipped (not visible) victim=%s dist=%.1f", tostring(child.Name), dist or -1)) end)
                return
            end

            _killEffectDone[child] = tick()
            pcall(function() print(string.format("[Eclipse KillFX] Trigger victim=%s dist=%.1f type=%s", tostring(child.Name), dist or -1, tostring(Config.Visuals.KillEffectType))) end)
            task.spawn(function() pcall(_spawnKillEffect, child) end)
        end)
        table.insert(UnloadConnections, conn)
    end

    do
        local db = Workspace:FindFirstChild("Debris")
        if db then _watchDebrisFolder(db) end
        table.insert(UnloadConnections, Workspace.ChildAdded:Connect(function(c)
            if c.Name == "Debris" then task.wait(0.1); _watchDebrisFolder(c) end
        end))
    end
end)()


