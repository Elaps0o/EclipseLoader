-- Try to disable a UI element cleanly across Obsidian variants (SetDisabled,
-- .Disabled prop, else fall back to silent-revert in the callback).
-- Track every skin-related control so we can lock ALL of them at once.
local _skinLockedUI = {}

-- Walk an Obsidian control table and collect every GuiObject Instance it
-- exposes (Holder, Container, TextLabel, DropdownFrame, DropdownButton, etc.).
function _collectGuiInstances(obj, out, depth, seen)
    out = out or {}; depth = depth or 0; seen = seen or {}
    if type(obj) ~= "table" or depth > 6 or seen[obj] then return out end
    seen[obj] = true
    for _, v in pairs(obj) do
        if typeof(v) == "Instance" and v:IsA("GuiObject") then
            table.insert(out, v)
        elseif type(v) == "table" then
            _collectGuiInstances(v, out, depth + 1, seen)
        end
    end
    return out
end


-- Robust visual+input lock. Sets Interactable=false on every TextButton /
-- ImageButton descendant of the control (that IS what Obsidian actually
-- clicks), and stamps a translucent overlay on the largest known frame so
-- the user sees it is locked. Works for any Obsidian toggle/dropdown.
function _uiSetDisabled(obj, disabled)
    if not obj then return end
    pcall(function() if type(obj.SetDisabled) == "function" then obj:SetDisabled(disabled) end end)
    pcall(function() obj.Disabled = disabled end)

    local roots = _collectGuiInstances(obj)
    local biggest, biggestArea = nil, -1
    for _, root in ipairs(roots) do
        -- 1) block input on every clickable descendant (and the root itself)
        pcall(function()
            if root:IsA("GuiButton") then root.Interactable = not disabled end
        end)
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("GuiButton") then
                pcall(function() d.Interactable = not disabled end)
            end
        end
        -- 2) find the largest frame to host the dim overlay
        local sz = root.AbsoluteSize
        local area = (sz and (sz.X * sz.Y)) or 0
        if area > biggestArea then biggest, biggestArea = root, area end
    end

    if biggest then
        local overlay = biggest:FindFirstChild("_EclipseLock")
        if disabled then
            if not overlay then
                overlay = Instance.new("Frame")
                overlay.Name = "_EclipseLock"
                overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                overlay.BackgroundTransparency = 0.55
                overlay.BorderSizePixel = 0
                overlay.Size = UDim2.fromScale(1, 1)
                overlay.ZIndex = 9999
                overlay.Active = true      -- Sinks clicks so nothing behind is interactable
                overlay.Selectable = false
                overlay.Parent = biggest
            end
        elseif overlay then
            overlay:Destroy()
        end
    end

end

