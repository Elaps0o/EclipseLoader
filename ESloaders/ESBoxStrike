-- ================================================================
-- LOADER GATE — refuses to run unless the user came through the
-- official Eclipse loader. Two independent checks: (1) the loader
-- sets getgenv().EclipseLoaderLoaded in the same executor session,
-- (2) the loader writes a signed session file we can re-verify with
-- the shared secret. If BOTH fail, we kick and bail — this blocks
-- "espertinhos" trying to loadstring ec.lua directly.
-- ================================================================
do
    local ok = rawget(getgenv(), "EclipseLoaderLoaded") == true
    if not ok and writefile and readfile and isfile then
        local SESSION_FILE = "EclipseHub_session.dat"
        local SIG_SECRET   = "ES_v1_9f2a4c1e8b6d3a57f2e0c9b1a48d76e2c5f0"
        local SESSION_TTL  = 30 * 86400
        local function _sign(data)
            local payload = data .. "|" .. SIG_SECRET
            if crypt and type(crypt.hash) == "function" then
                local o, h = pcall(crypt.hash, payload, "sha256"); if o and h then return h end
            end
            if syn and syn.crypto and type(syn.crypto.hash) == "function" then
                local o, h = pcall(syn.crypto.hash, "sha256", payload); if o and h then return h end
            end
            local h1, h2 = 2166136261, 3735928559
            for i = 1, #payload do
                local b = string.byte(payload, i)
                h1 = (bit32.bxor(h1, b) * 16777619) % 0x100000000
                h2 = (bit32.bxor(h2, b * 131 + i) * 2246822519) % 0x100000000
            end
            return string.format("%08x%08x", h1, h2)
        end
        local ex = pcall(isfile, SESSION_FILE) and isfile(SESSION_FILE)
        if ex then
            local _, body = pcall(readfile, SESSION_FILE)
            if body and body ~= "" then
                local payload, sig = body:match("^(.-)%.([^%.]+)$")
                if payload and sig and _sign(payload) == sig then
                    local o, tbl = pcall(function() return HttpService:JSONDecode(payload) end)
                    if o and type(tbl) == "table"
                        and tbl.userId == LocalPlayer.UserId
                        and tbl.username == LocalPlayer.Name
                        and type(tbl.issued) == "number"
                        and (os.time() - tbl.issued) <= SESSION_TTL then
                        ok = true
                    end
                end
            end
        end
    end
    if not ok then
        pcall(function()
            LocalPlayer:Kick("Eclipse Hub: please use the official loader. Direct execution is blocked.")
        end)
        error("Eclipse Hub: loader gate failed — script must be launched by the Eclipse loader.")
    end
end

