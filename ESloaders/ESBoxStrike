-- C4 TIMER  ·  Dedicated Obsidian-styled GUI (no Library:Notify spam).
-- =========================================================================
local C4Timer = {
    planted     = false,
    bomb        = nil,
    endT        = 0,
    duration    = 45,
    exact       = false,
    defuser     = nil,
    defAlerted  = false,
    hideAt      = 0,
}

-- The game resolves bomb/defuse timing through server-synced attributes.  The
-- old hardcoded 50s value could drift and leave 5-6s on-screen when the bomb
-- exploded, so this uses Bomb tag/attributes first and a 45s fallback only when
-- the server exposes no timestamp.
local C4_FALLBACK_DURATION = 40
local C4_ATTR_END = {
    "ExplodeTime", "ExplosionTime", "DetonationTime", "DetonateTime",
    "BombExplodeTime", "BombExplosionTime", "BombDetonateTime",
    "ExplodesAt", "DetonatesAt", "EndTime", "EndTimestamp", "FinishTime",
}
local C4_ATTR_START = {
    "PlantTime", "PlantedTime", "BombPlantTime", "BombPlantedTime",
    "PlantStartTime", "BombStartedAt", "StartedAt", "StartTime", "CreatedAt", "SpawnTime",
}
local C4_ATTR_REMAIN = {
    "TimeLeft", "RemainingTime", "BombTimeLeft", "DetonationTimeLeft",
    "FuseRemaining", "Timer", "Countdown",
}
local C4_ATTR_DURATION = {
    "BombDuration", "Duration", "FuseTime", "DetonationDuration",
    "ExplodeDuration", "ExplosionDuration", "C4Duration",
}

function c4ServerNow()
    local ok, now = pcall(function() return Workspace:GetServerTimeNow() end)
    if ok and typeof(now) == "number" then return now end
    return tick()
end

function c4ClampDuration(v)
    v = tonumber(v) or C4_FALLBACK_DURATION
    if v < 20 or v > 90 then return C4_FALLBACK_DURATION end
    return v
end

function c4ReadNumberAttr(inst, names, matcher)
    if not inst or not inst.GetAttribute then return nil end
    for _, name in ipairs(names) do
        local ok, value = pcall(function() return inst:GetAttribute(name) end)
        if ok and typeof(value) == "number" then return value, name end
    end
    local ok, attrs = pcall(function() return inst:GetAttributes() end)
    if not ok or type(attrs) ~= "table" then return nil end
    for name, value in pairs(attrs) do
        if typeof(value) == "number" and matcher(string.lower(tostring(name))) then
            return value, name
        end
    end
    return nil
end

function _bombLooksPlanted(inst)
    if not inst or not inst.GetAttribute then return false end
    -- Any real "planted" signal from the server: attribute flag, a plant/end
    -- timestamp, or a remaining-time attribute. Presence alone is NOT enough
    -- (the map ships a dummy 'Character' model that caused false positives).
    for _, k in ipairs({"Planted","BombPlanted","IsPlanted","Active"}) do
        if inst:GetAttribute(k) == true then return true end
    end
    for _, k in ipairs(C4_ATTR_END) do
        if typeof(inst:GetAttribute(k)) == "number" then return true end
    end
    for _, k in ipairs(C4_ATTR_START) do
        if typeof(inst:GetAttribute(k)) == "number" then return true end
    end
    for _, k in ipairs(C4_ATTR_REMAIN) do
        local v = inst:GetAttribute(k)
        if typeof(v) == "number" and v > 0 and v <= 90 then return true end
    end
    return false
end

-- Strict planted-bomb detection: only accept CollectionService-tagged "Bomb"
-- objects that ALSO have plant/fuse timing attributes. This eliminates the
-- false positives from the dummy "Character" model in workspace.Debris that
-- was making the C4 panel appear without a real plant. Uses the same signal
-- the game's own DefuseKit UI listens to.
function getBombModel()
    -- Primary: CollectionService "Bomb" tag (used by the game's DefuseKit UI).
    local ok, tagged = pcall(function() return CollectionService:GetTagged("Bomb") end)
    if ok and type(tagged) == "table" then
        for _, bomb in ipairs(tagged) do
            if bomb and bomb.Parent and bomb:IsDescendantOf(Workspace)
               and _bombLooksPlanted(bomb) then
                local n = string.lower(bomb.Name or "")
                if n == "c4" or n:find("bomb", 1, true) then return bomb end
            end
        end
    end
    -- Fallback: same signal the world-ESP uses — a Model in workspace.Debris
    -- with the BombPlanted attribute. Keeps the C4 panel in lockstep with the
    -- ESP marker (both trigger together) without scanning all of Workspace.
    local debris = Workspace:FindFirstChild("Debris")
    if debris then
        for _, m in ipairs(debris:GetChildren()) do
            if m:IsA("Model") and m:GetAttribute("BombPlanted") then
                return m
            end
        end
    end
    return nil
end

function isBombResolvedState(bomb)
    if not bomb then return false end
    return bomb:GetAttribute("Defused") == true
        or bomb:GetAttribute("Exploding") == true
        or bomb:GetAttribute("Exploded") == true
end

function readC4Timing(bomb)
    local now = c4ServerNow()
    local duration = c4ReadNumberAttr(bomb, C4_ATTR_DURATION, function(n)
        return n:find("duration", 1, true) or n:find("fuse", 1, true)
    end)
    duration = c4ClampDuration(duration)

    local remain = c4ReadNumberAttr(bomb, C4_ATTR_REMAIN, function(n)
        return n:find("remaining", 1, true) or n:find("timeleft", 1, true)
            or n:find("countdown", 1, true)
    end)
    if remain and remain >= 0 and remain <= 90 then
        return math.max(0, remain), duration, true
    end

    local endServer = c4ReadNumberAttr(bomb, C4_ATTR_END, function(n)
        return n:find("explode", 1, true) or n:find("explosion", 1, true)
            or n:find("detonate", 1, true) or n:find("endtime", 1, true)
            or n:find("finish", 1, true)
    end)
    if endServer and endServer > now - 2 and endServer < now + 120 then
        return math.max(0, endServer - now), duration, true
    end

    local startServer = c4ReadNumberAttr(bomb, C4_ATTR_START, function(n)
        return n:find("plant", 1, true) or n:find("start", 1, true)
            or n:find("created", 1, true) or n:find("spawn", 1, true)
    end)
    if startServer and startServer <= now and (now - startServer) >= 0 and (now - startServer) <= 120 then
        return math.max(0, (startServer + duration) - now), duration, true
    end

    return nil, duration, false
end

function syncC4Timer(bomb)
    local remain, duration, exact = readC4Timing(bomb)
    C4Timer.duration = duration or C4_FALLBACK_DURATION
    C4Timer.exact = exact == true
    if remain then
        C4Timer.endT = tick() + remain
    elseif C4Timer.endT <= 0 then
        C4Timer.endT = tick() + C4Timer.duration
    end
end

-- =====================================================================
-- C4 PANEL (pill style — matches Spectator List / Keybind List / Terms modal)
--   * Black bg (Transparency 0.4)  * White UIStroke (Transparency 0.6, 1px)
--   * 4px corner  * Font.Code 13px  * Auto-fits text via AutomaticSize.X
--   * Header dot (accent) + RichText body + animated trailing "…"
-- Compatible with the existing C4Show(status, timeText, sub, color) callers.
-- =====================================================================
local C4UI = {}
function ensureC4UI()
    if C4UI.frame and C4UI.frame.Parent then return end
    local parent = (Library and Library.ScreenGui) or nil
    if not parent then
        local g = Instance.new("ScreenGui")
        g.Name = "EclipseC4Timer"; g.ResetOnSpawn = false
        g.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        pcall(function() g.Parent = (gethui and gethui()) or CoreGui end)
        parent = g
    end

    local f = Instance.new("Frame")
    f.Name = "C4Frame"
    f.AnchorPoint = Vector2.new(0, 0.5)
    f.Position = UDim2.new(0, 14, 0.5, 0)
    f.BackgroundColor3 = Color3.new(0, 0, 0)
    f.BackgroundTransparency = 0.4
    f.BorderSizePixel = 0
    f.Size = UDim2.fromOffset(10, 30)                     -- min size; auto-grows to text
    f.AutomaticSize = Enum.AutomaticSize.X
    f.Visible = false; f.Active = true; f.ZIndex = 60
    f.Parent = parent
    local stroke = Instance.new("UIStroke", f)
    stroke.Color = Color3.new(1, 1, 1); stroke.Thickness = 1; stroke.Transparency = 0.6
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)

    local pad = Instance.new("UIPadding", f)
    pad.PaddingLeft = UDim.new(0, 10); pad.PaddingRight = UDim.new(0, 10)
    pad.PaddingTop  = UDim.new(0, 4);  pad.PaddingBottom = UDim.new(0, 4)
    local lay = Instance.new("UIListLayout", f)
    lay.FillDirection = Enum.FillDirection.Horizontal
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    lay.VerticalAlignment = Enum.VerticalAlignment.Center
    lay.Padding = UDim.new(0, 6)

    -- Dot as a glyph: shares font/size with body text → perfect baseline alignment.
    local dot = Instance.new("TextLabel", f)
    dot.Name = "Dot"; dot.LayoutOrder = 1
    dot.BackgroundTransparency = 1
    dot.AutomaticSize = Enum.AutomaticSize.X
    dot.Size = UDim2.fromOffset(0, 22)
    dot.Font = Enum.Font.Code; dot.TextSize = 13
    dot.TextColor3 = Color3.fromRGB(255, 90, 60)
    dot.TextXAlignment = Enum.TextXAlignment.Left
    dot.Text = "●"
    dot.ZIndex = 61

    local text = Instance.new("TextLabel", f)
    text.Name = "Body"; text.LayoutOrder = 2
    text.BackgroundTransparency = 1
    text.AutomaticSize = Enum.AutomaticSize.X
    text.Size = UDim2.fromOffset(0, 22)
    text.Font = Enum.Font.Code; text.TextSize = 13
    text.TextColor3 = Color3.new(1, 1, 1)
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.RichText = true; text.Text = ""
    text.ZIndex = 61

    local dots = Instance.new("TextLabel", f)
    dots.Name = "Dots"; dots.LayoutOrder = 3
    dots.BackgroundTransparency = 1
    dots.AutomaticSize = Enum.AutomaticSize.X
    dots.Size = UDim2.fromOffset(0, 22)
    dots.Font = Enum.Font.Code; dots.TextSize = 13
    dots.TextColor3 = Color3.fromRGB(200, 200, 205)
    dots.TextXAlignment = Enum.TextXAlignment.Left
    dots.RichText = false; dots.Text = ""
    dots.ZIndex = 61; dots.Visible = false

    -- Drag
    do
        local dragging, dStart, sPos
        f.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dStart = input.Position; sPos = f.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UserInput.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local d = input.Position - dStart
                f.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + d.X, sPos.Y.Scale, sPos.Y.Offset + d.Y)
            end
        end)
    end

    C4UI.frame  = f
    C4UI.dot    = dot
    C4UI.text   = text
    C4UI.time   = text  -- alias so legacy TextTransparency pulse still works
    C4UI.dots   = dots
    C4UI.stroke = stroke
    C4UI.shown  = false
    C4UI.pinned = false
end

-- Ring removed by pill-panel redesign; kept as no-op for old callers.
