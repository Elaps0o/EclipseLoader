    local function _nearestEnemyName()
        local myChar = LocalPlayer.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Torso"))
        if not myRoot then return nil, nil end
        local best, bd
        for _, plr in ipairs(Players:GetPlayers()) do
            if _isEnemyPlayer(plr) and plr.Character then
                local r = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Torso")
                if r then
                    local d = (r.Position - myRoot.Position).Magnitude
                    if not bd or d < bd then bd = d; best = plr end
                end
            end
        end
        return best, bd
    end

