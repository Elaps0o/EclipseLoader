local function _signalOnce(sig, cb)
    if not sig or type(cb) ~= "function" then return nil end
    local ok, conn = pcall(function() return sig:Once(cb) end)
    if ok then return conn end
    local c
    ok, c = pcall(function()
        return sig:Connect(function(...)
            if c then pcall(function() c:Disconnect() end); c = nil end
            cb(...)
        end)
    end)
    return ok and c or nil
end
local function restoreOriginalKnife()
    if not SkinSystem._hidden then return end
    for p, t in pairs(SkinSystem._hidden) do
        if p and p.Parent then pcall(function() p.Transparency = t end) end
    end
    SkinSystem._hidden = nil
    SkinSystem._hiddenOwner = nil
end
local function hideOriginalKnife(k)
    restoreOriginalKnife()
    SkinSystem._hidden = {}
    SkinSystem._hiddenOwner = k
    local function hideInst(inst)
        if not inst then return end
        if inst:IsA("BasePart") or inst:IsA("MeshPart") or inst:IsA("Texture") or inst:IsA("Decal") then
            if SkinSystem._hidden[inst] == nil then SkinSystem._hidden[inst] = inst.Transparency end
            pcall(function() inst.Transparency = 1 end)
        end
    end
    local function hideTree(root)
        if not root then return end
        hideInst(root)
        for _, p in ipairs(root:GetDescendants()) do hideInst(p) end
    end
    hideTree(k)
    -- Some maps/round states leave the native knife/arms/gloves as separate
    -- camera children. Hide them together with the original knife and restore
    -- their exact transparencies later, so the custom glove does not stack over
    -- the original hand/knife or remain visible after cleanup.
    pcall(function()
        for _, obj in ipairs(Camera:GetChildren()) do
            if obj ~= SkinSystem.vm then
                local n = tostring(obj.Name):lower()
                local looksOriginalKnifeOrGlove = (obj == k)
                    or n:find("knife", 1, true)
                    or n:find("glove", 1, true)
                    or obj:FindFirstChild("Left Arm")
                    or obj:FindFirstChild("Right Arm")
                if looksOriginalKnifeOrGlove then hideTree(obj) end
            end
        end
    end)
end

local function _cacheSkinTarget(target)
    if not target or SkinSystem._skinRestore[target] then return end
    local rec = { SurfaceAppearances = {}, TextureID = nil, Color = nil, Material = nil }
    if target:IsA("BasePart") then
        rec.Color = target.Color; rec.Material = target.Material
    end
    if target:IsA("MeshPart") then rec.TextureID = target.TextureID end
    for _, ch in ipairs(target:GetChildren()) do
        if ch:IsA("SurfaceAppearance") then table.insert(rec.SurfaceAppearances, ch:Clone()) end
    end
    SkinSystem._skinRestore[target] = rec
end

local function _restoreAppliedSkins()
    for target, rec in pairs(SkinSystem._skinRestore or {}) do
        if target and target.Parent and rec then
            pcall(function()
                for _, ch in ipairs(target:GetChildren()) do
                    if ch:IsA("SurfaceAppearance") then ch:Destroy() end
                end
                for _, old in ipairs(rec.SurfaceAppearances or {}) do
                    local restored = old:Clone(); restored.Parent = target
                end
                if target:IsA("MeshPart") and rec.TextureID ~= nil then target.TextureID = rec.TextureID end
                if target:IsA("BasePart") then
                    if rec.Color then target.Color = rec.Color end
                    if rec.Material then target.Material = rec.Material end
                end
                target:SetAttribute("EclipseSkinSource", nil)
            end)
        end
    end
    SkinSystem._skinRestore = {}
end

function _restoreSkinTarget(target)
    local rec = target and SkinSystem._skinRestore and SkinSystem._skinRestore[target]
    if not (target and target.Parent and rec) then return end
    pcall(function()
        for _, ch in ipairs(target:GetChildren()) do
            if ch:IsA("SurfaceAppearance") then ch:Destroy() end
        end
        for _, old in ipairs(rec.SurfaceAppearances or {}) do
            local restored = old:Clone(); restored.Parent = target
        end
        if target:IsA("MeshPart") and rec.TextureID ~= nil then target.TextureID = rec.TextureID end
        if target:IsA("BasePart") then
            if rec.Color then target.Color = rec.Color end
            if rec.Material then target.Material = rec.Material end
        end
        target:SetAttribute("EclipseSkinSource", nil)
    end)
    SkinSystem._skinRestore[target] = nil
end

function _targetBelongsToWeapon(target, weapon)
    if not (target and weapon) then return false end
    if GLOVES[weapon] or tostring(weapon) == "Sports Gloves" then
        local p = target
        while p and p ~= Camera do
            local n = tostring(p.Name)
            if n == "Glove" or n == "Left Arm" or n == "Right Arm" then return true end
            p = p.Parent
        end
        return false
    end
    local p = target
    while p and p ~= Camera do
        if tostring(p.Name) == tostring(weapon) then return true end
        p = p.Parent
    end
    return false
end

function _restoreWeaponSkinRuntime(weapon)
    local isGlove = GLOVES[weapon] or tostring(weapon) == "Sports Gloves"
    for target in pairs(SkinSystem._skinRestore or {}) do
        if _targetBelongsToWeapon(target, weapon) then _restoreSkinTarget(target) end
    end
    pcall(function()
        for _, obj in ipairs(Camera:GetChildren()) do
            if obj.Name == weapon or isGlove then
                obj:SetAttribute("SkinApplied", nil)
                for _, d in ipairs(obj:GetDescendants()) do
                    d:SetAttribute("SkinApplied", nil)
                    if _targetBelongsToWeapon(d, weapon) then d:SetAttribute("EclipseSkinSource", nil) end
                end
            end
        end
    end)
    if isGlove then pcall(_clearGloveSkinRuntime) end
end

function _clearGloveSkinRuntime()
    pcall(function()
        for _, obj in ipairs(Camera:GetChildren()) do
            for _, side in ipairs({"Left Arm", "Right Arm"}) do
                local arm = obj:FindFirstChild(side)
                local glove = arm and arm:FindFirstChild("Glove")
                if glove and glove:IsA("BasePart") then
                    if SkinSystem._skinRestore and SkinSystem._skinRestore[glove] then
                        _restoreSkinTarget(glove)
                    elseif glove:GetAttribute("EclipseSkinSource") ~= nil then
                        for _, ch in ipairs(glove:GetChildren()) do
                            if ch:IsA("SurfaceAppearance") then pcall(function() ch:Destroy() end) end
                        end
                        glove:SetAttribute("EclipseSkinSource", nil)
                    end
                    glove:SetAttribute("SkinApplied", nil)
                end
            end
        end
    end)
end

function _clearSkinChangerRuntime()
    pcall(_restoreAppliedSkins)
    pcall(_clearGloveSkinRuntime)
    pcall(restoreOriginalKnife)
    -- Fallback glove/weapon cleanup: strip any SurfaceAppearance we injected
    -- (tagged with EclipseSkinSource) even if the weak _skinRestore entry
    -- was GC'd. Prevents "gloves still skinned after disable/unload".
    pcall(function()
        for _, obj in ipairs(Camera:GetChildren()) do
            obj:SetAttribute("SkinApplied", nil)
            obj:SetAttribute("EclipseSkinSource", nil)
            for _, d in ipairs(obj:GetDescendants()) do
                d:SetAttribute("SkinApplied", nil)
                if d:IsA("BasePart") and d:GetAttribute("EclipseSkinSource") ~= nil then
                    for _, ch in ipairs(d:GetChildren()) do
                        if ch:IsA("SurfaceAppearance") then pcall(function() ch:Destroy() end) end
                    end
                    d:SetAttribute("EclipseSkinSource", nil)
                end
            end
        end
    end)
end

local function _applySkinSourceToPart(target, source)
    if not target or not source or not target:IsA("BasePart") then return end
    local sourceKey = nil
    pcall(function() sourceKey = source:GetFullName() end)
    if sourceKey and target:GetAttribute("EclipseSkinSource") == sourceKey then return end
    _cacheSkinTarget(target)
    pcall(function()
        for _, ch in ipairs(target:GetChildren()) do
            if ch:IsA("SurfaceAppearance") then ch:Destroy() end
        end
        local sa = source:IsA("SurfaceAppearance") and source or source:FindFirstChildOfClass("SurfaceAppearance")
        if sa then
            local c = sa:Clone(); c.Name = "SurfaceAppearance"; c.Parent = target
        elseif source:IsA("BasePart") then
            target.Color = source.Color
            target.Material = source.Material
        end
        if target:IsA("MeshPart") and source:IsA("MeshPart") and source.TextureID and source.TextureID ~= "" then
            target.TextureID = source.TextureID
        end
        if sourceKey then target:SetAttribute("EclipseSkinSource", sourceKey) end
    end)
end

-- Uniform mesh scale. Only touches BaseParts, so a single-MeshPart glove/sleeve
-- shrinks in place without breaking welds. Skips models with sub-parts (weld
-- offsets wouldn't scale together).
local function _uniformScale(inst, factor)
    if not inst or not factor or factor == 1 then return end
    if inst:IsA("BasePart") then
        pcall(function() inst.Size = inst.Size * factor end)
    end
end

local function _findArmPart(root, armName)
    if not root then return nil end
    local arm = root:FindFirstChild(armName, true)
    return (arm and arm:IsA("BasePart")) and arm or nil
end

local function _gloveReferenceFrom(root, armName)
    local arm = _findArmPart(root, armName)
    if not arm then return nil end
    local glove = arm:FindFirstChild("Glove")
    if not (glove and glove:IsA("BasePart")) then
        for _, d in ipairs(arm:GetDescendants()) do
            if d.Name == "Glove" and d:IsA("BasePart") then glove = d; break end
        end
    end
    if not (glove and glove:IsA("BasePart")) then return nil end
    local offset
    pcall(function() offset = arm.CFrame:ToObjectSpace(glove.CFrame) end)
    return { Part = glove, Size = glove.Size, Offset = offset }
end

local function _collectGloveReferences(originalModel)
    local refs = {}
    for _, side in ipairs({"Left Arm", "Right Arm"}) do
        refs[side] = _gloveReferenceFrom(originalModel, side)
        if not refs[side] then
            pcall(function()
                for _, obj in ipairs(Camera:GetChildren()) do
                    if obj ~= SkinSystem.vm then
                        refs[side] = _gloveReferenceFrom(obj, side)
                        if refs[side] then break end
                    end
                end
            end)
        end
    end
    return refs
end

local function _fitGloveToReference(mesh, ref, maxScale)
    if not (mesh and mesh:IsA("BasePart") and ref and ref.Size) then return false, nil end
    local s, r = mesh.Size, ref.Size
    if s.X <= 0 or s.Y <= 0 or s.Z <= 0 or r.X <= 0 or r.Y <= 0 or r.Z <= 0 then return false, nil end
    -- Uniform fit keeps the glove proportions intact while preventing the
    -- skinned clone from becoming wider/deeper than the player's native glove.
    local factor = math.min((r.X * 0.96) / s.X, (r.Y * 0.96) / s.Y, (r.Z * 0.96) / s.Z, maxScale or 0.96)
    if factor > 0 and factor < 1 then _uniformScale(mesh, factor) end
    return true, factor
end

local function attachAsset(folder, arm, model, name, offset, ref)
    if not folder or not SkinSystem.vm then return end
    local target = SkinSystem.vm:FindFirstChild(arm); if not target then return end
    local src = folder:WaitForChild(model, 5); if not src then return end
    local mesh = src:Clone()
    cleanPart(mesh); mesh.Name = name; mesh.Parent = target
    -- Luva: só encolhe se estiver claramente maior que o braço (evita "comer" a faca).
    -- Nunca amplia, nunca sobrescreve offset — assim a luva sempre aparece na mão.
    if name == "Glove" and mesh:IsA("BasePart") and target:IsA("BasePart") then
        local ts, ms = target.Size, mesh.Size
        if ms.X > 0 and ms.Y > 0 and ms.Z > 0 then
            -- alvo: no máximo ~1.35x o braço em qualquer eixo
            local fx, fy, fz = (ts.X * 1.35)/ms.X, (ts.Y * 1.35)/ms.Y, (ts.Z * 1.35)/ms.Z
            local factor = math.min(fx, fy, fz, 1.0)
            factor = math.max(factor, 0.70) -- nunca menor que 0.70 -> nunca some
            if factor < 1.0 then
                pcall(function() mesh.Size = ms * factor end)
                local prev = SkinSystem.gloveScale or 1.0
                if factor < prev then SkinSystem.gloveScale = factor end
            end
        end
    end
    local motor = Instance.new("Motor6D"); motor.Part0=target; motor.Part1=mesh; motor.C0=offset; motor.Parent=target
end

-- Empurra a faca (e demais partes presas ao Right Arm que nao sao luva/manga)
-- um pouco para fora, proporcional ao quanto a luva encolheu — assim a faca
-- nao fica "afundada" na luva menor, mas tambem nao voa longe.
local function _pushKnifeOutward()
    local vm = SkinSystem.vm; if not vm then return end
    local scale = SkinSystem.gloveScale or 1.0
    if scale >= 0.98 then return end
    local push = math.min((1 - scale) * 0.45, 0.18)  -- pequeno: só tira a faca de dentro da luva
    for _, d in ipairs(vm:GetDescendants()) do
        if d:IsA("Motor6D") and d.Part0 and (d.Part0.Name == "Right Arm" or d.Part0.Name == "Left Arm") then
            local n = d.Part1 and d.Part1.Name or ""
            if n ~= "Glove" and n ~= "Sleeve" then
                pcall(function() d.C0 = d.C0 * CFrame.new(0, push * 0.5, -push) end)
            end
        end
    end
end

-- Sound lookup order:
--  1) ReplicatedStorage.Sounds.<knife>.<folder>.<name>  (pre-cloned Sound instances)
--  2) ReplicatedStorage.Database.Audio.Weapons.<knife>  (ModuleScript returning
--     { <folder> = { Identifiers = {ids}, Properties = {..} } } — matches the
--     dumped Database.Audio schema so every knife's Handling1/Handling2/
--     SecondInspect/HitOne/etc. play with correct volume + rolloff).
local function playSound(folder, name)
    local s
    local sounds = ReplicatedSt:FindFirstChild("Sounds")
    local ws = sounds and sounds:FindFirstChild(Config.Skins.SelectedKnife)
    -- Folder name variants: some knives ship "Inspect", others "Inspect1"/"FirstInspect".
    local variants = { folder }
    if folder == "Inspect" then variants = { "Inspect", "Inspect1", "FirstInspect", "Inspect_1" }
    elseif folder == "SecondInspect" then variants = { "SecondInspect", "Inspect2", "SecondInspect_1" }
    elseif folder == "HitOne" then variants = { "HitOne", "Hit1", "Hit_1" }
    elseif folder == "HitTwo" then variants = { "HitTwo", "Hit2", "Hit_2" }
    elseif folder == "HitThree" then variants = { "HitThree", "Hit3", "Hit_3" }
    elseif folder == "Equip" then variants = { "Equip", "Draw", "Deploy" }
    end
    local sf, src
    for _, vname in ipairs(variants) do
        sf = ws and ws:FindFirstChild(vname)
        src = sf and (sf:FindFirstChild(name) or sf:FindFirstChild("1") or sf:FindFirstChildOfClass("Sound"))
        if src and src:IsA("Sound") then break end
        src = nil
    end
    if src and src:IsA("Sound") then
        s = src:Clone()
    else
        local db = ReplicatedSt:FindFirstChild("Database")
        local audio = db and db:FindFirstChild("Audio")
        local wpns = audio and audio:FindFirstChild("Weapons")
        local wm = wpns and wpns:FindFirstChild(Config.Skins.SelectedKnife)
        if not wm then return end
        local okReq, tbl = pcall(function()
            if wm:IsA("ModuleScript") then return require(wm) end
            return nil
        end)
        if not okReq or type(tbl) ~= "table" then return end
        local entry
        for _, vname in ipairs(variants) do
            if type(tbl[vname]) == "table" then entry = tbl[vname]; break end
        end
        if type(entry) ~= "table" or type(entry.Identifiers) ~= "table" or #entry.Identifiers == 0 then return end
        local id = entry.Identifiers[math.random(1, #entry.Identifiers)]
        s = Instance.new("Sound")
        s.SoundId = "rbxassetid://" .. tostring(id)
        if type(entry.Properties) == "table" then
            for k, v in pairs(entry.Properties) do pcall(function() s[k] = v end) end
        end
    end
    if not s then return end
    s.Parent = Camera; pcall(function() s:Play() end)
    _signalOnce(s.Ended, function() pcall(function() s:Destroy() end) end)
    task.delay(8, function() if s and s.Parent then pcall(function() s:Destroy() end) end end)
end

local function handleAction(actionName, state)
    if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
    if not SkinSystem.spawned or not SkinSystem.animator or not IsAlive() then return Enum.ContextActionResult.Pass end
    if actionName == "InspectKnifeAction" then
        if SkinSystem.inspecting or SkinSystem.swinging then return Enum.ContextActionResult.Pass end
        -- Alternating inspect: first press → Inspect, next press → Inspect2 (if the
        -- weapon has one — currently only Butterfly Knife ships Inspect2). After the
        -- alt plays it flips back so pattern is 1,2,1,2… Sounds mirror it: normal
        -- inspect plays Sounds.<knife>.Inspect.1; alt plays SecondInspect + Handling1
        -- then Handling2 shortly after (matches the dumped folder layout).
        local useAlt = SkinSystem.inspectAlt and SkinSystem._inspectFlip
        local track  = useAlt and SkinSystem.inspectAlt or SkinSystem.inspectAnim
        if not track then return Enum.ContextActionResult.Pass end
        SkinSystem.inspecting = true
        if SkinSystem.idleAnim then pcall(function() SkinSystem.idleAnim:Stop() end) end
        local ok = pcall(function() track:Play() end)
        if ok then
            if useAlt then
                playSound("SecondInspect","1")
                playSound("Handling1","1")
                task.delay(0.55, function()
                    if SkinSystem.inspecting then playSound("Handling2","1") end
                end)
            else
                playSound("Inspect","1")
            end
            if SkinSystem.inspectAlt then SkinSystem._inspectFlip = not SkinSystem._inspectFlip end
            _signalOnce(track.Stopped, function() SkinSystem.inspecting = false end)
        else SkinSystem.inspecting = false end
    elseif actionName == "AttackKnifeAction" or actionName == "RightAttackKnifeAction" then
        local now = os.clock()
        if now - SkinSystem.lastAttackTime < 1 then return Enum.ContextActionResult.Pass end
        SkinSystem.lastAttackTime = now
        if SkinSystem.inspecting then SkinSystem.inspecting=false; if SkinSystem.inspectAnim then pcall(function() SkinSystem.inspectAnim:Stop() end) end end
        SkinSystem.swinging = true
        if SkinSystem.idleAnim then pcall(function() SkinSystem.idleAnim:Stop() end) end
        local chosen, sf
        if actionName == "RightAttackKnifeAction" then
            -- Right click = heavy stab.
            chosen = SkinSystem.HeavySwingAnim or SkinSystem.Swing1Anim or SkinSystem.Swing2Anim
            sf = "HitOne"
        else
            local anims = { SkinSystem.HeavySwingAnim, SkinSystem.Swing1Anim, SkinSystem.Swing2Anim }
            local live = {}
            for _, tr in ipairs(anims) do if tr then table.insert(live, tr) end end
            if #live == 0 then SkinSystem.swinging = false; return Enum.ContextActionResult.Pass end
            chosen = live[math.random(1,#live)]
            sf = (chosen == SkinSystem.HeavySwingAnim and "HitOne") or (chosen == SkinSystem.Swing1Anim and "HitTwo") or "HitThree"
        end
        if not chosen then SkinSystem.swinging = false; return Enum.ContextActionResult.Pass end
        local ok = pcall(function() chosen:Play() end)
        if ok then
            playSound(sf, "1")
            _signalOnce(chosen.Stopped, function() SkinSystem.swinging = false end)
        else
            SkinSystem.swinging = false
        end
    end
    return Enum.ContextActionResult.Pass
end

local function removeViewmodel()
    SkinSystem.spawned = false
    pcall(function() ContextAction:UnbindAction("InspectKnifeAction") end)
    pcall(function() ContextAction:UnbindAction("AttackKnifeAction") end)
    pcall(function() ContextAction:UnbindAction("RightAttackKnifeAction") end)
    for _, tr in ipairs({SkinSystem.equipAnim, SkinSystem.idleAnim, SkinSystem.inspectAnim, SkinSystem.inspectAlt, SkinSystem.HeavySwingAnim, SkinSystem.Swing1Anim, SkinSystem.Swing2Anim}) do
        if tr then pcall(function() tr:Stop() end) end
    end
    if SkinSystem.vm then SkinSystem.vm:Destroy(); SkinSystem.vm=nil end
    SkinSystem.animator=nil; SkinSystem.inspecting=false; SkinSystem.swinging=false
    SkinSystem.equipAnim=nil; SkinSystem.idleAnim=nil; SkinSystem.inspectAnim=nil; SkinSystem.inspectAlt=nil; SkinSystem._inspectFlip=false
    SkinSystem.HeavySwingAnim=nil; SkinSystem.Swing1Anim=nil; SkinSystem.Swing2Anim=nil
    restoreOriginalKnife()
end

local function spawnViewmodel(knife)
    if SkinSystem.spawned or not SkinSystem.scriptRunning then return end
    local me = IsAlive(); if not me then return end
    _sanitizeSkinConfig()
    local ok, err = pcall(function()
    local assets = ReplicatedSt:WaitForChild("Assets", 5); if not assets then return end
    local weapons = assets:WaitForChild("Weapons", 5); if not weapons then return end
    local tpl = weapons:WaitForChild(Config.Skins.SelectedKnife, 5); if not tpl then return end
    local off = (knives[Config.Skins.SelectedKnife] or knives["Butterfly Knife"]).Offset
    local camTpl = tpl:WaitForChild("Camera", 5); if not camTpl then return end
    SkinSystem.vm = camTpl:Clone()
    SkinSystem.vm.Name = Config.Skins.SelectedKnife; SkinSystem.vm.Parent = Camera
    disableCollisions(SkinSystem.vm); hideOriginalKnife(knife)
    SkinSystem.gloveScale = 1.0
    local gloveRefs = _collectGloveReferences(knife)
    if me.Parent.Name == "Terrorists" then
        local g = weapons:WaitForChild("T Glove", 5)
        attachAsset(g,"Left Arm","Left Arm","Glove",CFrame.new(0,0,-1.5), gloveRefs and gloveRefs["Left Arm"])
        attachAsset(g,"Right Arm","Right Arm","Glove",CFrame.new(0,0,-1.5), gloveRefs and gloveRefs["Right Arm"])
    else
        local sleeves = assets:WaitForChild("Sleeves", 5)
        local sl = sleeves and sleeves:WaitForChild("IDF", 5)
        local g  = weapons:WaitForChild("CT Glove", 5)
        attachAsset(sl,"Left Arm","Left Arm","Sleeve",CFrame.new(0,0,0.5))
        attachAsset(g,"Left Arm","Left Arm","Glove",CFrame.new(0,0,-1.5), gloveRefs and gloveRefs["Left Arm"])
        attachAsset(sl,"Right Arm","Right Arm","Sleeve",CFrame.new(0,0,0.5))
        attachAsset(g,"Right Arm","Right Arm","Glove",CFrame.new(0,0,-1.5), gloveRefs and gloveRefs["Right Arm"])
    end
    pcall(_pushKnifeOutward)

    local ac = SkinSystem.vm:FindFirstChildOfClass("AnimationController") or SkinSystem.vm:FindFirstChildOfClass("Animator")
    if not ac then return end
    SkinSystem.animator = ac:FindFirstChildWhichIsA("Animator") or ac
    local animRoot = assets:WaitForChild("WeaponAnimations", 5); if not animRoot then return end
    local knifeAnims = animRoot:WaitForChild(Config.Skins.SelectedKnife, 5); if not knifeAnims then return end
    local af = knifeAnims:WaitForChild("CameraAnimations", 5); if not af then return end
    local function loadTrack(n)
        local anim = af:FindFirstChild(n); if not anim then return nil end
        local okTrack, track = pcall(function() return SkinSystem.animator:LoadAnimation(anim) end)
        return okTrack and track or nil
    end
    SkinSystem.equipAnim      = loadTrack("Equip")
    SkinSystem.idleAnim       = loadTrack("Idle")
    SkinSystem.inspectAnim    = loadTrack("Inspect")
    SkinSystem.inspectAlt     = loadTrack("Inspect2")  -- Butterfly-only (nil for others)
    SkinSystem._inspectFlip   = false
    SkinSystem.HeavySwingAnim = loadTrack("Heavy Swing")
    SkinSystem.Swing1Anim     = loadTrack("Swing1")
    SkinSystem.Swing2Anim     = loadTrack("Swing2")

    if not SkinSystem.vm.PrimaryPart then SkinSystem.vm.PrimaryPart = SkinSystem.vm:FindFirstChildWhichIsA("BasePart") end
    if SkinSystem.vm.PrimaryPart then
        SkinSystem.vm:SetPrimaryPartCFrame(Camera.CFrame * CFrame.new(0,-1.5,5))
        TweenService:Create(SkinSystem.vm.PrimaryPart, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {CFrame = Camera.CFrame * off}):Play()
    end
    if SkinSystem.equipAnim then pcall(function() SkinSystem.equipAnim:Play() end) end
    playSound("Equip","1")
    SkinSystem.spawned = true
    pcall(function() ContextAction:UnbindAction("InspectKnifeAction") end)
    pcall(function() ContextAction:UnbindAction("AttackKnifeAction") end)
    pcall(function() ContextAction:UnbindAction("RightAttackKnifeAction") end)
    ContextAction:BindAction("InspectKnifeAction", handleAction, false, Enum.KeyCode.F)
    ContextAction:BindAction("AttackKnifeAction", handleAction, false, Enum.UserInputType.MouseButton1)
    ContextAction:BindAction("RightAttackKnifeAction", handleAction, false, Enum.UserInputType.MouseButton2)
    end)
    if not ok then warn("[Eclipse] Custom knife spawn failed: " .. tostring(err)) end
    if not SkinSystem.spawned and SkinSystem.vm then pcall(function() SkinSystem.vm:Destroy() end); SkinSystem.vm=nil; restoreOriginalKnife() end
end

function _applySelectedGloveSkin()
    if not SkinsFolder or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
    local gloveSkin = Config.Skins.SelectedSkins["Sports Gloves"]; if not gloveSkin or gloveSkin == "" then return end
    pcall(function()
        local gf = SkinsFolder:FindFirstChild("Sports Gloves"); if not gf then return end
        local gs = gf:FindFirstChild(gloveSkin)
        local gsr = gs and gs:FindFirstChild("Camera") and gs.Camera:FindFirstChild("Factory New")
        if not gsr then return end
        for _, obj in ipairs(Camera:GetChildren()) do
            local l = obj:FindFirstChild("Left Arm"); local r = obj:FindFirstChild("Right Arm")
            if l or r then
                for _, side in {"Left Arm","Right Arm"} do
                    local arm = obj:FindFirstChild(side); local s = gsr:FindFirstChild(side)
                    if arm and s then
                        local gm = arm:FindFirstChild("Glove")
                        if gm then
                            _applySkinSourceToPart(gm, s)
                        end
                    end
                end
            end
        end
    end)
end

local function applyWeaponSkin(model, forcedSkin)
    if not SkinsFolder or not model or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
    pcall(_applySelectedGloveSkin)
    local skin = forcedSkin or Config.Skins.SelectedSkins[model.Name]; if not skin then return end
    pcall(function()
        local sf = SkinsFolder:FindFirstChild(model.Name); if not sf then return end
        local st = sf:FindFirstChild(skin)
        local src = st and st:FindFirstChild("Camera") and st.Camera:FindFirstChild("Factory New")
        if not src then return end
        if not GLOVES[model.Name] then
            local wf = model:FindFirstChild("Weapon")
            if wf then
                for _, p in wf:GetDescendants() do
                    if p:IsA("BasePart") then
                        local ns = src:FindFirstChild(p.Name)
                        if ns then _applySkinSourceToPart(p, ns) end
                    end
                end
            end
        end
        model:SetAttribute("SkinApplied", skin)
    end)
end

local function ApplyWeaponSkinsFast(model, skinName)
    applyWeaponSkin(model, skinName)
end

