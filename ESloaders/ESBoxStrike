local _warmT, _warmVal = 0, false
local _warmModule, _warmModuleT = nil, 0
function _isWarmup()
    local t = tick()
    if t - _warmT < 0.5 then return _warmVal end
    _warmT = t
    local hits = {}
    local function _push(v) if v ~= nil then hits[#hits+1] = tostring(v):lower() end end
    pcall(function() _push(workspace:GetAttribute("GameState")) end)
    pcall(function() _push(workspace:GetAttribute("RoundState")) end)
    pcall(function() _push(workspace:GetAttribute("MatchState")) end)
    pcall(function() _push(workspace:GetAttribute("Phase")) end)
    pcall(function() _push(ReplicatedSt:GetAttribute("GameState")) end)
    pcall(function() _push(ReplicatedSt:GetAttribute("RoundState")) end)
    pcall(function()
        local status = ReplicatedSt:FindFirstChild("Status", true) or ReplicatedSt:FindFirstChild("GameStatus", true)
        if status and (status:IsA("StringValue") or status:IsA("IntValue")) then _push(status.Value) end
    end)

    if not _warmModule or (t - _warmModuleT) > 8 then
        _warmModuleT = t
        pcall(function()
            for _, name in ipairs({"MatchLogging","RoundHandler","GameLogic"}) do
                local m = ReplicatedSt:FindFirstChild(name, true)
                if m and m:IsA("ModuleScript") then _warmModule = m; break end
            end
        end)
    end

    
    pcall(function() _push(LocalPlayer:GetAttribute("Warmup")) end)
    pcall(function() if LocalPlayer:GetAttribute("BuyMenu") == true then hits[#hits+1] = "warmup" end end)
    local match = false
    for _, s in ipairs(hits) do
        if s:find("warm") or s:find("wait") or s:find("prep") or s:find("freeze")
           or s:find("intermission") or s:find("pregame") or s:find("buy") then
            match = true; break
        end
    end
    _warmVal = match
    return _warmVal
end

