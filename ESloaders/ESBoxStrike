-- Aimbot smoothing state: acquisition ramp (no snap) + last-frame tick
-- for frame-rate-independent exponential smoothing.
local AimState = { lastTarget = nil, acquiredAt = 0, lastTick = 0 }
function updateAimbot()
    if not Config.GlobalEnable or not Config.Aimbot.Enabled or not Config.Aimbot.DrawFOV then
        FOVCircle.Visible = false
        FOVCircleInner.Visible = false
    end
    if not Config.GlobalEnable or not Config.Aimbot.Enabled then return end
    if Config.Aimbot.DisableInFlash and _isLocalFlashed() then return end
    local mouse = UserInput:GetMouseLocation()
    local r = ActiveAimFOV()
    FOVCircle.Visible = Config.Aimbot.DrawFOV
    FOVCircle.Radius = r
    FOVCircle.Color = Config.Aimbot.FOVColor
    FOVCircle.Position = mouse
    FOVCircleInner.Visible = Config.Aimbot.DrawFOV
    FOVCircleInner.Radius = math.max(1, r - 1)
    FOVCircleInner.Position = mouse

    local heldName = getHeldWeaponName and getHeldWeaponName() or nil
    local isAWP     = heldName == "AWP"
    local isSniper  = heldName and SniperWeapons[heldName] or false
    local scoped = (isAWP or isSniper) and (isScopedIn and isScopedIn())

    local keyHeld = false
    pcall(function()
        local kp = Library.Options and Library.Options.Aimbot_Key
        if kp and kp.GetState then keyHeld = kp:GetState() end
    end)
    if not keyHeld then
        keyHeld = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    end
    -- Scoped snipers engage aim automatically (RMB scope counts as aiming).
    local aiming = keyHeld or Config.TriggerBot.Enabled or scoped
    if not aiming then return end

    -- When scoped in (any sniper), the game locks the mouse and the reticle sits
    -- at screen center — GetMouseLocation() can lag / return offset coords, so
    -- reference viewport center and blow the FOV wide open so the scoped-in
    -- target is always eligible.
    local mp
    if scoped then
        local vp = Camera.ViewportSize
        mp = Vector2.new(vp.X/2, vp.Y/2)
    else
        mp = UserInput:GetMouseLocation()
    end
    local closestPart, closestDist = nil, scoped and math.huge or ActiveAimFOV()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not IsEnemy(plr) then continue end
        local char = GetCharacter(plr); if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part
        if isAWP or isSniper then
            -- All snipers: head lock for max precision.
            part = char:FindFirstChild("Head") or GetAimbotTargetPart(char)
        else
            part = GetAimbotTargetPart(char)
        end

        if not part then continue end
        -- Skip visibility/smoke checks when scoped (scope raycasts are unreliable
        -- and would drop every eligible target, leaving the aim doing nothing).
        if not scoped and Config.Aimbot.VisibilityCheck and not IsVisible(part) then continue end
        if not scoped and Config.Aimbot.DisableInSmoke and Camera and _aimRayHitsSmoke(Camera.CFrame.Position, part.Position) then continue end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if on then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < closestDist then closestDist = d; closestPart = part end
        end
    end
    if closestPart then
        local now = tick()
        if AimState.lastTarget ~= closestPart then
            AimState.lastTarget = closestPart
            AimState.acquiredAt = now
            AimState.frameN     = 0
        end
        AimState.frameN = (AimState.frameN or 0) + 1

        -- 2-frame ease-out ramp on acquisition (skip for snipers → hard snap).
        local ramp
        if isAWP or isSniper then
            ramp = 1
        else
            local t = math.clamp(AimState.frameN / 2, 0, 1)
            ramp = 1 - (1 - t) * (1 - t) -- ease-out quadratic over 2 frames
        end

        local s = math.clamp(ActiveAimSmooth() or 0.35, 0.05, 1.0)
        local dt = math.clamp(now - (AimState.lastTick > 0 and AimState.lastTick or now - 1/60), 1/240, 1/30)
        AimState.lastTick = now

        local k
        if isAWP or isSniper then
            k = 240                       -- Snipers: hard snap direto, grudância absurda
        else
            k = 3 + s * 20                -- snap bem mais leve; slider ainda controla
        end
        local alpha = 1 - math.exp(-dt * k)
        alpha = alpha * ramp

        -- No lateral prediction (all snipers, incl. AWP): aim straight at part.
        local sp = Camera:WorldToViewportPoint(closestPart.Position)
        local tp = Vector2.new(sp.X, sp.Y)
        local delta = tp - mp
        local mag = delta.Magnitude
        -- Sticky snap: quando bem próximo, gruda um pouquinho — leve, perceptível.
        if mag < 5 and not (isAWP or isSniper) then alpha = math.min(1, alpha * 1.5) end
        if isAWP or isSniper then alpha = 1 end

        local dx = delta.X * alpha
        local dy = delta.Y * alpha
        if mousemoverel then mousemoverel(dx, dy) end
    else
        AimState.lastTarget = nil
        AimState.frameN     = 0
    end
end

local lastTrigger = 0
function updateTriggerBot()
    if not Config.GlobalEnable or not Config.TriggerBot.Enabled or not IsAlive() then return end
    if tick() - lastTrigger < Config.TriggerBot.Delay then return end
    local fire = false
    if Config.TriggerBot.Mode == "HitChance" then
        if math.random(1,100) <= Config.TriggerBot.HitChance then fire = true end
    elseif Config.TriggerBot.Mode == "NoSpread" then fire = true end
    if not fire then return end

    local vp = Camera.ViewportSize
    local ap = Vector2.new(vp.X/2, vp.Y/2) + Vector2.new(
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread),
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread))
    local ray = Camera:ViewportPointToRay(ap.X, ap.Y)
    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    local ig = { Camera }; if LocalPlayer.Character then table.insert(ig, LocalPlayer.Character) end
    rp.FilterDescendantsInstances = ig
    local r = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
    if r and r.Instance then
        local m = r.Instance:FindFirstAncestorOfClass("Model")
        if m and m:FindFirstChildOfClass("Humanoid") then
            local h = m:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then
                local plr = Players:GetPlayerFromCharacter(m)
                if plr and Config.TeamCheck and IsAlly(plr) then return end
                lastTrigger = tick()
                if mouse1click then mouse1click() end
            
            end
        end
    end
end

