-- Aimbot smoothing state: acquisition ramp (no snap) + last-frame tick
-- for frame-rate-independent exponential smoothing.
local AimState = { lastTarget = nil, acquiredAt = 0, lastTick = 0 }
local function updateAimbot()
    if not Config.GlobalEnable or not Config.Aimbot.Enabled or not Config.Aimbot.DrawFOV then
        FOVCircle.Visible = false
    end
    if not Config.GlobalEnable or not Config.Aimbot.Enabled then return end
    FOVCircle.Visible = Config.Aimbot.DrawFOV
    FOVCircle.Radius = ActiveAimFOV()
    FOVCircle.Color = Config.Aimbot.FOVColor
    FOVCircle.Position = UserInput:GetMouseLocation()

    local keyHeld = false
    pcall(function()
        local kp = Library.Options and Library.Options.Aimbot_Key
        if kp and kp.GetState then keyHeld = kp:GetState() end
    end)
    if not keyHeld then
        keyHeld = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    end
    local aiming = keyHeld or Config.TriggerBot.Enabled
    if not aiming then return end
    local mp = UserInput:GetMouseLocation()
    local closestPart, closestDist = nil, ActiveAimFOV()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not IsEnemy(plr) then continue end
        local char = GetCharacter(plr); if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = GetAimbotTargetPart(char); if not part then continue end
        if Config.Aimbot.VisibilityCheck and not IsVisible(part) then continue end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if on then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < closestDist then closestDist = d; closestPart = part end
        end
    end
    if closestPart then
        -- Track acquisition to kill the initial-snap. When a target is first
        -- picked (or switched), we start with an easing factor of 0 and
        -- linearly ramp to 1 over ~120ms. Combined with exponential smoothing,
        -- the mouse eases toward the target instead of jumping.
        local now = tick()
        if AimState.lastTarget ~= closestPart then
            AimState.lastTarget   = closestPart
            AimState.acquiredAt   = now
        end
        local ramp = math.clamp((now - AimState.acquiredAt) / 0.12, 0, 1)
        ramp = ramp * ramp * (3 - 2 * ramp) -- smoothstep, ease-in-out

        -- Snipers get a boosted responsiveness (1-tap). Others use the slider
        -- as-is. Smoothness slider: 0.05 (slow, imperceptible) → 1.0 (instant).
        local held = getHeldWeaponName and getHeldWeaponName() or nil
        local isSniper = held and SniperWeapons[held] or false
        local s = math.clamp(ActiveAimSmooth() or 0.35, 0.05, 1.0)
        if isSniper then
            -- Snipers are one-tap: skip the ramp entirely, force max smoothness
            -- so the aim glues to the target and stays there.
            s = 1.0
            ramp = 1
        end

        -- Exponential smoothing: alpha = 1 - exp(-dt * k). k scales with the
        -- Smoothness slider so 1.0 lands the shot in ~1 frame, 0.05 takes
        -- ~500ms. Frame-rate independent. Snipers get a much higher k for stick.
        local dt = math.clamp(now - (AimState.lastTick > 0 and AimState.lastTick or now - 1/60), 1/240, 1/30)
        AimState.lastTick = now
        local k = 6 + s * 54           -- k range ~ 6..60
        if isSniper then k = 140 end   -- glue-tight sniper lock
        local alpha = 1 - math.exp(-dt * k)
        alpha = alpha * ramp

        local sp = Camera:WorldToViewportPoint(closestPart.Position)
        local tp = Vector2.new(sp.X, sp.Y)
        local dx = (tp.X - mp.X) * alpha
        local dy = (tp.Y - mp.Y) * alpha
        if mousemoverel then mousemoverel(dx, dy) end
    else
        AimState.lastTarget = nil
    end
end

local lastTrigger = 0
local function updateTriggerBot()
    if not Config.GlobalEnable or not Config.TriggerBot.Enabled or not IsAlive() then return end
    if tick() - lastTrigger < Config.TriggerBot.Delay then return end
    local fire = false
    if Config.TriggerBot.Mode == "HitChance" then
        if math.random(1,100) <= Config.TriggerBot.HitChance then fire = true end
    elseif Config.TriggerBot.Mode == "NoSpread" then fire = true end
    if not fire then return end

    local vp = Camera.ViewportSize
    local ap = Vector2.new(vp.X/2, vp.Y/2) + Vector2.new(
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread),
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread))
    local ray = Camera:ViewportPointToRay(ap.X, ap.Y)
    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    local ig = { Camera }; if LocalPlayer.Character then table.insert(ig, LocalPlayer.Character) end
    rp.FilterDescendantsInstances = ig
    local r = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
    if r and r.Instance then
        local m = r.Instance:FindFirstAncestorOfClass("Model")
        if m and m:FindFirstChildOfClass("Humanoid") then
            local h = m:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then
                local plr = Players:GetPlayerFromCharacter(m)
                if plr and Config.TeamCheck and IsAlly(plr) then return end
                lastTrigger = tick()
                if mouse1click then mouse1click() end
            end
        end
    end
end

local lastBhop = 0
local function updateMovement()
    if not Config.GlobalEnable then return end
    local char = LocalPlayer.Character; if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    -- BUNNY HOP (BlueX-style): while Space is held, jump the instant the
    -- humanoid is grounded. 0.12s cooldown to match BlueX feel.
    if Config.Movement.BunnyHop and UserInput:IsKeyDown(Enum.KeyCode.Space) then
        local st = hum:GetState()
        local grounded = (hum.FloorMaterial ~= Enum.Material.Air)
            and st ~= Enum.HumanoidStateType.Jumping
            and st ~= Enum.HumanoidStateType.Freefall
        if grounded and tick() - lastBhop > 0.12 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            lastBhop = tick()
        end
    end
    -- AUTO STRAFE (BlueX-style): during freefall, convert mouse-X delta into a
    -- horizontal velocity nudge. Hard-locked at 1.5x (no slider).
    if Config.Movement.AutoStrafe and hum:GetState() == Enum.HumanoidStateType.Freefall then
        local moveDir = UserInput:GetMouseDelta().X
        if math.abs(moveDir) > 1 then
            local strafeAmount = math.clamp(moveDir / 150, -1, 1) * 1.5
            local right = root.CFrame.RightVector
            local cv = root.Velocity
            root.Velocity = Vector3.new(
                cv.X + right.X * strafeAmount * 50,
                cv.Y,
                cv.Z + right.Z * strafeAmount * 50
            )
        end
    end

    -- Jumpbug: cancel fall damage by triggering a jump right before landing
    if Config.Movement.Jumpbug and hum:GetState() == Enum.HumanoidStateType.Freefall then
        local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.FilterDescendantsInstances = { char }
        local r = Workspace:Raycast(root.Position, Vector3.new(0,-6,0), rp)
        if r and (root.Position.Y - r.Position.Y) < 4 and root.Velocity.Y < -30 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
    -- Edgebug: on freefall over an edge, snap Y velocity to 0 for a single frame
    if Config.Movement.Edgebug and hum:GetState() == Enum.HumanoidStateType.Freefall then
        if UserInput:IsKeyDown(Enum.KeyCode.LeftControl) and root.Velocity.Y < -50 then
            local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances = { char }
            local r = Workspace:Raycast(root.Position, Vector3.new(0,-3,0), rp)
            if r then
                local v = root.Velocity
                root.Velocity = Vector3.new(v.X, 0, v.Z)
            end
        end
    end
end


