    local okSrc, src = pcall(function() return mod.Source end)
    if okSrc and type(src) == "string" and src ~= "" then
        info.Team = src:match('Team%s*=%s*"([^"]+)"') or src:match("Team%s*=%s*'([^']+)'") or info.Team
        -- Use a frontier pattern so only the exact Icon field is parsed.
        info.Icon = _assetString(src:match('%f[%w]Icon%s*=%s*"([^"]+)"') or src:match("%f[%w]Icon%s*=%s*'([^']+)'") or info.Icon)
    end
    if info.Icon or info.Team then return info end
    return nil
end

function _readWeaponRuntimeInfo(name)
    -- Never require game ModuleScripts from the executor/local context here.
    -- Some BAC/Frog modules are RobloxScript-only and requiring them prints
    -- "Cannot require a RobloxScript module from a non RobloxScript context",
    -- then breaks unrelated HUD systems (ammo/viewmodel/observers). HUD icon
    -- override must stay UI-only: hardcoded dump + safe attributes/instances.
    return nil
end

function _weaponInfo(name)
    if type(name) ~= "string" or name == "" then return nil end
    if HUDSkin.infoCache[name] ~= nil then return HUDSkin.infoCache[name] or nil end
    local hardcoded = HUD_KNIFE_ASSETS[name]
    local source = _readWeaponModuleSourceInfo(name)
    local info = source or hardcoded
    if info and hardcoded then
        info.Icon = info.Icon or hardcoded.Icon
        info.ReverseIcon = info.ReverseIcon or hardcoded.ReverseIcon
        info.Team = info.Team or hardcoded.Team
    end
    if info then HUDSkin.infoCache[name] = info end
    return info
end

function _iconFromModule(name)
    local mod = _weaponModule(name); if not mod then return nil end
    for _, key in ipairs(HUD_ICON_KEYS) do
        local ok, val = pcall(function() return mod:GetAttribute(key) end)
        local a = ok and _assetString(val) or nil
        if a then return a end
    end
    for _, d in ipairs(mod:GetDescendants()) do
        local dn = tostring(d.Name):lower()
        -- Skip anything that looks like a "reverse" icon variant so we never
        -- accidentally show the sideways/reverse art in the HUD slot.
        if not dn:find("reverse", 1, true) then
            if dn == "icon" or dn:find("^icon") or dn:find("image", 1, true) or dn:find("thumbnail", 1, true) then
                local a = _assetString(d); if a then return a end
            end
        end
    end
    return nil
end

function _iconFromAssetsFolder(name)
    if type(name) ~= "string" or name == "" then return nil end
    local ok, root = pcall(function()
        local assets = ReplicatedSt:FindFirstChild("Assets")
        local weapons = assets and assets:FindFirstChild("Weapons")
        return weapons and weapons:FindFirstChild(name)
    end)
    if not ok or not root then return nil end
    -- Check attributes first.
    for _, key in ipairs(HUD_ICON_KEYS) do
        local okA, val = pcall(function() return root:GetAttribute(key) end)
        local a = okA and _assetString(val) or nil
        if a then return a end
    end
    -- Then look for descendant named Icon/Image/Thumbnail (skip reverse).
    for _, d in ipairs(root:GetDescendants()) do
        local dn = tostring(d.Name):lower()
        if not dn:find("reverse", 1, true) then
            if dn == "icon" or dn:find("^icon") or dn:find("image", 1, true) or dn:find("thumbnail", 1, true) then
                local a = _assetString(d); if a then return a end
            end
        end
    end
    return nil
end

function _iconForWeapon(name, fallbackName)
    -- If the selected thing is a knife, do not ever borrow the T/CT Knife icon.
    -- Missing custom icon means keep the game's original visible instead.
    local function read(n)
        if type(n) ~= "string" or n == "" then return nil end
        local info = _weaponInfo(n)
        return (info and info.Icon)
            or _iconFromModule(n)
            or _iconFromAssetsFolder(n)
    end
    local direct = read(name)
    if direct then return direct end
    if KNIVES[name] or tostring(name or ""):lower():find("knife", 1, true) then return nil end
    return read(fallbackName)
end

function _localKnifeByTeam()
    -- Original slot identity: CT side owns CT Knife, T side owns T Knife.
    -- Check CT first because "Counter-Terrorists" contains "Terrorists".
    local teamName = ""
    pcall(function()
        teamName = tostring((LocalPlayer.Team and LocalPlayer.Team.Name)
            or (LocalPlayer.TeamColor and LocalPlayer.TeamColor.Name)
            or "")
    end)
    local function fromText(txt)
        txt = tostring(txt or ""):lower()
        if txt:find("counter", 1, true) or txt == "ct" or txt:find("counter%-terrorists") then return "CT Knife" end
        if txt:find("terrorists", 1, true) or txt == "t" then return "T Knife" end
        return nil
    end
    local byTeam = fromText(teamName); if byTeam then return byTeam end
    local ch = LocalPlayer.Character
    local parentName = ch and ch.Parent and ch.Parent.Name
    local byParent = fromText(parentName); if byParent then return byParent end
    if Camera then
        if Camera:FindFirstChild("CT Knife") then return "CT Knife" end
        if Camera:FindFirstChild("T Knife") then return "T Knife" end
    end
    return "T Knife"
end

function _selectedHUDKnife()
    local sel = Config.Skins.SelectedKnife or "Butterfly Knife"
    if KNIVES[sel] or tostring(sel):lower():find("knife", 1, true) or tostring(sel):lower():find("bayonet", 1, true) then return sel end
    return _localKnifeByTeam()
end

function _prettySkinName(raw)
    if type(raw) ~= "string" or raw == "" then return "" end
    local normalized = raw:gsub("_", " "):gsub("%-", " "):lower():gsub("^%s+", ""):gsub("%s+$", "")
    if normalized == "stock" or normalized == "vanilla" or normalized == "default" or normalized == "none"
       or normalized == "original" or normalized == "no skin" or normalized == "sem skin" then return "" end
    if raw:find("NEBULLA_PATTERN", 1, true) then return "Doppler" end
    if raw:match("_%d+$") then
        local base = raw:gsub("_%d+$", "")
        if base == "" or base:find("NEBULLA", 1, true) then return "Doppler" end
        return (base:gsub("_", " "))
    end
    return (raw:gsub("_", " "))
end

function _slotParts(slotFrame)
    local w = slotFrame and slotFrame:FindFirstChild("Weapon"); if not w then return nil end
    local nameLbl = w:FindFirstChild("WeaponName")
    if not (nameLbl and nameLbl:IsA("TextLabel")) then
        for _, d in ipairs(w:GetDescendants()) do
            if d.Name == "WeaponName" and d:IsA("TextLabel") then nameLbl = d; break end
        end
    end
    if not (nameLbl and nameLbl:IsA("TextLabel")) then return nil end
    -- The child named after the slot ("Melee", "Primary", "Secondary") can be
    -- either an ImageLabel/ImageButton (regular weapons) OR a ViewportFrame
    -- showing the 3D knife model (melee). We must handle BOTH so the icon we
    -- apply is actually visible.
    local iconLbl, iconViewport, iconAnchor = nil, nil, nil
    local named = w:FindFirstChild(slotFrame.Name)
    if named then
        iconAnchor = named:IsA("GuiObject") and named or nil
        if named:IsA("ImageLabel") or named:IsA("ImageButton") then iconLbl = named
        elseif named:IsA("ViewportFrame") then iconViewport = named end
        if not iconLbl and not iconViewport then
            for _, d in ipairs(named:GetDescendants()) do
                if tostring(d.Name):find("^EclipseHUD") then
                    -- ignore our own replacement images
                elseif (d:IsA("ImageLabel") or d:IsA("ImageButton")) and not iconLbl then
                    iconLbl = d
                elseif d:IsA("ViewportFrame") and not iconViewport then
                    iconViewport = d
                end
            end
        end
    end
    if not iconLbl and not iconViewport then
        for _, d in ipairs(w:GetDescendants()) do
            if tostring(d.Name):find("^EclipseHUD") then
                -- ignore our own overlays
            elseif (d:IsA("ImageLabel") or d:IsA("ImageButton")) and not iconLbl then
                iconLbl = d
            elseif d:IsA("ViewportFrame") and not iconViewport then
                iconViewport = d
            end
        end
    end
    return nameLbl, iconLbl, iconViewport, iconAnchor
end

function _cleanHUDWeaponText(t)
    if type(t) ~= "string" then return nil end
    local pipe = t:find(" | ", 1, true); if pipe then t = t:sub(1, pipe - 1) end
    if t:sub(1, 3) == "\xE2\x98\x85" then t = t:sub(4) end
    t = t:gsub("^%s+", ""):gsub("%s+$", "")
    if t == "" then return nil end
    local low = t:lower()
    if low == "primary" or low == "secondary" or low == "melee" or low == "knife" or low == "weapon" or low == "inventory" then return nil end
    return t
end

-- =====================================================================
-- SAFE IN-PLACE INJECTION (no external ScreenGui)
--
-- How it works: Eclipse overlays are parented DIRECTLY as siblings of the
-- native HUD element they mirror (inside the game's own PlayerGui.MainGui
-- hierarchy). This is the "old" injection style — but every element is
-- tagged with the attribute `EclipseHUD = true`, name-prefixed with
-- "EclipseHUD*", and set `Active/Selectable = false`. Result:
--   * Game observers iterating children skip us via the attribute + name
--   * We inherit the parent's coordinate space, so a simple AnchorPoint /
--     Position / Size copy mirrors the original perfectly (no AbsolutePos
--     math, no drift, no jitter on layout changes).
--   * The original element is NEVER destroyed or reparented — we only
--     toggle its Visible/TextTransparency, which we restore on cleanup.
--   * Every write is pcall-wrapped so a locked/GC'd instance can't cascade.
-- =====================================================================
function _syncHUDOverlayGeometry(original, overlay)
    if not (original and overlay) then return end
    pcall(function()
        overlay.AnchorPoint = original.AnchorPoint
        overlay.Position    = original.Position
        overlay.Size        = original.Size
        overlay.Rotation    = original.Rotation
        overlay.Visible     = original.Visible
        overlay.ZIndex      = math.max((original.ZIndex or 1) + 1, 2)
    end)
end

function _cloneHUDOverlay(original, overlayName)
    if not original or not original.Parent then return nil end
    local parent = original.Parent
    local existing = parent:FindFirstChild(overlayName)
    if existing then return existing end
    local clone; local ok = pcall(function() clone = original:Clone() end)
    if not ok or not clone then return nil end
    clone.Name = overlayName
    clone.Active = false; clone.Selectable = false
    pcall(function()
        clone:SetAttribute("EclipseHUD", true)
        clone.ZIndex = math.max((original.ZIndex or 1) + 1, 2)
    end)
    pcall(function() clone.Parent = parent end)
    return clone
end

function _destroyHUDIconViewport(rec)
    if not rec then return end
    if rec.iconViewport then pcall(function() rec.iconViewport:Destroy() end) end
    rec.iconViewport = nil; rec.iconViewportKnife = nil
end

function _visibleBBox(model)
    local minP, maxP
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") and p.Transparency < 1 then
            local cf, sz = p.CFrame, p.Size
            for dx=-1,1,2 do for dy=-1,1,2 do for dz=-1,1,2 do
                local w = (cf * CFrame.new(dx*sz.X/2, dy*sz.Y/2, dz*sz.Z/2)).Position
                if not minP then minP, maxP = w, w else
                    minP = Vector3.new(math.min(minP.X,w.X), math.min(minP.Y,w.Y), math.min(minP.Z,w.Z))
                    maxP = Vector3.new(math.max(maxP.X,w.X), math.max(maxP.Y,w.Y), math.max(maxP.Z,w.Z))
                end
            end end end
        end
    end
    if not minP then return CFrame.new(), Vector3.new() end
    return CFrame.new((minP + maxP) * 0.5), (maxP - minP)
end

function _hudKnifeViewportSource(knifeName)
    local ok, src = pcall(function()
        local assets = ReplicatedSt:FindFirstChild("Assets")
        local weapons = assets and assets:FindFirstChild("Weapons")
        local root = weapons and weapons:FindFirstChild(knifeName)
        return root and (root:FindFirstChild("Camera") or root)
    end)
    return ok and src or nil
end

function _showKnifeViewportIcon(rec, iconLbl, knifeName)
    if not (rec and iconLbl and knifeName) then return false end
    local src = _hudKnifeViewportSource(knifeName); if not src then return false end
    if not rec.iconViewport or not rec.iconViewport.Parent then
        local old = iconLbl.Parent and iconLbl.Parent:FindFirstChild("EclipseHUDKnifeViewport")
        if old then pcall(function() old:Destroy() end) end
        local vp = Instance.new("ViewportFrame")
        vp.Name = "EclipseHUDKnifeViewport"; vp.BackgroundTransparency = 1; vp.BorderSizePixel = 0
        vp.LightColor = Color3.fromRGB(255,255,255); vp.Ambient = Color3.fromRGB(170,170,180)
        vp.Active = false; vp.Selectable = false; vp.Parent = iconLbl.Parent
        rec.iconViewport = vp
    end
    _syncHUDOverlayGeometry(iconLbl, rec.iconViewport)
    rec.iconViewport.Visible = iconLbl.Visible
    if rec.iconViewportKnife == knifeName then if rec.iconOverlay then rec.iconOverlay.Visible = false end; return true end
    rec.iconViewport:ClearAllChildren()
    local cam = Instance.new("Camera"); cam.Parent = rec.iconViewport; rec.iconViewport.CurrentCamera = cam
    local clone; local okClone = pcall(function() clone = src:Clone() end)
    if not okClone or not clone then return false end
    if not clone:IsA("Model") then
        local wrap = Instance.new("Model"); wrap.Name = "HUDKnifeModel"
        for _, d in ipairs(clone:GetDescendants()) do if d:IsA("BasePart") then d.Parent = wrap end end
        clone:Destroy(); clone = wrap
    end
    local hasPart = false
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("LuaSourceContainer") or p:IsA("Humanoid") or p:IsA("AnimationController") then
            pcall(function() p:Destroy() end)
        elseif p:IsA("BasePart") then
            hasPart = true; p.Anchored = true; p.CanCollide = false; p.CanTouch = false; p.CanQuery = false
            local n = p.Name:lower()
            if n:find("arm", 1, true) or n:find("hitbox", 1, true) or n:find("root", 1, true) or n:find("bound", 1, true) then p.Transparency = 1 end
        end
    end
    if not hasPart then clone:Destroy(); return false end
    local cf0, size = _visibleBBox(clone); if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local offset = -cf0.Position
    for _, p in ipairs(clone:GetDescendants()) do if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end end
    cf0, size = _visibleBBox(clone); if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local maxDim = math.max(size.X, size.Y, size.Z, 1)
    cam.CFrame = CFrame.lookAt(Vector3.new(maxDim * 0.25, maxDim * 0.15, math.max(2.2, maxDim * 1.35)), Vector3.new(0,0,0))
    clone.Parent = rec.iconViewport; rec.iconViewportKnife = knifeName
    if rec.iconOverlay then rec.iconOverlay.Visible = false end
    return true
end

-- Sweep the entire slot subtree for duplicate Eclipse overlays with the given
-- name, destroying every match except `keep`. Prevents double-injection when
-- the game re-parents / rebuilds slot elements between apply passes.
function _sweepDuplicateOverlays(slotFrame, overlayName, keep)
    if not (slotFrame and slotFrame.Parent) then return end
    pcall(function()
        for _, d in ipairs(slotFrame:GetDescendants()) do
            if d ~= keep and d.Name == overlayName and d:GetAttribute("EclipseHUD") then
                pcall(function() d:Destroy() end)
            end
        end
    end)
end

function _purgeHUDOverlays(slotFrame)
    if not (slotFrame and slotFrame.Parent) then return end
    pcall(function()
        for _, d in ipairs(slotFrame:GetDescendants()) do
            local n = tostring(d.Name or "")
            if d:GetAttribute("EclipseHUD") or n:find("^EclipseHUD") then
                pcall(function() d:Destroy() end)
            end
        end
    end)
end

function _purgeAllHUDOverlays()
    local inv = _hudInventory and _hudInventory() or nil
    if not inv then return end
    for _, slot in ipairs(_hudInventorySlots(inv)) do _purgeHUDOverlays(slot) end
end

function _hudIconTint(rec)
    return (rec and rec.iconImageColor3) or Color3.fromRGB(188, 196, 208)
end

function _ensureIconImage(rec, anchor)

    if not (rec and anchor and anchor.Parent) then return nil end
    local parent = anchor.Parent
    -- Sweep any stale duplicates from previous passes BEFORE creating/reusing.
    _sweepDuplicateOverlays(rec.slotFrame, "EclipseHUDIcon", rec.iconImage)
    local img = rec.iconImage
    if not (img and img.Parent == parent) then
        if img then pcall(function() img:Destroy() end); rec.iconImage = nil end
        local old = parent:FindFirstChild("EclipseHUDIcon")
        if old then pcall(function() old:Destroy() end) end
        img = Instance.new("ImageLabel")
        img.Name = "EclipseHUDIcon"; img.BackgroundTransparency = 1; img.BorderSizePixel = 0
        img.ScaleType = Enum.ScaleType.Fit; img.Active = false; img.Selectable = false
        img.ClipsDescendants = false
        pcall(function() img:SetAttribute("EclipseHUD", true) end)
        pcall(function() img.Parent = parent end)
        rec.iconImage = img
    end

    pcall(function()
        if anchor:IsA("GuiObject") then
            img.AnchorPoint = anchor.AnchorPoint
            img.Position    = anchor.Position
            img.Size        = anchor.Size
            img.Rotation    = anchor.Rotation
            img.ZIndex      = math.max((anchor.ZIndex or 1) + 1, 2)
        else
            img.AnchorPoint = Vector2.new(0.5, 0.5)
            img.Position    = UDim2.fromScale(0.5, 0.5)
            img.Size        = UDim2.fromScale(1, 1)
            img.Rotation    = 0
            img.ZIndex      = 2
        end
        img.ImageColor3 = _hudIconTint(rec)
        img.ImageTransparency = 0
        img.BackgroundTransparency = 1
        img.Visible = true
        img.ScaleType = Enum.ScaleType.Fit
    end)
    return img
end

function _syncHUDFallbackGeometry(source, fallback)
    if not (source and fallback) then return end
    pcall(function()
        fallback.AnchorPoint = source.AnchorPoint
        fallback.Position    = source.Position
        fallback.Size        = source.Size
        fallback.Rotation    = source.Rotation
        fallback.ZIndex      = math.max((source.ZIndex or 2) - 1, 1)
        fallback.Visible     = source.Visible
    end)
end

function _ensureIconFallbackImage(rec, source)
    if not (rec and source and source.Parent) then return nil end
    local parent = source.Parent
    _sweepDuplicateOverlays(rec.slotFrame, "EclipseHUDIconThumbFallback", rec.iconFallbackImage)
    local img = rec.iconFallbackImage
    if not (img and img.Parent == parent) then
        if img then pcall(function() img:Destroy() end); rec.iconFallbackImage = nil end
        local old = parent:FindFirstChild("EclipseHUDIconThumbFallback")
        if old then pcall(function() old:Destroy() end) end
        img = Instance.new("ImageLabel")
        img.Name = "EclipseHUDIconThumbFallback"
        img.BackgroundTransparency = 1; img.BorderSizePixel = 0
        img.ScaleType = Enum.ScaleType.Fit; img.Active = false; img.Selectable = false
        img.ClipsDescendants = false
        pcall(function() img:SetAttribute("EclipseHUD", true) end)
        pcall(function() img.Parent = parent end)
        rec.iconFallbackImage = img
    end

    _syncHUDFallbackGeometry(source, img)
    pcall(function()
        img.ImageColor3 = _hudIconTint(rec)
        img.ImageTransparency = 0
        img.BackgroundTransparency = 1
        img.ScaleType = Enum.ScaleType.Fit
        img.ImageRectOffset = Vector2.new(0,0)
        img.ImageRectSize = Vector2.new(0,0)
    end)
    return img
end

function _preloadHUDIcon(icon)
    local candidates = _iconCandidates(icon)
    if #candidates == 0 then return end
    task.spawn(function()
        for _, candidate in ipairs(candidates) do
            local tmp = Instance.new("ImageLabel")
            tmp.BackgroundTransparency = 1
            tmp.Image = candidate
            local finalStatus = "Unknown"
            local ok, err = pcall(function()
                ContentProvider:PreloadAsync({tmp}, function(_, status)
                    finalStatus = tostring(status):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end)
            if ok then
                pcall(function()
                    finalStatus = tostring(ContentProvider:GetAssetFetchStatus(candidate)):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end
            _hudDbg("preload", candidate, ok and finalStatus or tostring(err))
            pcall(function() tmp:Destroy() end)
        end
    end)
end

function _prepHUDImageLabel(img, rec)
    if not img then return end
    pcall(function()
        img.BackgroundTransparency = 1
        img.ImageColor3 = _hudIconTint(rec)
        img.ImageTransparency = 0
        img.ImageRectOffset = Vector2.new(0,0)
        img.ImageRectSize = Vector2.new(0,0)
        img.ScaleType = Enum.ScaleType.Fit
        img.Visible = false
    end)
end

function _isImageLoaded(img)
    local loaded = false
    pcall(function() loaded = img.IsLoaded == true end)
    return loaded
end

function _assetFetchStatus(candidate)
    local status = "Unknown"
    pcall(function()
        status = tostring(ContentProvider:GetAssetFetchStatus(candidate)):gsub("Enum.AssetFetchStatus%.", "")
    end)
    return status
end

function _statusIsGood(status)
    status = tostring(status or "")
    return status:find("Success", 1, true) ~= nil or status:find("Loaded", 1, true) ~= nil
end

function _statusIsBad(status)
    status = tostring(status or "")
    return status:find("Failure", 1, true) ~= nil or status:find("Failed", 1, true) ~= nil
        or status:find("Error", 1, true) ~= nil or status:find("TimedOut", 1, true) ~= nil
end

function _imageCandidateReady(img, candidate)
    local loaded = _isImageLoaded(img)
    local status = _assetFetchStatus(candidate)
    return (loaded or _statusIsGood(status)) and not _statusIsBad(status), loaded, status
end

function _applyHUDImageWithFallback(rec, img, icon, debugTag, onLoaded, onFailed)
    if not (rec and img and img.Parent) then return false end
    local candidates = _iconCandidates(icon)
    if #candidates == 0 then return false end
    rec.iconToken = (rec.iconToken or 0) + 1
    local token = rec.iconToken
    _prepHUDImageLabel(img, rec)
    -- Apply immediately. Some executors/games never report IsLoaded or a good
    -- AssetFetchStatus for rbxthumb/rbxasset images even when the ImageLabel
    -- renders fine; waiting for validation made the HUD/icon look broken. We
    -- still preload/test candidates below, but the first valid candidate stays
    -- visible instead of restoring the native icon.
    img.Image = candidates[1]
    img.Visible = true
    rec.lastIcon = candidates[1]
    _hudDbg("image try", debugTag or "slot", "candidate=", candidates[1], "target=", img:GetFullName())

    -- Single-icon mode: never render a second fallback image under/over the
    -- real HUD slot. Multiple visible images caused the double-icon bug.
    if rec.iconFallbackImage then
        pcall(function() rec.iconFallbackImage:Destroy() end)
        rec.iconFallbackImage = nil
    end

    task.spawn(function()
        local finalIcon = candidates[1]
        local anyLoaded = false
        for i, candidate in ipairs(candidates) do
            if rec.iconToken ~= token or not img.Parent then return end
            pcall(function()
                _prepHUDImageLabel(img, rec)
                img.Image = candidate
                img.Visible = true
                if rec.iconFallbackImage then _syncHUDFallbackGeometry(img, rec.iconFallbackImage) end
            end)
            local preloadStatus = "Unknown"
            local preloadOk = pcall(function()
                ContentProvider:PreloadAsync({img}, function(_, status)
                    preloadStatus = tostring(status):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end)
            task.wait(i == 1 and 0.35 or 0.45)
            local ready, loaded, fetchStatus = _imageCandidateReady(img, candidate)
            if preloadStatus ~= "Unknown" then fetchStatus = preloadStatus end
            _hudDbg("image state", debugTag or "slot", "candidate=", candidate, "preload=", tostring(preloadOk), "status=", tostring(fetchStatus), "loaded=", tostring(loaded))
            if ready then
                anyLoaded = true
                finalIcon = candidate
                break
            end
        end
        if rec.iconToken ~= token or not img.Parent then return end
        local thumb = _assetThumb(icon)
        if not anyLoaded and thumb then
            finalIcon = thumb
            pcall(function()
                _prepHUDImageLabel(img, rec)
                img.Image = thumb
                img.Visible = true
            end)
            task.wait(0.25)
            local ready, loaded, fetchStatus = _imageCandidateReady(img, thumb)
            anyLoaded = ready
            _hudDbg("thumb fallback", debugTag or "slot", "status=", tostring(fetchStatus), "loaded=", tostring(loaded), "ready=", tostring(ready))
        end
        if not anyLoaded then
            _hudDbg("image unverified; keeping forced HUD icon", debugTag or "slot", tostring(finalIcon))
            pcall(function()
                _prepHUDImageLabel(img, rec)
                img.Image = finalIcon or candidates[1]
                img.Visible = true
                if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
            end)
            if onLoaded then pcall(onLoaded, finalIcon or candidates[1]) end
            return
        end
        if rec.iconFallbackImage then pcall(function() rec.iconFallbackImage.Visible = false end) end
        pcall(function() img.Visible = true; img.ImageColor3 = _hudIconTint(rec) end)
        rec.lastIcon = finalIcon
        _hudDbg("image accepted", debugTag or "slot", "final=", tostring(finalIcon))
        if onLoaded then pcall(onLoaded, finalIcon) end
    end)
    return true
end

