-- Heartbeat driver: rotation + "Waiting..." dot animation + position follow.
do
    local _rAcc, _dotAcc, _lastX, _lastY, _yaw = 0, 0, -1, -1, 180
    table.insert(UnloadConnections, RunService.Heartbeat:Connect(function(dt)
        if not (ESPPreview.gui and ESPPreview.visible and ESPPreview.frame) then return end
        local main
        pcall(function() main = Library.Main or (Library.ScreenGui and Library.ScreenGui:FindFirstChild("Main", true)) end)
        if main and main.AbsolutePosition then
            local p, s = main.AbsolutePosition, main.AbsoluteSize
            local nx, ny = p.X + s.X + 6, p.Y
            if nx ~= _lastX or ny ~= _lastY then
                _lastX, _lastY = nx, ny
                ESPPreview.frame.Position = UDim2.fromOffset(nx, ny)
            end
        end
        -- Animate "Waiting" dots when the placeholder is showing.
        _dotAcc = _dotAcc + dt
        if _dotAcc >= 0.4 and ESPPreview.waitLbl and ESPPreview.waitLbl.Visible then
            _dotAcc = 0
            local n = ((ESPPreview._dotN or 0) + 1) % 4
            ESPPreview._dotN = n
            ESPPreview.waitLbl.Text = "Waiting" .. string.rep(".", n)
        end
        -- Auto-rotate the ragdoll (~45°/s) so the preview shows the model spinning.
        _yaw = (_yaw + dt * 45) % 360
        _rAcc = _rAcc + dt
        if _rAcc < 1/30 then return end
        if ESPPreview.dummy then
            local base = ESPPreview._focus or Vector3.new()
            pcall(function()
                ESPPreview.dummy:PivotTo(CFrame.new(base) * CFrame.Angles(0, math.rad(_yaw), 0))
            end)
        end
        _rAcc = 0
    end))
end


