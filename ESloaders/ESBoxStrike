-- =====================================================================
-- C4 CARRIER ESP · marker above the head of whoever holds the bomb.
-- Lightweight: scans Backpack + Character for a Tool whose name contains
-- "C4" or "Bomb" once per second, caches a BillboardGui per player.
-- =====================================================================
do
    local C4Markers = {}
    local function _hasC4(plr)
        local function check(container)
            if not container then return false end
            for _, child in ipairs(container:GetChildren()) do
                if child:IsA("Tool") or child:IsA("Model") then
                    local n = child.Name:lower()
                    if n:find("c4") or n:find("bomb") then return true end
                end
            end
            return false
        end
        return check(plr:FindFirstChildOfClass("Backpack")) or check(plr.Character)
    end
    local function _clearMarker(plr)
        local m = C4Markers[plr]
        if m then pcall(function() m:Destroy() end); C4Markers[plr] = nil end
    end
    local function _makeMarker(plr)
        local char = plr.Character; if not char then return nil end
        local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not head then return nil end
        local bb = Instance.new("BillboardGui")
        bb.Name = "EclipseC4Carrier"
        bb.Adornee = head
        bb.AlwaysOnTop = true
        bb.Size = UDim2.fromOffset(32, 32)
        bb.StudsOffset = Vector3.new(0, 3.2, 0)
        bb.ResetOnSpawn = false
        pcall(function() bb.Parent = (gethui and gethui()) or CoreGui end)
        local pill = Instance.new("Frame", bb)
        pill.AnchorPoint = Vector2.new(0.5, 0.5)
        pill.Position = UDim2.new(0.5, 0, 0.5, 0)
        pill.Size = UDim2.fromOffset(28, 14)
        pill.BackgroundColor3 = Config.ESP.C4CarrierColor or Color3.fromRGB(255,90,60)
        pill.BorderSizePixel = 0
        Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
        local lbl = Instance.new("TextLabel", pill)
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.fromScale(1, 1)
        lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 10
        lbl.TextColor3 = Color3.new(1, 1, 1)
        lbl.Text = "C4"
        return bb
    end
    task.spawn(function()
        while scriptRunning do
            if Config.ESP.C4Carrier then
                local seen = {}
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and (not Config.TeamCheck or not IsAlly(plr)) and _hasC4(plr) then
                        seen[plr] = true
                        local m = C4Markers[plr]
                        if not m or not m.Parent or not m.Adornee or not m.Adornee.Parent then
                            _clearMarker(plr)
                            C4Markers[plr] = _makeMarker(plr)
                        else
                            local pill = m:FindFirstChildOfClass("Frame")
                            if pill then pill.BackgroundColor3 = Config.ESP.C4CarrierColor or Color3.fromRGB(255,90,60) end
                        end
                    end
                end
                for plr, _ in pairs(C4Markers) do
                    if not seen[plr] then _clearMarker(plr) end
                end
            else
                for plr, _ in pairs(C4Markers) do _clearMarker(plr) end
            end
            task.wait(1)
        end
    end)
end

