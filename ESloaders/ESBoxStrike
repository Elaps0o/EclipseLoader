local function _ecfgIsKeyPicker(opt)
    if not opt then return false end
    local t = rawget(opt, "Type") or opt.Type
    if t == "KeyPicker" then return true end

    return opt.Mode ~= nil and opt.SyncToggleState ~= nil
end

local function _ecfgOptType(opt)
    if not opt then return "" end
    return tostring(rawget(opt, "Type") or opt.Type or "")
end

local function _ecfgReadOptValue(opt)
    if not opt then return nil end
    local v = rawget(opt, "Value")
    if v == nil then v = opt.Value end
    if v == nil then v = rawget(opt, "CurrentValue") or opt.CurrentValue end
    if v == nil then v = rawget(opt, "Current") or opt.Current end
    if v == nil and type(opt.GetValue) == "function" then
        local ok, got = pcall(function() return opt:GetValue() end)
        if ok then v = got end
    end
    if v == nil then v = rawget(opt, "Default") or opt.Default end
    return v
end

local function _ecfgSetObjValue(obj, val)
    if not obj then return false end
    local used = false
    local oldDisabled = obj.Disabled
    if oldDisabled ~= nil and (_ecfgOptType(obj) == "Slider" or _ecfgOptType(obj) == "Dropdown") then
        pcall(function() obj.Disabled = false end)
    end
    if type(obj.SetValue) == "function" then
        local ok = pcall(function() obj:SetValue(val) end)
        used = ok or used
    elseif type(obj.Set) == "function" then
        local ok = pcall(function() obj:Set(val) end)
        used = ok or used
    end
    if oldDisabled ~= nil then pcall(function() obj.Disabled = oldDisabled end) end
    if not used then
        pcall(function() obj.Value = val end)
        if type(obj.Callback) == "function" then pcall(obj.Callback, val) end
        if type(obj.Changed) == "function" then pcall(obj.Changed, val) end
    end
    return used
end

local function _ecfgApplyPriority(id)
    local opt = Library.Options and Library.Options[id]
    local tog = Library.Toggles and Library.Toggles[id]
    if tog then return 10 end
    local t = _ecfgOptType(opt)
    if t == "Dropdown" then
        local s = tostring(id)
        if s:find("_Mode$") then return 20 end
        if s:find("_Category$") then return 21 end
        if s:find("_Weapon$") then return 22 end
        return 25
    end
    if _ecfgIsKeyPicker(opt) then return 30 end
    if t == "ColorPicker" then return 35 end
    if t == "Input" then return 40 end
    if t == "Slider" then return 80 end
    return 50
end

function _ecfgControlSnapshot()
    local out = {}
    pcall(function()
        for id, opt in pairs(Library.Toggles or {}) do
            local v = opt.Value
            if v == nil and type(opt.GetState) == "function" then v = opt:GetState() end
            if _ECLIPSE_TOGGLE_NORESTORE[id] then v = false end
            out[id] = v
        end
        for id, opt in pairs(Library.Options or {}) do
            if _ecfgIsKeyPicker(opt) then
                
                local key = _ecfgReadOptValue(opt)
                if typeof(key) == "EnumItem" then key = key.Name end
                out[id] = { __eclipseKP = true, Key = key or opt.Default, Mode = opt.Mode }
            else
                out[id] = _ecfgReadOptValue(opt)
            end
        end
    end)
    return out
end

function _ecfgApplyLoadedControls()
    local data = _EclipseAutoConfig.loaded
    if type(data) ~= "table" or type(data.Controls) ~= "table" then return end
    local cfg = _ecfgDecode(data.Config)
    if type(cfg) == "table" then
        _ecfgMerge(Config, cfg)
        _ecfgForceSkinChangerInactive(false)
    end
    local controls = _ecfgDecode(data.Controls)
    _EclipseConfigLoading = true
    local entries = {}
    for id, val in pairs(controls) do entries[#entries + 1] = { id = id, val = val, pr = _ecfgApplyPriority(id) } end
    table.sort(entries, function(a, b)
        if a.pr == b.pr then return tostring(a.id) < tostring(b.id) end
        return a.pr < b.pr
    end)
    for _, ent in ipairs(entries) do
        local id, val = ent.id, ent.val
        pcall(function()
            local tog = Library.Toggles and Library.Toggles[id]
            if tog then
                if _ECLIPSE_TOGGLE_NORESTORE[id] then val = false end
                local bv = val and true or false
                _ecfgSetObjValue(tog, bv)
                return
            end

            local opt = Library.Options and Library.Options[id]
            if opt then
                if _ecfgIsKeyPicker(opt) then
                    local key, mode
                    if type(val) == "table" and val.__eclipseKP then
                        key, mode = val.Key, val.Mode
                    elseif type(val) == "table" then
                        key  = val.Key or val[1] or val.Value
