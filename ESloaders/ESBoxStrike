local function _espProcessPlayer(plr, myRoot, center)
    if Config.TeamCheck and IsAlly(plr) then
        local old = ESPObjects[plr]
        if old then hideESP(old) end
        return nil
    end
    local char = GetCharacter(plr)
    local data = ESPObjects[plr]
    if not char then if data then hideESP(data) end; return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not root or not head or not hum or hum.Health <= 0 then if data then hideESP(data) end; return nil end

    local dist = (myRoot.Position - root.Position).Magnitude
    local maxD = Config.ESP.MaxDistance
    if Config.Aimbot.Enabled then maxD = math.max(maxD, 500) end
    if dist > maxD then if data then hideESP(data) end; return nil end

    if not data then
        data = createESPObjects()
        ESPObjects[plr] = data
    end

    local hP, hOn = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
    local fP, fOn = Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
    local onScreen = hOn and fOn and hP.Z > 0 and fP.Z > 0
    if not onScreen then
        hideESP(data)
        if Config.ESP.Arrows then _espDrawArrow(data, root) end
        return nil
    end

    local height  = math.abs(hP.Y - fP.Y); local width = height * 0.6
    local cx = hP.X; local cy = (hP.Y + fP.Y)/2
    local L, R = cx - width/2, cx + width/2
    local T, B = cy - height/2, cy + height/2

    -- Clamp box to viewport so partially off-screen players don't draw
    -- garbage lines snapping to screen corners.
    local vs = Camera.ViewportSize
    local margin = 6
    if L < -margin or R > vs.X + margin or T < -margin or B > vs.Y + margin then
        local anyInside = (cx >= 0 and cx <= vs.X and cy >= 0 and cy <= vs.Y)
        if not anyInside then
            hideESP(data)
            if Config.ESP.Arrows then _espDrawArrow(data, root) end
            return nil
        end
        L = math.clamp(L, 0, vs.X); R = math.clamp(R, 0, vs.X)
        T = math.clamp(T, 0, vs.Y); B = math.clamp(B, 0, vs.Y)
    end

    if Config.ESP.CornerBox then
        _espDrawCornerBox(data, plr, L, R, T, B, width*0.25, height*0.25)
    else for _, l in pairs(data.CornerLines) do l.Visible=false end end

    local topY = (Config.ESP.Position == "Top") and (T - 18) or (B + 18)
    local dY   = (Config.ESP.Position == "Top") and (T - 35) or (B + 35)

    if Config.ESP.Name then
        data.NameTag.Text = plr.Name
        data.NameTag.Position = Vector2.new(cx, topY)
        data.NameTag.Color = Config.ESP.NameColor
        data.NameTag.Visible = true
    else data.NameTag.Visible = false end

    if Config.ESP.Distance then
        data.DistTag.Text = math.floor(dist) .. "m"
        data.DistTag.Position = Vector2.new(cx, dY)
        data.DistTag.Color = Config.ESP.DistanceColor
        data.DistTag.Visible = true
    else data.DistTag.Visible = false end

    if Config.ESP.HealthBar then
        _espDrawHealth(data, hum, L, T, B, height)
    else
        data.HealthBg.Visible=false; data.HealthFill.Visible=false; data.HealthText.Visible=false
        for _, l in pairs(data.HealthSegments) do l.Visible = false end
        if data.HealthTicks then for _, l in pairs(data.HealthTicks) do l.Visible = false end end
    end

    if PresenceUsers[plr.UserId] then
        data.Presence.Color = Config.ESP.PresenceColor
        data.Presence.Position = Vector2.new(cx, T - 55)
        data.Presence.Visible = true
    else data.Presence.Visible = false end

    if Config.ESP.WeaponName and data.WeaponTag then
        local wn = _espGetWeaponName(plr)
        if wn and wn ~= "" then
            local tier, tierColor = getWeaponTier(wn)
            local starStr = tier and (string.rep("*", tier)) or ""
            data.WeaponTag.Text = (starStr ~= "" and (starStr.." ") or "")
                .."[    "..tostring(wn):upper().."    ]"
            local wY = (Config.ESP.Position == "Top") and (B + 18) or (T - 52)
            data.WeaponTag.Position = Vector2.new(cx, wY)
            data.WeaponTag.Color = tierColor or Config.ESP.WeaponNameColor
            data.WeaponTag.Visible = true
        else data.WeaponTag.Visible = false end
    elseif data.WeaponTag then data.WeaponTag.Visible = false end

    if Config.ESP.HeadDot and data.HeadDot then
        data.HeadDot.Position = Vector2.new(hP.X, hP.Y)
        data.HeadDot.Color = Config.ESP.HeadDotColor
        data.HeadDot.Radius = math.clamp(height * 0.04, 2, 5)
        data.HeadDot.Visible = true
    elseif data.HeadDot then data.HeadDot.Visible = false end

    if Config.ESP.Skeleton and data.Skeleton then
        _espDrawSkeleton(data, char)
    elseif data.Skeleton then for _, l in pairs(data.Skeleton) do l.Visible = false end end

    if data.Arrow then data.Arrow.Visible = false end

    local aimDist = (Vector2.new(hP.X, hP.Y) - center).Magnitude
    return { player=plr, head=head, root=root, hum=hum, dist=dist, aimDist=aimDist }
end

-- ===================== ESP CHAMS (Highlight) =====================
-- One Highlight per enemy character; parented to the character so it follows
-- the rig automatically. FillColor = body tint, OutlineColor = glow rim.
-- Config.ESP.ChamsGlow (0..1) fades the fill toward the outline for a glow feel.
local ChamsHL = setmetatable({}, { __mode = "k" }) -- weak keys on Player
local function updateChams()
    local on = Config.GlobalEnable and Config.ESP.Enabled and Config.ESP.Chams
    for plr, hl in pairs(ChamsHL) do
        if not plr.Parent or not on then
            pcall(function() hl:Destroy() end); ChamsHL[plr] = nil
        end
    end
    if not on then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char then continue end
        local hl = ChamsHL[plr]
        if not hl or not hl.Parent then
            hl = Instance.new("Highlight")
            hl.Name = "EclipseChams"
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = char; hl.Parent = char
            ChamsHL[plr] = hl
        else
            if hl.Adornee ~= char then hl.Adornee = char end
        end
        local fill = Config.ESP.ChamsColor
        hl.FillColor         = fill
        -- Auto-derive outline: lighten the fill so it always contrasts by ~40%.
        local h, s, v = Color3.toHSV(fill)
        hl.OutlineColor      = Color3.fromHSV(h, math.max(0, s - 0.15), math.min(1, v + 0.35))
        hl.FillTransparency  = math.clamp(Config.ESP.ChamsGlow or 0.35, 0, 1)
        hl.OutlineTransparency = 0
    end
end

local function updateESP()
    local espOn = Config.GlobalEnable and Config.ESP.Enabled
    local myChar = GetCharacter(LocalPlayer)
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not espOn or not myRoot then
        for _, d in pairs(ESPObjects) do hideESP(d) end
        TargetLine.Visible = false
        return
    end

    local closest, closestDist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local seen = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        seen[plr] = true
        local info = _espProcessPlayer(plr, myRoot, center)
        if info and info.aimDist < closestDist then
            closestDist = info.aimDist
            closest = info
        end
    end

    for p, d in pairs(ESPObjects) do
        if not seen[p] then
            hideESP(d)
            pcall(function()
                for _, l in pairs(d.CornerLines) do l:Remove() end
                for _, l in pairs(d.HealthSegments) do l:Remove() end
                if d.HealthTicks then for _, l in pairs(d.HealthTicks) do l:Remove() end end
                if d.Skeleton then for _, l in pairs(d.Skeleton) do l:Remove() end end
                d.NameTag:Remove(); d.DistTag:Remove()
                d.HealthBg:Remove(); d.HealthFill:Remove(); d.HealthText:Remove()
                d.Presence:Remove()
                if d.WeaponTag then d.WeaponTag:Remove() end
                if d.HeadDot then d.HeadDot:Remove() end
                if d.Arrow then d.Arrow:Remove() end
            end)
            ESPObjects[p] = nil
        end
    end

    if Config.ESP.TargetLine and closest then
        local sp, on = Camera:WorldToViewportPoint(closest.head.Position)
        if on then
            TargetLine.Color = Config.ESP.LineColor
            TargetLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            TargetLine.To = Vector2.new(sp.X, sp.Y); TargetLine.Visible = true
        else TargetLine.Visible = false end
    else TargetLine.Visible = false end
end


