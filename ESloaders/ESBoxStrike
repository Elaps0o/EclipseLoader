Config.WorldColor = Config.WorldColor or { Enabled=false, Color=Color3.fromRGB(120,180,255), Intensity=0.4 }
if Config.WorldColor.Enabled == nil then Config.WorldColor.Enabled = false end
if not Config.WorldColor.Color then Config.WorldColor.Color = Color3.fromRGB(120,180,255) end
if type(Config.WorldColor.Intensity) ~= "number" then Config.WorldColor.Intensity = 0.4 end

-- Intensity is a linear multiplier: 0 = original scene (no tint, no changes),
-- higher = progressively stronger tint + contrast + saturation punch. Tint is
-- blended from white -> user color by min(intensity,1), so intensity=0 leaves
-- the map exactly like vanilla.
function _applyWorldColorState()
    local e = _ensureWCEffect()
    local i = tonumber(Config.WorldColor.Intensity) or 0
    if i < 0 then i = 0 end
    local blend = math.min(i, 1)
    local c = Config.WorldColor.Color or Color3.fromRGB(255,255,255)
    local r = 1 + (c.R - 1) * blend
    local g = 1 + (c.G - 1) * blend
    local b = 1 + (c.B - 1) * blend
    e.TintColor   = Color3.new(r, g, b)
    e.Saturation  = i * 0.35
    e.Contrast    = i * 0.35
    e.Brightness  = i * 0.03
    e.Enabled     = (Config.WorldColor.Enabled and i > 0.001) and true or false
end

