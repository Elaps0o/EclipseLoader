function _showKnifeViewportIcon(rec, iconLbl, knifeName)
    if not (rec and iconLbl and knifeName) then return false end
    local src = _hudKnifeViewportSource(knifeName); if not src then return false end
    if not rec.iconViewport or not rec.iconViewport.Parent then
        local old = iconLbl.Parent and iconLbl.Parent:FindFirstChild("EclipseHUDKnifeViewport")
        if old then pcall(function() old:Destroy() end) end
        local vp = Instance.new("ViewportFrame")
        vp.Name = "EclipseHUDKnifeViewport"; vp.BackgroundTransparency = 1; vp.BorderSizePixel = 0
        vp.LightColor = Color3.fromRGB(255,255,255); vp.Ambient = Color3.fromRGB(170,170,180)
        vp.Active = false; vp.Selectable = false; vp.Parent = iconLbl.Parent
        rec.iconViewport = vp
    end
    _syncHUDOverlayGeometry(iconLbl, rec.iconViewport)
    rec.iconViewport.Visible = iconLbl.Visible
    if rec.iconViewportKnife == knifeName then if rec.iconOverlay then rec.iconOverlay.Visible = false end; return true end
    rec.iconViewport:ClearAllChildren()
    local cam = Instance.new("Camera"); cam.Parent = rec.iconViewport; rec.iconViewport.CurrentCamera = cam
    local clone; local okClone = pcall(function() clone = src:Clone() end)
    if not okClone or not clone then return false end
    if not clone:IsA("Model") then
        local wrap = Instance.new("Model"); wrap.Name = "HUDKnifeModel"
        for _, d in ipairs(clone:GetDescendants()) do if d:IsA("BasePart") then d.Parent = wrap end end
        clone:Destroy(); clone = wrap
    end
    local hasPart = false
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("LuaSourceContainer") or p:IsA("Humanoid") or p:IsA("AnimationController") then
            pcall(function() p:Destroy() end)
        elseif p:IsA("BasePart") then
            hasPart = true; p.Anchored = true; p.CanCollide = false; p.CanTouch = false; p.CanQuery = false
            local n = p.Name:lower()
            if n:find("arm", 1, true) or n:find("hitbox", 1, true) or n:find("root", 1, true) or n:find("bound", 1, true) then p.Transparency = 1 end
        end
    end
    if not hasPart then clone:Destroy(); return false end
    local cf0, size = _visibleBBox(clone); if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local offset = -cf0.Position
    for _, p in ipairs(clone:GetDescendants()) do if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end end
    cf0, size = _visibleBBox(clone); if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local maxDim = math.max(size.X, size.Y, size.Z, 1)
    cam.CFrame = CFrame.lookAt(Vector3.new(maxDim * 0.25, maxDim * 0.15, math.max(2.2, maxDim * 1.35)), Vector3.new(0,0,0))
    clone.Parent = rec.iconViewport; rec.iconViewportKnife = knifeName
    if rec.iconOverlay then rec.iconOverlay.Visible = false end
    return true
end

