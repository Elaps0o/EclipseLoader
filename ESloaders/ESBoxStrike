function gpdGetLine()
    local l = table.remove(GPD.LinePool)
    if not l and GPD_OK then
        local ok, obj = pcall(function()
            local x = Drawing.new("Line")
            x.Thickness = 2; x.Transparency = 1; x.Visible = false
            return x
        end)
        if ok then l = obj end
    end
    if l then GPD.ActiveLines[#GPD.ActiveLines + 1] = l end
    return l
end

function gpdClear()
    for _, l in ipairs(GPD.ActiveLines) do
        if l then pcall(function() l.Visible = false end) end
        GPD.LinePool[#GPD.LinePool + 1] = l
    end
    table.clear(GPD.ActiveLines)
    if GPD.Dot then pcall(function() GPD.Dot.Visible = false end) end
end

function gpdIdentifyGrenade()
    local cam = Workspace.CurrentCamera; if not cam then return nil end
    for _, c in ipairs(cam:GetChildren()) do
        if c:IsA("Model") and not c.Name:find("Arm") and c.Name ~= "Viewmodel" then
            local n = c.Name:lower()
            if n:find("molotov") or n:find("incendiary") then return GPD.PROPS.Molotov end
            if n:find("flash")                            then return GPD.PROPS.Flashbang end
            if n:find("smoke")                            then return GPD.PROPS.Smoke end
            if n:find("decoy")                            then return GPD.PROPS.Decoy end
            if n:find("he") or n:find("grenade")          then return GPD.PROPS.HE end
        end
    end
    return nil
end

function updateGrenadePrediction()
    if not GPD_OK then return end
    if not Config.GlobalEnable or not Config.Grenade.Prediction then
        if #GPD.ActiveLines > 0 or (GPD.Dot and GPD.Dot.Visible) then gpdClear() end
        GPD_Hold.wasHolding = false; GPD_Hold.showAfterRelease = false
        return
    end

    local gpp = gpdIdentifyGrenade()
    if not gpp then
        gpdClear(); GPD_Hold.wasHolding = false; GPD_Hold.showAfterRelease = false
        return
    end

    local cam = Workspace.CurrentCamera; if not cam then return end
    local isLMB = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    local isRMB = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    local isHolding = isLMB or isRMB
    local now = tick()

    if isHolding and not GPD_Hold.wasHolding then
        GPD_Hold.holdType = isRMB and "right" or "left"
        GPD_Hold.showAfterRelease = false
    end
    if not isHolding and GPD_Hold.wasHolding then
        GPD_Hold.releaseTime = now
        GPD_Hold.showAfterRelease = true
    end
    GPD_Hold.wasHolding = isHolding

    local shouldShow = isHolding
    if GPD_Hold.showAfterRelease then
        if (now - GPD_Hold.releaseTime) < 0.7 then shouldShow = true
        else GPD_Hold.showAfterRelease = false end
    end
    if not shouldShow then gpdClear(); return end

    local ch = LocalPlayer.Character
    if not ch or not ch.PrimaryPart then gpdClear(); return end

    local gPos = cam.CFrame.Position
    local gDir = cam.CFrame.LookVector
    local cc   = cam.CFrame
    local pV   = ch.PrimaryPart.AssemblyLinearVelocity

    local throwType = GPD_Hold.holdType or "left"
    if isHolding then
        throwType = isRMB and "right" or "left"
        GPD_Hold.holdType = throwType
    end

    -- Reuse the cached simulation when nothing meaningful has changed;
    -- keeps this cheap (30 FPS-ish sim cadence) even on weak executors.
    local cached = (now - GPD.LastCalc < 0.033)
        and (cc.Position   - GPD.LastCam.Position  ).Magnitude   < 0.05
        and (cc.LookVector - GPD.LastCam.LookVector).Magnitude   < 0.005
        and (pV            - GPD.LastVel           ).Magnitude   < 0.05

    if not cached then
        local throwSpeed = (throwType == "right") and 60 or 125
        local vel = (gDir * throwSpeed) + pV
        local pts = { gPos }
        local dts = 0.03
        local grav = Vector3.new(0, -Workspace.Gravity, 0)
        local elapsed = 0
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.IgnoreWater = true
        local filter = { ch, cam }
        local db = Workspace:FindFirstChild("Debris")
        if db then filter[#filter + 1] = db end
        pcall(function() rp.FilterDescendantsInstances = filter end)

        for _ = 1, math.floor(4.0 / dts) do
            elapsed = elapsed + dts
            vel = vel + (grav * dts)
            vel = vel * (1 - 0.01)
            local np = gPos + (vel * dts)
            local hit = Workspace:Raycast(gPos, np - gPos, rp)
            if hit then
                if gpp.ExplodeOnTouch and hit.Normal.Y > 0.5 then
                    gPos = hit.Position; break
                end
                local n = hit.Normal
                vel = (vel - (2 * vel:Dot(n) * n)) * gpp.Restitution
                gPos = hit.Position + (n * 0.05)
                if vel.Magnitude < 5 then break end
            else
                gPos = np
            end
            pts[#pts + 1] = gPos
            if elapsed >= gpp.Fuse then break end
        end

        GPD.CachedPts = pts
        GPD.LastCalc  = now
        GPD.LastCam   = cc
        GPD.LastVel   = pV
    end

    gpdClear()
    local pts = GPD.CachedPts
    for i = 1, #pts - 1 do
        local s1, v1 = cam:WorldToViewportPoint(pts[i])
        local s2, v2 = cam:WorldToViewportPoint(pts[i + 1])
        if v1 and v2 then
            local l = gpdGetLine()
            if l then
                l.From    = Vector2.new(s1.X, s1.Y)
                l.To      = Vector2.new(s2.X, s2.Y)
                l.Color   = Config.Grenade.LineColor
                l.Visible = true
            end
        end
    end
    if #pts > 0 and GPD.Dot then
        local sp, so = cam:WorldToViewportPoint(pts[#pts])
        if so then
            GPD.Dot.Position = Vector2.new(sp.X, sp.Y)
            GPD.Dot.Color    = Config.Grenade.DotColor
            GPD.Dot.Visible  = true
        else
            GPD.Dot.Visible = false
        end
    end
end




-- =====================================================================
-- Recoil Control  ·  Spread-based compensation model.
-- Reads the weapon's spray pattern from Database.Custom.Weapons.SprayPatterns,
-- integrates one pattern step per bullet, and nudges the aim opposite the
-- next spray offset. Strength falls off linearly with target distance:
-- full at <=30 studs, min 20% at >=150 studs. No per-frame jitter — the
-- correction is applied once per new bullet, not per RenderStepped.
-- =====================================================================
local SprayCache = {}
function _getSpray(name)
    if not name then return nil end
    if SprayCache[name] ~= nil then return SprayCache[name] or nil end
    -- BAC/Frog modules can be RobloxScript-only. Do not require internal game
    -- ModuleScripts from local/executor context; fall back to camera RCS only.
    SprayCache[name] = false
    return nil
end
-- ============================================================
-- RCS (Recoil Control System) — module-driven, AK-47 baseline.
-- Reads RecoilY / RecoilX / FireRate / WeaponType from
-- ReplicatedStorage.Assets.Weapons.<name>. Snipers (WeaponType
-- == "Sniper" or FireRate < 2) are excluded (1-tap weapons).
-- Every other weapon scales relative to AK-47's RecoilY so the
-- UI sliders remain calibrated against a single baseline.
-- Compensation is applied via Camera.CFrame *= CFrame.Angles(...)
-- on RenderStepped while the fire button is held, with a small
-- pending budget drained per frame for smoothness (no snaps).
-- ============================================================
local RCS_BASELINE = "AK-47"
local _rcsModCache = {}
local function _rcsGetWeaponModule(name)
    if not name then return nil end
    if _rcsModCache[name] ~= nil then
        local v = _rcsModCache[name]; if v == false then return nil end; return v
    end
    local ok, mod = pcall(function()
        local assets = ReplicatedSt:FindFirstChild("Assets")
        local weapons = assets and assets:FindFirstChild("Weapons")
        local m = weapons and weapons:FindFirstChild(name)
        if m then
            return {
                RecoilY = m:GetAttribute("RecoilY"),
                RecoilX = m:GetAttribute("RecoilX"),
                FireRate = m:GetAttribute("FireRate"),
                WeaponType = m:GetAttribute("WeaponType"),
            }
        end
        return nil
    end)
    local t = (ok and type(mod) == "table") and mod or false
    _rcsModCache[name] = t
    return t or nil
end
local function _rcsWeaponProfile(name)
    local m = _rcsGetWeaponModule(name); if not m then return nil end
    local ry = tonumber(m.RecoilY) or 0
    local rx = tonumber(m.RecoilX) or 0
    local fr = tonumber(m.FireRate) or 0
    local wt = tostring(m.WeaponType or "")
    return { RecoilY=ry, RecoilX=rx, FireRate=fr, WeaponType=wt }
end
local function _rcsIsSniper(name, prof)
    if SniperWeapons[name] then return true end
    prof = prof or _rcsWeaponProfile(name)
    if not prof then return false end
    if prof.WeaponType == "Sniper" then return true end
    if prof.FireRate > 0 and prof.FireRate < 2 then return true end
    return false
end
local function _rcsBaselineScale(prof)
    local base = _rcsWeaponProfile(RCS_BASELINE)
    if not base or (base.RecoilY or 0) <= 0 then return 1 end
    local ry = (prof and prof.RecoilY) or 0
    if ry <= 0 then return 1 end
    return ry / base.RecoilY
end

local RCSState = { weapon=nil, lastAmmo=nil, nextT=0, pendPitch=0, pendYaw=0, lastTick=0 }
function _rcsReset()
    RCSState.weapon=nil; RCSState.lastAmmo=nil; RCSState.nextT=0
    RCSState.pendPitch=0; RCSState.pendYaw=0
end
function updateRCS()
    if not Config.GlobalEnable or not Config.RCS.Enabled then _rcsReset(); return end
    local cam = Workspace.CurrentCamera; if not cam then return end
    local firing = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    if not firing then _rcsReset(); return end

    local held
    for _, ch in ipairs(cam:GetChildren()) do
        if ch:IsA("Model") then
            local n = ch.Name
            if n ~= "Arms" and n ~= "Arms1" and n ~= "Arms2" and n ~= "Viewmodel" then held = ch; break end
        end
    end
    if not held then _rcsReset(); return end

    local prof = _rcsWeaponProfile(held.Name)
    if _rcsIsSniper(held.Name, prof) then _rcsReset(); return end

    if RCSState.weapon ~= held.Name then
        RCSState.weapon = held.Name; RCSState.lastAmmo = nil
        RCSState.pendPitch = 0; RCSState.pendYaw = 0; RCSState.nextT = 0
    end

    -- Bullet edge via Ammo attribute; fallback to FireRate cadence.
    local ammo = held:GetAttribute("Ammo") or held:GetAttribute("Bullets") or held:GetAttribute("CurrentAmmo")
    local newBullet = false
    if ammo ~= nil then
        if RCSState.lastAmmo == nil then RCSState.lastAmmo = ammo
        elseif ammo < RCSState.lastAmmo then newBullet = true; RCSState.lastAmmo = ammo
        elseif ammo > RCSState.lastAmmo then
            RCSState.pendPitch = 0; RCSState.pendYaw = 0; RCSState.lastAmmo = ammo
        end
    else
        local now = tick()
        local fr = (prof and prof.FireRate) or 10
        local interval = (fr > 0) and (1 / fr) or 0.1
        if now >= (RCSState.nextT or 0) then newBullet = true; RCSState.nextT = now + interval end
    end

    if newBullet and prof then
        local scale  = _rcsBaselineScale(prof)
        local vSlider, hSlider = ActiveRCS()
        -- RecoilY/X are game units; 0.0015 rad/unit lands roughly on-target
        -- for AK-47 at 100% slider — sliders then scale linearly.
        local kV = (vSlider / 100) * scale * 0.0015
        local kH = (hSlider / 100) * scale * 0.0015
        RCSState.pendPitch = RCSState.pendPitch + (prof.RecoilY * kV)
        RCSState.pendYaw   = RCSState.pendYaw   + (prof.RecoilX * kH)
    end

    local now = tick()
    local last = RCSState.lastTick > 0 and RCSState.lastTick or (now - 1/60)
    local dt = math.max(1/240, math.min(1/30, now - last))
    RCSState.lastTick = now
    local drain = math.clamp(dt / 0.05, 0, 1)
    local aP = RCSState.pendPitch * drain
    local aY = RCSState.pendYaw   * drain
    RCSState.pendPitch = RCSState.pendPitch - aP
    RCSState.pendYaw   = RCSState.pendYaw   - aY
    -- Camera recoil desativado a pedido do usuário: não mexe mais na CFrame.
    -- if math.abs(aP) > 1e-5 or math.abs(aY) > 1e-5 then
    --     pcall(function() cam.CFrame = cam.CFrame * CFrame.Angles(-aP, -aY, 0) end)
    -- end
end






local function IsAlive()
    if not Characters then return false end
    local t  = Characters:FindFirstChild("Terrorists")
    local ct = Characters:FindFirstChild("Counter-Terrorists")
    return (t and t:FindFirstChild(LocalPlayer.Name)) or (ct and ct:FindFirstChild(LocalPlayer.Name))
end
function GetCharacter(plr)
    if not plr then return nil end
    local char = plr.Character
    if char and char.Parent and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")) then
        return char
    end

    local chars = Characters or Workspace:FindFirstChild("Characters")
    if chars then
        Characters = chars
        local direct = chars:FindFirstChild(plr.Name)
        if direct and direct.Parent then return direct end
        for _, folder in ipairs(chars:GetChildren()) do
            local found = folder:FindFirstChild(plr.Name)
            if found and found.Parent then return found end
        end
    end
    return char
end
function IsAlly(plr)
    local otherChar = GetCharacter(plr)
    local myChar = GetCharacter(LocalPlayer)
    if not otherChar or not myChar then return false end
    return otherChar.Parent == myChar.Parent
end
function IsEnemy(plr)
    if plr == LocalPlayer or not GetCharacter(plr) then return false end
    if Config.TeamCheck then return not IsAlly(plr) end
    return true
end
function IsVisible(part)
    if not part then return false end
    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin)
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = { GetCharacter(LocalPlayer) }
    local r = Workspace:Raycast(origin, dir, rp)
    if r then return r.Instance:IsDescendantOf(part.Parent) end
    return true
end
function GetAimbotTargetPart(character)
    if not character then return nil end
    local pn = Config.Aimbot.TargetPart
    local cand = { pn }
    if pn == "Neck"  then cand = {"Neck","Head","UpperTorso","Torso"}
    elseif pn == "Arms" then cand = {"LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm","LeftHand","RightHand"}
    elseif pn == "Legs" then cand = {"LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg","LeftFoot","RightFoot"}
    elseif pn == "HumanoidRootPart" then cand = {"HumanoidRootPart"} end
    for _, n in ipairs(cand) do
        local p = character:FindFirstChild(n)
        if p and p:IsA("BasePart") then return p end
    end
    return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
end

