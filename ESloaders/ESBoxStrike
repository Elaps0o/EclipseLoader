                        { Size = finalSz }):Play()
                    pcall(EX.rebuildKB)
                    lastSig = ""
                end
                -- Only rebuild when the visible entries actually changed. The
                -- previous unconditional rebuild every 0.25s made the panel
                -- flicker on its own ("piscar sozinho do nada").
                local sig = ""
                for _, e in ipairs(collectAllKeybinds()) do
                    local on = true; pcall(function() on = e.state() end)
                    sig = sig .. e.key .. "=" .. tostring(keyText(e.key)) .. (on and "+" or "-") .. "|"
                end
                if sig ~= lastSig then
                    lastSig = sig
                    pcall(EX.rebuildKB)
                end
            else
                EX.KBFrame.Visible = false
                lastSig = ""
            end
            task.wait(0.4)
