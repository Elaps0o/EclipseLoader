Config.Grenade.Trajectory3D = false
local _g3d = { folder=nil, parts={}, dot=nil }
local function _g3dEnsure()
    if _g3d.folder and _g3d.folder.Parent then return end
    local f = Instance.new("Folder"); f.Name = "EclipseGrenade3D"; f.Parent = Workspace
    _g3d.folder = f; _g3d.parts = {}
    local dot = Instance.new("Part")
    dot.Name="EclipseG3D_Dot"; dot.Shape=Enum.PartType.Ball; dot.Size=Vector3.new(0.9,0.9,0.9)
    dot.Anchored=true; dot.CanCollide=false; dot.CanQuery=false; dot.CanTouch=false
    dot.Material=Enum.Material.Neon; dot.Color=Config.Grenade.DotColor
    dot.Transparency=0.15; dot.Parent=f
    _g3d.dot = dot
end
local function _g3dHide()
    if _g3d.folder then _g3d.folder:Destroy() end
    _g3d.folder=nil; _g3d.parts={}; _g3d.dot=nil
end
local function _g3dSegment(i)
    local p = _g3d.parts[i]
    if p and p.Parent then return p end
    p = Instance.new("Part")
    p.Anchored=true; p.CanCollide=false; p.CanQuery=false; p.CanTouch=false
    p.Material=Enum.Material.Neon; p.Transparency=0.25
    p.TopSurface=Enum.SurfaceType.Smooth; p.BottomSurface=Enum.SurfaceType.Smooth
    p.Parent = _g3d.folder
    _g3d.parts[i] = p
    return p
end
function _renderGrenade3D()
    if not (Config and Config.GlobalEnable and Config.Grenade and (Config.Grenade.Prediction or Config.Grenade.Warning)) then
        _g3dHide(); return
    end
    local hasPred = Config.Grenade.Prediction and GPD and GPD.ShowNow and GPD.CachedPts and #GPD.CachedPts >= 2
    local warnPts = (Config.Grenade.Warning and ECLIPSE and ECLIPSE._warn3DPts) or nil
    local hasWarn = warnPts and #warnPts >= 2
    if not (hasPred or hasWarn) then _g3dHide(); return end
    local pts = hasPred and GPD.CachedPts or warnPts
    local col = hasPred and (Config.Grenade.LineColor or Color3.fromRGB(0,200,255))
                          or (Config.Grenade.WarningColor or Color3.fromRGB(255,120,60))
    _g3dEnsure()
    local used = 0
    for i = 1, #pts - 1 do
        local a, b = pts[i], pts[i+1]
        local d = (b - a); local mag = d.Magnitude
        if mag > 0.05 then
            used = used + 1
            local seg = _g3dSegment(used)
            seg.Size = Vector3.new(0.18, 0.18, mag)
            seg.CFrame = CFrame.lookAt(a + d*0.5, b)
            seg.Color = col
        end
    end
    for i = used+1, #_g3d.parts do
        if _g3d.parts[i] then _g3d.parts[i]:Destroy(); _g3d.parts[i]=nil end
    end
    if _g3d.dot then
        _g3d.dot.Position = pts[#pts]
        _g3d.dot.Color = hasPred and (Config.Grenade.DotColor or Color3.fromRGB(255,60,60))
                                  or (Config.Grenade.WarningColor or Color3.fromRGB(255,120,60))
    end
end

game:GetService("RunService").Heartbeat:Connect(function()
