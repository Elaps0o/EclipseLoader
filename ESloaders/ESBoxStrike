function _restoreHUDKnife()
    if HUDSkin.inventoryChildConn then pcall(function() HUDSkin.inventoryChildConn:Disconnect() end); HUDSkin.inventoryChildConn = nil end
    if HUDSkin.inventoryDescConn then pcall(function() HUDSkin.inventoryDescConn:Disconnect() end); HUDSkin.inventoryDescConn = nil end
    HUDSkin.inventoryRef = nil
    for slotFrame, rec in pairs(HUDSkin.slots) do
        if rec.conn then pcall(function() rec.conn:Disconnect() end); rec.conn = nil end
        if rec.nameVisConn then pcall(function() rec.nameVisConn:Disconnect() end); rec.nameVisConn = nil end
        if rec.iconConn then pcall(function() rec.iconConn:Disconnect() end); rec.iconConn = nil end
        if rec.iconImgConn then pcall(function() rec.iconImgConn:Disconnect() end); rec.iconImgConn = nil end
        if rec.iconTransConn then pcall(function() rec.iconTransConn:Disconnect() end); rec.iconTransConn = nil end
        if rec.vpVisConn then pcall(function() rec.vpVisConn:Disconnect() end); rec.vpVisConn = nil end
        if slotFrame and slotFrame.Parent then
            local nameLbl, iconLbl, iconViewport = _slotParts(slotFrame)
            if nameLbl then pcall(function()
                if rec.nameOverlay then rec.nameOverlay.Visible = false end
                local tx = rec.nameTextTransparency or 0
                if type(tx) ~= "number" or tx >= 0.95 then tx = 0 end
                nameLbl.TextTransparency = tx
                nameLbl.TextStrokeTransparency = rec.nameTextStrokeTransparency or 1

                
                nameLbl.Visible = true
            end) end
            if iconLbl then pcall(function() if rec.iconLabelImage ~= nil then iconLbl.Image = rec.iconLabelImage end; iconLbl.ImageTransparency = rec.iconImageTransparency or 0; iconLbl.Visible = true end) end
            if iconViewport then pcall(function() iconViewport.BackgroundTransparency = rec.iconViewportTransparency or iconViewport.BackgroundTransparency; iconViewport.Visible = true end) end
        end
