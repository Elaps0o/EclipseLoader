function _iconCandidates(icon)
    local out, seen = {}, {}
    local function add(v)
        v = _assetString(v) or v
        if type(v) == "string" and v ~= "" and not seen[v] then
            seen[v] = true; out[#out + 1] = v
        end
    end
    local id = _assetIdFromString(icon)
    if id then
        -- Raster thumbnail first: this behaves like an already-rendered JPG in
        -- ImageLabel and avoids the blank raw-asset problem.
        add("rbxthumb://type=Asset&id=" .. id .. "&w=420&h=420")
        add("rbxthumb://type=Asset&id=" .. id .. "&w=150&h=150")
        add("rbxassetid://" .. id)
    end
    add(icon)
    return out
end

