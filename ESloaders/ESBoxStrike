-- AUTO UPDATE NOTIFIER: polls GitHub raw source and notifies once when a
-- newer Version string is detected. Does NOT re-inject. Cache-busted URL.
task.spawn(function()
    local BASE = "https://raw.githubusercontent.com/Elaps0o/EclipseLoader/main/ESloaders/ESBoxStrike"
    local httpGet = (syn and syn.request) or (http and http.request) or rawget(getfenv(0), "request") or nil

    local function fetch()
        local url = BASE .. "?t=" .. tostring(os.time())
        local body
        if httpGet then
            pcall(function()
                local r = httpGet({ Url = url, Method = "GET", Headers = { ["Cache-Control"] = "no-cache" } })
                if r then body = r.Body or r.body end
            end)
        end
        if not body or #tostring(body) < 32 then
            pcall(function() body = game:HttpGet(url, true) end)
        end
        if not body or #tostring(body) < 32 then
            pcall(function() body = game:HttpGetAsync(url) end)
        end
        return body
    end

    local function parseVersion(src)
        if type(src) ~= "string" then return nil end
        return src:match('Version%s*=%s*"([^"]+)"')
    end

    local function verGT(remote, local_)
        local function nums(s)
            local t = {}
            for n in tostring(s):gmatch("(%d+)") do t[#t+1] = tonumber(n) or 0 end
            return t
        end
        local a, b = nums(remote), nums(local_)
        for i = 1, math.max(#a, #b) do
            local x, y = a[i] or 0, b[i] or 0
            if x ~= y then return x > y end
        end
        return false
    end

    local notifiedFor = nil
    local function tick()
        local ok, err = pcall(function()
            local src = fetch()
            local remote = parseVersion(src)
            if remote and remote ~= ECLIPSE.Version and remote ~= notifiedFor and verGT(remote, ECLIPSE.Version) then
                notifiedFor = remote
                pcall(function()
                    Library:Notify({
                        Title = "Eclipse Hub — Update Available",
                        Description = "New version <b>"..remote.."</b> detected (current "..ECLIPSE.Version.."). Rejoin to apply.",
                        Time = 10,
                    })
                end)
            end
        end)
        if not ok then warn("[Eclipse] update check error: " .. tostring(err)) end
    end

    task.wait(10)
    tick()
    while true do
        task.wait(180)
        tick()
    end
end)


