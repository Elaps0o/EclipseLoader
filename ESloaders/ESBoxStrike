    local isAWP     = heldName == "AWP"
    local isSniper  = heldName and SniperWeapons[heldName] or false
    local scoped = (isAWP or isSniper) and (isScopedIn and isScopedIn())

    local keyHeld = false
    pcall(function()
        local kp = Library.Options and Library.Options.Aimbot_Key
        if kp and kp.GetState then keyHeld = kp:GetState() end
    end)
    if not keyHeld then
        keyHeld = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    end
    
    local aiming = keyHeld or Config.TriggerBot.Enabled or scoped or (isAWP or isSniper)
    if not aiming then return end

    local mp
    if scoped then
        local vp = Camera.ViewportSize
        mp = Vector2.new(vp.X/2, vp.Y/2)
    else
        mp = UserInput:GetMouseLocation()
    end

    local scopeFOV
    if scoped then
        scopeFOV = 220
    else
        scopeFOV = ActiveAimFOV()
    end
    local closestPart, closestDist = nil, scopeFOV
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not IsEnemy(plr) then continue end
        local char = GetCharacter(plr); if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part
        if isAWP or isSniper then
            part = char:FindFirstChild("Head") or GetAimbotTargetPart(char)
        else
            part = GetAimbotTargetPart(char)
        end

        if not part then continue end

        if Config.Aimbot.VisibilityCheck then
            local okHit = _EclipseHitPossible(part, Config.Aimbot.WallBang)
            if not okHit then continue end
        end

        if Config.Aimbot.DisableInSmoke and Camera and _aimRayHitsSmoke(Camera.CFrame.Position, part.Position) then continue end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if on and sp.Z > 0 and sp.X == sp.X and sp.Y == sp.Y then
            local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
            if d < closestDist then closestDist = d; closestPart = part end
        end
    end
    if closestPart then
        local now = tick()
        if AimState.lastTarget ~= closestPart then
            AimState.lastTarget = closestPart
            AimState.acquiredAt = now
            AimState.frameN     = 0
        end
        AimState.frameN = (AimState.frameN or 0) + 1

        local t = math.clamp(AimState.frameN / 2, 0, 1)
        local ramp = 1 - (1 - t) * (1 - t)

        local s = math.clamp(ActiveAimSmooth() or 0.35, 0.05, 1.0)
        local dt = math.clamp(now - (AimState.lastTick > 0 and AimState.lastTick or now - 1/60), 1/240, 1/30)
        AimState.lastTick = now

        local k
        if scoped then
            k = 240
        else
            k = 3 + s * 20
        end
        local alpha = 1 - math.exp(-dt * k)
        alpha = alpha * ramp

        local sp = Camera:WorldToViewportPoint(closestPart.Position)
        local tp = Vector2.new(sp.X, sp.Y)
        local delta = tp - mp
        local mag = delta.Magnitude

        if mag < 5 then alpha = math.min(1, alpha * 1.5) end
        if scoped then alpha = 1 end

        local dx = delta.X * alpha
        local dy = delta.Y * alpha
        if mousemoverel then mousemoverel(dx, dy) end
    else
        AimState.lastTarget = nil
        AimState.frameN     = 0
    end
end

local lastTrigger = 0
function updateTriggerBot()
    if not Config.GlobalEnable or not Config.TriggerBot.Enabled or not IsAlive() then return end
    if tick() - lastTrigger < Config.TriggerBot.Delay then return end
    local fire = false
    if Config.TriggerBot.Mode == "HitChance" then
        if math.random(1,100) <= Config.TriggerBot.HitChance then fire = true end
    elseif Config.TriggerBot.Mode == "NoSpread" then fire = true end
    if not fire then return end

    local vp = Camera.ViewportSize
    local ap = Vector2.new(vp.X/2, vp.Y/2) + Vector2.new(
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread),
        math.random(-Config.TriggerBot.Spread, Config.TriggerBot.Spread))
    local ray = Camera:ViewportPointToRay(ap.X, ap.Y)
    local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude
    local ig = { Camera }; if LocalPlayer.Character then table.insert(ig, LocalPlayer.Character) end
    rp.FilterDescendantsInstances = ig
    local r = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
    local function _tryFireOnPlayer(pl)
        if not pl then return false end
        if pl and not _IS_DEATHMATCH and Config.TeamCheck and IsAlly(pl) then return false end
        local ch = pl.Character; if not ch then return false end
        local h = ch:FindFirstChildOfClass("Humanoid"); if not h or h.Health <= 0 then return false end
        lastTrigger = tick()
        if mouse1click then mouse1click() end
        return true
    end
    if r and r.Instance then
        local m = r.Instance:FindFirstAncestorOfClass("Model")
        if m and m:FindFirstChildOfClass("Humanoid") then
            local plr = Players:GetPlayerFromCharacter(m)
            if _tryFireOnPlayer(plr) then return end
        elseif Config.TriggerBot.AutoWall then
            local origin = ray.Origin
            local dir = ray.Direction.Unit
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl ~= LocalPlayer and pl.Character then
                    local root = pl.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local toRoot = (root.Position - origin)
                        if toRoot.Magnitude > 0 and math.acos(math.clamp(dir:Dot(toRoot.Unit), -1, 1)) < math.rad(2.5) then
                            local pStats = GetPenetrationStats(origin, dir, tonumber(Config.Aimbot.WallDepth) or 1.0, { LocalPlayer.Character, Camera }, pl.Character)
                            if pStats and pStats.Success then
                                if _tryFireOnPlayer(pl) then return end
                            end
                        end
                    end
                end
            end
        end
    end
end


