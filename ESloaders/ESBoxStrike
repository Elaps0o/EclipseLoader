-- =====================================================================
-- SERVER HOP  ·  Teleport to another public server of this place.
-- Pulls the public server list via HttpGet, filters out the current one,
-- optionally sorts by lowest ping / most players.
-- =====================================================================
local SHGB = Tabs.General:AddLeftGroupbox("SERVER HOP", "globe")
Config.ServerHop = { Mode="Lowest Ping", MinPlayers=1, MaxPlayers=10 }
local SH_STATE = { last=nil, busy=false }
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
SafeAddDropdown(SHGB, "SH_Mode", {
    Text="MODE", Values={"Lowest Ping","Most Players","Least Players","Random"},
    Default="Lowest Ping", Callback=function(v) Config.ServerHop.Mode=v end })
SHGB:AddSlider("SH_MinPlayers", { Text="MIN PLAYERS", Default=1, Min=1, Max=10, Rounding=0,
    Callback=function(v) Config.ServerHop.MinPlayers=v end })
SHGB:AddSlider("SH_MaxPlayers", { Text="MAX PLAYERS", Default=10, Min=1, Max=10, Rounding=0,
    Callback=function(v) Config.ServerHop.MaxPlayers=v end })
local function _pickServer()
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", game.PlaceId)
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if not ok or not body then return nil, "HTTP failed" end
    local ok2, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok2 or type(data) ~= "table" or type(data.data) ~= "table" then return nil, "Bad JSON" end
    local pool = {}
    for _, s in ipairs(data.data) do
        if s.id ~= game.JobId
           and (s.playing or 0) >= Config.ServerHop.MinPlayers
           and (s.playing or 0) < math.min(s.maxPlayers or 99, Config.ServerHop.MaxPlayers) then
            table.insert(pool, s)
        end
    end
    if #pool == 0 then return nil, "No servers" end
    if Config.ServerHop.Mode == "Lowest Ping" then
        table.sort(pool, function(a,b) return (a.ping or 999) < (b.ping or 999) end)
    elseif Config.ServerHop.Mode == "Most Players" then
        table.sort(pool, function(a,b) return (a.playing or 0) > (b.playing or 0) end)
    elseif Config.ServerHop.Mode == "Least Players" then
        table.sort(pool, function(a,b) return (a.playing or 0) < (b.playing or 0) end)
    else
        -- Random
        for i = #pool, 2, -1 do local j = math.random(i); pool[i], pool[j] = pool[j], pool[i] end
    end
    return pool[1]
end
