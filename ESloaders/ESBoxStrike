    if GPD then GPD.ShowNow = false end
    if not GPD_OK then return end

    if not Config.GlobalEnable or not Config.Grenade.Prediction then
        if #GPD.ActiveLines > 0 or (GPD.Dot and GPD.Dot.Visible) then gpdClear() end
        GPD_Hold.wasHolding = false; GPD_Hold.showAfterRelease = false
        return
    end

    local gpp = gpdIdentifyGrenade()
    if not gpp then
        gpdClear(); GPD_Hold.wasHolding = false; GPD_Hold.showAfterRelease = false
        return
    end

    local cam = Workspace.CurrentCamera; if not cam then return end
    local isLMB = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    local isRMB = UserInput:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    local isHolding = isLMB or isRMB
    local now = tick()

    if isHolding and not GPD_Hold.wasHolding then
        GPD_Hold.holdType = isRMB and "right" or "left"
        GPD_Hold.showAfterRelease = false
    end
    if not isHolding and GPD_Hold.wasHolding then
        GPD_Hold.releaseTime = now
        GPD_Hold.showAfterRelease = true
    end
    GPD_Hold.wasHolding = isHolding

    local shouldShow = isHolding
    if GPD_Hold.showAfterRelease then
        if (now - GPD_Hold.releaseTime) < 0.7 then shouldShow = true
        else GPD_Hold.showAfterRelease = false end
    end
    if not shouldShow then gpdClear(); return end

    local ch = LocalPlayer.Character
    if not ch or not ch.PrimaryPart then gpdClear(); return end

    local gPos = cam.CFrame.Position
    local gDir = cam.CFrame.LookVector
    local cc   = cam.CFrame
    local pV   = ch.PrimaryPart.AssemblyLinearVelocity

    local throwType = GPD_Hold.holdType or "left"
    if isHolding then
        throwType = isRMB and "right" or "left"
        GPD_Hold.holdType = throwType
    end

    
    local cached = (now - GPD.LastCalc < 0.033)
        and (cc.Position   - GPD.LastCam.Position  ).Magnitude   < 0.05
        and (cc.LookVector - GPD.LastCam.LookVector).Magnitude   < 0.005
        and (pV            - GPD.LastVel           ).Magnitude   < 0.05

    if not cached then
        local throwSpeed = (throwType == "right") and 60 or 125
        local vel = (gDir * throwSpeed) + pV
        local pts = { gPos }
        local dts = 0.03
        local grav = Vector3.new(0, -Workspace.Gravity, 0)
        local elapsed = 0
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        rp.IgnoreWater = true
        local filter = { ch, cam }
        local db = Workspace:FindFirstChild("Debris")
        if db then filter[#filter + 1] = db end
        pcall(function() rp.FilterDescendantsInstances = filter end)

        for _ = 1, math.floor(4.0 / dts) do
            elapsed = elapsed + dts
            vel = vel + (grav * dts)
            vel = vel * (1 - 0.02)
            local np = gPos + (vel * dts)
            local hit = Workspace:Raycast(gPos, np - gPos, rp)
            if hit then
                if gpp.ExplodeOnTouch and hit.Normal.Y > 0.5 then
                    gPos = hit.Position; break
                end
                local n = hit.Normal
                vel = (vel - (2 * vel:Dot(n) * n)) * gpp.Restitution
                gPos = hit.Position + (n * 0.05)
                if vel.Magnitude < 5 then break end
            else
                gPos = np
            end
            pts[#pts + 1] = gPos
            if elapsed >= gpp.Fuse then break end
        end

        GPD.CachedPts = pts
        GPD.LastCalc  = now
        GPD.LastCam   = cc
        GPD.LastVel   = pV
    end

    gpdClear()
    local pts = GPD.CachedPts
    for i = 1, #pts - 1 do
        local s1, v1 = cam:WorldToViewportPoint(pts[i])
        local s2, v2 = cam:WorldToViewportPoint(pts[i + 1])
        if v1 and v2 then
            local l = gpdGetLine()
            if l then
                l.From    = Vector2.new(s1.X, s1.Y)
                l.To      = Vector2.new(s2.X, s2.Y)
                l.Color   = Config.Grenade.LineColor
                l.Visible = true
            end
        end
    end
    if #pts > 0 and GPD.Dot then
        local sp, so = cam:WorldToViewportPoint(pts[#pts])
        if so then
            GPD.Dot.Position = Vector2.new(sp.X, sp.Y)
            GPD.Dot.Color    = Config.Grenade.DotColor
            GPD.Dot.Visible  = true
        else
            GPD.Dot.Visible = false
        end
    end
    GPD.ShowNow = true
end


