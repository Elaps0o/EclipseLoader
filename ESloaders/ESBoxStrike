            local hl = Instance.new("Highlight", clone)
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = clone; hl.Enabled = false
            ESPPreview.hl = hl
            -- Frame the model
            local cf, size = clone:GetBoundingBox()
            local maxDim = math.max(size.X, size.Y, size.Z)
            local dist = math.max(6, maxDim * 3)
            ESPPreview.cam.CFrame = CFrame.new(cf.Position + Vector3.new(0, 0.5, dist), cf.Position)
