local function findDefuser()
    for _, p in ipairs(Players:GetPlayers()) do
        if p:GetAttribute("IsDefusingBomb") then return p end
    end
    return nil
end

local function isBombDefused()
    local ok, cs = pcall(function() return CollectionService:GetTagged("Bomb")[1] end)
    if ok and cs and cs:GetAttribute("Defused") then return true end
    return false
end

-- Auto Defuse: when the bomb is planted and we're within ~2m (7 studs) of a
-- valid defuse position, automatically HOLD the E key via VirtualInputManager
-- (mirroring what the game's own DefuseKit prompt listens for) and also fires
-- the DefuseBomb remote as a fallback. Runs continuously until the bomb is
-- defused / removed / we die / we leave the range.
local AutoDefuse = { remote=nil, resolved=false, lastFire=0, holding=false, VIM=nil }
local function resolveDefuseRemote()
    if AutoDefuse.resolved then return AutoDefuse.remote end
    AutoDefuse.resolved = true
    pcall(function()
        local db = ReplicatedSt:WaitForChild("Database", 10)
        local R = require(db:WaitForChild("Security"):WaitForChild("Remotes"))
        local candidates = { R.DefuseBomb, R.StartDefuse, R.Defuse, R.BombDefuse }
        for _, r in ipairs(candidates) do
            if r and (r.Fire or r.InvokeServer or r.FireServer) then
                AutoDefuse.remote = r; return
            end
        end
    end)
    return AutoDefuse.remote
end
local function _getVIM()
    if AutoDefuse.VIM then return AutoDefuse.VIM end
    pcall(function() AutoDefuse.VIM = game:GetService("VirtualInputManager") end)
    return AutoDefuse.VIM
end
local function _holdE(down)
    if AutoDefuse.holding == down then return end
    AutoDefuse.holding = down
    local vim = _getVIM(); if not vim then return end
    pcall(function() vim:SendKeyEvent(down, Enum.KeyCode.E, false, game) end)
end
local function tryAutoDefuse()
    if not Config.Misc.AutoDefuse or not C4Timer.planted then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    if isBombDefused() then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local ch = LocalPlayer.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local team = LocalPlayer:GetAttribute("Team")
    if team and team ~= "Counter-Terrorists" then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    -- Range + valid-space check: within ~2m (6 studs) AND roughly facing the
    -- bomb (dot > 0.3) so we only hold E when the player is in a real defuse
    -- position, not just adjacent behind a wall.
    local bomb = C4Timer.bomb or getBombModel()
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    local bpart = bomb and (bomb.PrimaryPart or bomb:FindFirstChildWhichIsA("BasePart"))
    if not (bpart and root) then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local delta = bpart.Position - root.Position
    local dist = delta.Magnitude
    if dist > 6 then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    -- Facing check: dot of look vector vs bomb direction (skip if very close).
    if dist > 1.2 then
        local look = root.CFrame.LookVector
        local dir = delta.Unit
        if look:Dot(dir) < 0.25 then
            if AutoDefuse.holding then _holdE(false) end
            return
        end
    end

    -- In-range: hold E and also ping the remote as a safety net.
    _holdE(true)
    local now = tick()
    if now - AutoDefuse.lastFire < 0.15 then return end
    AutoDefuse.lastFire = now
    local r = resolveDefuseRemote(); if not r then return end
    pcall(function()
        if r.Fire then r:Fire()
        elseif r.FireServer then r:FireServer()
        elseif r.InvokeServer then r:InvokeServer() end
    end)
end

local function startC4Timer(bomb)
    if C4Timer.planted then return end
    C4Timer.planted = true
    C4Timer.bomb = bomb
    C4Timer.endT = 0
    syncC4Timer(bomb)
    if C4Timer.endT <= 0 then C4Timer.endT = tick() + C4Timer.duration end
    C4Timer.defuser = nil
    C4Timer.defAlerted = false
    C4Timer.hideAt = 0
end

local function stopC4Timer()
    C4Timer.planted = false
    C4Timer.bomb = nil
    C4Timer.endT = 0
    C4Timer.exact = false
    C4Timer.defuser = nil
    C4Timer.defAlerted = false
end

local function updateC4Timer()
    -- Timer runs internally regardless of the toggle; toggle only hides the UI
    -- so toggling off/on mid-round does NOT reset the countdown.
    local hideOnly = not Config.Misc.C4Timer
    -- GUI open preview: while the main GUI is on-screen and the C4 toggle is
    -- enabled, keep the panel visible even without a live bomb so the user can
    -- drag/position it. When GUI closes and there's no bomb, it auto-hides.
    local previewOpen = false
    if not hideOnly then
        local guiOpen = (ECLIPSE._isGuiOpen and ECLIPSE._isGuiOpen()) or false
        if guiOpen and not C4Timer.planted and C4Timer.hideAt == 0 then
            previewOpen = true
            C4Show("", "40", "", Color3.fromRGB(120,120,130))
        end
    end
    if hideOnly then C4Hide() end
    -- When previewing (GUI open, no bomb), skip the rest — nothing else to compute.
    if previewOpen then return end
    local _C4Show = hideOnly and function() end or C4Show
    local bomb = getBombModel()
    local resolved = isBombResolvedState(bomb)
    local planted = bomb ~= nil and not resolved

    if resolved and C4Timer.planted then
        if bomb and bomb:GetAttribute("Defused") == true then
            _C4Show("BOMB DEFUSED", "SAFE", "", Color3.fromRGB(90,220,140))
        elseif bomb and (bomb:GetAttribute("Exploded") == true or bomb:GetAttribute("Exploding") == true) then
            _C4Show("BOMB DETONATED", "BOOM", "", Color3.fromRGB(255,80,80))
        else
            _C4Show("TIME UP", "0", "fuse ended", Color3.fromRGB(255,140,60))
        end
        C4Timer.hideAt = tick() + 2.5
        stopC4Timer(); return
    end

    if planted and not C4Timer.planted then startC4Timer(bomb) end
    if planted and C4Timer.planted then
        C4Timer.bomb = bomb
        syncC4Timer(bomb)
    end
    if not planted and C4Timer.planted then
        local remainLeft = math.max(0, C4Timer.endT - tick())
        if isBombDefused() then
            _C4Show("BOMB DEFUSED", "SAFE", "", Color3.fromRGB(90,220,140))
        elseif remainLeft <= 0.5 then
            _C4Show("BOMB DETONATED", "BOOM", "", Color3.fromRGB(255,80,80))
        else
            _C4Show("BOMB LOST", "--", "signal lost", Color3.fromRGB(200,200,200))
        end
        C4Timer.hideAt = tick() + 2.5
        stopC4Timer(); return
    end
    if C4Timer.hideAt > 0 and tick() >= C4Timer.hideAt then
        C4Timer.hideAt = 0; C4Hide()
    end
    if not C4Timer.planted then
        -- Nothing planted, no timer running: if the panel is showing only because
        -- of the GUI-open preview and the GUI just closed, animate the hide.
        if C4UI.shown and not hideOnly then
            local guiOpen = (ECLIPSE._isGuiOpen and ECLIPSE._isGuiOpen()) or false
            if not guiOpen then C4Hide() end
        end
        return
    end

    local remain = math.max(0, C4Timer.endT - tick())
    if remain <= 0 and C4Timer.exact then
        remain = 0
    end
    local d = findDefuser()
    local sub, col = "", nil
    if d then
        -- Defuse phase mirrors game logic (DefuseBomb script dump):
        --   duration = 5s with kit, 10s without.
        --   start is the defuser's server-synced DefuseStartTime attribute
        --   (workspace:GetServerTimeNow() timebase). Fall back to local tick()
        --   only when the attribute is missing or stale.
        local kit = d:GetAttribute("HasDefuseKit") == true
        local dur = kit and 5 or 10
        local nowServer = c4ServerNow()
        local startServer = d:GetAttribute("DefuseStartTime")
        local elapsed
        if typeof(startServer) == "number"
           and startServer <= nowServer
           and (nowServer - startServer) >= 0
           and (nowServer - startServer) <= math.max(dur, 12) then
            elapsed = nowServer - startServer
        else
            if C4Timer.defuser ~= d then
                C4Timer.defuser = d
                C4Timer.defuseStart = tick()
                C4Timer.defuseDuration = dur
            end
            elapsed = tick() - (C4Timer.defuseStart or tick())
        end
        local defRemain = math.max(0, dur - elapsed)
        local pct = math.clamp(defRemain / dur, 0, 1)
        _C4Show("DEFUSING",
            tostring(math.ceil(defRemain)),
            string.format("%s [%s]", d.DisplayName or d.Name, kit and "KIT" or "NO KIT"),
            Color3.fromRGB(90, 200, 255))
        if C4UI.bar then
            -- Stepped bar: snap to per-second segments with a short tween ("travadinha").
            local steps = math.max(1, math.ceil(dur))
            local stepPct = math.ceil(defRemain) / steps
            TweenService:Create(C4UI.bar, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2.new(stepPct, 0, 1, 0) }):Play()
        end
        return
    else
        C4Timer.defuser = nil
        C4Timer.defuseStart = nil
    end
    if remain <= 5 then       col = Color3.fromRGB(255, 70, 70)
    elseif remain <= 15 then  col = Color3.fromRGB(255, 180, 60)
    else                      col = Color3.fromRGB(255, 90, 60) end
    _C4Show("PLANTED", tostring(math.ceil(remain)), sub, col)
    if C4UI.bar then
        -- Stepped bar per whole second remaining, gives a subtle click cadence.
        local total  = C4Timer.duration > 0 and C4Timer.duration or C4_FALLBACK_DURATION
        local steps  = math.max(1, math.ceil(total))
        local stepPct = math.clamp(math.ceil(remain) / steps, 0, 1)
        TweenService:Create(C4UI.bar, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            { Size = UDim2.new(stepPct, 0, 1, 0) }):Play()
    end
    -- Ticking pulse: subtle scale/transparency beat that speeds up as remain drops.
    if C4UI.time then
        local speed  = (remain <= 5) and 6 or (remain <= 15 and 3 or 1.5)
        local beat   = 0.5 + 0.5 * math.sin(tick() * speed * math.pi)
        C4UI.time.TextTransparency = (remain <= 15) and (0.15 * (1 - beat)) or 0
        if C4UI.stroke then
            C4UI.stroke.Transparency = 0.15 + 0.55 * (1 - beat) * (remain <= 15 and 1 or 0)
        end
    end

    tryAutoDefuse()
end








