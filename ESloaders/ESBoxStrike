-- ────────────────────────────────────────────────────────────────
-- ASSET AUTO-MAP (Charms + Badges under game:GetChildren()[109].Assets)
-- Enumerates Charms (folder → numbered subfolders → Model) and Badges
-- (folder → MeshPart) into flat lookup tables. Exposed on _G so future
-- accessory/skinchanger work can consume them without re-walking the tree.
-- No behavior change on its own; purely a discovery helper.
-- ────────────────────────────────────────────────────────────────
local EclipseCharms, EclipseBadges = {}, {}
local function _buildAssetMaps()
    local rootAssets
    pcall(function()
        local node = game:GetChildren()[109]
        rootAssets = node and node:FindFirstChild("Assets") or nil
    end)
    if not rootAssets then return end
    local charmsFolder = rootAssets:FindFirstChild("Charms")
    if charmsFolder then
        for _, charmGroup in ipairs(charmsFolder:GetChildren()) do
            local slots = {}
            for _, slotFolder in ipairs(charmGroup:GetChildren()) do
                local slotNum = tonumber(slotFolder.Name)
                if slotNum then
                    local model = slotFolder:FindFirstChildWhichIsA("Model")
                    if model then slots[slotNum] = model end
                end
            end
            if next(slots) then EclipseCharms[charmGroup.Name] = slots end
        end
    end
    local badgesFolder = rootAssets:FindFirstChild("Badges")
    if badgesFolder then
        for _, badgeGroup in ipairs(badgesFolder:GetChildren()) do
            local mesh = badgeGroup:FindFirstChildWhichIsA("MeshPart")
            if mesh then EclipseBadges[badgeGroup.Name] = mesh end
        end
    end
end
pcall(_buildAssetMaps)
_G.EclipseCharms = EclipseCharms
_G.EclipseBadges = EclipseBadges

