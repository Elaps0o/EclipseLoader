            if alive then _espPreviewRefresh() end
        else
            if _lastVisible ~= false then
                _lastVisible = false
                _lastAlive = nil
                if ESPPreview.visible then _espPreviewClose() end
            end
        end
        task.wait(0.1)
    end
end)
