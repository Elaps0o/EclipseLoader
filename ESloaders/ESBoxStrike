local function classifyDebrisItem(item)
    if not item or not item.Parent then return nil end
    if Config.ESP.WorldWeapons and item:IsA("Model")
        and item:GetAttribute("Weapon") and item:GetAttribute("CanPickup") == true then
        local wname = tostring(item:GetAttribute("Weapon") or item.Name)
        return { kind = "weapon", label = "▸ "..wname:upper(), color = Config.ESP.WeaponColor }
    end
    if Config.ESP.WorldBomb and item:IsA("Model")
        and item.Name == "Character" and item:GetAttribute("BombPlanted") then
        return { kind = "bomb", label = "◈ C4", color = Config.ESP.BombColor }
    end
    if Config.ESP.WorldMolotov and item:IsA("Folder") and item.Name:match("^VoxelFire") then
        return { kind = "molotov", label = "◆ MOLOTOV", color = Config.ESP.MolotovColor }
    end
    if Config.ESP.WorldSmoke and item:IsA("Folder") and item.Name:match("^VoxelSmoke") then
        return { kind = "smoke", label = "◉ SMOKE", color = Config.ESP.SmokeColor }
    end
    return nil
end

local function getWorldPivot(inst)
    if inst:IsA("BasePart") then return inst.Position, inst.Size end
    if inst:IsA("Model") then
        if inst.PrimaryPart then return inst.PrimaryPart.Position, inst.PrimaryPart.Size end
        local ok, cf, sz = pcall(function() return inst:GetBoundingBox() end)
        if ok and cf then return cf.Position, sz end
    end
    if inst:IsA("Folder") then
        local sum, n = Vector3.new(), 0
        for _, ch in ipairs(inst:GetChildren()) do
            if ch:IsA("BasePart") then sum = sum + ch.Position; n = n + 1 end
        end
        if n > 0 then return sum / n, Vector3.new(6, 6, 6) end
    end
    return nil
end

local function updateWorldESP()
    if not Config.GlobalEnable or not (Config.ESP.WorldBomb or Config.ESP.WorldWeapons or Config.ESP.WorldMolotov or Config.ESP.WorldSmoke) then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end

    local debris = Workspace:FindFirstChild("Debris")
    if not debris then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end

    WorldEspSeen = {}
    for _, child in ipairs(debris:GetChildren()) do
        local info = classifyDebrisItem(child)
        if info then
            local pos = getWorldPivot(child)
            if pos then
                WorldEspSeen[child] = true
                local e = getWorldEspEntry(child)
                local sp, on = Camera:WorldToViewportPoint(pos)
                if on then
                    local dist = (myRoot.Position - pos).Magnitude
                    local s = math.clamp(260 / math.max(1, dist), 10, 30)
                    local bx, by = sp.X - s/2, sp.Y - s/2
                    -- Distance fade: fully opaque up to 40m, fade to 55% at MaxDistance.
                    local fade = math.clamp(1 - (dist - 40) / math.max(1, (Config.ESP.MaxDistance or 500) - 40), 0.55, 1)
                    -- Pulse: hazards (molotov/smoke) breathe; C4 pulses fast; weapons steady.
                    local pulse = 1
                    if info.kind == "bomb"    then pulse = 0.75 + 0.25 * math.sin(tick() * 6)
                    elseif info.kind == "molotov" then pulse = 0.80 + 0.20 * math.sin(tick() * 3)
                    elseif info.kind == "smoke"   then pulse = 0.85 + 0.15 * math.sin(tick() * 2) end
                    if e.Fill then e.Fill.Visible = false end
                    e.Box.Size = Vector2.new(s, s)
                    e.Box.Position = Vector2.new(bx, by)
                    e.Box.Color = info.color
                    e.Box.Transparency = fade * pulse
                    e.Box.Visible = true
                    e.Dot.Position = Vector2.new(sp.X, sp.Y)
                    e.Dot.Color = info.color
                    e.Dot.Transparency = fade * pulse
                    e.Dot.Visible = true
                    e.Tag.Text = string.format("%s  [%dm]", info.label, math.floor(dist))
                    e.Tag.Color = info.color
                    e.Tag.Transparency = fade
                    e.Tag.Position = Vector2.new(sp.X, by - 18)
                    e.Tag.Visible = true

                else
                    hideWorldEntry(e)
                end
            end
        end
    end
    local debrisRef = Workspace:FindFirstChild("Debris")
    for inst, e in pairs(WorldEspPool) do
        local alive = inst.Parent ~= nil and debrisRef and (inst.Parent == debrisRef or inst:IsDescendantOf(debrisRef))
        if not WorldEspSeen[inst] or not alive then
            hideWorldEntry(e)
            if not alive then
                pcall(function() e.Tag:Remove() end); pcall(function() e.Box:Remove() end); pcall(function() if e.Fill then e.Fill:Remove() end end); pcall(function() if e.Dot then e.Dot:Remove() end end)
                WorldEspPool[inst] = nil
            end
        end
    end


end

