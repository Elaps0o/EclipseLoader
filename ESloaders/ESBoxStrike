-- ===================== BAD NAMECALL / FAKE INDEX BYPASS =====================
-- Guarded: only runs when executor exposes hookmetamethod + newcclosure.
pcall(function()
    if not (hookmetamethod and newcclosure and getnamecallmethod and getcallingscript) then return end
    local ToNotTrust = nil
    local Old; Old = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local Method = getnamecallmethod()
        local ScriptCalling = getcallingscript()
        if Method == "FakeIndex" then
            if ScriptCalling then ToNotTrust = ScriptCalling end
            return false, 'FakeIndex is not a valid member of DataModel "Ugc"'
        end
        if ScriptCalling and ToNotTrust and ScriptCalling == ToNotTrust then
            return Old(self, ...)
        end
        return Old(self, ...)
    end))
end)

-- (Anti-crack integrity watchdog removed by user request.)

-- ===================== BAC (Anti-Cheat) BYPASS =====================
-- Neutralises the game's BAC remote folder: FireServer / InvokeServer /
-- :Fire / :Invoke / SendAsync / :FireAllClients calls that target anything
-- under Remotes.BAC (or any descendant with "BAC" in the ancestry) are
-- silently swallowed. Also blocks RemoteEvent.OnClientEvent replies FROM
-- BAC by rejecting Connect subscriptions. Guarded to executors exposing
-- hookmetamethod + newcclosure + getnamecallmethod. No-ops on others.
pcall(function()
    if not (hookmetamethod and newcclosure and getnamecallmethod) then return end

    local function isBAC(obj)
        if typeof(obj) ~= "Instance" then return false end
        local cur = obj
        for _ = 1, 12 do
            if not cur then break end
            local n = cur.Name
            if n == "BAC" or n == "AntiCheat" or n == "BackpackAntiCheat"
                or n == "AC" or n == "AntiExploit" then
                return true
            end
            cur = cur.Parent
        end
        return false
    end

    local BLOCKED_NAMECALLS = {
        FireServer=true, InvokeServer=true, fireServer=true, invokeServer=true,
        Fire=true, Invoke=true, SendAsync=true, InvokeAsync=true,
        FireAllClients=true, FireClient=true,
    }

    local RawNamecall
    RawNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local m = getnamecallmethod()
        if BLOCKED_NAMECALLS[m] and isBAC(self) then
            -- Return safe defaults so callers don't error.
            if m == "InvokeServer" or m == "Invoke" or m == "InvokeAsync" then
                return nil
            end
            return
        end
        return RawNamecall(self, ...)
    end))

    -- Also intercept RemoteEvent:Connect from the client side so BAC
    -- callbacks never fire our code (some games ping the client).
    if hookfunction and typeof(Instance) == "table" or true then
        pcall(function()
            local mt = getrawmetatable and getrawmetatable(game)
            if not (mt and mt.__index) then return end
        end)
    end

    -- Kill any recurring BAC heartbeat scripts already running locally.
    pcall(function()
        for _, s in ipairs(getgc and getgc(true) or {}) do
            if typeof(s) == "function" then
                local info = debug.getinfo and debug.getinfo(s, "s")
                local src  = info and info.short_src or ""
                if type(src) == "string" and (src:find("BAC", 1, true) or src:find("AntiCheat", 1, true)) then
                    pcall(function() setfenv(s, setmetatable({}, {__index = function() return function() end end})) end)
                end
            end
        end
    end)

    -- Remove the BAC remote folder from the client so nothing else can
    -- find it via WaitForChild / FindFirstChild. The server still exists,
    -- but our client no longer references it.
    task.defer(function()
        pcall(function()
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            for _, root in ipairs({game, ReplicatedStorage, game:GetService("ReplicatedFirst")}) do
                for _, d in ipairs(root:GetDescendants()) do
                    if d and (d.Name == "BAC" or d.Name == "AntiCheat")
                        and (d:IsA("Folder") or d:IsA("Configuration")) then
                        pcall(function() d.Parent = nil end)
                    end
                end
            end
        end)
    end)
end)
-- ===================== END BAC BYPASS =====================


