function _restoreOriginalHUDIcon(rec, iconLbl, iconViewport)
    if rec then rec.iconToken = (rec.iconToken or 0) + 1 end
    if rec and rec.iconImage then pcall(function() rec.iconImage:Destroy() end); rec.iconImage = nil end
    if rec and rec.iconFallbackImage then pcall(function() rec.iconFallbackImage:Destroy() end); rec.iconFallbackImage = nil end
    if iconLbl then
        pcall(function()
            if rec and rec.iconLabelImage ~= nil then iconLbl.Image = rec.iconLabelImage end
            if rec and rec.iconImageColor3 ~= nil then iconLbl.ImageColor3 = rec.iconImageColor3 end
            if rec and rec.iconImageRectOffset ~= nil then iconLbl.ImageRectOffset = rec.iconImageRectOffset end
            if rec and rec.iconImageRectSize ~= nil then iconLbl.ImageRectSize = rec.iconImageRectSize end
            if rec and rec.iconScaleType ~= nil then iconLbl.ScaleType = rec.iconScaleType end
            iconLbl.ImageTransparency = rec and rec.iconImageTransparency or 0
            -- Force visible on restore: after death/respawn the snapshot may have
            -- captured Visible=false (transient hide), which would leave the
            -- native knife icon invisible forever. Default to true unless the
            -- snapshot explicitly recorded false.
            iconLbl.Visible = (rec and rec.iconLabelVisible == false) and false or true
        end)
    end
    if iconViewport then
        pcall(function()
            iconViewport.BackgroundTransparency = rec and rec.iconViewportTransparency or iconViewport.BackgroundTransparency
            iconViewport.Visible = (rec and rec.iconViewportVisible == false) and false or true
        end)
    end
end

function _ensureSlotRec(slotFrame, nameLbl, iconLbl, iconViewport, iconAnchor)
    local rec = HUDSkin.slots[slotFrame]
    if rec then
        if nameLbl and rec.nameLblRef ~= nameLbl and nameLbl:GetAttribute("EclipseHUD") ~= true then
            rec.nameLblRef = nameLbl
            if not rec.applying and nameLbl.Text ~= rec.currentOverlayText then
                rec.nameText = nameLbl.Text
                rec.nameTextTransparency = nameLbl.TextTransparency
                rec.nameTextStrokeTransparency = nameLbl.TextStrokeTransparency
            end
        end
        if nameLbl and (not rec.nameOverlay or not rec.nameOverlay.Parent) then rec.nameOverlay = _cloneHUDOverlay(nameLbl, "EclipseHUDNameOverlay") end
        rec.iconLabelRef = iconLbl or rec.iconLabelRef
        rec.iconViewportRef = iconViewport or rec.iconViewportRef
        rec.iconAnchorRef = iconAnchor or rec.iconAnchorRef
        return rec
    end
    local rawText = nameLbl.Text
    local cleanText = _cleanHUDWeaponText(rawText) or tostring(slotFrame.Name)
