-- Persistence watchdog: the game re-tunes Lighting frequently and can wipe
-- our tint. Every 0.25s reapply the user's chosen values.
task.spawn(function()
    while scriptRunning do
        pcall(function()
            local e = _ensureWCEffect()
            if Config.WorldColor.Enabled then
                if not e.Enabled then e.Enabled = true end
                if e.TintColor ~= Config.WorldColor.Color then e.TintColor = Config.WorldColor.Color end
                if math.abs(e.Saturation - Config.WorldColor.Intensity) > 0.005 then
                    e.Saturation = Config.WorldColor.Intensity
