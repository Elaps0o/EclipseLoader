local function _espPreviewRefresh()
    if not ESPPreview.gui then return end
    local espOn = Config.ESP.Enabled
    if ESPPreview.hl then
        ESPPreview.hl.Enabled = espOn and Config.ESP.Chams
        local fill = Config.ESP.ChamsColor
        ESPPreview.hl.FillColor = fill
        local h, s, v = Color3.toHSV(fill)
        ESPPreview.hl.OutlineColor = Color3.fromHSV(h, math.max(0, s - 0.15), math.min(1, v + 0.35))
        ESPPreview.hl.FillTransparency = math.clamp(Config.ESP.ChamsGlow or 0.35, 0, 1)
    end
    local corner = Config.ESP.CornerBox
    for _, p in ipairs(ESPPreview.corners) do
        p.Visible = espOn and Config.ESP.Box and corner
        p.BackgroundColor3 = Config.ESP.BoxColor
    end
    ESPPreview.fullBox.Visible = espOn and Config.ESP.Box and not corner
    ESPPreview.fbStroke.Color = Config.ESP.BoxColor
    ESPPreview.nameLbl.Visible = espOn and Config.ESP.Name
    ESPPreview.nameLbl.TextColor3 = Config.ESP.NameColor or Color3.fromRGB(255,255,255)
    ESPPreview.distLbl.Visible = espOn and Config.ESP.Distance
    ESPPreview.distLbl.TextColor3 = Config.ESP.DistanceColor or Color3.fromRGB(255,255,255)
    ESPPreview.wepLbl.Visible = espOn and Config.ESP.Weapon
    ESPPreview.wepLbl.TextColor3 = (Config.ESP.WeaponColor or Color3.fromRGB(255,255,255))
    -- Health: mirror local player's health in real-time
    local hp, mhp = 100, 100
    pcall(function()
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hp = hum.Health; mhp = hum.MaxHealth end
    end)
    local pct = math.clamp((mhp > 0 and hp/mhp) or 1, 0, 1)
    local show = espOn and Config.ESP.Health
    ESPPreview.hbBG.Visible = show; ESPPreview.hbFG.Visible = show; ESPPreview.hpLbl.Visible = show
    ESPPreview.hbFG.Size = UDim2.new(1, 0, pct, 0)
    ESPPreview.hbFG.BackgroundColor3 = Color3.fromRGB(math.floor(255*(1-pct)), math.floor(220*pct), 60)
    ESPPreview.hpLbl.Text = tostring(math.floor(hp))
    ESPPreview.line.Visible = espOn and Config.ESP.TargetLine
    ESPPreview.line.BackgroundColor3 = Config.ESP.LineColor or Color3.fromRGB(255,255,255)
end

