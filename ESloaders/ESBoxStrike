                    if not killedByLP and vplr and _lastDamagedByLP[vplr] and (tick()-_lastDamagedByLP[vplr]) < 1.25 then killedByLP = true end
                    if killedByLP then
                        if vplr then _markLocalLethal(vplr) end
                        _triggerLocalKillEffect(vplr, vchar)
                    end
                end)
                if conn and typeof(conn)=="RBXScriptConnection" then table.insert(UnloadConnections, conn) end
