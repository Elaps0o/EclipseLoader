        pcall(function() menuOpen = Library.Toggled ~= false end)
        local onVisuals = false
        pcall(function()
            local cur = rawget(Library, "ActiveTab") or Library.ActiveTab
            if cur and Tabs.Visuals and cur == Tabs.Visuals then onVisuals = true end
        end)
        local shouldShow = menuOpen and onVisuals
        if shouldShow then
            _dummyRefresh()
            local alive = (ESPPreview.dummy and ESPPreview.dummy.Parent) and true or false
