-- Open/close animation for the ESP overlay. Tracks the last requested state
-- and produces a 0..1 eased scale that widgets multiply into their size and
-- transparency, so ESP smoothly grows on enable and collapses on disable.
_ESP_ANIM = _ESP_ANIM or { on=false, t0=-1e9, dur=0.28 }
function _espAnimScale()
    local dt = tick() - _ESP_ANIM.t0
    local p  = math.clamp(dt / math.max(0.01, _ESP_ANIM.dur), 0, 1)
    -- easeOutBack-ish for open, easeIn for close
    local eased
    if _ESP_ANIM.on then
        local c1, c3 = 1.70158, 2.70158
        eased = 1 + c3 * (p-1)^3 + c1 * (p-1)^2
        eased = math.clamp(eased, 0, 1.15)
    else
        eased = 1 - p*p
    end
    return math.max(0, eased)
end

