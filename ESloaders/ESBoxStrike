function _collectGuiInstances(obj, out, depth, seen)
    out = out or {}; depth = depth or 0; seen = seen or {}
    if type(obj) ~= "table" or depth > 6 or seen[obj] then return out end
    seen[obj] = true
    for _, v in pairs(obj) do
        if typeof(v) == "Instance" and v:IsA("GuiObject") then
            table.insert(out, v)
        elseif type(v) == "table" then
            _collectGuiInstances(v, out, depth + 1, seen)
        end
    end
    return out
end

function _uiSetDisabled(obj, disabled)
