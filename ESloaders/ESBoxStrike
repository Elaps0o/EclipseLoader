local _webhookOnce = {}
local ONE_SHOT_KINDS = { connected=true, left=true, kicked=true, banned=true, unloaded=true }
function sendWebhook(kind, reason)
    if not ECLIPSE.Webhook or ECLIPSE.Webhook == "" then return end
    -- Global one-shot dedupe: connect/leave/kick/ban/unload must fire ONCE
    -- per session even if multiple code paths race to report them.
    if ONE_SHOT_KINDS[kind] then
        if _webhookOnce[kind] then return end
        _webhookOnce[kind] = true
    end
    local meta = KIND_META[kind] or { label = kind, color = 10367231 }
    local uptime = os.time() - sessionStart
    local h = math.floor(uptime/3600); local m = math.floor((uptime%3600)/60); local s = uptime%60
    local uptimeStr = string.format("%02d:%02d:%02d", h, m, s)

    local fields = {
        { name = "User",     value = string.format("**%s** — `%d`", LocalPlayer.Name, LocalPlayer.UserId), inline = false },
        { name = "Game",     value = string.format("**%s** — `%d`", GameName or "Unknown", game.PlaceId),  inline = true  },
        { name = "Executor", value = string.format("**%s**", getExecutor()),                                inline = true  },
        { name = "Session",  value = string.format("`%s`", uptimeStr),                                      inline = true  },
    }
    if reason and reason ~= "" then
        table.insert(fields, { name = "Reason", value = string.format("`%s`", tostring(reason)), inline = false })
    end
    local payload = HttpService:JSONEncode({
        username = "Eclipse Hub",
        avatar_url = "https://eclipssehub.lovable.app/favicon.ico",
        embeds = {{
            title = string.format("Eclipse Hub — %s", meta.label),
            type = "rich",
            color = meta.color,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            fields = fields,
            footer = { text = "Eclipse Hub" },
        }},
    })
    task.spawn(function() httpPost(ECLIPSE.Webhook, payload) end)
end

local PresenceUsers = {} -- [userId] = true
local presenceSocket
function markPresence(userId, on)
    if userId and userId ~= LocalPlayer.UserId then
        PresenceUsers[userId] = on and true or nil
    end
end

function connectPresenceWS()
    local wsLib = WebSocket or websocket
    if not wsLib or not wsLib.connect then
        print("Eclipse Hub: WebSocket is not available, falling back to HTTP presence updates.")
        return
    end
    local ok, sock = pcall(wsLib.connect, ECLIPSE.PresenceWS)
    if not ok or not sock then
        local err = tostring(sock or "unknown error")
        print("Eclipse Hub: Presence WebSocket connection failed: " .. err)
        return
    end
    presenceSocket = sock
    pcall(function()
        sock:Send(HttpService:JSONEncode({
            type = "hello", userId = LocalPlayer.UserId,
            name = LocalPlayer.Name, executor = getExecutor(),
            placeId = game.PlaceId, jobId = game.JobId, version = ECLIPSE.Version,
        }))
    end)
    connectSignal(sock.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok2 or type(data) ~= "table" then return end
        if data.type == "presence" and type(data.users) == "table" then
            table.clear(PresenceUsers)
            for _, u in ipairs(data.users) do markPresence(tonumber(u), true) end
        elseif data.type == "join" then
            markPresence(tonumber(data.userId), true)
        elseif data.type == "leave" then
            markPresence(tonumber(data.userId), false)
        end
    end))
    connectSignal(sock.OnClose:Connect(function()
        presenceSocket = nil
        task.delay(8, function()
            if scriptRunning and not presenceSocket then pcall(connectPresenceWS) end
        end)
    end))

    if not getgenv().Eclipse.connectedFired then
        getgenv().Eclipse.connectedFired = true
        Library:Notify({
            Title = "Eclipse Hub",
            Description = "<b>The connection has been established successfully.</b>",
            Time = 5,
        })
        sendWebhook("connected")
    end
end

