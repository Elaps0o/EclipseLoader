    local function _isEnemyPlayer(plr)
        if not plr or plr == LocalPlayer then return false end
        if IsAlly and IsAlly(plr) then return false end
        return true
    end

    local function _attackerIsLocal(attacker)
        if attacker == LocalPlayer then return true end
        if typeof(attacker) == "Instance" then
            if attacker.Name == LocalPlayer.Name then return true end
            local ch = LocalPlayer.Character
            if ch and attacker:IsDescendantOf(ch) then return true end
            local _, plr = _charPlayerFromAny(attacker)
            if plr == LocalPlayer then return true end
        elseif type(attacker) == "table" then
            local _, plr = _charPlayerFromAny(attacker)
            if plr == LocalPlayer then return true end
            for _, key in ipairs({"Player","player","Killer","killer","Attacker","attacker","Creator","creator","Owner","owner"}) do
                if _attackerIsLocal(rawget(attacker, key)) then return true end
            end
        elseif tostring(attacker) == LocalPlayer.Name or tostring(attacker) == tostring(LocalPlayer.UserId) then
            return true
        end
        return false
    end

    local function _markLocalLethal(plr)
        if not plr or plr == LocalPlayer then return end
        _lastLethalByLP[plr] = tick()
        pcall(function() _lastLethalByUid[tonumber(plr.UserId)] = tick() end)
    end

    local function _killFeedPlayerFrom(value)
        if value == nil then return nil end
        local _, plr = _charPlayerFromAny(value)
        if plr then return plr end
        local n = tonumber(value)
        if n then return Players:GetPlayerByUserId(n) end
        local s = tostring(value)
        if s ~= "" then
            local byName = Players:FindFirstChild(s)
            if byName and byName:IsA("Player") then return byName end
        end
        return nil
    end

    local function _killFeedKillerIsLocal(info)
        if type(info) ~= "table" then return false end
        for _, key in ipairs({"Killer","killer","KillerId","killerId","KillerUserId","killerUserId","Attacker","attacker","AttackerId","attackerId","Player","player"}) do
            local v = rawget(info, key)
            if v ~= nil then
                local p = _killFeedPlayerFrom(v)
                if p == LocalPlayer then return true end
                local n = tonumber(v)
                if n and n == LocalPlayer.UserId then return true end
                if tostring(v) == LocalPlayer.Name then return true end
            end
        end
        return _attackerIsLocal(info)
    end

    local function _killFeedVictim(info)
        if type(info) ~= "table" then return nil end
        for _, key in ipairs({"Victim","victim","VictimId","victimId","VictimUserId","victimUserId","Target","target","Dead","dead","Killed","killed","Enemy","enemy"}) do
            local p = _killFeedPlayerFrom(rawget(info, key))
            if p and p ~= LocalPlayer then return p end
        end
        return nil
    end

    local function _localIsAlive()
        local ch = LocalPlayer and LocalPlayer.Character
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        return hum and hum.Health > 0
    end

    local function _killCharVisible(char)
        if not char then return false end
        local cam = Workspace.CurrentCamera
        if not cam then return false end
        local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
        if not root then return false end
        local camPos = cam.CFrame.Position
        if (camPos - root.Position).Magnitude > 500 then return false end
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local ex = { char }
        if LocalPlayer.Character then table.insert(ex, LocalPlayer.Character) end
        rp.FilterDescendantsInstances = ex
        rp.IgnoreWater = true
        local candidates = {
            "Head","UpperTorso","LowerTorso","Torso","HumanoidRootPart",
            "LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm",
            "LeftHand","RightHand","LeftUpperLeg","RightUpperLeg",
            "LeftFoot","RightFoot"
        }
        for _, name in ipairs(candidates) do
            local p = char:FindFirstChild(name)
            if p and p:IsA("BasePart") then
                local sp, onScreen = cam:WorldToViewportPoint(p.Position)
                if onScreen and sp.Z > 0 then
                    local dir = p.Position - camPos
                    local mag = dir.Magnitude
                    local hit = Workspace:Raycast(camPos, dir, rp)
                    if not hit or (hit.Position - camPos).Magnitude >= (mag - 1.5) then
                        return true
                    end
                end
            end
        end
        return false
    end


    local function _triggerLocalKillEffect(plr, char)
        if not char or _killEffectDone[char] then return end
        if plr == LocalPlayer then return end
        if plr and IsAlly and IsAlly(plr) then return end
        if not _localIsAlive() then return end
        local lethalAt = plr and (_lastLethalByLP[plr] or _lastLethalByUid[tonumber(plr.UserId)])
        if not (lethalAt and (tick()-lethalAt) < 5.0) then
            local dmgAt = plr and _lastDamagedByLP[plr]
            if not (dmgAt and (tick()-dmgAt) < 1.25) then return end
            _markLocalLethal(plr)
        end
        _killEffectDone[char] = tick()
        if Config.Logging.Enabled then
            local vname = (plr and plr.Name) or (char and char.Name) or "enemy"
            pcall(function() Library:Notify({ Title="Enemy Eliminated", Description=vname.." was eliminated", Time=4 }) end)
        end
        if Config.GlobalEnable and Config.Visuals.KillEffect then
            task.spawn(function() pcall(_spawnKillEffect, char) end)
        end
    end

    local function _tryKillEffectFromHealth(plr, char)
        if not char or _killEffectDone[char] then return end
        if plr == LocalPlayer then return end
        if plr and IsAlly and IsAlly(plr) then return end
        if not _localIsAlive() then return end
        if not _killCharVisible(char) then return end
        _killEffectDone[char] = tick()
        if Config.GlobalEnable and Config.Visuals.KillEffect then
            task.spawn(function() pcall(_spawnKillEffect, char) end)
        end
    end

