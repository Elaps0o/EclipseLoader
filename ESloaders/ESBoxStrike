    if C4Timer.endT <= 0 then C4Timer.endT = tick() + C4Timer.duration end
    C4Timer.defuser = nil
    C4Timer.defAlerted = false
    C4Timer.hideAt = 0
end

function stopC4Timer()
    C4Timer.planted = false
    C4Timer.bomb = nil
    C4Timer.endT = 0
    C4Timer.exact = false
    C4Timer.defuser = nil
    C4Timer.defAlerted = false
end

function updateC4Timer()
    -- Timer runs internally regardless of the toggle; toggle only hides the UI
    -- so toggling off/on mid-round does NOT reset the countdown.
    local hideOnly = not Config.Misc.C4Timer
    -- GUI open preview: while the main GUI is on-screen and the C4 toggle is
    -- enabled, keep the panel visible even without a live bomb so the user can
    -- drag/position it. When GUI closes and there's no bomb, it auto-hides.
    local previewOpen = false
    if not hideOnly then
        local guiOpen = (ECLIPSE._isGuiOpen and ECLIPSE._isGuiOpen()) or false
        if guiOpen and not C4Timer.planted and C4Timer.hideAt == 0 then
            previewOpen = true
            C4Show("", "40", "", Color3.fromRGB(120,120,130))
        end
    end
    if hideOnly then C4Hide() end
    -- When previewing (GUI open, no bomb), skip the rest — nothing else to compute.
    if previewOpen then return end
    local _C4Show = hideOnly and function() end or C4Show
    local bomb = getBombModel()
    local resolved = isBombResolvedState(bomb)
    local planted = bomb ~= nil and not resolved

    if resolved and C4Timer.planted then
        if bomb and bomb:GetAttribute("Defused") == true then
            _C4Show("BOMB DEFUSED", "SAFE", "", Color3.fromRGB(90,220,140))
        elseif bomb and (bomb:GetAttribute("Exploded") == true or bomb:GetAttribute("Exploding") == true) then
            _C4Show("BOMB DETONATED", "BOOM", "", Color3.fromRGB(255,80,80))
        else
            _C4Show("TIME UP", "0", "fuse ended", Color3.fromRGB(255,140,60))
        end
        -- Keep the panel visible showing SAFE / BOOM until the round ends
        -- (bomb model despawns from the workspace tag). No auto-hide timer.
        C4Timer.hideAt = 0
        C4Timer.resolvedShown = true
        stopC4Timer(); return
    end

    if planted and not C4Timer.planted then startC4Timer(bomb) end
    if planted and C4Timer.planted then
        C4Timer.bomb = bomb
        syncC4Timer(bomb)
    end
    if not planted and C4Timer.planted then
        local remainLeft = math.max(0, C4Timer.endT - tick())
        if isBombDefused() then
            _C4Show("BOMB DEFUSED", "SAFE", "", Color3.fromRGB(90,220,140))
        elseif remainLeft <= 0.5 then
            _C4Show("BOMB DETONATED", "BOOM", "", Color3.fromRGB(255,80,80))
        else
            _C4Show("BOMB LOST", "--", "signal lost", Color3.fromRGB(200,200,200))
        end
        -- Same rule as above: linger on SAFE/BOOM/LOST until round ends.
        C4Timer.hideAt = 0
        C4Timer.resolvedShown = true
        stopC4Timer(); return
    end
    -- Round-end detection: panel is holding a resolved state (SAFE/BOOM/LOST)
    -- with no live bomb. Keep visible until the next-round WARMUP is detected
    -- (via _isWarmup from match logging), then animate the hide.
    if C4Timer.resolvedShown and not planted and not resolved then
        if _isWarmup and _isWarmup() then
            C4Timer.resolvedShown = false
            C4Hide()
        end
    end
    if C4Timer.hideAt > 0 and tick() >= C4Timer.hideAt then
        C4Timer.hideAt = 0; C4Hide()
    end

    if not C4Timer.planted then
        -- Nothing planted, no timer running: if the panel is showing only because
        -- of the GUI-open preview and the GUI just closed, animate the hide.
        if C4UI.shown and not hideOnly then
            local guiOpen = (ECLIPSE._isGuiOpen and ECLIPSE._isGuiOpen()) or false
            if not guiOpen then C4Hide() end
        end
        return
    end

    local remain = math.max(0, C4Timer.endT - tick())
    if remain <= 0 and C4Timer.exact then
        remain = 0
    end
    local d = findDefuser()
    local sub, col = "", nil
    if d then
        -- Defuse phase mirrors game logic (DefuseBomb script dump):
        --   duration = 5s with kit, 10s without.
        --   start is the defuser's server-synced DefuseStartTime attribute
        --   (workspace:GetServerTimeNow() timebase). Fall back to local tick()
        --   only when the attribute is missing or stale.
        local kit = d:GetAttribute("HasDefuseKit") == true
        local dur = kit and 5 or 10
        local nowServer = c4ServerNow()
        local startServer = d:GetAttribute("DefuseStartTime")
        local elapsed
        if typeof(startServer) == "number"
           and startServer <= nowServer
           and (nowServer - startServer) >= 0
           and (nowServer - startServer) <= math.max(dur, 12) then
            elapsed = nowServer - startServer
        else
            if C4Timer.defuser ~= d then
                C4Timer.defuser = d
                C4Timer.defuseStart = tick()
                C4Timer.defuseDuration = dur
            end
            elapsed = tick() - (C4Timer.defuseStart or tick())
        end
        local defRemain = math.max(0, dur - elapsed)
        local pct = math.clamp(defRemain / dur, 0, 1)
        _C4Show("DEFUSING",
            tostring(math.ceil(defRemain)),
            string.format("%s [%s]", d.DisplayName or d.Name, kit and "KIT" or "NO KIT"),
            Color3.fromRGB(90, 200, 255))
        -- Circular ring reflects defuse progress in seconds.
        updateC4Ring(defRemain, dur, Color3.fromRGB(90, 200, 255))
        return
    else
        C4Timer.defuser = nil
        C4Timer.defuseStart = nil
    end
    -- CS2-style urgency tiers based on time REMAINING on a 40s fuse:
    --   >30s (elapsed 0-10) : calm red   · 1 beat/sec
    --   20-30 (elapsed 10-20): warm ramp  · 1→2 beats/sec
    --   10-20 (elapsed 20-30): orange     · 2→3 beats/sec
    --    5-10 (elapsed 30-35): high red   · 5 beats/sec
    --    <5   (elapsed 35-40): frenetic   · 8 beats/sec
    if     remain <= 5  then col = Color3.fromRGB(255, 50, 50)
    elseif remain <= 10 then col = Color3.fromRGB(255, 90, 60)
    elseif remain <= 20 then col = Color3.fromRGB(255, 170, 60)
    else                     col = Color3.fromRGB(255, 110, 70) end
    _C4Show("PLANTED", tostring(math.ceil(remain)), sub, col)
    do
        -- Segmented circular ring around the seconds text, one tick per second.
        local total = C4Timer.duration > 0 and C4Timer.duration or C4_FALLBACK_DURATION
        updateC4Ring(remain, total, col)
    end
    -- Ticking pulse: mirrors the CS2 beep cadence. `speed` here is 2× beats/sec
    -- because sin(tick * speed * pi) completes a cycle every 2/speed seconds.
    if C4UI.time then
        local speed
        if     remain > 30 then speed = 2                                 -- 1 bps
        elseif remain > 20 then speed = 2 + (30 - remain) / 10 * 2        -- 1→2 bps
        elseif remain > 10 then speed = 4 + (20 - remain) / 10 * 2        -- 2→3 bps
        elseif remain > 5  then speed = 10                                -- 5 bps
        else                    speed = 16                                -- 8 bps (frenetic)
        end
        local beat = 0.5 + 0.5 * math.sin(tick() * speed * math.pi)
        C4UI.time.TextTransparency = (remain <= 30) and (0.15 * (1 - beat)) or 0
        if C4UI.stroke then
            C4UI.stroke.Transparency = 0.15 + 0.55 * (1 - beat) * (remain <= 30 and 1 or 0)
        end
    end

    tryAutoDefuse()
end








