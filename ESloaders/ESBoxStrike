    }

    -- Walk every sound folder under ReplicatedSt.Sounds (no filter). The UI
    -- decides which categories are considered "weapons"; here we just visit
    -- every Sound so the override map can address anything.
    local function walkSounds(cb)
        local root = ReplicatedSt:FindFirstChild("Sounds"); if not root then return end
        for _, cat in ipairs(root:GetChildren()) do
            for _, snd in ipairs(cat:GetDescendants()) do
                if snd:IsA("Sound") then cb(cat.Name, snd) end
            end
        end
    end
    EX.walkSounds = walkSounds

    -- Per-category override only (global preset removed by user request).
    local function resolvePresetId(catName)
        local per = Config.Sounds.PresetOverrides[catName]
        if per and per ~= "Default" then
            local pid = EX.SoundPresets[per]
            if pid and pid ~= "" then return pid end
        end
        return nil
    end

    EX.applySoundOverrides = function()
        if not Config.Sounds.Enabled then
            for snd, id in pairs(EX.originalSoundIds) do
                if snd and snd.Parent then pcall(function() snd.SoundId = id end) end
            end
            return
        end
        walkSounds(function(catName, snd)
            if not EX.originalSoundIds[snd] then EX.originalSoundIds[snd] = snd.SoundId end
            -- "Bullet" impact/whizby sfx are never remapped (removed by user request).
            if catName == "Bullet" then
                pcall(function() snd.SoundId = EX.originalSoundIds[snd] end)
                return
            end
            local pid = resolvePresetId(catName)
            if pid then
                pcall(function() snd.SoundId = pid end)
            else
                pcall(function() snd.SoundId = EX.originalSoundIds[snd] end)
            end
        end)
    end

    EX.restoreAllSounds = function()
        for snd, id in pairs(EX.originalSoundIds) do
            if snd and snd.Parent then pcall(function() snd.SoundId = id end) end
        end
    end
