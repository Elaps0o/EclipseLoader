function _queueHUDSlotApply(slotFrame)
    local rec = slotFrame and HUDSkin.slots[slotFrame]
    if rec and rec.queued then return end
    if rec then rec.queued = true end
    task.delay(0.04, function()
        if rec then rec.queued = false end
        if scriptRunning and Config.Skins.SkinChangerEnabled and _hudCanApply() and slotFrame and slotFrame.Parent then pcall(function() _applyOneSlot(slotFrame, false) end) end
    end)
end

function _resetHUDRuntimeForRespawn()
    if EX_LIMITED then return end
    pcall(_hideAllHUDOverlays)
    for slotFrame, rec in pairs(HUDSkin.slots) do
        pcall(function()
            if rec then
                rec.iconAppliedKey = nil
                rec.currentOverlayText = nil
                rec.lastAppliedWeapon = nil
                rec.iconToken = (rec.iconToken or 0) + 1
                if rec.nameOverlay then rec.nameOverlay.Visible = false end
                if rec.iconImage then rec.iconImage:Destroy(); rec.iconImage = nil end
                if rec.iconFallbackImage then rec.iconFallbackImage:Destroy(); rec.iconFallbackImage = nil end
                if slotFrame and slotFrame.Parent then _purgeHUDOverlays(slotFrame) end
            end
        end)
        if not slotFrame or not slotFrame.Parent then HUDSkin.slots[slotFrame] = nil end
    end
    HUDSkin.inventoryRef = nil
end

function _isSpectatingOther()
    local owner = _hudCameraOwnerPlayer and _hudCameraOwnerPlayer() or nil
    return owner ~= nil and owner ~= LocalPlayer
end

function _hudCanApply()
    return IsAlive() and not _isSpectatingOther()
end

function _hideAllHUDOverlays()
    for slotFrame, rec in pairs(HUDSkin.slots) do
        pcall(function()
            if rec.nameOverlay then rec.nameOverlay.Visible = false end
            if rec.iconOverlay then rec.iconOverlay.Visible = false end
            if rec.iconImage then rec.iconImage.Visible = false end
            if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
            if rec.iconViewport then rec.iconViewport.Visible = false end
            rec.iconAppliedKey = nil
            rec.currentOverlayText = nil
            rec.lastAppliedWeapon = nil
            if rec.nameLblRef and rec.nameLblRef.Parent then
                local tx = rec.nameTextTransparency or 0
                if type(tx) ~= "number" or tx >= 0.95 then tx = 0 end
                rec.nameLblRef.TextTransparency = tx
                rec.nameLblRef.TextStrokeTransparency = rec.nameTextStrokeTransparency or 1
                rec.nameLblRef.Visible = true
            end
            if rec.iconLabelRef and rec.iconLabelRef.Parent then
                rec.iconLabelRef.Visible = true
                rec.iconLabelRef.ImageTransparency = rec.iconImageTransparency or 0
                -- Do NOT override ImageColor3 here: while spectating another player the game paints the
                -- native icon with the spectated player's team color. Forcing our local tint would leak
                -- LocalPlayer's UI color onto other players' HUD.
            end
            if rec.iconViewportRef and rec.iconViewportRef.Parent then
                rec.iconViewportRef.Visible = true
            end
        end)
    end
end

function _applyOneSlot(slotFrame, forceKnife)
    if not slotFrame or not slotFrame.Parent or not Config.Skins.SkinChangerEnabled or not _hudCanApply() then return end
    local nameLbl, iconLbl, iconViewport, iconAnchor = _slotParts(slotFrame); if not nameLbl then return end
    local rec = _ensureSlotRec(slotFrame, nameLbl, iconLbl, iconViewport, iconAnchor)
    _refreshHUDSlotBaselines(rec, slotFrame, nameLbl, iconLbl, iconViewport, iconAnchor)
    local rawWeapon = _slotWeaponKey(slotFrame, nameLbl) or rec.baseName or tostring(slotFrame.Name)
    if forceKnife then rawWeapon = rawWeapon or _localKnifeByTeam() end
    local isMelee = _isHUDMeleeSlot(slotFrame, rawWeapon)

    
    
    if not isMelee then
        rec.iconAppliedKey = nil
        pcall(function()
            _restoreOriginalHUDIcon(rec, iconLbl, iconViewport)
            if rec.iconImage then rec.iconImage.Visible = false end
            if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
        end)
    end

    local text, icon, baseName, hasSkin = _desiredHUDForSlot(slotFrame, rawWeapon); if not text then return end

    
    
    if rec.lastAppliedWeapon and rec.lastAppliedWeapon ~= baseName then
        pcall(function()
            if rec.nameOverlay then rec.nameOverlay.Visible = false end
            if rec.iconImage then rec.iconImage.Visible = false end
            if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
        end)
        rec.iconAppliedKey = nil
        rec.currentOverlayText = nil
    end
    rec.lastAppliedWeapon = baseName
    rec.baseName = baseName or rawWeapon or rec.baseName

    if rec.iconOverlay then pcall(function() rec.iconOverlay.Visible = false end) end
    if rec.iconViewport then pcall(function() rec.iconViewport.Visible = false end) end

    rec.applying = true
    if hasSkin then
        _applyHUDNameOverlay(rec, nameLbl, text)
    else
        _restoreHUDName(rec, nameLbl)
    end
    _hudDbg("slot=", slotFrame.Name, "weapon=", baseName, "hasSkin=", hasSkin, "icon=", icon, "iconLbl=", iconLbl and iconLbl:GetFullName() or "nil", "vp=", iconViewport and iconViewport:GetFullName() or "nil")

    if isMelee and SkinSystem.scriptRunning and type(icon) == "string" and icon ~= "" and _hudIconOverrideAllowed() then

        
        
        local directIcon = _assetString(icon) or icon
        local img = nil
        local usingNativeImage = false
        img = _ensureIconImage(rec, iconLbl or iconViewport or iconAnchor or slotFrame)
        if img then
            if rec.iconViewport then pcall(function() rec.iconViewport.Visible = false end) end
            local alreadyApplied = rec.iconAppliedKey == directIcon and img.Visible ~= false and (not usingNativeImage or tostring(img.Image or "") ~= tostring(rec.iconLabelImage or ""))
            if alreadyApplied then
                _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
            else
                rec.iconAppliedKey = directIcon
                rec.iconHiddenForOverride = nil
                if rec.iconImage then rec.iconImage.Image = "" end
                if iconLbl then pcall(function() iconLbl.Visible = true end) end
                if iconViewport then pcall(function() iconViewport.Visible = true end) end
                _preloadHUDIcon(directIcon)
                _applyHUDImageWithFallback(rec, img, directIcon, tostring(slotFrame.Name) .. ":slot-image", function(finalIcon)
                    _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
                    _hudDbg("melee HUD icon injected", Config.Skins.SelectedKnife, finalIcon)
                end, function()
                    rec.iconAppliedKey = nil
                    rec.iconHiddenForOverride = nil
                    if iconLbl then pcall(function() iconLbl.Visible = true end) end
                    if iconViewport then pcall(function() iconViewport.Visible = true end) end
                    _hudDbg("melee HUD icon failed", Config.Skins.SelectedKnife)
                end)
            end
        else
            _hudDbg("failed to create melee HUD image", slotFrame:GetFullName())
        end
    elseif isMelee then
        rec.iconAppliedKey = nil
        _restoreOriginalHUDIcon(rec, iconLbl, iconViewport)
    end
    rec.applying = false

    if not rec.conn then
        rec.conn = nameLbl:GetPropertyChangedSignal("Text"):Connect(function() if not rec.applying and Config.Skins.SkinChangerEnabled and IsAlive() then _queueHUDSlotApply(slotFrame) end end)
        table.insert(UnloadConnections, rec.conn)
    end
    if not rec.nameVisConn then
        rec.nameVisConn = nameLbl:GetPropertyChangedSignal("Visible"):Connect(function() if not rec.applying and Config.Skins.SkinChangerEnabled and IsAlive() then _queueHUDSlotApply(slotFrame) end end)
        table.insert(UnloadConnections, rec.nameVisConn)
    end
    if isMelee and iconLbl and not rec.iconImgConn then
        rec.iconImgConn = iconLbl:GetPropertyChangedSignal("Image"):Connect(function()
            if rec.applying or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
            if rec.iconAppliedKey and rec.iconImage and rec.iconImage.Parent then
                _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
            end
            _queueHUDSlotApply(slotFrame)
        end)
        table.insert(UnloadConnections, rec.iconImgConn)
    end
    if isMelee and iconLbl and not rec.iconTransConn then
        rec.iconTransConn = iconLbl:GetPropertyChangedSignal("ImageTransparency"):Connect(function()
            if rec.applying or rec.suppressIconVis or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
            if rec.iconAppliedKey and rec.iconImage and rec.iconImage.Parent then
                _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
                _scheduleHUDApply(0.05)
            end
        end)
        table.insert(UnloadConnections, rec.iconTransConn)
    end
    if isMelee and iconLbl and not rec.iconConn then
        rec.iconConn = iconLbl:GetPropertyChangedSignal("Visible"):Connect(function()
            if rec.applying or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
            if rec.suppressIconVis then return end
            if rec.iconAppliedKey and rec.iconImage and rec.iconImage.Parent then
                _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
                _scheduleHUDApply(0.05)
            elseif not iconLbl.Visible then
                _queueHUDSlotApply(slotFrame)
            end
        end)
        table.insert(UnloadConnections, rec.iconConn)
    end
    if isMelee and iconViewport and not rec.vpVisConn then
        rec.vpVisConn = iconViewport:GetPropertyChangedSignal("Visible"):Connect(function()
            if rec.applying or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
            if rec.iconAppliedKey and rec.iconImage and rec.iconImage.Parent then
                _hideNativeHUDIconForOverride(rec, iconLbl, iconViewport)
                _scheduleHUDApply(0.05)
            elseif iconViewport.Visible then
                _queueHUDSlotApply(slotFrame)
            end
        end)
        table.insert(UnloadConnections, rec.vpVisConn)
    end
end

