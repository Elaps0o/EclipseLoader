connectSignal(RunService.RenderStepped:Connect(function()
    if not scriptRunning then return end
    _frameN = _frameN + 1
    local now = tick()
    local dt = now - _lastFrameT; _lastFrameT = now
    _emaDt = _emaDt * 0.9 + dt * 0.1

    local laggy = _emaDt > (1/45)
    local heavy = (not laggy) or (_frameN % 2 == 0)
    local severeLag = _emaDt > (1/25)
    local runLowPri = (not severeLag) or (_frameN % 3 == 0)

    safeUpdate("Aimbot", updateAimbot)
    safeUpdate("TriggerBot", updateTriggerBot)
    safeUpdate("RCS", updateRCS)
    safeUpdate("Movement", updateMovement)
    safeUpdate("SniperCrosshair", updateSniperCrosshair)
    safeUpdate("PenetrationCrosshair", updatePenetrationCrosshair)
    safeUpdate("C4Timer", updateC4Timer)
    safeUpdate("ForceScope", _updateForceScope)
    safeUpdate("GrenadePrediction", updateGrenadePrediction)

    safeUpdate("ESP", updateESP)
    if heavy then
        safeUpdate("Chams", updateChams)
        
        safeUpdate("WorldESP", updateWorldESP)
        safeUpdate("AntiFlash", updateAntiFlash)
        safeUpdate("AntiSmoke", updateAntiSmoke)
    end

    if runLowPri then
        safeUpdate("SkinSystem", function()
            if SkinSystem.scriptRunning and SkinSystem.vm and SkinSystem.vm.PrimaryPart then
                local k = knives[Config.Skins.SelectedKnife] or knives["Butterfly Knife"]
                SkinSystem.vm.PrimaryPart.CFrame = Camera.CFrame * k.Offset
                if not SkinSystem.inspecting and not SkinSystem.swinging then
                if SkinSystem.idleAnim and not SkinSystem.idleAnim.IsPlaying then SkinSystem.idleAnim:Play() end
                end
            end
        end)
        safeUpdate("Weather", function()
            if WeatherPart then
                local cam = Workspace.CurrentCamera
                if cam then
                    WeatherPart.CFrame = cam.CFrame * CFrame.new(0,30,0)
                    if WeatherEmitter then
                        local ch = LocalPlayer.Character
                        local head = ch and (ch:FindFirstChild("Head") or ch:FindFirstChild("HumanoidRootPart"))
                        local underCover = false
                        if head then
                            local rp = RaycastParams.new()
                            rp.FilterType = Enum.RaycastFilterType.Exclude
                            rp.IgnoreWater = true
                            pcall(function() rp.FilterDescendantsInstances = { ch, WeatherPart } end)
                            local res = Workspace:Raycast(head.Position, Vector3.new(0, 100, 0), rp)
                            if res and res.Instance and res.Instance.Transparency < 1 then underCover = true end
                        end
                        WeatherEmitter.Enabled = not underCover
                    end
                end
            end
        end)
        safeUpdate("Footstep", function()
            if not (Config.GlobalEnable and Config.ESP.Footstep) then return end
            _EclipseFootstepTick = _EclipseFootstepTick or {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local ch = p.Character
                    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 and (IsAlly == nil or not IsAlly(p)) then
                        local st = _EclipseFootstepTick[p] or { last=0, lastPos=hrp.Position }
                        _EclipseFootstepTick[p] = st
                        local now = tick()
                        local moved = (hrp.Position - st.lastPos).Magnitude
                        if now - st.last > 0.42 and moved > 3.5 then
                            st.last = now; st.lastPos = hrp.Position
                            local col = Config.ESP.FootstepColor or Color3.fromRGB(150,95,255)
                            local rayParams = RaycastParams.new()
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            rayParams.FilterDescendantsInstances = { ch, LocalPlayer.Character }
                            rayParams.IgnoreWater = true
                            local hit = Workspace:Raycast(hrp.Position, Vector3.new(0, -12, 0), rayParams)
                            local floorPos = hit and hit.Position or (hrp.Position - Vector3.new(0, 3, 0))
                            local floorNormal = hit and hit.Normal or Vector3.new(0, 1, 0)
                            
                            local orient = CFrame.lookAt(floorPos + floorNormal * 0.06, floorPos + floorNormal * 0.06 + floorNormal) * CFrame.Angles(0, math.rad(90), 0)
                            -- inner bright ring (visible)
                            local disc = Instance.new("Part")
                            disc.Name = "EclipseFootstep"
                            disc.Shape = Enum.PartType.Cylinder
                            disc.Anchored = true; disc.CanCollide = false; disc.CanQuery = false; disc.CanTouch = false
                            disc.CastShadow = false
                            disc.Material = Enum.Material.Neon
                            disc.Color = col
                            disc.Transparency = 0.15
                            disc.Size = Vector3.new(0.06, 2.0, 2.0)
                            disc.CFrame = orient
                            disc.Parent = Workspace
                            -- outer soft halo
                            local halo = Instance.new("Part")
                            halo.Name = "EclipseFootstepHalo"
                            halo.Shape = Enum.PartType.Cylinder
                            halo.Anchored = true; halo.CanCollide = false; halo.CanQuery = false; halo.CanTouch = false
                            halo.CastShadow = false
                            halo.Material = Enum.Material.Neon
                            halo.Color = col
                            halo.Transparency = 0.55
                            halo.Size = Vector3.new(0.04, 2.4, 2.4)
                            halo.CFrame = orient
                            halo.Parent = Workspace
                            -- glow light
                            local pl = Instance.new("PointLight")
                            pl.Color = col; pl.Brightness = 4; pl.Range = 10
                            pl.Parent = disc
                            local ti = TweenInfo.new(1.7, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
                            TweenService:Create(disc, ti, { Size = Vector3.new(0.06, 10, 10), Transparency = 1 }):Play()
                            TweenService:Create(halo, ti, { Size = Vector3.new(0.04, 12, 12), Transparency = 1 }):Play()
                            TweenService:Create(pl,   ti, { Brightness = 0, Range = 2 }):Play()
                            Debris:AddItem(disc, 1.8)
                            Debris:AddItem(halo, 1.8)
                        end
                    end
                end
            end
        end)
    end
end))

