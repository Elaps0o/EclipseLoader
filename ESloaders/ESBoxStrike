function _scheduleHUDApply(delayT)
    if HUDSkin.applyQueued then return end
    HUDSkin.applyQueued = true
    task.delay(delayT or 0.08, function()
        HUDSkin.applyQueued = false
        if scriptRunning and Config.Skins.SkinChangerEnabled and _hudCanApply() then pcall(_applyHUDKnife, true) end
    end)
