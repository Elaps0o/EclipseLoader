-- === JUMPBUG / EDGEBUG (tripleware-ported) ===============================
-- Fall-frame accumulator + explicit LandedFrame edge + edge-detection rays.
-- Applies a small horiz/vert boost on the landing frame (jumpbug) and clamps
-- vy to zero while sliding off a ledge (edgebug). Matches tripleware feel.
local JB_HORIZ_BOOST, JB_VERT_BOOST, JB_MIN_FRAMES = 2, 3, 3
local JBEB_RP = RaycastParams.new(); JBEB_RP.FilterType = Enum.RaycastFilterType.Exclude
local JBEB_LastChar, JBCooldown = nil, 0
local JBActive, EB_Active, EB_StartTime = false, false, 0
local JBEB_WasAir, JBEB_LandedFrame, JBEB_FallFrames = true, false, 0
local JB_LastTick = tick()
local GND_OFF = { Vector3.new(0,0,0), Vector3.new(0.8,0,0), Vector3.new(-0.8,0,0),
    Vector3.new(0,0,0.8), Vector3.new(0,0,-0.8) }
local EDGE_SIDE = { Vector3.new(2,0,0), Vector3.new(-2,0,0), Vector3.new(0,0,2), Vector3.new(0,0,-2),
    Vector3.new(1.5,0,1.5), Vector3.new(-1.5,0,1.5), Vector3.new(1.5,0,-1.5), Vector3.new(-1.5,0,-1.5) }
local EDGE_STILL = { Vector3.new(1.5,0,0), Vector3.new(-1.5,0,0), Vector3.new(0,0,1.5), Vector3.new(0,0,-1.5) }
local function _jbebSetFilter(c)
    if c == JBEB_LastChar then return end
    JBEB_LastChar = c
    JBEB_RP.FilterDescendantsInstances = { c, Camera }
end
local function _jbebGround(pos)
    for _, off in ipairs(GND_OFF) do
        local r = Workspace:Raycast(pos + off, Vector3.new(0, -3.1, 0), JBEB_RP)
        if r and r.Normal.Y > 0.7 and r.Instance.CanCollide then return true end
    end
    return false
end
local function _jbebNearEdge(pos)
    local c = Workspace:Raycast(pos, Vector3.new(0, -3.5, 0), JBEB_RP)
    if c and c.Normal.Y > 0.7 then return false end
    local hits = 0
    for _, off in ipairs(EDGE_SIDE) do
        local r = Workspace:Raycast(pos + off, Vector3.new(0, -5, 0), JBEB_RP)
        if r and r.Normal.Y > 0.7 then hits = hits + 1 end
    end
    return hits >= 2
end
local function _jbebStillEdge(pos)
    local c = Workspace:Raycast(pos, Vector3.new(0, -3.5, 0), JBEB_RP)
    if c and c.Normal.Y > 0.7 then return false end
    for _, off in ipairs(EDGE_STILL) do
        local r = Workspace:Raycast(pos + off, Vector3.new(0, -5, 0), JBEB_RP)
        if r then return true end
    end
    return false
end

local lastBhop = 0
function updateMovement()
    if not Config.GlobalEnable then return end
    local char = LocalPlayer.Character; if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    -- BUNNY HOP (BlueX-style): while Space is held, jump the instant the
    -- humanoid is grounded. 0.12s cooldown to match BlueX feel.
    if Config.Movement.BunnyHop and UserInput:IsKeyDown(Enum.KeyCode.Space) then
        local st = hum:GetState()
        local grounded = (hum.FloorMaterial ~= Enum.Material.Air)
            and st ~= Enum.HumanoidStateType.Jumping
            and st ~= Enum.HumanoidStateType.Freefall
        if grounded and tick() - lastBhop > 0.12 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            lastBhop = tick()
        end
    end
    -- AUTO STRAFE (fixed): gentle horizontal nudge during freefall based on
    -- mouse-X delta. Caps horizontal speed and skips when velocity spikes
    -- (collision with wall/object) to avoid the "boost extremo" glitch.
    if Config.Movement.AutoStrafe and hum:GetState() == Enum.HumanoidStateType.Freefall then
        local moveDir = UserInput:GetMouseDelta().X
        if math.abs(moveDir) > 1 then
            local cv = root.Velocity
            local horizSpeed = math.sqrt(cv.X * cv.X + cv.Z * cv.Z)
            -- Skip if we just collided (unrealistic speed spike) or if we're
            -- already at/above the target horizontal speed cap.
            local MAX_HORIZ = 34
            if horizSpeed < MAX_HORIZ and horizSpeed < 200 then
                local strafeAmount = math.clamp(moveDir / 220, -1, 1)
                local right = root.CFrame.RightVector
                local addX = right.X * strafeAmount * 7
                local addZ = right.Z * strafeAmount * 7
                local newX = cv.X + addX
                local newZ = cv.Z + addZ
                -- Clamp resulting horizontal magnitude to the cap.
                local newMag = math.sqrt(newX * newX + newZ * newZ)
                if newMag > MAX_HORIZ then
                    local s = MAX_HORIZ / newMag
                    newX, newZ = newX * s, newZ * s
                end
                root.Velocity = Vector3.new(newX, cv.Y, newZ)
            end
        end
    end

    -- JUMPBUG / EDGEBUG — tripleware-ported logic (fall-frame accumulator,
    -- explicit landed-frame edge, edge detection). Runs once per frame.
    if Config.Movement.Jumpbug or Config.Movement.Edgebug then
        local now = tick()
        local dt = now - JB_LastTick; if dt <= 0 then dt = 1/60 end
        JB_LastTick = now
        _jbebSetFilter(char)
        local vel = root.AssemblyLinearVelocity
        local pos = root.Position
        local vy = vel.Y
        local inAir = (hum.FloorMaterial == Enum.Material.Air)
        local onGround = _jbebGround(pos)
        if JBCooldown > 0 then JBCooldown = JBCooldown - dt end
        if EB_Active then
            if not Config.Movement.Edgebug then
                EB_Active = false
            elseif (onGround and vy <= 1) or not _jbebStillEdge(pos) or (tick() - EB_StartTime > 2.0) then
                EB_Active = false
            else
                root.AssemblyLinearVelocity = Vector3.new(vel.X * 0.995, 0, vel.Z * 0.995)
                return
            end
        end
        local grd = (onGround and vy <= 1) or not inAir
        if not grd then
            JBEB_WasAir = true; JBEB_LandedFrame = false
            if vy < -1 then JBEB_FallFrames = JBEB_FallFrames + 1 end
        end
        if grd and JBEB_WasAir then
            JBEB_LandedFrame = true; JBEB_WasAir = false
        elseif grd and not JBEB_WasAir then
            JBEB_LandedFrame = false
        end
        if Config.Movement.Jumpbug and JBEB_LandedFrame and JBCooldown <= 0
            and JBEB_FallFrames >= JB_MIN_FRAMES then
            local hSpeed = math.sqrt(vel.X * vel.X + vel.Z * vel.Z)
            local newH = math.min(hSpeed + JB_HORIZ_BOOST, 24.5)
            local newVY = vy + JB_VERT_BOOST
            if hSpeed > 0.5 then
                local dir = Vector3.new(vel.X, 0, vel.Z).Unit
                root.AssemblyLinearVelocity = Vector3.new(dir.X * newH, newVY, dir.Z * newH)
            else
                root.AssemblyLinearVelocity = Vector3.new(vel.X, newVY, vel.Z)
            end
            JBCooldown = 0.4; JBActive = true; JBEB_FallFrames = 0
            task.delay(0.2, function() JBActive = false end)
        end
        if grd and not JBEB_LandedFrame then JBEB_FallFrames = 0 end
        if Config.Movement.Edgebug and not grd and vy < -8
            and not EB_Active and not JBActive then
            if _jbebNearEdge(pos) then
                EB_Active = true; EB_StartTime = tick(); JBEB_FallFrames = 0
                root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
            end
        end
    end
end


