        if EX.WarnLabel    then pcall(function() EX.WarnLabel:Remove()    end) end
        EX.WarnRing, EX.WarnRingGlow, EX.WarnDot, EX.WarnLabel = nil, nil, nil, nil
    end)
    pcall(function()
        for _, l in ipairs(GPD.ActiveLines) do if l then l:Remove() end end
        for _, l in ipairs(GPD.LinePool)    do if l then l:Remove() end end
        if GPD.Dot then GPD.Dot:Remove() end
        table.clear(GPD.ActiveLines); table.clear(GPD.LinePool); GPD.Dot = nil
    end)
    -- C4 panel UI
    pcall(function() if C4UI and C4UI.frame then C4UI.frame:Destroy() end end)
    if WeatherPart then pcall(function() WeatherPart:Destroy() end) end
    if presenceSocket then pcall(function() presenceSocket:Close() end) end
    for inst, e in pairs(WorldEspPool) do pcall(function() e.Tag:Remove() end); pcall(function() e.Box:Remove() end); pcall(function() if e.Fill then e.Fill:Remove() end end); pcall(function() if e.Dot then e.Dot:Remove() end end) end
    table.clear(WorldEspPool)
    removeViewmodel()
    -- Destroy detached preview GUIs (skin + esp preview panels)
    pcall(function()
        local ui = (gethui and gethui()) or CoreGui
        for _, n in ipairs({"EclipseSkinPreview", "EclipseEspPreview"}) do
            local g = ui:FindFirstChild(n)
            if g then g:Destroy() end
        end
        local pool = Workspace:FindFirstChild("EclipseTracerPool")
        if pool then pool:Destroy() end
    end)
    if Library and type(Library.Unload) == "function" then pcall(function() Library:Unload() end) end
    getgenv().EclipseHubLoaded = nil
end

