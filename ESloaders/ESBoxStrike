function _visibleBBox(model)
    local minP, maxP
    for _, p in ipairs(model:GetDescendants()) do
        if p:IsA("BasePart") and p.Transparency < 1 then
            local cf, sz = p.CFrame, p.Size
            for dx=-1,1,2 do for dy=-1,1,2 do for dz=-1,1,2 do
                local w = (cf * CFrame.new(dx*sz.X/2, dy*sz.Y/2, dz*sz.Z/2)).Position
                if not minP then minP, maxP = w, w else
                    minP = Vector3.new(math.min(minP.X,w.X), math.min(minP.Y,w.Y), math.min(minP.Z,w.Z))
                    maxP = Vector3.new(math.max(maxP.X,w.X), math.max(maxP.Y,w.Y), math.max(maxP.Z,w.Z))
                end
            end end end
        end
    end
    if not minP then return CFrame.new(), Vector3.new() end
    return CFrame.new((minP + maxP) * 0.5), (maxP - minP)
end

