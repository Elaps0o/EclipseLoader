function _espGetPlayerAmmo(plr, weaponName)
    local function num(v) return (type(v) == "number") and v or tonumber(v) end
    local cur, mx
    local ok1 = pcall(function()
        cur = num(plr:GetAttribute("Ammo") or plr:GetAttribute("Bullets") or plr:GetAttribute("CurrentAmmo") or plr:GetAttribute("Clip") or plr:GetAttribute("AmmoInClip"))
        mx  = num(plr:GetAttribute("MaxAmmo") or plr:GetAttribute("Magazine") or plr:GetAttribute("MagazineSize") or plr:GetAttribute("ClipSize"))
    end); if not ok1 then cur, mx = nil, nil end
    if not cur then
        local char = GetCharacter(plr) or plr.Character
        cur = _espReadNumber(char, {"Ammo","Bullets","CurrentAmmo","Clip","AmmoInClip"})
        mx  = mx or _espReadNumber(char, {"MaxAmmo","Magazine","MagazineSize","ClipSize"})
    end
    if not cur then
        local char = GetCharacter(plr) or plr.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if tool then
            cur = num(tool:GetAttribute("Ammo") or tool:GetAttribute("Bullets") or tool:GetAttribute("CurrentAmmo") or tool:GetAttribute("Clip") or tool:GetAttribute("AmmoInClip"))
            mx  = mx or num(tool:GetAttribute("MaxAmmo") or tool:GetAttribute("MagazineSize") or tool:GetAttribute("ClipSize"))
        end
    end
    if not mx and weaponName and _weaponModule then
        local mod = _weaponModule(weaponName)
        if mod then
            pcall(function()
                mx = num(mod:GetAttribute("MagazineSize") or mod:GetAttribute("Magazine") or mod:GetAttribute("MaxAmmo"))
            end)
        end
    end
    if not cur or not mx or mx <= 0 then return nil end
    return math.max(0, cur), mx
end

