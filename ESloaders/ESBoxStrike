function _espPreviewBuild()
    if ESPPreview.gui then return end
    local MAIN_    = Color3.fromRGB(20, 20, 20)
    local OUTLINE_ = Color3.fromRGB(40, 40, 40)

    local sg = Instance.new("ScreenGui")
    sg.Name = "EclipseEspPreview"; sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = 60; sg.Enabled = false
    pcall(function() sg.Parent = (gethui and gethui()) or CoreGui end)

    local f = Instance.new("Frame", sg)
    f.Name = "EclipseEspPreviewFrame"
    f.Size = UDim2.fromOffset(360, 500)
    f.Position = UDim2.new(0.5, 460, 0.5, -250)
    f.BackgroundColor3 = MAIN_; f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
    local st = Instance.new("UIStroke", f); st.Color = OUTLINE_; st.Thickness = 1

    local vp = Instance.new("ViewportFrame", f)
    vp.Position = UDim2.fromOffset(6, 6); vp.Size = UDim2.new(1, -12, 1, -52)
    vp.BackgroundColor3 = Color3.fromRGB(15, 15, 15); vp.BorderSizePixel = 0
    Instance.new("UICorner", vp).CornerRadius = UDim.new(0, 3)
    local vps = Instance.new("UIStroke", vp); vps.Color = OUTLINE_; vps.Thickness = 1

    local camPart = Instance.new("Camera"); camPart.Parent = vp; vp.CurrentCamera = camPart

    -- 2D overlay in vp-local coords (matches Camera:WorldToViewportPoint output)
    local overlay = Instance.new("Frame", f)
    overlay.BackgroundTransparency = 1
    overlay.Position = vp.Position; overlay.Size = vp.Size; overlay.ZIndex = 5
    overlay.ClipsDescendants = true

    -- 8 corner-arm segments (mirrors _espDrawCornerBox: 4 horizontals + 4 verticals)
    local corners = {}
    for i = 1, 8 do
        local p = Instance.new("Frame", overlay)
        p.BorderSizePixel = 0; p.ZIndex = 7
        p.BackgroundColor3 = Color3.fromRGB(255,255,255)
        corners[i] = p
    end

    local chamsFill = Instance.new("Frame", overlay)
    chamsFill.BorderSizePixel = 0; chamsFill.ZIndex = 4
    chamsFill.BackgroundTransparency = 0.45
    chamsFill.Visible = false

    -- Health bar: bg line + 24 segments (same shape as _espDrawHealth)
    local hbBG = Instance.new("Frame", overlay)
    hbBG.BackgroundColor3 = Color3.fromRGB(8,8,12)
    hbBG.BorderSizePixel = 0; hbBG.ZIndex = 6
    hbBG.Visible = false
    local hbSegs = {}
    for i = 1, 24 do
        local seg = Instance.new("Frame", overlay)
        seg.BorderSizePixel = 0; seg.ZIndex = 7; seg.Visible = false
        hbSegs[i] = seg
    end

    local function mkTxt(size)
        local t = Instance.new("TextLabel", overlay)
        t.BackgroundTransparency = 1
        t.Font = Enum.Font.Code; t.TextSize = size
        t.TextColor3 = Color3.fromRGB(255,255,255)
        t.TextStrokeTransparency = 0.4
        t.TextXAlignment = Enum.TextXAlignment.Center
        t.TextYAlignment = Enum.TextYAlignment.Center
        t.AnchorPoint = Vector2.new(0.5, 0.5)
        t.Size = UDim2.fromOffset(200, size + 4)
        t.ZIndex = 8; t.Visible = false
        return t
    end
    local nameLbl = mkTxt(14)
    local distLbl = mkTxt(12)
    local wepLbl  = mkTxt(13)

    -- HeadDot circle (Frame with UICorner → perfect circle)
    local headDot = Instance.new("Frame", overlay)
    headDot.BorderSizePixel = 0; headDot.ZIndex = 9; headDot.Visible = false
    headDot.AnchorPoint = Vector2.new(0.5, 0.5)
    headDot.BackgroundColor3 = Color3.fromRGB(255,255,255)
    Instance.new("UICorner", headDot).CornerRadius = UDim.new(1, 0)

    -- Skeleton: reuse the SkeletonBones list length so every real bone has a line
    local skelLines = {}
    for i = 1, #SkeletonBones do
        local ln = Instance.new("Frame", overlay)
        ln.BorderSizePixel = 0; ln.ZIndex = 7; ln.Visible = false
        ln.AnchorPoint = Vector2.new(0.5, 0)
        ln.BackgroundColor3 = Color3.fromRGB(220,220,220)
        skelLines[i] = ln
    end

    -- "Waiting..." placeholder shown when the local character isn't alive.
    local waitLbl = Instance.new("TextLabel", f)
    waitLbl.BackgroundTransparency = 1
    waitLbl.Font = Enum.Font.Code; waitLbl.TextSize = 18
    waitLbl.TextColor3 = Color3.fromRGB(200, 200, 210)
    waitLbl.TextStrokeTransparency = 0.5
    waitLbl.AnchorPoint = Vector2.new(0.5, 0.5)
    waitLbl.Position = UDim2.fromScale(0.5, 0.5)
    waitLbl.Size = UDim2.fromOffset(220, 30)
    waitLbl.Text = "Waiting"
    waitLbl.ZIndex = 20
    waitLbl.Visible = false

    -- ---------- Position cycle buttons (obsidian-style outline) ----------
    -- Each button cycles Config.ESP.SlotPos[kind] through its side list.
    -- Non-default slot → purple outline (active). Default slot → gray outline.
    local ACCENT = Color3.fromRGB(140, 90, 255)
    local INACT  = Color3.fromRGB(60, 60, 68)
    local btnRow = Instance.new("Frame", f)
    btnRow.Name = "SlotButtons"
    btnRow.BackgroundTransparency = 1
    btnRow.Position = UDim2.new(0, 6, 1, -42)
    btnRow.Size = UDim2.new(1, -12, 0, 36)
    btnRow.ZIndex = 20
    local layoutBR = Instance.new("UIListLayout", btnRow)
    layoutBR.FillDirection = Enum.FillDirection.Horizontal
    layoutBR.Padding = UDim.new(0, 6)
    layoutBR.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layoutBR.VerticalAlignment = Enum.VerticalAlignment.Center

    ESPPreview.slotButtons = {}
    local function makeSlotBtn(kind, label)
        local b = Instance.new("TextButton", btnRow)
        b.AutoButtonColor = false
        b.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
        b.BorderSizePixel = 0
        b.Size = UDim2.fromOffset(62, 26)
        b.Text = label
        b.Font = Enum.Font.Code
        b.TextSize = 12
        b.TextColor3 = Color3.fromRGB(220, 220, 230)
        b.ZIndex = 21
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
        local s = Instance.new("UIStroke", b)
        s.Color = INACT; s.Thickness = 1
        b.MouseButton1Click:Connect(function()
            local cyc = ESP_SLOT_CYCLES[kind]
            Config.ESP.SlotPos[kind] = ((Config.ESP.SlotPos[kind] or 1) % #cyc) + 1
            -- Keep label clean (letters only); accent stroke shows non-default.
            b.Text = label
            local nonDef = not _espIsSlotDefault(kind)
            s.Color = nonDef and ACCENT or INACT
            s.Thickness = nonDef and 2 or 1
            b.BackgroundColor3 = nonDef and Color3.fromRGB(38, 30, 58) or Color3.fromRGB(24, 24, 30)
        end)
        ESPPreview.slotButtons[kind] = b
        return b
    end
    makeSlotBtn("Name",     "NAME")
    makeSlotBtn("Distance", "DIST")
    makeSlotBtn("Weapon",   "WEP")
    makeSlotBtn("Health",   "HP")

    ESPPreview.gui, ESPPreview.frame = sg, f
    ESPPreview.viewport, ESPPreview.cam = vp, camPart
    ESPPreview.overlay  = overlay
    ESPPreview.corners  = corners
    ESPPreview.chamsFill = chamsFill
    ESPPreview.hbBG, ESPPreview.hbSegs = hbBG, hbSegs
    ESPPreview.nameLbl, ESPPreview.distLbl, ESPPreview.wepLbl = nameLbl, distLbl, wepLbl
    ESPPreview.waitLbl = waitLbl
    ESPPreview.headDot  = headDot
    ESPPreview.skelLines = skelLines
end

-- Toggle the ESP preview between "alive" (dummy + overlays) and "waiting"
-- (spinning "Waiting..." placeholder). GUI stays enabled either way.
function _espPreviewSetAlive(alive)
    if not ESPPreview.gui then return end
    if ESPPreview.viewport then ESPPreview.viewport.Visible = alive and true or false end
    if ESPPreview.overlay  then ESPPreview.overlay.Visible  = alive and true or false end
    if ESPPreview.waitLbl  then ESPPreview.waitLbl.Visible  = not alive end
end

function _projHRP()
    -- Preview is GUI-centered by design: ESP is applied in the middle of the
    -- ESP preview panel, independent from ragdoll/model projection.
    if ESPPreview.overlay then
        local sz = ESPPreview.overlay.AbsoluteSize
        if sz.X > 0 and sz.Y > 0 then
            -- 5% wider/taller than baseline so the corner boxes and side
            -- labels sit slightly further from the middle of the panel.
            local height = math.max(190, sz.Y * 0.56) * 1.05
            local width = height * 0.44 * 1.05
            local cx, cy = sz.X * 0.5, sz.Y * 0.52
            return {
                L = cx - width/2, R = cx + width/2, T = cy - height/2, B = cy + height/2,
                cx = cx, cy = cy, hP = Vector3.new(cx, cy - height/2 + 10, 1),
                height = height, width = width,
            }
        end
    end

    local d = ESPPreview.dummy; if not d or not ESPPreview.cam then return nil end
    local cf, size
    if ESPPreview._visBB then cf, size = ESPPreview._visBB(d) end
    if not size or size.Magnitude == 0 then
        local ok, bcf, bsz = pcall(function() local a,b = d:GetBoundingBox(); return true, a, b end)
        if not ok or not bsz or bsz.Magnitude == 0 then return nil end
        cf, size = bcf, bsz
    end
    local hx, hy, hz = size.X/2, size.Y/2, size.Z/2
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local anyOn = false
    for dx = -1, 1, 2 do for dy = -1, 1, 2 do for dz = -1, 1, 2 do
        local wp = (cf * CFrame.new(dx*hx, dy*hy, dz*hz)).Position
        local sp = ESPPreview.cam:WorldToViewportPoint(wp)
        if sp.Z > 0 then
            anyOn = true
            if sp.X < minX then minX = sp.X end
            if sp.Y < minY then minY = sp.Y end
            if sp.X > maxX then maxX = sp.X end
            if sp.Y > maxY then maxY = sp.Y end
        end
    end end end
    if not anyOn then return nil end
    local topP = ESPPreview.cam:WorldToViewportPoint((cf * CFrame.new(0, hy, 0)).Position)
    return {
        L = minX, R = maxX, T = minY, B = maxY,
        cx = (minX + maxX)/2, cy = (minY + maxY)/2,
        hP = topP, height = (maxY - minY), width = (maxX - minX),
    }
end


function _espPreviewRefresh()
    if not ESPPreview.gui then return end
    local espOn = Config.ESP.Enabled
    -- Chams: apply as Highlight AND fall back to per-part color override,
    -- because Roblox Highlights sometimes fail to render inside ViewportFrames.
    -- The override recolors every BasePart and adds a white SelectionBox for
    -- the outline (restored from _origColors when chams is turned off).
    local chamsOn = espOn and Config.ESP.Chams
    if ESPPreview.hl then
        ESPPreview.hl.Enabled          = chamsOn
        ESPPreview.hl.FillColor        = Config.ESP.ChamsColor
        ESPPreview.hl.OutlineColor     = Color3.fromRGB(255, 255, 255)
        ESPPreview.hl.FillTransparency    = 0
        ESPPreview.hl.OutlineTransparency = 0
    end
    if ESPPreview.dummy and ESPPreview._origColors then
        for part, orig in pairs(ESPPreview._origColors) do
            if part and part.Parent then
                if chamsOn then
                    part.Color        = Config.ESP.ChamsColor
                    part.Material     = Enum.Material.Neon
                    part.Transparency = 0
                else
                    part.Color        = orig.Color
                    part.Material     = orig.Material
                    part.Transparency = orig.Transparency
                end
            end
        end
        if ESPPreview._selBox then
            ESPPreview._selBox.Visible     = chamsOn
            ESPPreview._selBox.SurfaceColor3 = Color3.fromRGB(255, 255, 255)
            ESPPreview._selBox.LineThickness = 0.05
        end
    end

    local proj = _projHRP()
    local hideAll = (not espOn) or (not proj)

    if hideAll then
        for _, p in ipairs(ESPPreview.corners) do p.Visible = false end
        ESPPreview.hbBG.Visible = false
        if ESPPreview.chamsFill then ESPPreview.chamsFill.Visible = false end
        for _, s in ipairs(ESPPreview.hbSegs) do s.Visible = false end
        ESPPreview.nameLbl.Visible = false
        ESPPreview.distLbl.Visible = false
        ESPPreview.wepLbl.Visible  = false
        if ESPPreview.headDot then ESPPreview.headDot.Visible = false end
        if ESPPreview.skelLines then
            for _, ln in ipairs(ESPPreview.skelLines) do ln.Visible = false end
        end
        return
    end

    local L, R, T, B = proj.L, proj.R, proj.T, proj.B
    local cx, height = proj.cx, proj.height
    local cW, cH = proj.width * 0.25, height * 0.25

    if ESPPreview.chamsFill then
        local chamsOn = Config.ESP.Chams
        ESPPreview.chamsFill.Visible = chamsOn
        ESPPreview.chamsFill.BackgroundColor3 = Config.ESP.ChamsColor or Color3.fromRGB(255, 60, 60)
        ESPPreview.chamsFill.Position = UDim2.fromOffset(L, T)
        ESPPreview.chamsFill.Size = UDim2.fromOffset(math.max(1, R - L), math.max(1, B - T))
    end

    -- Corner box (mirrors _espDrawCornerBox — 8 arms) ---------------------
    local showBox = Config.ESP.CornerBox
    local col = Config.ESP.BoxColor
    local function armH(idx, x1, x2, y)
        local p = ESPPreview.corners[idx]
        p.Visible = showBox; p.BackgroundColor3 = col
        p.Position = UDim2.fromOffset(math.min(x1,x2), y)
        p.Size = UDim2.fromOffset(math.abs(x2-x1), 1)
    end
    local function armV(idx, x, y1, y2)
        local p = ESPPreview.corners[idx]
        p.Visible = showBox; p.BackgroundColor3 = col
        p.Position = UDim2.fromOffset(x, math.min(y1,y2))
        p.Size = UDim2.fromOffset(1, math.abs(y2-y1))
    end
    armH(1, L,   L+cW, T);  armV(2, L,   T, T+cH)
    armH(3, R-cW, R,   T);  armV(4, R,   T, T+cH)
    armH(5, L,   L+cW, B);  armV(6, L,   B-cH, B)
    armH(7, R-cW, R,   B);  armV(8, R,   B-cH, B)

    -- Labels: per-element cycled layout (same helper the real ESP uses) -----
    local layout = _espTextLayout(L, R, T, B, cx)

    if Config.ESP.Name then
        local p = layout.Name
        ESPPreview.nameLbl.Text = tostring(LocalPlayer.Name)
        ESPPreview.nameLbl.Position = UDim2.fromOffset(p.x, p.y)
        ESPPreview.nameLbl.TextColor3 = Config.ESP.NameColor or Color3.fromRGB(255,255,255)
        ESPPreview.nameLbl.Visible = true
    else ESPPreview.nameLbl.Visible = false end

    if Config.ESP.Distance then
        local p = layout.Distance
        ESPPreview.distLbl.Text = "[ "..tostring(ESP_PREVIEW_FAKE.Dist).."M ]"
        ESPPreview.distLbl.Position = UDim2.fromOffset(p.x, p.y)
        ESPPreview.distLbl.TextColor3 = Config.ESP.DistanceColor or Color3.fromRGB(255,255,255)
        ESPPreview.distLbl.Visible = true
    else ESPPreview.distLbl.Visible = false end

    if Config.ESP.WeaponName then
        local wn = ESP_PREVIEW_FAKE.Weapon
        local _, tierColor = getWeaponTier(wn)
        local p = layout.Weapon
        ESPPreview.wepLbl.Text = "[ "..tostring(wn):upper().." ]"
        ESPPreview.wepLbl.Position = UDim2.fromOffset(p.x, p.y)
        ESPPreview.wepLbl.TextColor3 = tierColor or Config.ESP.WeaponNameColor or Color3.fromRGB(255,255,255)
        ESPPreview.wepLbl.Visible = true
    else ESPPreview.wepLbl.Visible = false end

    -- Health bar (same segmented shape as _espDrawHealth) ------------------
    if Config.ESP.HealthBar then
        local pct = math.clamp(ESP_PREVIEW_FAKE.Health / ESP_PREVIEW_FAKE.MaxHP, 0, 1)
        local hSide = _espSlotSide("Health")
        local bx = (hSide == "Right") and (R + 10) or (L - 10)
        ESPPreview.hbBG.Position = UDim2.fromOffset(bx - 1, T)
        ESPPreview.hbBG.Size = UDim2.fromOffset(3, math.max(1, B - T))
        ESPPreview.hbBG.Visible = true
        local maxSegs = #ESPPreview.hbSegs
        local segments = math.clamp(math.floor(height / 4), 6, maxSegs)
        local thick = (height < 40) and 2 or 3
        for i = 1, maxSegs do
            local seg = ESPPreview.hbSegs[i]
            if i <= segments then
                local a = (i - 1) / segments
                local b = i / segments
                local y1 = B - (height * a)
                local y2 = B - (height * b) + 1
                seg.Position = UDim2.fromOffset(bx - math.floor(thick/2), math.min(y1, y2))
                seg.Size = UDim2.fromOffset(thick, math.max(1, math.abs(y2 - y1)))
                seg.BackgroundColor3 = GetHealthColor((a + b) * 0.5)
                seg.Visible = b <= pct + (1 / segments)
            else
                seg.Visible = false
            end
        end
    else
        ESPPreview.hbBG.Visible = false
        for _, s in ipairs(ESPPreview.hbSegs) do s.Visible = false end
    end

    -- HeadDot: project the dummy's Head, draw a circle at that vp point.
    do
        local d = ESPPreview.dummy
        local head = d and d:FindFirstChild("Head")
        if Config.ESP.HeadDot and ESPPreview.headDot then
            local sp = proj.hP
            if sp and sp.Z > 0 then
                local r = math.clamp(height * 0.04, 2, 5)
                ESPPreview.headDot.BackgroundColor3 = Config.ESP.HeadDotColor
                ESPPreview.headDot.Position = UDim2.fromOffset(sp.X, sp.Y)
                ESPPreview.headDot.Size     = UDim2.fromOffset(r * 2, r * 2)
                ESPPreview.headDot.Visible  = true
            else ESPPreview.headDot.Visible = false end
        elseif ESPPreview.headDot then
            ESPPreview.headDot.Visible = false
        end
    end

    -- Skeleton: draw each SkeletonBones pair as a thin Frame between the two
    -- projected 2D points (rotated to match the bone direction).
    do
        local d = ESPPreview.dummy
        if Config.ESP.Skeleton and ESPPreview.skelLines then
            local col = Config.ESP.SkeletonColor or Color3.fromRGB(220,220,220)
            local function drawSeg(i, ax, ay, bx, by)
                local ln = ESPPreview.skelLines[i]; if not ln then return end
                local dx, dy = bx - ax, by - ay
                local len = math.sqrt(dx*dx + dy*dy)
                ln.BackgroundColor3 = col
                ln.Position = UDim2.fromOffset((ax + bx)/2, ay)
                ln.Size = UDim2.fromOffset(1, len)
                ln.Rotation = math.deg(math.atan2(dy, dx)) - 90
                ln.Visible = true
            end
            if false and d and ESPPreview.cam then
                for i, bone in ipairs(SkeletonBones) do
                    local ln = ESPPreview.skelLines[i]
                    local pa = d:FindFirstChild(bone[1])
                    local pb = d:FindFirstChild(bone[2])
                    if ln and pa and pb then
                        local a = ESPPreview.cam:WorldToViewportPoint(pa.Position)
                        local b = ESPPreview.cam:WorldToViewportPoint(pb.Position)
                        if a.Z > 0 and b.Z > 0 then drawSeg(i, a.X, a.Y, b.X, b.Y) else ln.Visible = false end
                    elseif ln then ln.Visible = false end
                end
            else
                local headY, neckY, hipY, footY = T + height*0.12, T + height*0.28, T + height*0.58, B - height*0.06
                local shL, shR = L + (R-L)*0.25, R - (R-L)*0.25
                local handL, handR = L + (R-L)*0.08, R - (R-L)*0.08
                local footL, footR = L + (R-L)*0.24, R - (R-L)*0.24
                for _, ln in ipairs(ESPPreview.skelLines) do ln.Visible = false end
                drawSeg(1, cx, headY, cx, neckY); drawSeg(2, cx, neckY, cx, hipY)
                drawSeg(3, cx, neckY, shL, neckY + 8); drawSeg(4, shL, neckY + 8, handL, hipY - 8)
                drawSeg(5, cx, neckY, shR, neckY + 8); drawSeg(6, shR, neckY + 8, handR, hipY - 8)
                drawSeg(7, cx, hipY, footL, footY); drawSeg(8, cx, hipY, footR, footY)
            end
        elseif ESPPreview.skelLines then
            for _, ln in ipairs(ESPPreview.skelLines) do ln.Visible = false end
        end
    end
end

local _dummyRefresh -- forward declaration (defined below); referenced by _espPreviewShow / CharacterAdded / Heartbeat
function _espPreviewClose()
    if ESPPreview.gui then ESPPreview.gui.Enabled = false end
    ESPPreview.visible = false
end
function _espPreviewShow()
    if not ESPPreview.gui then _espPreviewBuild() end
    _dummyRefresh()
    local alive = ESPPreview.dummy and ESPPreview.dummy.Parent
    ESPPreview.gui.Enabled = true
    ESPPreview.visible = true
    _espPreviewSetAlive(alive and true or false)
    if alive then _espPreviewRefresh() end
end

-- (Re)build the dummy inside the viewport from the LIVE local character.
-- If the player isn't spawned, drop the dummy and flip the panel into
-- "Waiting..." mode. Called by the heartbeat + CharacterAdded hooks.
_dummyRefresh = function()
    if not ESPPreview.viewport then return end
    local alive = ESPPreview.dummy and ESPPreview.dummy.Parent
    if alive then _espPreviewSetAlive(true); return end
    local clone = _cloneLocalCharacter()
    if not clone then _espPreviewSetAlive(false); return end

    -- Ragdoll fix: hide the invisible collision/rig parts (HumanoidRootPart,
    -- Hitbox, BoundingBox) so bounding-box math + projection reflect what
    -- the player actually sees. Without this, on a ragdoll snapshot those
    -- parts drift far from the visible body and the ESP box + chams miss.
    local HIDDEN = { HumanoidRootPart=true, Hitbox=true, BoundingBox=true }
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") and HIDDEN[p.Name] then
            p.Transparency = 1; p.CanCollide = false
        end
    end
    -- Visible bbox (only parts with Transparency<1) — used for both centering
    -- AND ESP overlay projection so both agree on the "real" model bounds.
    local function _visBB(model)
        local minP, maxP
        for _, p in ipairs(model:GetDescendants()) do
            if p:IsA("BasePart") and p.Transparency < 1 then
                local cf, sz = p.CFrame, p.Size
                for dx=-1,1,2 do for dy=-1,1,2 do for dz=-1,1,2 do
                    local w = (cf * CFrame.new(dx*sz.X/2, dy*sz.Y/2, dz*sz.Z/2)).Position
                    if not minP then minP = w; maxP = w
                    else
                        minP = Vector3.new(math.min(minP.X,w.X), math.min(minP.Y,w.Y), math.min(minP.Z,w.Z))
                        maxP = Vector3.new(math.max(maxP.X,w.X), math.max(maxP.Y,w.Y), math.max(maxP.Z,w.Z))
                    end
                end end end
            end
        end
        if not minP then return CFrame.new(), Vector3.new() end
        return CFrame.new((minP + maxP) * 0.5), (maxP - minP)
    end
    ESPPreview._visBB = _visBB
    local cf0, size = _visBB(clone)
    if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local offset = -cf0.Position
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end
    end
    clone.Parent = ESPPreview.viewport
    ESPPreview.dummy = clone
    -- Snapshot each part's original Color/Material/Transparency so we can
    -- restore them when chams is toggled off. Populated once per rebuild.
    ESPPreview._origColors = {}
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") then
            ESPPreview._origColors[p] = { Color=p.Color, Material=p.Material, Transparency=p.Transparency }
        end
    end
    -- Also add a white SelectionBox on the torso for a crisp outline that
    -- ViewportFrames DO render (Highlight support inside VP is unreliable).
    pcall(function()
        if ESPPreview._selBox then ESPPreview._selBox:Destroy() end
        local torso = clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChildWhichIsA("BasePart")
        if torso then
            local sb = Instance.new("SelectionBox")
            sb.Adornee        = clone
            sb.SurfaceColor3  = Color3.fromRGB(255,255,255)
            sb.SurfaceTransparency = 0
            sb.LineThickness  = 0.05
            sb.Visible        = false
            sb.Parent         = torso
            ESPPreview._selBox = sb
        end
    end)
    -- Create the preview's Chams highlight ONCE per dummy (destroyed with the
    -- dummy when the preview rebuilds). Adornee = clone → follows the ragdoll
    -- automatically inside the ViewportFrame.
    pcall(function()
        if ESPPreview.hl then ESPPreview.hl:Destroy() end
        local hl = Instance.new("Highlight")
        hl.Name = "EclipsePreviewChams"
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = clone; hl.Parent = clone
        hl.Enabled = false
        ESPPreview.hl = hl
    end)
    ESPPreview._focus = Vector3.new(0, 0, 0)
    ESPPreview._ang   = 0
    -- Frame the camera so the whole body fits nicely inside the viewport.
    local maxDim = math.max(size.X, size.Y, size.Z)
    local dist   = math.max(6, maxDim * 2.2)
    if ESPPreview.cam then
        ESPPreview.cam.CFrame = CFrame.new(Vector3.new(0, 0, dist), ESPPreview._focus)
        ESPPreview.cam.FieldOfView = 55
    end
    -- Chams highlight for the preview dummy (mirrors live ESP chams).
    if not ESPPreview.hl then
        local hl = Instance.new("Highlight")
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = false
        hl.Parent = clone
        ESPPreview.hl = hl
    else
        ESPPreview.hl.Parent = clone
    end
    _espPreviewSetAlive(true)
end

_espPreviewBuild()
