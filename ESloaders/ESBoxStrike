-- Heartbeat when the weapon supports scoping. Everything is gated on the
-- Config toggles so flipping OFF returns to normal behavior instantly.
-- =====================================================================
local RecoilHook = { installed=false }

local _RECOIL_METHODS = {
    weaponKick = true, WeaponKick = true,
    setWeaponRecoil = true, SetWeaponRecoil = true,
    addRecoil = true, AddRecoil = true,
    applyRecoil = true, ApplyRecoil = true,
}

