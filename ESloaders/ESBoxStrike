-- Adaptive dispatcher: aim/RCS/crosshair MUST run every frame (input path).
-- Heavier passes (WorldESP, GrenadePrediction, ESP redraws) run every frame
-- when we're above 60fps and drop to every-other-frame when frame time
-- exceeds ~22ms (~45fps). Lazy — no work is dropped, just paced.
local _frameN = 0
local _lastFrameT = tick()
local _emaDt = 1/60
connectSignal(RunService.RenderStepped:Connect(function()
    if not scriptRunning then return end
    _frameN = _frameN + 1
    local now = tick()
    local dt = now - _lastFrameT; _lastFrameT = now
    _emaDt = _emaDt * 0.9 + dt * 0.1
    local heavy = (_emaDt <= 1/45) or (_frameN % 2 == 0) -- lazy every-2nd-frame when laggy

    -- Input-critical passes: every frame.
    safeUpdate("Aimbot", updateAimbot)
    safeUpdate("TriggerBot", updateTriggerBot)
    safeUpdate("RCS", updateRCS)
    safeUpdate("Movement", updateMovement)
    safeUpdate("SniperCrosshair", updateSniperCrosshair)
    safeUpdate("C4Timer", updateC4Timer)
    -- Grenade prediction/warning: every frame, no delay, no spam (single connection).
    safeUpdate("GrenadePrediction", updateGrenadePrediction)

    -- Visual / world passes: paced under load.
    if heavy then
        safeUpdate("ESP", updateESP)
        safeUpdate("Chams", updateChams)
        safeUpdate("WorldESP", updateWorldESP)
        safeUpdate("AntiFlash", updateAntiFlash)
        safeUpdate("AntiSmoke", updateAntiSmoke)
    end

    safeUpdate("SkinSystem", function()
        if SkinSystem.scriptRunning and SkinSystem.vm and SkinSystem.vm.PrimaryPart then
            SkinSystem.vm.PrimaryPart.CFrame = Camera.CFrame * knives[Config.Skins.SelectedKnife].Offset
            if not SkinSystem.inspecting and not SkinSystem.swinging then
                if SkinSystem.idleAnim and not SkinSystem.idleAnim.IsPlaying then SkinSystem.idleAnim:Play() end
            end
        end
    end)
    safeUpdate("Weather", function()
        if WeatherPart then WeatherPart.CFrame = Camera.CFrame * CFrame.new(0,30,0) end
    end)
end))

-- Periodic light cleanup: releases dead references from ESP / warn / spray
-- caches so long sessions don't leak memory. Runs every 30s off the main
-- thread, capped work per pass so it never adds a hitch.
task.spawn(function()
    while scriptRunning do
        task.wait(30)
        pcall(function()
            local players = {}
            for _, p in ipairs(Players:GetPlayers()) do players[p] = true end
            for p, d in pairs(ESPObjects) do
                if not players[p] then
                    for _, obj in pairs(d) do
                        if type(obj) == "table" then
                            for _, sub in pairs(obj) do pcall(function() sub:Remove() end) end
                        else pcall(function() obj:Remove() end) end
                    end
                    ESPObjects[p] = nil
                end
            end
        end)
    end
end)

