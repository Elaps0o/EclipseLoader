function _hudInventorySlots(inv)
    local out, seen = {}, {}
    local function add(slot)
        if slot and not seen[slot] and slot:FindFirstChild("Weapon") then
            seen[slot] = true; out[#out + 1] = slot
        end
    end
    for _, child in ipairs(inv:GetChildren()) do add(child) end
    for _, d in ipairs(inv:GetDescendants()) do add(d) end
    return out
end

