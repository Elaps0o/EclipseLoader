-- Session flag: random per-user filename bound to UserId + HWID. Old
-- session.flag files are no longer accepted; a forged flag with the wrong
-- signature is rejected. Salt is hard-coded to add friction against forgery.
local ECLIPSE_SALT = "Ecl!pseHubV1-2026-#"
local function _eclHwid() local ok, id = pcall(function() return game:GetService("RbxAnalyticsService"):GetClientId() end); return ok and id or "nohwid" end
local function _eclSig(uid, hwid, ts)
    local s = tostring(uid) .. "|" .. tostring(hwid) .. "|" .. tostring(ts) .. "|" .. ECLIPSE_SALT
    local sum = 0
    for i = 1, #s do sum = (sum * 131 + string.byte(s, i)) % 2147483647 end
    return string.format("%x", sum)
end
local function _eclFlagName(uid, hwid)
    local s = tostring(uid) .. tostring(hwid) .. ECLIPSE_SALT
    local h = 0
    for i = 1, #s do h = (h * 33 + string.byte(s, i)) % 2147483647 end
    return "EclipseHub/" .. string.format("%x", h) .. ".flag"
end
do
    if isfile and isfolder then
        local uid = LocalPlayer.UserId
        local hwid = _eclHwid()
        local path = _eclFlagName(uid, hwid)
        if pcall(isfile, path) and isfile(path) then
            local ok, val = pcall(readfile, path)
            if ok and val then
                local ts, sig = val:match("^(%d+)|([%x]+)$")
                ts = tonumber(ts)
                if ts and sig and sig == _eclSig(uid, hwid, ts) then
                    getgenv().Eclipse.sessionSeen = (os.time() - ts) < 8 * 3600
                end
            end
        end
        -- Purge legacy plain-text flag to prevent forgery via the old format.
        pcall(function() if isfile("EclipseHub/session.flag") then delfile("EclipseHub/session.flag") end end)
    end
end

