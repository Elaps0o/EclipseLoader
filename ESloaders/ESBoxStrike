-- Parchment reveal: unroll vertically from center with slight scale-in, gives
-- a "scroll unfurling" feel on panels (Spec list, Keybind list, C4 timer).
local function parchmentReveal(frame, finalSize)
    if not frame or not finalSize then return end
    frame.Visible = true
    -- Start collapsed: full width, zero height, centered vertically at target.
    local baseAnchor = frame.AnchorPoint
    local w = finalSize.X.Offset ~= 0 and finalSize.X.Offset or 200
    local h = finalSize.Y.Offset ~= 0 and finalSize.Y.Offset or 40
    frame.Size = UDim2.fromOffset(math.floor(w * 0.6), 2)
    TweenService:Create(frame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Size = finalSize }):Play()
    frame.AnchorPoint = baseAnchor
end

local function isGuiOpen()
    local t = rawget(Library, "Toggled")
    if t == nil then return true end
    return t == true
end

local function parchmentHide(frame)
    if not frame or not frame.Visible then return end
    local orig = frame.Size
    local target = UDim2.fromOffset(math.floor((orig.X.Offset ~= 0 and orig.X.Offset or 200) * 0.6), 2)
    local tw = TweenService:Create(frame, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        { Size = target })
    tw:Play()
    tw.Completed:Once(function()
        frame.Visible = false
        frame.Size = orig
    end)
end

