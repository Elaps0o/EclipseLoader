local function applyWeaponSkin(model)
    if not SkinsFolder or not model or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
    local skin = Config.Skins.SelectedSkins[model.Name]; if not skin then return end
    -- Skip work if this exact skin is already applied — prevents flicker from
    -- re-cloning SurfaceAppearance every 0.5s scan tick.
    if model:GetAttribute("SkinApplied") == skin then return end
    pcall(function()
        local sf = SkinsFolder:FindFirstChild(model.Name); if not sf then return end
        local st = sf:FindFirstChild(skin)
        local src = st and st:FindFirstChild("Camera") and st.Camera:FindFirstChild("Factory New")
        if not src then return end
        -- Gloves: apply ONLY when this model actually has arms, and only when the
        -- selected glove skin differs from what's already stamped on the arms.
        local myL = model:FindFirstChild("Left Arm"); local myR = model:FindFirstChild("Right Arm")
        if myL or myR then
            local gSkin = Config.Skins.SelectedSkins["Sports Gloves"]
            if gSkin and model:GetAttribute("GlovesApplied") ~= gSkin then
                local gf = SkinsFolder:FindFirstChild("Sports Gloves")
                local gs = gf and gf:FindFirstChild(gSkin)
                local gsr = gs and gs:FindFirstChild("Camera") and gs.Camera:FindFirstChild("Factory New")
                if gsr then
                    for _, side in {"Left Arm","Right Arm"} do
                        local arm = model:FindFirstChild(side); local s = gsr:FindFirstChild(side)
                        if arm and s then
                            local gm = arm:FindFirstChild("Glove")
                            if gm then
                                local ex = gm:FindFirstChildOfClass("SurfaceAppearance"); if ex then ex:Destroy() end
                                local c = s:Clone(); c.Name="SurfaceAppearance"; c.Parent=gm
                            end
                        end
                    end
                    model:SetAttribute("GlovesApplied", gSkin)
                end
            end
        end
        if not GLOVES[model.Name] then
            local wf = model:FindFirstChild("Weapon")
            if wf then
                for _, p in wf:GetDescendants() do
                    if p:IsA("BasePart") then
                        local ns = src:FindFirstChild(p.Name)
                        if ns then
                            local ex = p:FindFirstChildOfClass("SurfaceAppearance"); if ex then ex:Destroy() end
                            local c = ns:Clone(); c.Name="SurfaceAppearance"; c.Parent=p
                        end
                    end
                end
            end
        end
        model:SetAttribute("SkinApplied", skin)
    end)
end

local function CleanupScript()
    scriptRunning = false
    sendWebhook("unloaded", "Script unloaded")
    for _, c in ipairs(UnloadConnections) do pcall(function() c:Disconnect() end) end
    table.clear(UnloadConnections)
    if Camera.CameraType == Enum.CameraType.Scriptable then
        Camera.CameraType = OriginalCameraType
        if LocalPlayer.Character then
            local h = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if h then Camera.CameraSubject = h end
        end
    end
    if Camera.FieldOfView ~= OriginalCameraFOV then Camera.FieldOfView = OriginalCameraFOV end
    for _, d in pairs(ESPObjects) do
        for _, l in pairs(d.CornerLines) do pcall(function() l:Remove() end) end
        for _, l in pairs(d.HealthSegments or {}) do pcall(function() l:Remove() end) end
        for _, l in pairs(d.HealthTicks or {}) do pcall(function() l:Remove() end) end
        for _, l in pairs(d.Skeleton or {}) do pcall(function() l:Remove() end) end
