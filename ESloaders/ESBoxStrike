ECLIPSE._collectSpectators = function()
    local names, seen = {}, {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local subject
            pcall(function()
                local pcam = plr:FindFirstChildOfClass("Camera")
                subject = (pcam and pcam.CameraSubject) or nil
            end)
            local watching = false
            if subject and LocalPlayer.Character then
                if subject:IsA("Humanoid") and subject.Parent == LocalPlayer.Character then watching = true end
                if subject:IsA("BasePart") and subject:IsDescendantOf(LocalPlayer.Character) then watching = true end
            end
            if watching and not seen[plr.Name] then
                seen[plr.Name] = true
                table.insert(names, plr.Name)
            end
        end
    end
    return names
end

