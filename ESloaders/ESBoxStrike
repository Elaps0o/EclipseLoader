function C4Hide()
    if not C4UI.frame then return end
    if not C4UI.shown then C4UI.frame.Visible = false; return end
    C4UI.shown = false; C4UI.pinned = false
    local f = C4UI.frame
    local tw = TweenService:Create(f, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        { BackgroundTransparency = 1 })
    tw:Play()
    tw.Completed:Once(function() if not C4UI.shown then f.Visible = false; f.BackgroundTransparency = 0.4 end end)
end

-- Legacy-compatible signature: (status, timeText, sub, color)
function C4Show(status, timeText, sub, color)
    ensureC4UI()
    if not C4UI.frame then return end

    local rich
    if status == "PLANTED" then
        rich = string.format("<b>C4</b>  %s", tostring(timeText or ""))
    elseif status == "DEFUSING" then
        local who = (sub and sub ~= "" and (" · " .. sub)) or ""
        rich = string.format("<b>DEFUSING</b>  %s%s", tostring(timeText or ""), who)
    elseif status == "BOMB DEFUSED"   then rich = "<b>BOMB DEFUSED</b>"
    elseif status == "BOMB DETONATED" then rich = "<b>BOMB DETONATED</b>"
    elseif status == "BOMB LOST"      then rich = "<b>BOMB LOST</b>  signal lost"
    elseif status == "TIME UP"        then rich = "<b>TIME UP</b>  fuse ended"
    else
        rich = string.format("<b>C4</b>  %s", tostring(timeText or ""))
    end

    C4UI.text.Text = rich
    local animate = (status == "PLANTED" or status == "DEFUSING")
    C4UI.dots.Visible = animate
    C4UI.pinned = (status == "BOMB DEFUSED" or status == "BOMB DETONATED"
                   or status == "BOMB LOST" or status == "TIME UP")

    if color then
        C4UI.dot.TextColor3 = color
        C4UI.stroke.Color = color; C4UI.stroke.Transparency = 0.45
    else
        C4UI.stroke.Color = Color3.new(1,1,1); C4UI.stroke.Transparency = 0.6
    end

    if not C4UI.shown then
        C4UI.shown = true
        C4UI.frame.Visible = true
        C4UI.frame.BackgroundTransparency = 1
        TweenService:Create(C4UI.frame, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            { BackgroundTransparency = 0.4 }):Play()
    end
end

-- Trailing "…" animation loop.
task.spawn(function()
    while true do
        task.wait(0.33)
        if C4UI.dots and C4UI.dots.Visible then
            local n = (#C4UI.dots.Text % 3) + 1
            C4UI.dots.Text = string.rep(".", n)
        end
    end
