        pcall(function() d.HealthText:Remove() end)
        pcall(function() d.Presence:Remove() end)
        pcall(function() if d.WeaponTag then d.WeaponTag:Remove() end end)
        pcall(function() if d.HeadDot then d.HeadDot:Remove() end end)
        pcall(function() if d.Arrow then d.Arrow:Remove() end end)
    end
    table.clear(ESPObjects)
    pcall(function() TargetLine:Remove() end); pcall(function() FOVCircle:Remove() end)
    -- Sniper crosshair drawings
    pcall(function() for _, o in pairs(CH) do pcall(function() o.Visible=false; o:Remove() end) end end)
    -- Grenade Warning drawings + line pool
    pcall(function()
        for _, p in ipairs(EX.WarnLines or {}) do
            pcall(function() if p.outer then p.outer:Remove() end end)
            pcall(function() if p.inner then p.inner:Remove() end end)
