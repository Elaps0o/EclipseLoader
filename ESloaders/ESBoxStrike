local AutoDefuse = { remote=nil, resolved=false, lastFire=0, holding=false, VIM=nil }
function resolveDefuseRemote()
    if AutoDefuse.resolved then return AutoDefuse.remote end
    AutoDefuse.resolved = true

    return AutoDefuse.remote
end
function _getVIM()
    if AutoDefuse.VIM then return AutoDefuse.VIM end
    pcall(function() AutoDefuse.VIM = game:GetService("VirtualInputManager") end)
    return AutoDefuse.VIM
end
function _holdE(down)
    if AutoDefuse.holding == down then return end
    AutoDefuse.holding = down
    local vim = _getVIM(); if not vim then return end
    pcall(function() vim:SendKeyEvent(down, Enum.KeyCode.E, false, game) end)
end
function tryAutoDefuse()
    if not Config.Misc.AutoDefuse or not C4Timer.planted then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    if isBombDefused() then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local ch = LocalPlayer.Character
    local hum = ch and ch:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local team = LocalPlayer:GetAttribute("Team")
    if team and team ~= "Counter-Terrorists" then
        if AutoDefuse.holding then _holdE(false) end
        return
    end

    
    local bomb = C4Timer.bomb or getBombModel()
    local root = ch and ch:FindFirstChild("HumanoidRootPart")
    local bpart = bomb and (bomb.PrimaryPart or bomb:FindFirstChildWhichIsA("BasePart"))
    if not (bpart and root) then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    local delta = bpart.Position - root.Position
    local dist = delta.Magnitude
    if dist > 6 then
        if AutoDefuse.holding then _holdE(false) end
        return
    end
    
    if dist > 1.2 then
        local look = root.CFrame.LookVector
        local dir = delta.Unit
        if look:Dot(dir) < 0.25 then
            if AutoDefuse.holding then _holdE(false) end
            return
        end
    end

    _holdE(true)
    local now = tick()
    if now - AutoDefuse.lastFire < 0.15 then return end
    AutoDefuse.lastFire = now
    local r = resolveDefuseRemote(); if not r then return end
    pcall(function()
        if r.Fire then r:Fire()
        elseif r.FireServer then r:FireServer()
        elseif r.InvokeServer then r:InvokeServer() end
    end)
end

