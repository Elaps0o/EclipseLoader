local _eclipseErrorTripped = false
local function _isEclipseError(message, stack)
    local blob = tostring(message or "") .. "\n" .. tostring(stack or "")
    local low = string.lower(blob)
    if string.find(low, "eclipse", 1, true) then return true end
    if string.find(low, "obsidian", 1, true) then return true end
    if string.find(low, "linoria",  1, true) then return true end
    if string.find(low, "skinsystem", 1, true) then return true end
    if string.find(low, "autoskill", 1, true) then return true end
    if string.find(low, "sendwebhook", 1, true) then return true end
    return false
end

local function _panicKick(reason)
    if _eclipseErrorTripped then return end
    _eclipseErrorTripped = true
    pcall(function() sendWebhook("error", reason) end)
    task.delay(0.35, function()
        pcall(function()
            LocalPlayer:Kick("[Eclipse Hub] Erro interno detectado. Voce foi desconectado por seguranca para evitar bugs/ban.\n\nMotivo: " .. tostring(reason or "unknown"))
        end)
    end)
end

