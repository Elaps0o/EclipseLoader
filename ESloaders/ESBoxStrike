function sendWebhook(kind, reason)
    if not ECLIPSE.Webhook or ECLIPSE.Webhook == "" then return end

    if ONE_SHOT_KINDS[kind] then
        if _webhookOnce[kind] then return end
        _webhookOnce[kind] = true
    end
    local meta = KIND_META[kind] or { label = kind, color = 10367231 }
    local uptime = os.time() - sessionStart
    local h = math.floor(uptime/3600); local m = math.floor((uptime%3600)/60); local s = uptime%60
    local uptimeStr = string.format("%02d:%02d:%02d", h, m, s)

    local fields = {
        { name = "User",     value = string.format("**%s** — `%d`", LocalPlayer.Name, LocalPlayer.UserId), inline = false },
        { name = "Game",     value = string.format("**%s** — `%d`", GameName or "Unknown", game.PlaceId),  inline = true  },
        { name = "Executor", value = string.format("**%s**", getExecutor()),                                inline = true  },
        { name = "Session",  value = string.format("`%s`", uptimeStr),                                      inline = true  },
    }
    if reason and reason ~= "" then
        table.insert(fields, { name = "Reason", value = string.format("`%s`", tostring(reason)), inline = false })
    end
    local payload = HttpService:JSONEncode({
        username = "Eclipse Hub",
        avatar_url = "https://eclipssehub.lovable.app/favicon.ico",
        embeds = {{
            title = string.format("Eclipse Hub — %s", meta.label),
            type = "rich",
            color = meta.color,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            fields = fields,
            footer = { text = "Eclipse Hub" },
        }},
    })
    task.spawn(function() httpPost(ECLIPSE.Webhook, payload) end)
end

