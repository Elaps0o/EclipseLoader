function updateSniperCrosshair()
    local on = Config.GlobalEnable and Config.Crosshair.SniperEnabled
    if not on then
        for _, o in pairs(CH) do o.Visible = false end
        return
    end
    local wn = getHeldWeaponName()
    if not wn or not SniperWeapons[wn] then
        for _, o in pairs(CH) do o.Visible = false end
        return
    end
    if Config.Crosshair.HideOnScope and isScopedIn() then
        for _, o in pairs(CH) do o.Visible = false end
        return
    end
    local vs = Camera.ViewportSize
    local cx, cy = vs.X/2, vs.Y/2
    local size, gap = Config.Crosshair.Size, Config.Crosshair.Gap
    local col, th = Config.Crosshair.Color, Config.Crosshair.Thickness
    CH.U.From = Vector2.new(cx, cy - gap); CH.U.To = Vector2.new(cx, cy - gap - size)
    CH.D.From = Vector2.new(cx, cy + gap); CH.D.To = Vector2.new(cx, cy + gap + size)
    CH.L.From = Vector2.new(cx - gap, cy); CH.L.To = Vector2.new(cx - gap - size, cy)
    CH.R.From = Vector2.new(cx + gap, cy); CH.R.To = Vector2.new(cx + gap + size, cy)
    for k, o in pairs(CH) do
        if k ~= "Dot" then o.Thickness = th; o.Color = col; o.Visible = true end
    end
    if Config.Crosshair.Dot then
        CH.Dot.Position = Vector2.new(cx, cy); CH.Dot.Color = col; CH.Dot.Visible = true
    else CH.Dot.Visible = false end
end


