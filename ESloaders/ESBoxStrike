        for _, l in ipairs(data.TagBorder) do l.Thickness = 1; l.Transparency = 0.65 * math.min(1,s); l.Color = Color3.fromRGB(140,140,160); l.Visible = true end

        local segs = ESP_TAG_GRAD_SEGS
