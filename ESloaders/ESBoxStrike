local function _genHex(n)
    local t = {}
    for i = 1, n do t[i] = string.format("%X", math.random(0, 15)) end
    return table.concat(t)
end
local function _genHWID()
    -- classic Windows-style GUID: 8-4-4-4-12
    return string.format("%s-%s-%s-%s-%s",
        _genHex(8), _genHex(4), _genHex(4), _genHex(4), _genHex(12))
end
local function _genClientId()
    return _genHex(8):lower() .. "-" .. _genHex(4):lower() .. "-" .. _genHex(12):lower()
end
