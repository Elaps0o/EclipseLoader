-- Kick / disconnect classifier:
--  * "BAC Alpha-3B"            → BANIDO webhook (red)
--  * "DisconnectClientInitiated" → silent: stop heartbeats, no webhook
--  * anything else              → normal KICK webhook
getgenv().Eclipse.heartbeatEnabled = true
pcall(function()
    local GuiService = game:GetService("GuiService")
    connectSignal(GuiService.ErrorMessageChanged:Connect(function()
        local msg = GuiService:GetErrorMessage() or ""
        if msg == "" or not scriptRunning then return end
        wasKicked = true
        if string.find(msg, "BAC Alpha%-3B") then
            sendWebhook("banned", msg)
            getgenv().Eclipse.heartbeatEnabled = false
        elseif string.find(msg, "DisconnectClientInitiated") then
            -- User disconnected on their own — do not spam webhook, kill heartbeat loop.
            getgenv().Eclipse.heartbeatEnabled = false
        else
            sendWebhook("kicked", msg)
        end
    end))
end)

