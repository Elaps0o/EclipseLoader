function CreateSkinDropdown(weapon, section)
    if not SkinsFolder then return end
    local folder = SkinsFolder:FindFirstChild(weapon); if not folder then return end
    local opts = {"Vanilla"}
    local _seen = { Vanilla = true }
    for _, s in ipairs(folder:GetChildren()) do
        local n = s and s.Name
        if n and n ~= "" and not _seen[n] then _seen[n] = true; table.insert(opts, n) end
    end
    if #opts <= 1 then return end
    pcall(table.sort, opts, function(a, b)
        if a == b then return false end
        if a == "Vanilla" then return true end
        if b == "Vanilla" then return false end
        return tostring(a) < tostring(b)
    end)
    if Config.Skins.SelectedSkins[weapon] == "" then Config.Skins.SelectedSkins[weapon] = nil end
    local defaultSkin = Config.Skins.SelectedSkins[weapon]
    if defaultSkin and not table.find(opts, defaultSkin) then defaultSkin = nil end
    if not defaultSkin then
        defaultSkin = opts[2]
        Config.Skins.SelectedSkins[weapon] = defaultSkin
    end
    SafeAddDropdown(section, "Skin_"..weapon, { Text=weapon, Options=opts,
        Default=defaultSkin or "Vanilla",
        Callback=function(v)
            if not Config.Skins.SkinChangerEnabled and not _EclipseConfigLoading then
                pcall(function() Options["Skin_"..weapon]:SetValue(Config.Skins.SelectedSkins[weapon] or "Vanilla") end)
                return
            end
            if v == "Vanilla" or v == "None" then Config.Skins.SelectedSkins[weapon] = nil else Config.Skins.SelectedSkins[weapon] = v end

            
            if _EclipseConfigLoading then return end
            if v == "Vanilla" or v == "None" then
                pcall(_skinPreviewClose)
                pcall(_restoreWeaponSkinRuntime, weapon)
                if Config.Skins.SkinChangerEnabled and IsAlive() then
                    for _, obj in ipairs(Camera:GetChildren()) do
                        local skinName = Config.Skins.SelectedSkins[obj.Name]
