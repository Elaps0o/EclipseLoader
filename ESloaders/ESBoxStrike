;(function() -- CUSTOM SHOOT SOUNDS (IIFE for register budget)
    -- Preset sounds shipped with the app; no external loader needed.
    EX.SoundPresets = {
        ["Default"]        = "",
        ["Silenced Pop"]   = "rbxassetid://131961136",
        ["MP5 Burst"]      = "rbxassetid://168143115",
        ["Deep Boom"]      = "rbxassetid://131237241",
