        applying = false,
        conn = nil,
        iconConn = nil,
        iconToken = 0,
        slotFrame = slotFrame,
    }
    HUDSkin.slots[slotFrame] = rec

    return rec
end

function _restoreHUDName(rec, nameLbl)
    if not nameLbl then return end
    pcall(function()
        if rec and rec.nameOverlay then rec.nameOverlay.Visible = false end
        if rec then rec.currentOverlayText = nil; rec.lastAppliedWeapon = nil end
        -- Do NOT write nameLbl.Text. The game HUD owns that string and
        -- rewrites it every frame with the real weapon name. Writing our
        -- cached value would stamp stale text like "Primary"/"Secondary"
        -- or "" (invisible) and the game wouldn't refresh it back.
        local tx = (rec and rec.nameTextTransparency ~= nil) and rec.nameTextTransparency or 0
        if type(tx) ~= "number" or tx >= 0.95 then tx = 0 end
        local sx = (rec and rec.nameTextStrokeTransparency ~= nil) and rec.nameTextStrokeTransparency or 1
        if type(sx) ~= "number" then sx = 1 end
        nameLbl.TextTransparency = tx
        nameLbl.TextStrokeTransparency = sx
        nameLbl.Visible = true
    end)
end

function _applyHUDNameOverlay(rec, nameLbl, text)
    if not (rec and nameLbl and text and text ~= "") then return end
    if not rec.nameOverlay or not rec.nameOverlay.Parent then
        rec.nameOverlay = _cloneHUDOverlay(nameLbl, "EclipseHUDNameOverlay")
    end
    if not rec.nameOverlay then return end
    pcall(function()
        _syncHUDOverlayGeometry(nameLbl, rec.nameOverlay)
        rec.nameOverlay.Text = text
        rec.currentOverlayText = text
        rec.nameOverlay.TextColor3 = nameLbl.TextColor3
        rec.nameOverlay.TextTransparency = 0
        rec.nameOverlay.TextStrokeTransparency = 1
        rec.nameOverlay.Visible = true
        rec.nameOverlay.ZIndex = math.max((nameLbl.ZIndex or 1) + 5, 10)
        -- Hide the real game label via transparency only. Never mutate
        -- .Text: the game re-emits its own weapon name each frame, so
        -- writing to it causes flicker and permanent invisible / "Primary"
        -- bugs when we later restore.
        nameLbl.TextTransparency = 1
        nameLbl.TextStrokeTransparency = 1
    end)
end

function _slotWeaponKey(slotFrame, nameLbl)
    local rec = HUDSkin.slots[slotFrame]
    local clean = _cleanHUDWeaponText(nameLbl.Text)
    if clean and clean ~= "" then
        if rec and nameLbl.Text ~= rec.currentOverlayText then
            rec.baseName = clean
            rec.nameText = nameLbl.Text
            if type(nameLbl.TextTransparency) == "number" and nameLbl.TextTransparency < 0.95 then
                rec.nameTextTransparency = nameLbl.TextTransparency
            end
            rec.nameTextStrokeTransparency = nameLbl.TextStrokeTransparency
        end
        return clean
    end
    return rec and rec.baseName or nil
end

function _isHUDMeleeSlot(slotFrame, weaponKey)
    weaponKey = _cleanHUDWeaponText(weaponKey) or weaponKey
    local sn = tostring(slotFrame and slotFrame.Name or ""):lower()
    if sn:find("primary", 1, true) or sn:find("secondary", 1, true) or sn:find("pistol", 1, true) then return false end
    if sn:find("melee", 1, true) or sn:find("knife", 1, true) then return true end
    if weaponKey == "T Knife" or weaponKey == "CT Knife" then return true end
    if KNIVES[weaponKey] == true then return true end
    local wk = tostring(weaponKey or ""):lower()
    return wk:find("knife", 1, true) ~= nil or wk:find("bayonet", 1, true) ~= nil or wk == "karambit"
end

function _hudSkinForWeapon(weaponName, fallbackWeapon)
    if type(weaponName) ~= "string" or weaponName == "" then return nil end
    -- Preserve other/renamed weapon skins: only show/apply configured skins when
    -- the current weapon name is an exact, known game skin folder.
    if SkinsFolder and not SkinsFolder:FindFirstChild(weaponName) then return nil end
    local skin = Config.Skins.SelectedSkins[weaponName]
    if (not skin or skin == "") and fallbackWeapon then skin = Config.Skins.SelectedSkins[fallbackWeapon] end
    local pretty = _prettySkinName(skin)
    return pretty ~= "" and pretty or nil
end

function _hudDefaultKnifeText()
    local originalKnife = _localKnifeByTeam()
    local selected = Config.Skins.SelectedKnife
    if SkinSystem.scriptRunning and type(selected) == "string" and selected ~= "" and selected ~= "T Knife" and selected ~= "CT Knife" then
        return "\xE2\x98\x85 " .. selected
    end
    return originalKnife
end

function _desiredHUDForSlot(slotFrame, rawWeapon)
    rawWeapon = _cleanHUDWeaponText(rawWeapon) or rawWeapon
    if _isHUDMeleeSlot(slotFrame, rawWeapon) then
        local originalKnife = _localKnifeByTeam()
        if not SkinSystem.scriptRunning then
            return _hudDefaultKnifeText(), nil, originalKnife, true
        end
        local knifeName = _selectedHUDKnife()
        local prettySkin = _hudSkinForWeapon(knifeName, originalKnife)
        local base = knifeName
        local text = prettySkin and ("\xE2\x98\x85 " .. base .. " | " .. prettySkin) or ("\xE2\x98\x85 " .. base)
        local icon = _iconForWeapon(knifeName)
        return text, icon, originalKnife, true
    end
    local weaponName = rawWeapon; if not weaponName or weaponName == "" then return nil, nil, nil, false end
    -- HUD override fallback list: for weapons where the icon/asset override
    -- cannot be resolved reliably (gloves and Sawed-Off), keep the original
    -- HUD name AND original icon untouched — never write "Weapon | Skin".
    if HUD_OVERRIDE_UNSUPPORTED and HUD_OVERRIDE_UNSUPPORTED[weaponName] then
        return weaponName, nil, weaponName, false
    end
    local prettySkin = _hudSkinForWeapon(weaponName)
    local text = prettySkin and (weaponName .. " | " .. prettySkin) or weaponName
    return text, nil, weaponName, prettySkin ~= nil
end

-- Weapons whose HUD name/icon override we intentionally skip because the
-- resolver can't find a stable asset (mirrors SKIN_PREVIEW_BLOCKED for the
-- HUD path). Keep original slot content untouched.
HUD_OVERRIDE_UNSUPPORTED = {
    ["Sports Gloves"]=true, ["Specialist Gloves"]=true, ["Driver Gloves"]=true,
    ["Hand Wraps"]=true, ["Moto Gloves"]=true, ["Bloodhound Gloves"]=true,
    ["Broken Fang Gloves"]=true, ["Hydra Gloves"]=true, ["Operator Gloves"]=true,
    ["Gloves"]=true, ["T Glove"]=true, ["CT Glove"]=true,
    ["Sawed-Off"]=true, ["Sawed Off"]=true, ["SawedOff"]=true,
    ["Hellfire"]=true,
}

function _queueHUDSlotApply(slotFrame)
    local rec = slotFrame and HUDSkin.slots[slotFrame]
    if rec and rec.queued then return end
    if rec then rec.queued = true end
    task.delay(0.04, function()
        if rec then rec.queued = false end
        if scriptRunning and Config.Skins.SkinChangerEnabled and IsAlive() and not _isSpectatingOther() and slotFrame and slotFrame.Parent then pcall(function() _applyOneSlot(slotFrame, false) end) end
    end)
end

-- === SPECTATOR GATE ============================================
-- Quando o player local morre e passa a espectar OUTRO player, o jogo
-- reaproveita o mesmo `PlayerGui.MainGui.Gameplay.Bottom.Inventory` para
-- renderizar o loadout do espectado. Nossos overlays (nome/ícone) ficariam
-- grudados no slot mostrando "Glock-18 | Aurora" e ícones sobrepostos na
-- HUD dele. Detectamos isso via Camera.CameraSubject: se o Humanoid dono
-- do subject não pertence ao LocalPlayer, escondemos todos os overlays
-- (sem destruir) e não reaplicamos até voltarmos a controlar.
function _isSpectatingOther()
    local subj = Camera and Camera.CameraSubject
    if not subj then return false end
    local hum = subj:IsA("Humanoid") and subj or (subj:IsA("BasePart") and subj.Parent and subj.Parent:FindFirstChildOfClass("Humanoid"))
    if not hum then return false end
    local char = hum.Parent; if not char then return false end
    local owner = Players:GetPlayerFromCharacter(char)
    return owner ~= nil and owner ~= LocalPlayer
end

function _hideAllHUDOverlays()
    for slotFrame, rec in pairs(HUDSkin.slots) do
        pcall(function()
            if rec.nameOverlay then rec.nameOverlay.Visible = false end
            if rec.iconOverlay then rec.iconOverlay.Visible = false end
            if rec.iconImage then rec.iconImage.Visible = false end
            if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
            if rec.iconViewport then rec.iconViewport.Visible = false end
            rec.iconAppliedKey = nil
            rec.currentOverlayText = nil
            rec.lastAppliedWeapon = nil
            if rec.nameLblRef and rec.nameLblRef.Parent then
                local tx = rec.nameTextTransparency or 0
                if type(tx) ~= "number" or tx >= 0.95 then tx = 0 end
                rec.nameLblRef.TextTransparency = tx
                rec.nameLblRef.TextStrokeTransparency = rec.nameTextStrokeTransparency or 1
                rec.nameLblRef.Visible = true
            end
            if rec.iconLabelRef and rec.iconLabelRef.Parent then
                rec.iconLabelRef.Visible = rec.iconLabelVisible ~= false
                if rec.iconLabelImage ~= nil then rec.iconLabelRef.Image = rec.iconLabelImage end
                rec.iconLabelRef.ImageTransparency = rec.iconImageTransparency or 0
            end
            if rec.iconViewportRef and rec.iconViewportRef.Parent then
                rec.iconViewportRef.Visible = rec.iconViewportVisible ~= false
            end
        end)
    end
end

function _applyOneSlot(slotFrame, forceKnife)
    if not slotFrame or not slotFrame.Parent or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
    if _isSpectatingOther() then return end
    local nameLbl, iconLbl, iconViewport, iconAnchor = _slotParts(slotFrame); if not nameLbl then return end
    local rec = _ensureSlotRec(slotFrame, nameLbl, iconLbl, iconViewport, iconAnchor)
    local rawWeapon = _slotWeaponKey(slotFrame, nameLbl) or rec.baseName or tostring(slotFrame.Name)
    if forceKnife then rawWeapon = rawWeapon or _localKnifeByTeam() end
    local isMelee = _isHUDMeleeSlot(slotFrame, rawWeapon)
    local text, icon, baseName, hasSkin = _desiredHUDForSlot(slotFrame, rawWeapon); if not text then return end

    -- Se a arma no slot mudou desde a última aplicação, limpa overlay antigo
    -- ANTES de escrever o novo (evita "Glock-18|Aurora" ficar por cima de
    -- outra arma, ou dois ícones empilhados quando o loadout troca).
    if rec.lastAppliedWeapon and rec.lastAppliedWeapon ~= baseName then
        pcall(function()
            if rec.nameOverlay then rec.nameOverlay.Visible = false end
            if rec.iconImage then rec.iconImage.Visible = false end
            if rec.iconFallbackImage then rec.iconFallbackImage.Visible = false end
        end)
        rec.iconAppliedKey = nil
        rec.currentOverlayText = nil
    end
    rec.lastAppliedWeapon = baseName
    rec.baseName = baseName or rawWeapon or rec.baseName

    if rec.iconOverlay then pcall(function() rec.iconOverlay.Visible = false end) end
    if rec.iconViewport then pcall(function() rec.iconViewport.Visible = false end) end

    rec.applying = true
    if hasSkin then
        _applyHUDNameOverlay(rec, nameLbl, text)
    else
        _restoreHUDName(rec, nameLbl)
    end
    _hudDbg("slot=", slotFrame.Name, "weapon=", baseName, "hasSkin=", hasSkin, "icon=", icon, "iconLbl=", iconLbl and iconLbl:GetFullName() or "nil", "vp=", iconViewport and iconViewport:GetFullName() or "nil")

    if isMelee and SkinSystem.scriptRunning and type(icon) == "string" and icon ~= "" and _hudIconOverrideAllowed() then
        -- Previous in-slot method: no top-level transparent GUI. We inject an
        -- ImageLabel into the real melee slot / mutate the slot ImageLabel when
        -- available. The chosen asset is hardcoded from dumps and converted to
        -- rbxthumb first so Roblox renders it as a stable thumbnail image.
        local directIcon = _assetString(icon) or icon
        local img = nil
        local usingNativeImage = false
        img = _ensureIconImage(rec, iconLbl or iconViewport or iconAnchor or slotFrame)
        if img then
            if rec.iconViewport then pcall(function() rec.iconViewport.Visible = false end) end
            local alreadyApplied = rec.iconAppliedKey == directIcon and img.Visible ~= false and (not usingNativeImage or tostring(img.Image or "") ~= tostring(rec.iconLabelImage or ""))
            if alreadyApplied then
                if iconViewport then pcall(function() iconViewport.Visible = false end) end
                if iconLbl then pcall(function() iconLbl.Visible = false end) end
                if rec.iconImage then pcall(function() rec.iconImage.Visible = true end) end
            else
                rec.iconAppliedKey = directIcon
                if iconLbl then pcall(function() iconLbl.Visible = rec.iconLabelVisible ~= false end) end
