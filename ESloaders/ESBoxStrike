    task.spawn(function()
        local lastSig = ""
        while scriptRunning do
            for _, opt in pairs(Library.Options or {}) do hookOption(opt) end
            if Config.KeybindList.Enabled then
                if not EX.KBFrame.Visible then
                    -- Parchment reveal on first show.
                    local finalSz = EX.KBFrame.Size
                    EX.KBFrame.Visible = true
                    EX.KBFrame.Size = UDim2.fromOffset(math.floor(finalSz.X.Offset * 0.6), 2)
