    if not ok or not ScriptContext then return end
    pcall(function()
        ScriptContext.Error:Connect(function(message, stack, sk)
            if _eclipseErrorTripped then return end
            if not _isEclipseError(message, stack) then return end
            _panicKick(tostring(message))
        end)
    end)
end)

