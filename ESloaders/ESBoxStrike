-- Build a glove preview by cloning some OTHER player's arms (any random alive
-- player in the server, same as the eps/skin preview from Roblox). We do NOT
-- use LocalPlayer — the user specifically wants a random third-party character
-- so the gloves are visible on a "dummy" model. Falls back to LocalPlayer only
-- if the server is empty.
local function _pickRandomCharacter()
    local candidates = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local la = plr.Character:FindFirstChild("Left Arm")
            local ra = plr.Character:FindFirstChild("Right Arm")
            if la and la:IsA("BasePart") and ra and ra:IsA("BasePart") then
                table.insert(candidates, plr.Character)
            end
        end
    end
    if #candidates > 0 then return candidates[math.random(1, #candidates)] end
    return LocalPlayer.Character
end

local function _buildGloveArmsPreview()
    local char = _pickRandomCharacter()
    if not char then return nil end
    local la = char:FindFirstChild("Left Arm")
    local ra = char:FindFirstChild("Right Arm")
    if not (la and la:IsA("BasePart") and ra and ra:IsA("BasePart")) then return nil end
    local model = Instance.new("Model"); model.Name = "GloveArmsPreview"
    local function cloneArm(arm, isLeft)
        local c = arm:Clone()
        c.Anchored = true; c.CanCollide = false; c.Massless = true
        c.Transparency = 0
        -- Copy over accessories/decorations parented to the arm (the glove
        -- mesh from CT/T Glove is attached as a child model with parts).
        for _, d in ipairs(arm:GetChildren()) do
            if d:IsA("BasePart") or d:IsA("Model") or d:IsA("Accessory")
               or d:IsA("MeshPart") or d:IsA("SpecialMesh") or d:IsA("Decal")
               or d:IsA("Texture") or d:IsA("SurfaceAppearance") then
                local ok, dc = pcall(function() return d:Clone() end)
                if ok and dc then
                    if dc:IsA("BasePart") then
                        dc.Anchored = true; dc.CanCollide = false; dc.Massless = true
                    end
                    dc.Parent = c
                end
            end
        end
        c.Parent = model
        return c
    end
    local lc = cloneArm(la, true)
    local rc = cloneArm(ra, false)
    -- Cross the arms in front of the camera: left arm tilted right, right arm
    -- tilted left, slight forward stagger so they overlap visibly.
    local baseCF = CFrame.new()
    local function reposArm(part, extras, cf)
        local old = part.CFrame
        part.CFrame = cf
        local delta = cf * old:Inverse()
        for _, d in ipairs(extras) do
            if d:IsA("BasePart") then d.CFrame = delta * d.CFrame end
        end
    end
    local lExtras, rExtras = {}, {}
    for _, d in ipairs(lc:GetDescendants()) do if d:IsA("BasePart") then table.insert(lExtras, d) end end
    for _, d in ipairs(rc:GetDescendants()) do if d:IsA("BasePart") then table.insert(rExtras, d) end end
    reposArm(lc, lExtras, baseCF * CFrame.new(-0.15, 0, 0) * CFrame.Angles(0, 0, math.rad(-35)))
    reposArm(rc, rExtras, baseCF * CFrame.new( 0.15, 0, -0.05) * CFrame.Angles(0, 0, math.rad( 35)))
    return model
end

-- Skin preview is intentionally disabled for these weapons/families (per user
-- request: gloves preview is unreliable, and Sawed-Off / Hellfire don't render
-- well in the small preview viewport).
local SKIN_PREVIEW_BLOCKED = {
    ["Sports Gloves"]=true, ["Specialist Gloves"]=true, ["Driver Gloves"]=true,
    ["Hand Wraps"]=true, ["Moto Gloves"]=true, ["Bloodhound Gloves"]=true,
    ["Broken Fang Gloves"]=true, ["Hydra Gloves"]=true, ["Operator Gloves"]=true,
    ["Gloves"]=true, ["T Glove"]=true, ["CT Glove"]=true,
    ["Sawed-Off"]=true, ["Sawed Off"]=true, ["SawedOff"]=true,
    ["Hellfire"]=true,
}
function SetSkinPreview(weapon)
    if not SkinsFolder then return end
    if weapon and SKIN_PREVIEW_BLOCKED[weapon] then
        pcall(_skinPreviewClose)
        return
    end
    _skinPreviewBuild()
    local skin = weapon and Config.Skins.SelectedSkins[weapon]
    if not (weapon and skin) then return end
    -- Sports Gloves: build the preview from the local character's arms so the
    -- currently-applied glove skin (and any real-time change) shows in the
    -- preview viewport. Other glove families (Specialist/Operator/Sawed-Off)
    -- fall through to the standard asset path.
    if weapon == "Sports Gloves" then
        if SkinPreview.model then SkinPreview.model:Destroy(); SkinPreview.model = nil end
        local armsModel = _buildGloveArmsPreview()
        if armsModel then
            armsModel.Parent = SkinPreview.vp
            SkinPreview.model = armsModel
            local cf0, size = armsModel:GetBoundingBox()
            local offset = -cf0.Position
            for _, p in ipairs(armsModel:GetDescendants()) do
                if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end
            end
            SkinPreview.focus = Vector3.new(0, 0, 0)
            SkinPreview.rotX = -5
            SkinPreview.rotY = 0
            SkinPreview.spin = true
            local maxDim = math.max(size.X, size.Y, size.Z)
            SkinPreview.dist = math.max(3.0, maxDim * 1.6)
            if SkinPreview.title then
                SkinPreview.title.Text = tostring(weapon) .. "  ·  " .. tostring(skin)
            end
            SkinPreview.gui.Enabled = true
            return
        end
        -- Fallback to original path if character/arms unavailable.
    end
    -- Resolve a viewable base model:
    --   1) ReplicatedStorage.Assets.Weapons[weapon].Camera (guns/knives)
    --   2) ReplicatedStorage.Assets.Gloves[weapon]         (glove types)
    --   3) SkinsFolder[weapon][skin].Camera                (fallback for
    --      gloves + oddly-named weapons like Sawed-Off whose weapon model
    --      lives under the skin folder itself).
    local assetsFolder = ReplicatedSt:FindFirstChild("Assets")
    local weaponsFolder = assetsFolder and assetsFolder:FindFirstChild("Weapons")
    local glovesFolder  = assetsFolder and assetsFolder:FindFirstChild("Gloves")
    local wTgt = weaponsFolder and weaponsFolder:FindFirstChild(weapon)
    if not wTgt and glovesFolder then wTgt = glovesFolder:FindFirstChild(weapon) end
    local camMod = wTgt and (wTgt:FindFirstChild("Camera") or wTgt)
    if not camMod then
        local sf = SkinsFolder:FindFirstChild(weapon)
        local sk = sf and sf:FindFirstChild(skin)
        camMod = sk and (sk:FindFirstChild("Camera") or sk)
    end
    if not camMod then return end
    if SkinPreview.model then SkinPreview.model:Destroy(); SkinPreview.model = nil end
    local clone
    local ok = pcall(function() clone = camMod:Clone() end)
    if not ok or not clone then return end
    -- ViewportFrame only renders Models/BaseParts. If we cloned a Folder or a
    -- container whose parts live deeper (e.g. gloves' Camera > Factory New >
    -- Left Arm, or Sawed-Off whose weapon parts sit under a nested model),
    -- wrap all BaseParts into a fresh Model so bounding-box + parenting work.
    if not clone:IsA("Model") then
        local wrap = Instance.new("Model")
        wrap.Name = "PreviewWrap"
        for _, d in ipairs(clone:GetDescendants()) do
            if d:IsA("BasePart") then d.Parent = wrap end
        end
        clone:Destroy()
        clone = wrap
    end
    -- If clone is a Model but has zero BaseParts (empty container), bail.
    do
        local hasPart = false
        for _, d in ipairs(clone:GetDescendants()) do
            if d:IsA("BasePart") then hasPart = true; break end
        end
        if not hasPart then clone:Destroy(); return end
    end
    for _, part in ipairs(clone:GetDescendants()) do
        if part:IsA("BasePart") then
            local n = part.Name
            if n == "Left Arm" or n == "Right Arm" or n == "HumanoidRootPart"
                or n == "Hitbox" or n == "BoundingBox" then
                part.Transparency = 1
            end
            part.CanCollide = false; part.Anchored = true
        end
    end
    pcall(function()
        local sf = SkinsFolder:FindFirstChild(weapon)
        local sk = sf and sf:FindFirstChild(skin)
        local src = sk and sk:FindFirstChild("Camera") and sk.Camera:FindFirstChild("Factory New")
        if not src then return end
        local wf = clone:FindFirstChild("Weapon") or clone
        for _, p in ipairs(wf:GetDescendants()) do
            if p:IsA("BasePart") then
                local ns = src:FindFirstChild(p.Name)
                if ns then
                    local ex = p:FindFirstChildOfClass("SurfaceAppearance"); if ex then ex:Destroy() end
                    local c = ns:Clone(); c.Name = "SurfaceAppearance"; c.Parent = p
                end
            end
        end
    end)
    clone.Parent = SkinPreview.vp
    SkinPreview.model = clone
    -- Visible bounding box: ignore invisible collision/rig parts (they were
    -- set to Transparency=1 above) so the model center matches what the
    -- player actually sees, not the invisible hitbox that skews the AABB.
    local function _visBBox(model)
        local minP, maxP
        for _, p in ipairs(model:GetDescendants()) do
            if p:IsA("BasePart") and p.Transparency < 1 then
                local cf, sz = p.CFrame, p.Size
                for dx=-1,1,2 do for dy=-1,1,2 do for dz=-1,1,2 do
                    local w = (cf * CFrame.new(dx*sz.X/2, dy*sz.Y/2, dz*sz.Z/2)).Position
                    if not minP then minP = w; maxP = w
                    else
                        minP = Vector3.new(math.min(minP.X,w.X), math.min(minP.Y,w.Y), math.min(minP.Z,w.Z))
                        maxP = Vector3.new(math.max(maxP.X,w.X), math.max(maxP.Y,w.Y), math.max(maxP.Z,w.Z))
                    end
                end end end
            end
        end
        if not minP then return CFrame.new(), Vector3.new() end
        return CFrame.new((minP + maxP) * 0.5), (maxP - minP)
    end
    local cf0, size = _visBBox(clone)
    if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
    local offset = -cf0.Position
    for _, p in ipairs(clone:GetDescendants()) do
        if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end
    end
    local isKnife = KNIVES[weapon] == true
    if isKnife then
        -- Knives: rotate so the longest axis points UP (vertical showcase),
        -- then recenter. Auto-spin uses the same logic as other weapons.
        local rot = CFrame.new()
        if size.X >= size.Y and size.X >= size.Z then
            rot = CFrame.Angles(0, 0, math.rad(90))
        elseif size.Z >= size.Y and size.Z >= size.X then
            rot = CFrame.Angles(math.rad(-90), 0, 0)
        end
        for _, p in ipairs(clone:GetDescendants()) do
            if p:IsA("BasePart") then p.CFrame = rot * p.CFrame end
        end
        -- Recenter after rotation using visible bbox.
        cf0, size = _visBBox(clone)
        if size.Magnitude == 0 then cf0, size = clone:GetBoundingBox() end
        offset = -cf0.Position
        for _, p in ipairs(clone:GetDescendants()) do
            if p:IsA("BasePart") then p.CFrame = p.CFrame + offset end
        end
        SkinPreview.rotX = -10
        SkinPreview.rotY = 0
        SkinPreview.spin = true  -- <<<< knives now auto-rotate 360° like others
    else
        SkinPreview.rotX = -10
        SkinPreview.spin = true
    end
    SkinPreview.focus = Vector3.new(0, 0, 0)
    -- Per-weapon size tuning.
    local maxDim = math.max(size.X, size.Y, size.Z)
    local mult
    if isKnife then
        mult = 0.845  -- knives ~30% smaller than before (was 0.65)
    elseif maxDim > 6 then
        mult = 0.945  -- rifles/snipers
    elseif maxDim > 3 then
        mult = 1.08   -- SMGs/pistols
    else
        mult = 1.40   -- tiny models: gloves
    end
    SkinPreview.dist = math.max(2.0, maxDim * mult)
    if SkinPreview.title then
        SkinPreview.title.Text = tostring(weapon) .. "  ·  " .. tostring(skin)
    end
    SkinPreview.gui.Enabled = true
end

-- Follow the main Eclipse window (position + visibility). If the main GUI is
-- hidden the preview hides with it; when Skins tab isn't active it also hides.
-- RenderStepped position follow: glues to the main window without lag.
-- Heartbeat + change detection: only touches the frame when Main moves.
do
    local _lastX, _lastY = -1, -1
    table.insert(UnloadConnections, RunService.Heartbeat:Connect(function()
        if not (SkinPreview.gui and SkinPreview.gui.Enabled and SkinPreview.frame) then return end
        local main
        pcall(function() main = Library.Main or (Library.ScreenGui and Library.ScreenGui:FindFirstChild("Main", true)) end)
        if main and main.AbsolutePosition then
            local p, s = main.AbsolutePosition, main.AbsoluteSize
            local nx, ny = p.X + s.X + 6, p.Y
            if nx ~= _lastX or ny ~= _lastY then
                _lastX, _lastY = nx, ny
                SkinPreview.frame.Position = UDim2.fromOffset(nx, ny)
            end
        end
    end))
end

-- Slow-path: enable/disable + destroy on unload.
task.spawn(function()
    local _lastState = nil
    while scriptRunning do
        if SkinPreview.gui and SkinPreview.frame then
            local menuOpen = false
            pcall(function() menuOpen = Library.Toggled ~= false end)
            local onSkins = false
            pcall(function()
                local cur = rawget(Library, "ActiveTab") or Library.ActiveTab
                if cur and Tabs.Skins and cur == Tabs.Skins then onSkins = true end
            end)
            local shouldShow = menuOpen and onSkins and Config.Skins.SkinChangerEnabled
                and (SkinPreview.model ~= nil)
            -- Edge-triggered: only touch GUI.Enabled when the state changes,
            -- otherwise re-assigning the same value causes visible flicker.
            if shouldShow ~= _lastState then
                _lastState = shouldShow
                if shouldShow then
                    SkinPreview.gui.Enabled = true
                else
                    _skinPreviewClose()
                end
            end
        end
        task.wait(0.1)
    end
    _skinPreviewDestroy()
end)




function CreateSkinDropdown(weapon, section)
    if not SkinsFolder then return end
    local folder = SkinsFolder:FindFirstChild(weapon); if not folder then return end
    local opts = {"Vanilla"}
    local _seen = { Vanilla = true }
    for _, s in ipairs(folder:GetChildren()) do
        local n = s and s.Name
        if n and n ~= "" and not _seen[n] then _seen[n] = true; table.insert(opts, n) end
    end
    if #opts <= 1 then return end
    pcall(table.sort, opts, function(a, b)
        if a == b then return false end
        if a == "Vanilla" then return true end
        if b == "Vanilla" then return false end
        return tostring(a) < tostring(b)
    end)
    if Config.Skins.SelectedSkins[weapon] == "" then Config.Skins.SelectedSkins[weapon] = nil end
    local defaultSkin = Config.Skins.SelectedSkins[weapon]
    if defaultSkin and not table.find(opts, defaultSkin) then defaultSkin = nil end
    if not defaultSkin then
        defaultSkin = opts[2]
        Config.Skins.SelectedSkins[weapon] = defaultSkin
    end
    SafeAddDropdown(section, "Skin_"..weapon, { Text=weapon, Options=opts,
        Default=defaultSkin or "Vanilla",
        Callback=function(v)
            if not Config.Skins.SkinChangerEnabled and not _EclipseConfigLoading then
                pcall(function() Options["Skin_"..weapon]:SetValue(Config.Skins.SelectedSkins[weapon] or "Vanilla") end)
                return
            end
            if v == "Vanilla" or v == "None" then Config.Skins.SelectedSkins[weapon] = nil else Config.Skins.SelectedSkins[weapon] = v end
            if v == "Vanilla" or v == "None" then
                pcall(_skinPreviewClose)
                pcall(_restoreWeaponSkinRuntime, weapon)
                if Config.Skins.SkinChangerEnabled and IsAlive() then
                    for _, obj in ipairs(Camera:GetChildren()) do
                        local skinName = Config.Skins.SelectedSkins[obj.Name]
                        if skinName then pcall(applyWeaponSkin, obj, skinName) end
                    end
                    pcall(_applySelectedGloveSkin)
                    pcall(_applyHUDKnife, true)
                end
                return
            end
            -- Skin preview now runs for gloves too (falls back to the skin's
            -- own Camera model when there's no matching weapon model).
            pcall(SetSkinPreview, weapon)
            if Config.Skins.SkinChangerEnabled and IsAlive() then
                for _, obj in ipairs(Camera:GetChildren()) do
                    if obj.Name == weapon then pcall(applyWeaponSkin, obj, v) end
                end
                pcall(_applyHUDKnife, true)
            end
            -- Real-time apply: if the weapon is a glove family, immediately
            -- reapply the new skin on the currently-equipped viewmodel arms
            -- without needing to re-equip.
            if (GLOVES[weapon] or weapon == "Sports Gloves") and IsAlive() then
                pcall(function()
                    local sf = SkinsFolder:FindFirstChild(weapon); if not sf then return end
                    local st = sf:FindFirstChild(v)
                    local src = st and st:FindFirstChild("Camera") and st.Camera:FindFirstChild("Factory New")
                    if not src then return end
                    for _, obj in ipairs(Camera:GetChildren()) do
                        for _, side in ipairs({"Left Arm","Right Arm"}) do
                            local arm = obj:FindFirstChild(side)
                            local s   = src:FindFirstChild(side)
                            if arm and s then
                                local gm = arm:FindFirstChild("Glove")
                                if gm and _applySkinSourceToPart then
                                    _applySkinSourceToPart(gm, s)
                                end
                            end
                        end
                    end
                end)
            end
        end })
    -- Register for global skin-changer lock.
    if Options and Options["Skin_"..weapon] then
        table.insert(_skinLockedUI, Options["Skin_"..weapon])
    end
end

