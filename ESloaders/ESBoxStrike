function _restoreWeaponSkinRuntime(weapon)
    local isGlove = GLOVES[weapon] or tostring(weapon) == "Sports Gloves"
    for target in pairs(SkinSystem._skinRestore or {}) do
        if _targetBelongsToWeapon(target, weapon) then _restoreSkinTarget(target) end
    end
    if isGlove then pcall(_clearGloveSkinRuntime); return end
    pcall(function()
        for _, obj in ipairs(Camera:GetChildren()) do
            if obj.Name == weapon or isGlove then
                obj:SetAttribute("SkinApplied", nil)
                for _, d in ipairs(obj:GetDescendants()) do
                    if isGlove and d.Name == "Glove" and d:IsA("BasePart") then
                        _restoreGloveSurfaceOnly(d)
                    else
                        d:SetAttribute("SkinApplied", nil)
                        if _targetBelongsToWeapon(d, weapon) then d:SetAttribute("EclipseSkinSource", nil) end
                    end
                end
            end
        end
    end)
end

function _clearGloveSkinRuntime()
    pcall(function()
        for _, armObj in ipairs(Camera:GetChildren()) do
            local left, right = armObj:FindFirstChild("Left Arm"), armObj:FindFirstChild("Right Arm")
            if left or right then
                for _, side in ipairs({"Left Arm", "Right Arm"}) do
                    local arm = armObj:FindFirstChild(side)
                    local glove = arm and arm:FindFirstChild("Glove")
                    if glove and glove:IsA("BasePart") then
                        _restoreGloveSurfaceOnly(glove, side, armObj)
                    end
                end
            end
        end
    end)
end



function _clearSkinChangerRuntime()
    local function _sweep()
        pcall(_restoreAppliedSkins)
        pcall(_clearGloveSkinRuntime)

        
        
        SkinSystem.gloveScale = 1.0

        
        pcall(function()
            for _, obj in ipairs(Camera:GetChildren()) do
                obj:SetAttribute("SkinApplied", nil)
                obj:SetAttribute("EclipseSkinSource", nil)
                for _, d in ipairs(obj:GetDescendants()) do
                    local hadSkinSource = d:GetAttribute("EclipseSkinSource") ~= nil
                    d:SetAttribute("SkinApplied", nil)
                    if d:IsA("BasePart") and hadSkinSource then
                        if d.Name == "Glove" then
                            _restoreGloveSurfaceOnly(d)
                        elseif SkinSystem._skinRestore and SkinSystem._skinRestore[d] then
                            _restoreSkinTarget(d)
                        else
                            for _, ch in ipairs(d:GetChildren()) do
                                if ch:IsA("SurfaceAppearance") and (ch:GetAttribute("EclipseSkinSurface") or ch:GetAttribute("EclipseSurfaceSource")) then pcall(function() ch:Destroy() end) end
                            end
                            d:SetAttribute("EclipseSkinSource", nil)
                        end
                    end
                end
            end
        end)

        

        if not Config.Skins.SkinChangerEnabled then
            pcall(function()
                for _, obj in ipairs(Camera:GetChildren()) do
                    for _, d in ipairs(obj:GetDescendants()) do
                        if d:GetAttribute("EclipseAttached") then
                            pcall(function() d:Destroy() end)
                        end
                    end
                end
            end)
        end
    end
    _sweep()
    pcall(restoreOriginalKnife)

    
    for _, d in ipairs({0.1, 0.35, 0.8, 1.6, 2.8}) do
        task.delay(d, function()
            if Config.Skins.SkinChangerEnabled then return end
            pcall(_sweep)
        end)
    end
end

function _findDefaultGloveTemplate(side)
    local assets = ReplicatedSt and ReplicatedSt:FindFirstChild("Assets")
    local weapons = assets and assets:FindFirstChild("Weapons")
    if not weapons then return nil end
    local teamName = ""
    pcall(function()
        if LocalPlayer and LocalPlayer.Team then teamName = tostring(LocalPlayer.Team.Name) end
    end)
    local first = (teamName == "Terrorists" or teamName == "T") and "T Glove" or "CT Glove"
    local candidates = { first, first == "T Glove" and "CT Glove" or "T Glove" }
    for _, folderName in ipairs(candidates) do
        local folder = weapons:FindFirstChild(folderName)
        if folder then
            local arm = folder:FindFirstChild(side or "", true)
            if arm then
                if arm:IsA("SurfaceAppearance") then return arm end
                local glove = arm:FindFirstChild("Glove")
                if glove and glove:IsA("BasePart") then return glove end
                for _, d in ipairs(arm:GetDescendants()) do
                    if d.Name == "Glove" and d:IsA("BasePart") then return d end
                end
                local sa = arm:FindFirstChildOfClass("SurfaceAppearance")
                if sa then return sa end
            end
            local glove = folder:FindFirstChild("Glove", true)
            if glove and glove:IsA("BasePart") then return glove end
        end
    end
    return nil
end

function _restoreDefaultGloveVisual(glove, side)
    if not (glove and glove:IsA("BasePart")) then return false end
    local src = _findDefaultGloveTemplate(side)
    if not src then return false end
    local restored = false
    pcall(function()
        local surfaces = {}
        if src:IsA("SurfaceAppearance") then
            table.insert(surfaces, src)
        else
            for _, ch in ipairs(src:GetChildren()) do
                if ch:IsA("SurfaceAppearance") then table.insert(surfaces, ch) end
            end
        end
        if #surfaces > 0 then
            for _, ch in ipairs(glove:GetChildren()) do
                if ch:IsA("SurfaceAppearance") then ch:Destroy() end
            end
            for _, old in ipairs(surfaces) do
                local c = old:Clone(); c.Parent = glove
            end
            restored = true
        end
        if src:IsA("MeshPart") and glove:IsA("MeshPart") then
            glove.TextureID = src.TextureID
            restored = true
        end
        if src:IsA("BasePart") then
            glove.Color = src.Color
            glove.Material = src.Material
            restored = true
        end
    end)
    return restored
end

_restoreGloveSurfaceOnly = function(glove, side)
    if not (glove and glove:IsA("BasePart")) then return end
    if not side then pcall(function() if glove.Parent then side = tostring(glove.Parent.Name) end end) end
    if SkinSystem._skinRestore and SkinSystem._skinRestore[glove] then
        _restoreSkinTarget(glove)
    else
        pcall(function()
            local hadEclipseSkin = glove:GetAttribute("EclipseSkinSource") ~= nil or glove:GetAttribute("SkinApplied") ~= nil
            local restoredDefault = false
            if hadEclipseSkin then restoredDefault = _restoreDefaultGloveVisual(glove, side) end
            if hadEclipseSkin and not restoredDefault then
                for _, ch in ipairs(glove:GetChildren()) do
                    if ch:IsA("SurfaceAppearance") and (ch:GetAttribute("EclipseSkinSurface") or ch:GetAttribute("EclipseSurfaceSource")) then ch:Destroy() end
                end
            end
            glove:SetAttribute("EclipseSkinSource", nil)
            glove:SetAttribute("SkinApplied", nil)
        end)
    end
end

