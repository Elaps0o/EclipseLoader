    rec = {
        baseName = cleanText,
        nameText = restoreText,
        nameTextTransparency = nameLbl.TextTransparency,
        nameTextStrokeTransparency = nameLbl.TextStrokeTransparency,
        nameLblRef = nameLbl,
        iconLabelImage = (iconLbl and (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.Image) or nil,
        iconImageColor3 = (iconLbl and (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ImageColor3) or nil,
        iconImageRectOffset = (iconLbl and (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ImageRectOffset) or nil,
        iconImageRectSize = (iconLbl and (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ImageRectSize) or nil,
        iconScaleType = (iconLbl and (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ScaleType) or nil,
        iconImageTransparency = (iconLbl and iconLbl.ImageTransparency) or nil,
        iconLabelVisible = (iconLbl and iconLbl.Visible) or nil,
        iconLabelRef = iconLbl,
        iconViewportTransparency = (iconViewport and iconViewport.BackgroundTransparency) or nil,
        iconViewportVisible = (iconViewport and iconViewport.Visible) or nil,
