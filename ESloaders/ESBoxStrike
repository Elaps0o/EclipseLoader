function _espDrawArrow(data, root)
    local arrow = ensureESPArrow(data)
    if not arrow then return end
    local cf  = Camera.CFrame
    local rel = cf:PointToObjectSpace(root.Position)
    local ang
    if rel.Z > 0 then
        ang = math.atan2(-rel.X, rel.Z)
    else
        ang = math.atan2(rel.X, -rel.Z)
    end
    local vs = Camera.ViewportSize
    local cx2, cy2 = vs.X/2, vs.Y/2
    local rad = math.min(cx2, cy2) - 80
    local tipX = cx2 + math.sin(ang) * rad
    local tipY = cy2 - math.cos(ang) * rad
    local size = 12
    local dx, dy = math.sin(ang), -math.cos(ang)
    local perpX, perpY = -dy, dx
    local baseX = tipX - dx * size * 1.8
    local baseY = tipY - dy * size * 1.8
    arrow.PointA = Vector2.new(tipX, tipY)
    arrow.PointB = Vector2.new(baseX + perpX*size, baseY + perpY*size)
    arrow.PointC = Vector2.new(baseX - perpX*size, baseY - perpY*size)
    arrow.Color = Config.ESP.ArrowsColor
    arrow.Filled = true
    arrow.Transparency = 1
    arrow.Visible = true
end

function _espDrawCornerBox(data, plr, L, R, T, B, cW, cH)
    local col = IsAlly(plr) and Config.ESP.AllyBoxColor or Config.ESP.BoxColor
    local ln = data.CornerLines
    ln[1].From=Vector2.new(L,T); ln[1].To=Vector2.new(L+cW,T); ln[1].Color=col; ln[1].Visible=true
    ln[2].From=Vector2.new(L,T); ln[2].To=Vector2.new(L,T+cH); ln[2].Color=col; ln[2].Visible=true
    ln[3].From=Vector2.new(R,T); ln[3].To=Vector2.new(R-cW,T); ln[3].Color=col; ln[3].Visible=true
    ln[4].From=Vector2.new(R,T); ln[4].To=Vector2.new(R,T+cH); ln[4].Color=col; ln[4].Visible=true
    ln[5].From=Vector2.new(L,B); ln[5].To=Vector2.new(L+cW,B); ln[5].Color=col; ln[5].Visible=true
    ln[6].From=Vector2.new(L,B); ln[6].To=Vector2.new(L,B-cH); ln[6].Color=col; ln[6].Visible=true
    ln[7].From=Vector2.new(R,B); ln[7].To=Vector2.new(R-cW,B); ln[7].Color=col; ln[7].Visible=true
    ln[8].From=Vector2.new(R,B); ln[8].To=Vector2.new(R,B-cH); ln[8].Color=col; ln[8].Visible=true
end

function _espNum(v)
    if type(v) == "number" then return v end
    if type(v) == "string" then return tonumber(v) end
    return nil
end

function _espReadNumber(inst, keys)
    if not inst then return nil end
    for _, key in ipairs(keys) do
        local okA, av = pcall(function() return inst:GetAttribute(key) end)
        local n = okA and _espNum(av) or nil
        if n ~= nil then return n end
        local obj = inst:FindFirstChild(key, true)
        if obj and (obj:IsA("NumberValue") or obj:IsA("IntValue")) then
            n = _espNum(obj.Value)
            if n ~= nil then return n end
        end
    end
    return nil
end

function _espHealthValues(plr, char, hum)
    local hpKeys = {"Health","HP","CurrentHealth","CurrentHP","health","hp"}
    local maxKeys = {"MaxHealth","MaxHP","HealthMax","Max","maxHealth","maxhp"}
    local hum2 = hum or (char and char:FindFirstChildOfClass("Humanoid"))
    local hp, mx
    -- Prefer the LIVE humanoid unconditionally when it exists (fixes empty-bar
    -- bug where a stale attribute Health=0 masked a full-HP humanoid).
    if hum2 then
        hp = _espNum(hum2.Health)
        mx = _espNum(hum2.MaxHealth)
    end
    -- Only fall back to attributes if humanoid did not provide sane values.
    if not hp then
        hp = _espReadNumber(char, hpKeys) or _espReadNumber(plr, hpKeys)
    end
    if not mx or mx <= 0 then
        mx = _espReadNumber(char, maxKeys) or _espReadNumber(plr, maxKeys) or mx
    end
    if not hp then return nil, nil end
    if not mx or mx <= 0 then mx = math.max(100, hp) end
    -- Guarantee at least 1 HP shown when humanoid reports Alive but Health
    -- momentarily reads 0 mid-frame (respawn/teleport races).
    if hp <= 0 and hum2 and hum2:GetState() ~= Enum.HumanoidStateType.Dead then
        hp = 1
    end
    return math.clamp(hp, 0, mx), mx
end

function _espDrawHealth(data, hp, maxHp, L, R, T, B, height)
    local hSide = _espSlotSide("Health")
    local bx = (hSide == "Right") and (R + 10) or (L - 10)
    local pct = math.clamp((hp or 0) / math.max(maxHp or 100, 1), 0, 1)
    data.HealthBg.From = Vector2.new(bx, T); data.HealthBg.To = Vector2.new(bx, B); data.HealthBg.Visible = true
    data.HealthFill.Visible = false
    local maxSegs = #data.HealthSegments
    local segments = math.clamp(math.floor(height / 4), 6, maxSegs)
    for i = 1, maxSegs do
        local seg = data.HealthSegments[i]
        if i <= segments then
            local a = (i - 1) / segments
            local b = i / segments
            seg.From = Vector2.new(bx, B - (height * a))
            seg.To = Vector2.new(bx, B - (height * b) + 1)
            seg.Color = GetHealthColor(pct)
            seg.Thickness = (height < 40) and 2 or 3
            seg.Transparency = 1
            seg.Visible = pct > 0 and a < pct
        else
            seg.Visible = false
        end
    end
    if data.HealthTicks then
        local showTicks = height >= 48
        local tickX1, tickX2 = bx - 4, bx + 4
        for i, tick in ipairs(data.HealthTicks) do
            if showTicks then
                local frac = (i == 1) and (1/3) or (2/3)
                local ty = B - (height * frac)
                tick.From = Vector2.new(tickX1, ty)
                tick.To   = Vector2.new(tickX2, ty)
                tick.Transparency = 1
                tick.Visible = true
            else
                tick.Visible = false
            end
        end
    end
    -- Numeric HP label removed per user request (bars only).
    data.HealthText.Visible = false

end


function _espDrawSkeleton(data, char)
    local col = Config.ESP.SkeletonColor
    local shown = {}
    for i, bone in ipairs(SkeletonBones) do
        local ln = data.Skeleton[i]
        local a = char:FindFirstChild(bone[1])
        local b = char:FindFirstChild(bone[2])
        if a and b and a:IsA("BasePart") and b:IsA("BasePart") then
            local pa, oa = Camera:WorldToViewportPoint(a.Position)
            local pb, ob = Camera:WorldToViewportPoint(b.Position)
            if oa and ob then
                ln.From = Vector2.new(pa.X, pa.Y)
                ln.To   = Vector2.new(pb.X, pb.Y)
                ln.Color = col; ln.Visible = true
                shown[i] = true
            end
        end
    end
    for i, ln in ipairs(data.Skeleton) do if not shown[i] then ln.Visible = false end end
end

function _espGetWeaponName(plr)
    local ok, attr = pcall(function() return plr:GetAttribute("CurrentEquipped") end)
    if not (ok and type(attr) == "string") then return nil end
    local okj, decoded = pcall(function() return HttpService:JSONDecode(attr) end)
    if okj and type(decoded) == "table" and decoded.Name then return tostring(decoded.Name) end
    return attr
end

-- Read equipped weapon ammo for an enemy player. Returns (cur, max) or nil.
-- Priority: player attributes → character tool attributes → weapon module MagazineSize.
function _espGetPlayerAmmo(plr, weaponName)
    local function num(v) return (type(v) == "number") and v or tonumber(v) end
    local cur, mx
    local ok1 = pcall(function()
        cur = num(plr:GetAttribute("Ammo") or plr:GetAttribute("Bullets") or plr:GetAttribute("CurrentAmmo") or plr:GetAttribute("Clip") or plr:GetAttribute("AmmoInClip"))
        mx  = num(plr:GetAttribute("MaxAmmo") or plr:GetAttribute("Magazine") or plr:GetAttribute("MagazineSize") or plr:GetAttribute("ClipSize"))
    end); if not ok1 then cur, mx = nil, nil end
    if not cur then
        local char = GetCharacter(plr) or plr.Character
        cur = _espReadNumber(char, {"Ammo","Bullets","CurrentAmmo","Clip","AmmoInClip"})
        mx  = mx or _espReadNumber(char, {"MaxAmmo","Magazine","MagazineSize","ClipSize"})
    end
    if not cur then
        local char = GetCharacter(plr) or plr.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if tool then
            cur = num(tool:GetAttribute("Ammo") or tool:GetAttribute("Bullets") or tool:GetAttribute("CurrentAmmo") or tool:GetAttribute("Clip") or tool:GetAttribute("AmmoInClip"))
            mx  = mx or num(tool:GetAttribute("MaxAmmo") or tool:GetAttribute("MagazineSize") or tool:GetAttribute("ClipSize"))
        end
    end
    if not mx and weaponName and _weaponModule then
        local mod = _weaponModule(weaponName)
        if mod then
            pcall(function()
                mx = num(mod:GetAttribute("MagazineSize") or mod:GetAttribute("Magazine") or mod:GetAttribute("MaxAmmo"))
            end)
        end
    end
    if not cur or not mx or mx <= 0 then return nil end
    return math.max(0, cur), mx
end

function _espHideAmmo(data)
    if data.TagAmmoBg then data.TagAmmoBg.Visible = false end
    if data.TagAmmoFill then data.TagAmmoFill.Visible = false end
end

function _espDrawAmmo(data, L, R, T, cx, plr, weaponName)
    local cur, mx = _espGetPlayerAmmo(plr, weaponName)
    if not cur or not mx or mx <= 0 then _espHideAmmo(data); return end
    local pct = math.clamp(cur / mx, 0, 1)
    local width = math.clamp((R - L) + 28, 42, 118)
    local x1, x2 = cx - width / 2, cx + width / 2
    local y = T - 8
    data.TagAmmoBg.From = Vector2.new(x1, y)
    data.TagAmmoBg.To = Vector2.new(x2, y)
    data.TagAmmoBg.Thickness = 3
    data.TagAmmoBg.Color = Color3.fromRGB(0, 0, 0)
    data.TagAmmoBg.Transparency = 0.55
    data.TagAmmoBg.Visible = true
    data.TagAmmoFill.From = Vector2.new(x1, y)
    data.TagAmmoFill.To = Vector2.new(x1 + width * pct, y)
    data.TagAmmoFill.Thickness = 2
    data.TagAmmoFill.Color = Config.ESP.AmmoColor or Color3.fromRGB(255, 255, 255)
    data.TagAmmoFill.Transparency = 1
    data.TagAmmoFill.Visible = pct > 0.001
end

-- Warmup detector — multi-source (GameState / RoundState / MatchState /
-- Phase attributes on workspace + ReplicatedStorage, Status value, and the
-- MatchLogging / RoundHandler / GameLogic modules). Cached for perf.
local _warmT, _warmVal = 0, false
local _warmModule, _warmModuleT = nil, 0
function _isWarmup()
    local t = tick()
    if t - _warmT < 0.5 then return _warmVal end
    _warmT = t
    local hits = {}
    local function _push(v) if v ~= nil then hits[#hits+1] = tostring(v):lower() end end
    pcall(function() _push(workspace:GetAttribute("GameState")) end)
    pcall(function() _push(workspace:GetAttribute("RoundState")) end)
    pcall(function() _push(workspace:GetAttribute("MatchState")) end)
    pcall(function() _push(workspace:GetAttribute("Phase")) end)
    pcall(function() _push(ReplicatedSt:GetAttribute("GameState")) end)
    pcall(function() _push(ReplicatedSt:GetAttribute("RoundState")) end)
    pcall(function()
        local status = ReplicatedSt:FindFirstChild("Status", true) or ReplicatedSt:FindFirstChild("GameStatus", true)
        if status and (status:IsA("StringValue") or status:IsA("IntValue")) then _push(status.Value) end
    end)
    -- Cache the match/round module so we don't iterate GetDescendants() every tick
    -- (this was the source of the "Identity Money" lag reported by the user).
    if not _warmModule or (t - _warmModuleT) > 8 then
        _warmModuleT = t
        pcall(function()
            for _, name in ipairs({"MatchLogging","RoundHandler","GameLogic"}) do
                local m = ReplicatedSt:FindFirstChild(name, true)
                if m and m:IsA("ModuleScript") then _warmModule = m; break end
            end
        end)
    end
    if _warmModule then
        pcall(function()
            local ok, mod = pcall(require, _warmModule)
            if ok and type(mod) == "table" then
                _push(mod.State); _push(mod.CurrentState); _push(mod.Phase); _push(mod.RoundState)
            end
        end)
    end
    pcall(function() _push(LocalPlayer:GetAttribute("Warmup")) end)
    pcall(function() if LocalPlayer:GetAttribute("BuyMenu") == true then hits[#hits+1] = "warmup" end end)
    local match = false
    for _, s in ipairs(hits) do
        if s:find("warm") or s:find("wait") or s:find("prep") or s:find("freeze")
           or s:find("intermission") or s:find("pregame") or s:find("buy") then
            match = true; break
        end
    end
    _warmVal = match
    return _warmVal
end

-- Draw the premium ESP tag ABOVE the enemy's head.

-- Layout (top → bottom): gradient accent line, weapon name, white ammo bar.
-- The whole tag scales via _espAnimScale() so it grows on ESP enable and
-- collapses on disable. When WeaponName is enabled the tag is enlarged.
function _espDrawTag(data, L, R, T, cx, plr, dist, weaponName, B)
    local s = _espAnimScale()
    if s <= 0.001 then
        data.TagBg.Visible=false
        for _,l in pairs(data.TagBorder) do l.Visible=false end
        for _,l in pairs(data.TagGrad)   do l.Visible=false end
        data.TagAmmoBg.Visible=false; data.TagAmmoFill.Visible=false
        data.TagText.Visible=false
        return 0
    end
    local hasWeapon = Config.ESP.WeaponName and weaponName and weaponName ~= ""
    local baseW = math.max(130, math.min(210, (R - L) + 40))
    local baseH = hasWeapon and 34 or 26
    local width  = math.floor(baseW * (0.6 + 0.4 * math.min(1, s)))
    local height = math.floor(baseH * (0.6 + 0.4 * math.min(1, s)))
    local x  = math.floor(cx - width / 2)
    -- Container fica ABAIXO do jogador para não atrapalhar a visão da cabeça.
    local y  = math.floor((B or (T + 120)) + 10)
    local trBase = 1 * math.min(1, s)  -- Drawing transparency: 1 = opaque

    -- Background + border
    data.TagBg.Size = Vector2.new(width, height)
    data.TagBg.Position = Vector2.new(x, y)
    data.TagBg.Filled = true; data.TagBg.Color = Color3.fromRGB(15,15,20)
    data.TagBg.Transparency = 0.72 * math.min(1, s); data.TagBg.Visible = true
    local tl, tr, bl, br = Vector2.new(x,y), Vector2.new(x+width,y), Vector2.new(x,y+height), Vector2.new(x+width,y+height)
    data.TagBorder[1].From, data.TagBorder[1].To = tl, tr
    data.TagBorder[2].From, data.TagBorder[2].To = tr, br
    data.TagBorder[3].From, data.TagBorder[3].To = br, bl
    data.TagBorder[4].From, data.TagBorder[4].To = bl, tl
    for _, l in ipairs(data.TagBorder) do l.Transparency = 0.85 * math.min(1,s); l.Color = Color3.fromRGB(70,70,78); l.Visible = true end
    -- Gradient top line (accent).
    local segs = ESP_TAG_GRAD_SEGS
    local segW = width / segs
    local a, b = ESP_TAG_GRAD_A, ESP_TAG_GRAD_B
    for i = 1, segs do
        local t = (i - 0.5) / segs
        local ln = data.TagGrad[i]
        ln.From = Vector2.new(x + (i-1)*segW, y + 1)
        ln.To   = Vector2.new(x + i*segW,      y + 1)
        ln.Color = Color3.new(a.R + (b.R-a.R)*t, a.G + (b.G-a.G)*t, a.B + (b.B-a.B)*t)
        ln.Thickness = 2; ln.Transparency = trBase; ln.Visible = true
    end
    -- Weapon name goes on TOP (just under the gradient).
    local topTextY = y + 5
    local nameParts = {}
    if Config.ESP.Name then table.insert(nameParts, plr.Name) end
    if Config.ESP.Distance then table.insert(nameParts, math.floor(dist) .. "m") end
    -- Money is rendered on its own Drawing (fixed green) only during warmup.
    -- Read from player attribute, leaderstats.Money/Cash, or character attribute.
    local moneyStr = nil
    if Config.ESP.IdentifyMoney and _isWarmup and _isWarmup() then
        local m = tonumber(plr:GetAttribute("Money")) or tonumber(plr:GetAttribute("Cash"))
        if not m then
            local ls = plr:FindFirstChild("leaderstats")
            if ls then
                local v = ls:FindFirstChild("Money") or ls:FindFirstChild("Cash") or ls:FindFirstChild("$")
                if v then m = tonumber(v.Value) end
            end
        end
        if not m and plr.Character then
            m = tonumber(plr.Character:GetAttribute("Money")) or tonumber(plr.Character:GetAttribute("Cash"))
        end
        if m then
            moneyStr = "$" .. tostring(math.floor(m)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
        end
    end
    _espHideAmmo(data)
    -- Weapon on top line, name/distance beneath it (still above ammo).
    local lines = {}
    if hasWeapon then table.insert(lines, tostring(weaponName):upper()) end
    if #nameParts > 0 then table.insert(lines, table.concat(nameParts, "  •  ")) end
    data.TagText.Size = hasWeapon and 13 or 12
    data.TagText.Text = table.concat(lines, "\n")
    data.TagText.Position = Vector2.new(cx, topTextY)
    data.TagText.Color = Color3.fromRGB(240,240,245)
    data.TagText.Transparency = trBase
    data.TagText.Visible = #lines > 0
    -- Money text: fixed green, positioned just below the info text, warmup-only.
    if moneyStr then
        if not data.MoneyText then
            data.MoneyText = Drawing.new("Text")
            data.MoneyText.Font=2; data.MoneyText.Size=12; data.MoneyText.Outline=true
            data.MoneyText.OutlineColor=Color3.new(0,0,0); data.MoneyText.Center=true
        end
        data.MoneyText.Text = moneyStr
        data.MoneyText.Color = Color3.fromRGB(60,220,90)
        data.MoneyText.Transparency = trBase
        local lineH = (data.TagText.Size or 12) + 2
        data.MoneyText.Position = Vector2.new(cx, topTextY + lineH * #lines + 8)
        data.MoneyText.Visible = true
    elseif data.MoneyText then
        data.MoneyText.Visible = false
    end
    return height + 12
end


-- ---------------- Per-element ESP label positioning ---------------------
-- Each element (Name/Distance/Weapon/Health) cycles through preset sides.
-- Labels that share the same side are stacked with a small gap so they
-- never overlap. The preview panel and the world ESP both use this layout.
ESP_SLOT_CYCLES = {
    Name     = {"Top","Bottom","Left","Right"},
    Distance = {"Top","Bottom","Left","Right"},
    Weapon   = {"Bottom","Top","Left","Right"},
    Health   = {"Left","Right"},
}

function _espSlotSide(kind)
    local cyc = ESP_SLOT_CYCLES[kind]; if not cyc then return "Top" end
    local i = (Config.ESP.SlotPos and Config.ESP.SlotPos[kind]) or 1
    return cyc[((i-1) % #cyc) + 1]
end

function _espIsSlotDefault(kind)
    return ((Config.ESP.SlotPos and Config.ESP.SlotPos[kind]) or 1) == 1
end

-- Build 2D anchor points for Name/Distance/Weapon labels. Stacks siblings.
function _espTextLayout(L, R, T, B, cx)
    local buckets = { Top={}, Bottom={}, Left={}, Right={} }
    -- Order matters: labels enter their bucket in this order and stack outward.
    for _, kind in ipairs({"Name","Distance","Weapon"}) do
        table.insert(buckets[_espSlotSide(kind)], kind)
    end
    local out = {}
    for side, list in pairs(buckets) do
        for i, kind in ipairs(list) do
            local step = (i-1) * 16
            local x, y
            if side == "Top"    then x, y = cx,        T - 18 - step
            elseif side == "Bottom" then x, y = cx,    B + 18 + step
            elseif side == "Left"   then x, y = L - 55 - step, (T + B) * 0.5 + (i-1) * 16
            else                          x, y = R + 55 + step, (T + B) * 0.5 + (i-1) * 16
            end
            out[kind] = { side=side, x=x, y=y }
        end
    end
    return out
end

-- (Tier bars removed by user request; weapon label now clean & centered.)
function _espWeaponTierBars(_) return "" end

function _espProcessPlayer(plr, myRoot, center)

    if Config.TeamCheck and IsAlly(plr) then
        local old = ESPObjects[plr]
        if old then hideESP(old) end
        return nil
    end
    local char = GetCharacter(plr)
    local data = ESPObjects[plr]
    if not char then if data then hideESP(data) end; return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not root or not head or not hum then if data then hideESP(data) end; return nil end
    local hp, maxHp = _espHealthValues(plr, char, hum)
    if not hp or hp <= 0 then if data then hideESP(data) end; return nil end

    local dist = (myRoot.Position - root.Position).Magnitude
    local maxD = Config.ESP.MaxDistance
    if Config.Aimbot.Enabled then maxD = math.max(maxD, 500) end
    if dist > maxD then if data then hideESP(data) end; return nil end

    if not data then
        data = createESPObjects()
        ESPObjects[plr] = data
    end

    local hP, hOn = Camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
    local fP, fOn = Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
    local onScreen = hOn and fOn and hP.Z > 0 and fP.Z > 0
    if not onScreen then
        hideESP(data)
        if Config.ESP.Arrows then _espDrawArrow(data, root) end
        return nil
    end

    local height  = math.abs(hP.Y - fP.Y); local width = height * 0.6
    local cx = hP.X; local cy = (hP.Y + fP.Y)/2
    local L, R = cx - width/2, cx + width/2
    local T, B = cy - height/2, cy + height/2

    -- Clamp box to viewport so partially off-screen players don't draw
    -- garbage lines snapping to screen corners.
    local vs = Camera.ViewportSize
    local margin = 6
    if L < -margin or R > vs.X + margin or T < -margin or B > vs.Y + margin then
        local anyInside = (cx >= 0 and cx <= vs.X and cy >= 0 and cy <= vs.Y)
        if not anyInside then
            hideESP(data)
            if Config.ESP.Arrows then _espDrawArrow(data, root) end
            return nil
        end
        L = math.clamp(L, 0, vs.X); R = math.clamp(R, 0, vs.X)
        T = math.clamp(T, 0, vs.Y); B = math.clamp(B, 0, vs.Y)
    end

    if Config.ESP.CornerBox then
        _espDrawCornerBox(data, plr, L, R, T, B, width*0.25, height*0.25)
    else for _, l in pairs(data.CornerLines) do l.Visible=false end end

    local layout = _espTextLayout(L, R, T, B, cx)
    local weaponName = _espGetWeaponName(plr)

    -- Premium unified tag replaces the individual Name / Distance / Weapon labels.
    local wantTag = Config.ESP.Name or Config.ESP.Distance or Config.ESP.WeaponName or (Config.ESP.IdentifyMoney and _isWarmup and _isWarmup())
    if wantTag then
        _espDrawTag(data, L, R, T, cx, plr, dist, weaponName, B)
        data.NameTag.Visible = false
        data.DistTag.Visible = false
        if data.WeaponTag then data.WeaponTag.Visible = false end
    else
        data.NameTag.Visible = false
        data.DistTag.Visible = false
        if data.WeaponTag then data.WeaponTag.Visible = false end
        if data.TagBg then data.TagBg.Visible = false end
        if data.TagBorder then for _, l in pairs(data.TagBorder) do l.Visible = false end end
        if data.TagGrad then for _, l in pairs(data.TagGrad) do l.Visible = false end end
        _espHideAmmo(data)
        if data.TagText then data.TagText.Visible = false end
        if data.MoneyText then data.MoneyText.Visible = false end
    end

    if Config.ESP.HealthBar and hp and hp > 0 then
        _espDrawHealth(data, hp, maxHp, L, R, T, B, height)
    else
        data.HealthBg.Visible=false; data.HealthFill.Visible=false; data.HealthText.Visible=false
        for _, l in pairs(data.HealthSegments) do l.Visible = false end
        if data.HealthTicks then for _, l in pairs(data.HealthTicks) do l.Visible = false end end
    end

    _espHideAmmo(data)

    if PresenceUsers[plr.UserId] then
        data.Presence.Color = Config.ESP.PresenceColor
        data.Presence.Position = Vector2.new(cx, T - 55)
        data.Presence.Visible = true
    else data.Presence.Visible = false end
    -- (Old individual Name/Distance/Weapon labels replaced by unified tag above.)
    local _unused_layout = layout


    if Config.ESP.HeadDot and data.HeadDot then
        data.HeadDot.Position = Vector2.new(hP.X, hP.Y)
        data.HeadDot.Color = Config.ESP.HeadDotColor
        data.HeadDot.Radius = math.clamp(height * 0.04, 2, 5)
        data.HeadDot.Visible = true
    elseif data.HeadDot then data.HeadDot.Visible = false end

    if Config.ESP.Skeleton and data.Skeleton then
        _espDrawSkeleton(data, char)
    elseif data.Skeleton then for _, l in pairs(data.Skeleton) do l.Visible = false end end

    if data.Arrow then data.Arrow.Visible = false end

    local aimDist = (Vector2.new(hP.X, hP.Y) - center).Magnitude
    return { player=plr, head=head, root=root, hum=hum, dist=dist, aimDist=aimDist }
end

-- ===================== ESP CHAMS (Highlight) =====================
-- One Highlight per enemy character; parented to the character so it follows
-- the rig automatically. FillColor = body tint, OutlineColor = glow rim.
-- Config.ESP.ChamsGlow (0..1) fades the fill toward the outline for a glow feel.
local ChamsHL = setmetatable({}, { __mode = "k" }) -- weak keys on Player
function updateChams()
    local on = Config.GlobalEnable and Config.ESP.Enabled and Config.ESP.Chams
    for plr, hl in pairs(ChamsHL) do
        if not plr.Parent or not on then
            pcall(function() hl:Destroy() end); ChamsHL[plr] = nil
        end
    end
    if not on then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        -- Ally exclusion: Chams NEVER paint teammates, regardless of the
        -- global TeamCheck toggle. Enemy-only visual by design.
        if IsAlly(plr) then
            local old = ChamsHL[plr]
            if old then pcall(function() old:Destroy() end); ChamsHL[plr] = nil end
            continue
        end
        local char = plr.Character
        if not char then
            local old = ChamsHL[plr]
            if old then pcall(function() old:Destroy() end); ChamsHL[plr] = nil end
            continue
        end
        local hl = ChamsHL[plr]
        if not hl or not hl.Parent then
            hl = Instance.new("Highlight")
            hl.Name = "EclipseChams"
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Adornee = char; hl.Parent = char
            ChamsHL[plr] = hl
        else
            if hl.Adornee ~= char then hl.Adornee = char end
        end
        -- Solid full-body fill + crisp WHITE outline (user request).
        hl.FillColor           = Config.ESP.ChamsColor
        hl.OutlineColor        = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency    = 0
        hl.OutlineTransparency = 0
    end
end

function updateESP()
    local wantOn = Config.GlobalEnable and Config.ESP.Enabled
    if wantOn ~= _ESP_ANIM.on then
        _ESP_ANIM.on = wantOn
        _ESP_ANIM.t0 = tick()
    end
    local animScale = _espAnimScale()
    local espOn = wantOn or animScale > 0.001
    local myChar = GetCharacter(LocalPlayer)
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not espOn or not myRoot then
        for _, d in pairs(ESPObjects) do hideESP(d) end
        TargetLine.Visible = false
        return
    end

    local closest, closestDist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local seen = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        seen[plr] = true
        local info = _espProcessPlayer(plr, myRoot, center)
        if info and info.aimDist < closestDist then
            closestDist = info.aimDist
            closest = info
        end
    end

    for p, d in pairs(ESPObjects) do
        if not seen[p] then
            hideESP(d)
            pcall(function()
                for _, l in pairs(d.CornerLines) do l:Remove() end
                for _, l in pairs(d.HealthSegments) do l:Remove() end
                if d.HealthTicks then for _, l in pairs(d.HealthTicks) do l:Remove() end end
                if d.Skeleton then for _, l in pairs(d.Skeleton) do l:Remove() end end
                d.NameTag:Remove(); d.DistTag:Remove()
                d.HealthBg:Remove(); d.HealthFill:Remove(); d.HealthText:Remove()
                d.Presence:Remove()
                if d.WeaponTag then d.WeaponTag:Remove() end
                if d.HeadDot then d.HeadDot:Remove() end
                if d.Arrow then d.Arrow:Remove() end
                if d.TagBg then d.TagBg:Remove() end
                if d.TagBorder then for _, l in pairs(d.TagBorder) do l:Remove() end end
                if d.TagGrad then for _, l in pairs(d.TagGrad) do l:Remove() end end
                if d.TagAmmoBg then d.TagAmmoBg:Remove() end
                if d.TagAmmoFill then d.TagAmmoFill:Remove() end
                if d.TagText then d.TagText:Remove() end
                if d.MoneyText then d.MoneyText:Remove() end

            end)
            ESPObjects[p] = nil
        end
    end

    if Config.ESP.TargetLine and closest then
        local sp, on = Camera:WorldToViewportPoint(closest.head.Position)
        if on then
            TargetLine.Color = Config.ESP.LineColor
            TargetLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            TargetLine.To = Vector2.new(sp.X, sp.Y); TargetLine.Visible = true
        else TargetLine.Visible = false end
    else TargetLine.Visible = false end
end


local WorldEspPool = {}   -- [instance] = { Tag=Drawing.new("Text"), Box=Drawing.new("Square") }
local WorldEspSeen = {}

function getWorldEspEntry(inst)
    if WorldEspPool[inst] then return WorldEspPool[inst] end
    local e = {
        Tag  = Drawing.new("Text"),
        Box  = Drawing.new("Square"),
        Fill = Drawing.new("Square"),
        Dot  = Drawing.new("Circle"),
    }
    e.Tag.Font = 2; e.Tag.Size = 14; e.Tag.Outline = true; e.Tag.Center = true; e.Tag.Visible = false
    e.Box.Thickness = 2; e.Box.Transparency = 1; e.Box.Filled = false; e.Box.Visible = false
    e.Fill.Thickness = 1; e.Fill.Transparency = 0.28; e.Fill.Filled = true; e.Fill.Visible = false
    e.Dot.Thickness = 1; e.Dot.NumSides = 20; e.Dot.Radius = 3; e.Dot.Filled = true
    e.Dot.Transparency = 1; e.Dot.Visible = false
    WorldEspPool[inst] = e
    return e
end

function hideWorldEntry(e)
    if not e then return end
    e.Tag.Visible = false; e.Box.Visible = false
    if e.Fill then e.Fill.Visible = false end
    if e.Dot  then e.Dot.Visible  = false end
end

function classifyDebrisItem(item)
    if not item or not item.Parent then return nil end
    if Config.ESP.WorldWeapons and item:IsA("Model")
        and item:GetAttribute("Weapon") and item:GetAttribute("CanPickup") == true then
        local wname = tostring(item:GetAttribute("Weapon") or item.Name)
        return { kind = "weapon", label = "▸ "..wname:upper(), color = Config.ESP.WeaponColor }
    end
    if Config.ESP.WorldBomb and item:IsA("Model")
        and item.Name == "Character" and item:GetAttribute("BombPlanted") then
        return { kind = "bomb", label = "◈ C4", color = Config.ESP.BombColor }
    end
    if Config.ESP.WorldMolotov and item:IsA("Folder") and item.Name:match("^VoxelFire") then
        return { kind = "molotov", label = "◆ MOLOTOV", color = Config.ESP.MolotovColor }
    end
    if Config.ESP.WorldSmoke and item:IsA("Folder") and item.Name:match("^VoxelSmoke") then
        return { kind = "smoke", label = "◉ SMOKE", color = Config.ESP.SmokeColor }
    end
    return nil
end

function getWorldPivot(inst)
    if inst:IsA("BasePart") then return inst.Position, inst.Size end
    if inst:IsA("Model") then
        if inst.PrimaryPart then return inst.PrimaryPart.Position, inst.PrimaryPart.Size end
        local ok, cf, sz = pcall(function() return inst:GetBoundingBox() end)
        if ok and cf then return cf.Position, sz end
    end
    if inst:IsA("Folder") then
        local sum, n = Vector3.new(), 0
        for _, ch in ipairs(inst:GetChildren()) do
            if ch:IsA("BasePart") then sum = sum + ch.Position; n = n + 1 end
        end
        if n > 0 then return sum / n, Vector3.new(6, 6, 6) end
    end
    return nil
end

function updateWorldESP()
    if not Config.GlobalEnable or not (Config.ESP.WorldBomb or Config.ESP.WorldWeapons or Config.ESP.WorldMolotov or Config.ESP.WorldSmoke) then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end

    local debris = Workspace:FindFirstChild("Debris")
    if not debris then
        for _, e in pairs(WorldEspPool) do hideWorldEntry(e) end
        return
    end

    WorldEspSeen = {}
    for _, child in ipairs(debris:GetChildren()) do
        local info = classifyDebrisItem(child)
        if info then
            local pos = getWorldPivot(child)
            if pos then
                WorldEspSeen[child] = true
                local e = getWorldEspEntry(child)
                local sp, on = Camera:WorldToViewportPoint(pos)
                if on then
                    local dist = (myRoot.Position - pos).Magnitude
                    local s = math.clamp(260 / math.max(1, dist), 10, 30)
                    local bx, by = sp.X - s/2, sp.Y - s/2
                    -- Distance fade: fully opaque up to 40m, fade to 55% at MaxDistance.
                    local fade = math.clamp(1 - (dist - 40) / math.max(1, (Config.ESP.MaxDistance or 500) - 40), 0.55, 1)
                    -- Pulse: hazards (molotov/smoke) breathe; C4 pulses fast; weapons steady.
                    local pulse = 1
                    if info.kind == "bomb"    then pulse = 0.75 + 0.25 * math.sin(tick() * 6)
                    elseif info.kind == "molotov" then pulse = 0.80 + 0.20 * math.sin(tick() * 3)
                    elseif info.kind == "smoke"   then pulse = 0.85 + 0.15 * math.sin(tick() * 2) end
                    if e.Fill then e.Fill.Visible = false end
                    e.Box.Size = Vector2.new(s, s)
                    e.Box.Position = Vector2.new(bx, by)
                    e.Box.Color = info.color
                    e.Box.Transparency = fade * pulse
                    e.Box.Visible = true
                    e.Dot.Position = Vector2.new(sp.X, sp.Y)
                    e.Dot.Color = info.color
                    e.Dot.Transparency = fade * pulse
                    e.Dot.Visible = true
                    e.Tag.Text = string.format("%s  [%dm]", info.label, math.floor(dist))
                    e.Tag.Color = info.color
                    e.Tag.Transparency = fade
                    e.Tag.Position = Vector2.new(sp.X, by - 18)
                    e.Tag.Visible = true

                else
                    hideWorldEntry(e)
                end
            end
        end
    end
    local debrisRef = Workspace:FindFirstChild("Debris")
    for inst, e in pairs(WorldEspPool) do
        local alive = inst.Parent ~= nil and debrisRef and (inst.Parent == debrisRef or inst:IsDescendantOf(debrisRef))
        if not WorldEspSeen[inst] or not alive then
            hideWorldEntry(e)
            if not alive then
                pcall(function() e.Tag:Remove() end); pcall(function() e.Box:Remove() end); pcall(function() if e.Fill then e.Fill:Remove() end end); pcall(function() if e.Dot then e.Dot:Remove() end end)
                WorldEspPool[inst] = nil
            end
        end
    end


end

