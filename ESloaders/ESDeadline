        if not Config.Sounds.Enabled then
            for snd, data in pairs(EX.originalSoundIds) do
                if snd and snd.Parent then pcall(function()
                    if type(data) == "table" then
                        snd.SoundId = data.SoundId or snd.SoundId
                        snd.Volume = data.Volume or snd.Volume
                        snd.PlaybackSpeed = data.PlaybackSpeed or snd.PlaybackSpeed
                    else
