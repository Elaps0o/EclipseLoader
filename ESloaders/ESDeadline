    slot.Active = true
    slot.Parent = label
    local c = Instance.new("UICorner", slot); c.CornerRadius = UDim.new(0, isKey and 5 or 6)
    local st = Instance.new("UIStroke", slot)
    st.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    st.Color = Color3.fromRGB(120, 95, 200); st.Thickness = 1.2; st.Transparency = 0.05
