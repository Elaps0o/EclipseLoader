            if not EX.originalSoundIds[snd] then EX.originalSoundIds[snd] = { SoundId=snd.SoundId, Volume=snd.Volume, PlaybackSpeed=snd.PlaybackSpeed } end
            if catName == "Bullet" or not _isFireSound(catName, snd) then
