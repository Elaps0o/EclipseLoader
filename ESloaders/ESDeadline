local function wrapPage(page)
    local T = { _page = page }
    local function _addSection(name, side, icon)
        local sec
        local ok, err = pcall(function()
            sec = page:Section({ Name = name or "GROUP", Side = side, Icon = _sectionIcon(icon, name) })
        end)
        if not ok then warn("[Eclipse] section err '"..tostring(name).."': "..tostring(err)) end
        if sec then table.insert(Library._sections, sec) end
        return makeGroupbox(sec)
    end
    function T:AddLeftGroupbox(name, icon)  return _addSection(name, 1, icon) end
    function T:AddRightGroupbox(name, icon) return _addSection(name, 2, icon) end
    T.AddLeftTabbox  = function(self, name) return T:AddLeftGroupbox(name or "TABBOX") end
    T.AddRightTabbox = function(self, name) return T:AddRightGroupbox(name or "TABBOX") end
    return T
end

