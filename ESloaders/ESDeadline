RunService:BindToRenderStep("DL_Crosshair", Enum.RenderPriority.Camera.Value + 2, function()
    local cfg = Config.Crosshair
    if not cfg.Enabled then
        for k,d in pairs(_CH) do pcall(function() d.Visible=false end) end
        return
    end
    local cam = Workspace.CurrentCamera; if not cam then return end
    local vp = cam.ViewportSize
    local cx, cy = vp.X/2, vp.Y/2
    local s, g, t = cfg.Size, cfg.Gap, cfg.Thickness
    local col, ocol = cfg.Color, Color3.new(0,0,0)
    local function setLine(k, ok, from, to, color, thick, vis)
        local L = _CH[k]; if not L then return end
        L.From=from; L.To=to; L.Color=color; L.Thickness=thick; L.Visible=vis
        local O = _CH[ok]; if O then O.From=from; O.To=to; O.Color=ocol; O.Thickness=thick+2; O.Visible=vis and cfg.Outline end
    end
    setLine("L","LO", Vector2.new(cx-g-s, cy), Vector2.new(cx-g, cy), col, t, true)
    setLine("R","RO", Vector2.new(cx+g,   cy), Vector2.new(cx+g+s, cy), col, t, true)
    setLine("U","UO", Vector2.new(cx, cy-g-s), Vector2.new(cx, cy-g), col, t, true)
    setLine("D","DO", Vector2.new(cx, cy+g),   Vector2.new(cx, cy+g+s), col, t, true)
    if _CH.Dot then
        if cfg.Dot then
            _CH.Dot.Size=Vector2.new(t+1, t+1); _CH.Dot.Position=Vector2.new(cx-(t+1)/2, cy-(t+1)/2)
            _CH.Dot.Color=col; _CH.Dot.Visible=true
            if cfg.Outline then
                _CH.DotO.Size=Vector2.new(t+3, t+3); _CH.DotO.Position=Vector2.new(cx-(t+3)/2, cy-(t+3)/2); _CH.DotO.Visible=true
            else _CH.DotO.Visible=false end
        else _CH.Dot.Visible=false; _CH.DotO.Visible=false end
    end
end)



