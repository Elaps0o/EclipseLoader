local currentTarget = nil

local function findAimTarget()
    local origin = getMouseDrawingPos()
    local best, bestDist = nil, Config.Aimbot.FOV
    local folder = _charFolder(); if not folder then return nil end
    local lc = _localCharacter()
    for _, model in _iter(folder:GetChildren()) do
        if model ~= lc and model.Name ~= LocalPlayer.Name then
            local ok = true
            if Config.Aimbot.TeamCheck and not isEnemyChar(model) then ok = false end
            if ok then
                local hrp, hum, head = getCharParts(model)
                if hrp then
                    local part = resolveTargetPart(model, Config.Aimbot.TargetPart or "Head") or head or hrp
                    local sp, on = worldToScreen(part.Position)
                    if on then
                        local d = (sp - origin).Magnitude
                        if d < bestDist then
                            if not Config.Aimbot.VisCheck or isVisibleFromCamera(part, model) then
                                best, bestDist = { model=model, part=part }, d
                            end
                        end
                    end
                end
            end
        end
    end
    return best
end

RunService:BindToRenderStep("DL_Aimbot", Enum.RenderPriority.Camera.Value + 1, function(dt)
    local mousePos = getMouseDrawingPos()
    if FOVCircle then
        FOVCircle.Visible  = Config.Aimbot.DrawFOV and Config.Aimbot.Enabled
        FOVCircle.Position = mousePos
        FOVCircle.Radius   = Config.Aimbot.FOV
        FOVCircle.Color    = Config.Aimbot.FOVColor
    end
    if not Config.Aimbot.Enabled or not (Config.Global and Config.Global.Enabled) then currentTarget = nil; return end
    local key = Config.Aimbot.AimKey
    local held = false
    if typeof(key) == "EnumItem" and key.EnumType == Enum.UserInputType then
        held = UserInput:IsMouseButtonPressed(key)
    else
        held = UserInput:IsKeyDown(key)
    end
    if not held then currentTarget = nil; return end
    -- Fixed: keep same model while held (re-resolve part in case of movement)
    -- Dynamic: refind closest every frame
    if Config.Aimbot.Mode == "Fixed" and currentTarget and currentTarget.model and currentTarget.model.Parent then
        local part = resolveTargetPart(currentTarget.model, Config.Aimbot.TargetPart or "Head")
        if part then currentTarget.part = part else currentTarget = findAimTarget() end
    else
        currentTarget = findAimTarget()
    end
    if currentTarget then
        local part = currentTarget.part
        local aimPos = part.Position
        -- Prediction inteligente: usa AssemblyLinearVelocity + tempo até o alvo
        -- para liderar mira em inimigos em movimento. Fator configurável.
        local vel
        pcall(function() vel = part.AssemblyLinearVelocity end)
        if not vel then pcall(function() vel = part.Velocity end) end
        if vel and vel.Magnitude > 0.5 then
            local dist = (aimPos - Workspace.CurrentCamera.CFrame.Position).Magnitude
            local lead = math.clamp(dist / 900, 0, 0.35) -- ~0..0.35s de antecipação
            aimPos = aimPos + vel * lead
        end
        local sp = Workspace.CurrentCamera:WorldToViewportPoint(aimPos)
        local inset = Vector2.new(0,0); pcall(function() inset = GuiService:GetGuiInset() end)
        local mouseVP = mousePos - inset
        local delta = Vector2.new(sp.X, sp.Y) - mouseVP
        local s = math.clamp(Config.Aimbot.Smoothness, 0.05, 1)
        pcall(mousemoverel, delta.X * s, delta.Y * s)
    end
end)

