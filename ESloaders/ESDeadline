function _isImageLoaded(img)
    local loaded = false
    pcall(function() loaded = img.IsLoaded == true end)
    return loaded
end

function _assetFetchStatus(candidate)
    local status = "Unknown"
    pcall(function()
        status = tostring(ContentProvider:GetAssetFetchStatus(candidate)):gsub("Enum.AssetFetchStatus%.", "")
    end)
    return status
end

function _statusIsGood(status)
    status = tostring(status or "")
    return status:find("Success", 1, true) ~= nil or status:find("Loaded", 1, true) ~= nil
end

function _statusIsBad(status)
    status = tostring(status or "")
    return status:find("Failure", 1, true) ~= nil or status:find("Failed", 1, true) ~= nil
        or status:find("Error", 1, true) ~= nil or status:find("TimedOut", 1, true) ~= nil
end

function _imageCandidateReady(img, candidate)
    local loaded = _isImageLoaded(img)
    local status = _assetFetchStatus(candidate)
    return (loaded or _statusIsGood(status)) and not _statusIsBad(status), loaded, status
end

function _applyHUDImageWithFallback(rec, img, icon, debugTag, onLoaded, onFailed)
    if EX_LIMITED then return false end
    if not (rec and img and img.Parent) then return false end
    local candidates = _iconCandidates(icon)
    if #candidates == 0 then return false end
    rec.iconToken = (rec.iconToken or 0) + 1
    local token = rec.iconToken
    _prepHUDImageLabel(img, rec)

    img.Image = candidates[1]
    rec.lastIcon = candidates[1]
    _hudDbg("image try", debugTag or "slot", "candidate=", candidates[1], "target=", img:GetFullName())

    if rec.iconFallbackImage then
        pcall(function() rec.iconFallbackImage:Destroy() end)
        rec.iconFallbackImage = nil
    end

    task.spawn(function()
        local finalIcon = nil
        local anyLoaded = false
        for i, candidate in ipairs(candidates) do
            if rec.iconToken ~= token or not img.Parent then return end
            pcall(function()
                _prepHUDImageLabel(img, rec)
                img.Image = candidate
                if rec.iconFallbackImage then _syncHUDFallbackGeometry(img, rec.iconFallbackImage) end
            end)
            local preloadStatus = "Unknown"
            local preloadOk = pcall(function()
                ContentProvider:PreloadAsync({img}, function(_, status)
                    preloadStatus = tostring(status):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end)
            task.wait(i == 1 and 0.35 or 0.45)
            local ready, loaded, fetchStatus = _imageCandidateReady(img, candidate)
            if preloadStatus ~= "Unknown" then fetchStatus = preloadStatus end
            _hudDbg("image state", debugTag or "slot", "candidate=", candidate, "preload=", tostring(preloadOk), "status=", tostring(fetchStatus), "loaded=", tostring(loaded))
            if ready then
                anyLoaded = true
                finalIcon = candidate
                break
            end
        end
        if rec.iconToken ~= token or not img.Parent then return end
        local thumb = _assetThumb(icon)
        if not anyLoaded and thumb then
            finalIcon = thumb
            pcall(function()
                _prepHUDImageLabel(img, rec)
                img.Image = thumb
                if rec.iconFallbackImage then _syncHUDFallbackGeometry(img, rec.iconFallbackImage) end
            end)
            task.wait(0.25)
            local ready, loaded, fetchStatus = _imageCandidateReady(img, thumb)
            anyLoaded = ready
            _hudDbg("thumb fallback", debugTag or "slot", "status=", tostring(fetchStatus), "loaded=", tostring(loaded), "ready=", tostring(ready))
        end
        if not anyLoaded then
            _hudDbg("image unverified; keeping native HUD icon", debugTag or "slot", tostring(finalIcon or candidates[1]))
            if onFailed then pcall(onFailed) end
            return
        end
        if rec.iconFallbackImage then pcall(function() rec.iconFallbackImage.Visible = false end) end
        pcall(function()
            img.Visible = true
            img.ImageColor3 = _hudIconTint(rec)
        end)
        rec.lastIcon = finalIcon
        _hudDbg("image accepted", debugTag or "slot", "final=", tostring(finalIcon))
        if onLoaded then pcall(onLoaded, finalIcon) end
    end)
    return true
end

