local ES152 = {
    Load    = 0,
    LastDt  = 1/60,
    Faults  = {},
    Timers  = {},
    Muted   = {},
    Enabled = true,
}
_G.ES152 = ES152
do
    local acc, samples = 0, 0
    ES152._monitor = RunService.Heartbeat:Connect(function(dt)
        ES152.LastDt = dt
        acc = acc + dt; samples = samples + 1
        if samples >= 12 then
            local avg = acc / samples
            local overshoot = math.clamp((avg - 0.0167) / 0.0167, 0, 1)
            ES152.Load = ES152.Load * 0.7 + overshoot * 0.3
            acc, samples = 0, 0
        end
    end)
end

function ES152.tick(name, _baseInterval)
    if not ES152.Enabled then return true end
    if ES152.Muted[name] then return false end
    return true
end
function ES152.guard(name, fn)
    return function(...)
        if ES152.Muted[name] then return end
        local ok = pcall(fn, ...)
        if ok then
            ES152.Faults[name] = 0
        else
            ES152.Faults[name] = (ES152.Faults[name] or 0) + 1
            if ES152.Faults[name] >= 6 then
                ES152.Muted[name] = true
                task.delay(3, function()
                    ES152.Muted[name] = nil
                    ES152.Faults[name] = 0
                end)
            end
        end
    end
end
function ES152.coalesce(name, fn)
    return function(...)
        local key = "__co_"..name
        local now = os.clock()
        if ES152.Timers[key] == now then return end
        ES152.Timers[key] = now
        return fn(...)
    end
end

function ES152.yieldEvery(counter, step)
    step = step or 240
    if counter > 0 and (counter % step) == 0 then
        EclipseYield()
    end
end

function ES152.adaptiveInterval(base, _maxMul)
    base = math.max(tonumber(base) or 0.1, 0.01)
    local maxMul = math.max(tonumber(_maxMul) or 1, 1)
    if not ES152.Enabled then return base end
    local load = math.clamp(tonumber(ES152.Load) or 0, 0, 1)
    local pulse = math.max(tonumber(ES152.LastDt) or 0, 0.01)
    base = math.max(base, pulse)
    return base * (1 + load * (maxMul - 1))
end

