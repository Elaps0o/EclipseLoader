    if _copyGloveSkinDirect(glove, source, sourceKey, gsr) then
        glove:SetAttribute("EclipseSkinSource", sourceKey)
        glove:SetAttribute("SkinApplied", gloveSkin)
    end
end

function _applyGloveSkinCore(gloveType, gloveSkin)
    if not (Config.Skins and Config.Skins.SkinChangerEnabled) then return end
    if not SkinsFolder then return end
    if not gloveType or not gloveSkin or gloveSkin == "" or gloveSkin == "Vanilla" or gloveSkin == "Default" or gloveSkin == "None" then return end

    local cam = workspace.CurrentCamera; if not cam then return end
    local am
    for _, ch in ipairs(cam:GetChildren()) do
        if ch:IsA("Model") and (ch.Name:match("Arms") or ch:FindFirstChild("Right Arm")) then
            am = ch; break
        end
    end
    if not am then return end
    local la = am:FindFirstChild("Left Arm"); local ra = am:FindFirstChild("Right Arm")
    if not la or not ra then return end
    local lg = la:FindFirstChild("Glove"); local rg = ra:FindFirstChild("Glove")
    if not lg or not rg then return end

    local gloveSkinFolder = SkinsFolder:FindFirstChild(gloveType); if not gloveSkinFolder then return end
    local skinVariant = gloveSkinFolder:FindFirstChild(gloveSkin);   if not skinVariant then return end
    local cameraFolder = skinVariant:FindFirstChild("Camera");       if not cameraFolder then return end
    local factoryNew = cameraFolder:FindFirstChild("Factory New")
                    or cameraFolder:FindFirstChild("Minimal Wear")
                    or cameraFolder:FindFirstChild("Field-Tested")
                    or cameraFolder:FindFirstChild("Well-Worn")
                    or cameraFolder:FindFirstChild("Battle-Scarred")
    if not factoryNew then return end

    local sourceKey = tostring(gloveType) .. "/" .. tostring(gloveSkin)
    if lg:GetAttribute("EclipseSkinSource") == sourceKey and rg:GetAttribute("EclipseSkinSource") == sourceKey then return end

    pcall(_cacheSkinTarget, lg); pcall(_cacheSkinTarget, rg)
    for _, old in ipairs(lg:GetChildren()) do if old:IsA("SurfaceAppearance") then old:Destroy() end end
    for _, old in ipairs(rg:GetChildren()) do if old:IsA("SurfaceAppearance") then old:Destroy() end end

    for _, sa in ipairs(factoryNew:GetChildren()) do
        if sa:IsA("SurfaceAppearance") then
            local c1 = sa:Clone(); pcall(function() c1:SetAttribute("EclipseSkinSurface", true) end); c1.Parent = lg
            local c2 = sa:Clone(); pcall(function() c2:SetAttribute("EclipseSkinSurface", true) end); c2.Parent = rg
        end
    end
    lg:SetAttribute("EclipseSkinSource", sourceKey); lg:SetAttribute("SkinApplied", gloveSkin)
    rg:SetAttribute("EclipseSkinSource", sourceKey); rg:SetAttribute("SkinApplied", gloveSkin)
    return true
end

function _applySelectedGloveSkin()
    if EX_LIMITED then return end
    if not SkinsFolder or not Config.Skins.SkinChangerEnabled or not IsAlive() then return end
    local now = tick()
    if (now - (_TW_GloveLastApplyAt or 0)) < 0.30 then return end
    local activeType, activeSkin
    for gt in pairs(GLOVES) do
        local s = Config.Skins.SelectedSkins[gt]
        if s and s ~= "" and s ~= "Vanilla" and s ~= "Default" and s ~= "None" then
            activeType, activeSkin = gt, s; break
        end
    end
    if not activeSkin then
        _TW_GloveLastApplyAt = now
        pcall(_clearGloveSkinRuntime)
        _forEachCameraGlove(function(glove) _restoreGloveSurfaceOnly(glove) end)
        return
    end
    _TW_GloveLastApplyAt = now
    pcall(_applyGloveSkinCore, activeType, activeSkin)
end

function _applyWeaponSkinCore(model, skin)
    if not (model and model:IsA("Model") and SkinsFolder) then return end
    local own = model.Name
    local ewn = own
    local canApply = false
    if own == "CT Knife" or own == "T Knife" or own == "Knife" then
        ewn = Config.Skins.SelectedKnife or ewn
        canApply = Config.Skins.SkinChangerEnabled and true or false
    else
        canApply = Config.Skins.SkinChangerEnabled and true or false
    end
    if GLOVES[ewn] or not canApply then return end
    local sel = skin or Config.Skins.SelectedSkins[ewn]
    if not sel or sel == "Vanilla" or sel == "Default" or sel == "None" then return end
    if model:GetAttribute("BankrollSkin") == sel then return end

    local wsf = SkinsFolder:FindFirstChild(ewn); if not wsf then return end
    local sf  = wsf:FindFirstChild(sel);         if not sf  then return end
    local cf  = sf:FindFirstChild("Camera");     if not cf  then return end
    local fn  = cf:FindFirstChild("Factory New")
             or cf:FindFirstChild("Minimal Wear")
             or cf:FindFirstChild("Field-Tested")
             or cf:FindFirstChild("Well-Worn")
             or cf:FindFirstChild("Battle-Scarred")
    if not fn then return end

    local appliedCount = 0
    for _, sa in ipairs(fn:GetChildren()) do
        if sa:IsA("SurfaceAppearance") then
            local pt = model:FindFirstChild(sa.Name, true)
            if pt and (pt:IsA("BasePart") or pt:IsA("MeshPart")) then
                appliedCount = appliedCount + 1
                pcall(_cacheSkinTarget, pt)
                for _, old in ipairs(pt:GetChildren()) do
                    if old:IsA("SurfaceAppearance") then old:Destroy() end
                end
                local c = sa:Clone()
                pcall(function() c:SetAttribute("EclipseSkinSurface", true) end)
                c.Parent = pt
                if appliedCount % 8 == 0 then EclipseYield() end
            end
        end
    end
    model:SetAttribute("SkinApplied", sel)
    model:SetAttribute("BankrollSkin", sel)
end

