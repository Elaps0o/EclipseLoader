    local function _attackerIsLocal(attacker)
        if attacker == LocalPlayer then return true end
        if typeof(attacker) == "Instance" then
            if attacker.Name == LocalPlayer.Name then return true end
            local ch = LocalPlayer.Character
            if ch and attacker:IsDescendantOf(ch) then return true end
            local _, plr = _charPlayerFromAny(attacker)
            if plr == LocalPlayer then return true end
        elseif type(attacker) == "table" then
            local _, plr = _charPlayerFromAny(attacker)
            if plr == LocalPlayer then return true end
            for _, key in ipairs({"Player","player","Killer","killer","Attacker","attacker","Creator","creator","Owner","owner"}) do
                if _attackerIsLocal(rawget(attacker, key)) then return true end
            end
        elseif tostring(attacker) == LocalPlayer.Name or tostring(attacker) == tostring(LocalPlayer.UserId) then
            return true
        end
        return false
    end

    local function _markLocalLethal(plr)
        if not plr or plr == LocalPlayer then return end
        _lastLethalByLP[plr] = tick()
        pcall(function() _lastLethalByUid[tonumber(plr.UserId)] = tick() end)
    end

    local function _killFeedPlayerFrom(value)
        if value == nil then return nil end
        local _, plr = _charPlayerFromAny(value)
        if plr then return plr end
        local n = tonumber(value)
        if n then return Players:GetPlayerByUserId(n) end
        local s = tostring(value)
        if s ~= "" then
            local byName = Players:FindFirstChild(s)
            if byName and byName:IsA("Player") then return byName end
        end
        return nil
    end

    local function _killFeedKillerIsLocal(info)
        if type(info) ~= "table" then return false end
        for _, key in ipairs({"Killer","killer","KillerId","killerId","KillerUserId","killerUserId","Attacker","attacker","AttackerId","attackerId","Player","player"}) do
            local v = rawget(info, key)
            if v ~= nil then
                local p = _killFeedPlayerFrom(v)
                if p == LocalPlayer then return true end
                local n = tonumber(v)
                if n and n == LocalPlayer.UserId then return true end
                if tostring(v) == LocalPlayer.Name then return true end
            end
        end
        return _attackerIsLocal(info)
    end

    local function _killFeedVictim(info)
        if type(info) ~= "table" then return nil end
        for _, key in ipairs({"Victim","victim","VictimId","victimId","VictimUserId","victimUserId","Target","target","Dead","dead","Killed","killed","Enemy","enemy"}) do
            local p = _killFeedPlayerFrom(rawget(info, key))
            if p and p ~= LocalPlayer then return p end
        end
        return nil
    end

