                local ok2, info = pcall(function() return MarketplaceSvc:GetProductInfo(item.Id) end)
                if ok2 and type(info) == "table" then
                    local t = tonumber(info.AssetTypeId)
                    if BODY_TYPE_FIELDS[t] then
                        out.body[BODY_TYPE_FIELDS[t]] = item.Id
                    elseif ACC_TYPE_FIELDS[t] then
                        local f = ACC_TYPE_FIELDS[t]
                        out.accessories[f] = out.accessories[f] or {}
                        table.insert(out.accessories[f], item.Id)
                    end
                end
            end
        end
        _bundleCache[bundleId] = out
        return out
    end

