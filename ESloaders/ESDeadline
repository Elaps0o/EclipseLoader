function _weaponInfo(name)
    if type(name) ~= "string" or name == "" then return nil end
    if HUDSkin.infoCache[name] ~= nil then return HUDSkin.infoCache[name] or nil end
    local hardcoded = HUD_KNIFE_ASSETS[name] or HUD_WEAPON_ICON_FALLBACKS[name]
    local source = _readWeaponModuleSourceInfo(name)
    local runtime = _readWeaponRuntimeInfo(name)

    local info = nil
    local function merge(src)
        if type(src) ~= "table" then return end
        info = info or {}
        info.Icon = info.Icon or src.Icon
        info.ReverseIcon = info.ReverseIcon or src.ReverseIcon
        info.Team = info.Team or src.Team
        info.Slot = info.Slot or src.Slot
    end
    merge(source); merge(runtime); merge(hardcoded)

    if info then HUDSkin.infoCache[name] = info end
    return info
end

