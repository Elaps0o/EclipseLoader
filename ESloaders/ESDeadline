            btn = nlSection:Button({
                Name     = text,
                Callback = function() if fn then pcall(fn) end end,
            })
        end)
        return { AddButton = G.AddButton, _nl = btn }
    end
    function G:AddToggle(id, data)
        data = data or {}
        local cbs = {}
        local nlT
        local createdOk, createErr = pcall(function()
            nlT = nlSection:Toggle({
                Name     = data.Text or id or "Toggle",
                Flag     = makeFlag(id),
                Default  = data.Default and true or false,
                Callback = function(v)
                    local changed = false
                    for _, f in _iter(cbs) do
                        local ok, didChange = pcall(f, v)
                        if ok and didChange then changed = true end
                    end
                    if changed and data.Callback then pcall(data.Callback, v) end
                end,
            })
        end)
        if not createdOk or not nlT then
            warn("[AddToggle] failed to create nlSection.Toggle for id", id, "createdOk", createdOk, "err", createErr, "nlT type", typeof(nlT), type(nlT))
            nlT = { Value = data.Default and true or false, Set = function(_,v) end, Colorpicker = function() return {} end, Keybind = function() return {} end }
        end
        local w = wrapToggle(id, nlT, cbs)
        if type(w) ~= "table" then
            warn("[AddToggle] wrapToggle returned invalid object for id", id, "type", typeof(w), type(w))
            w = { Type="Toggle", Value=data.Default and true or false, Disabled=false, Visible=true, _nl=nlT, _changed={},
                SetValue=function() end, SetVisible=function() end, SetDisabled=function() end,
                OnChanged=function() end,
            }
        end
        if type(w.AddColorPicker) ~= "function" then
            w.AddColorPicker = function() return w end
        end
        if type(w.AddKeyPicker) ~= "function" then
            w.AddKeyPicker = function() return w end
        end
        w._extCb = data.Callback
        w.Value = data.Default and true or false
        return registerEntry(Library.Toggles, id, w)
    end
    function G:AddSlider(id, data)
        data = data or {}
        local nlS
        local w = { Value = tonumber(data.Default) or 0 }

        local rounding = data.Rounding
        if rounding == nil then rounding = data.Decimals end
        rounding = tonumber(rounding) or 0
        if rounding < 0 then rounding = 0 end
        local step = 1
        for _ = 1, rounding do step = step / 10 end
        pcall(function()
            nlS = nlSection:Slider({
                Name     = data.Text or id or "Slider",
                Flag     = makeFlag(id),
                Min      = tonumber(data.Min) or 0,
                Max      = tonumber(data.Max) or 100,
                Default  = tonumber(data.Default) or tonumber(data.Min) or 0,
                Suffix   = data.Suffix or "",
                Decimals = step,
                Callback = function(v)
                    if w then w.Value = tonumber(v) or 0 end
                    if data.Callback then pcall(data.Callback, v) end
                end,
            })
        end)
        w.Type      = "Slider"
        w.Disabled  = false
        w.Visible   = true
        w.SetValue  = function(_, v)
            w.Value = tonumber(v) or 0
            pcall(function() if nlS then nlS:Set(w.Value) end end)
        end
        w.SetVisible = function(_, b) w.Visible = b and true or false; _setControlVisible(nlS, w.Visible) end
