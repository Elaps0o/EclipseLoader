function _weaponModule(name)
    if type(name) ~= "string" or name == "" then return nil end
    name = (_cleanHUDWeaponText and _cleanHUDWeaponText(name)) or name
    name = tostring(name):gsub("^%s+", ""):gsub("%s+$", "")
    local ok, mod = pcall(function()
        local weapons = ReplicatedSt:FindFirstChild("Database")
            and ReplicatedSt.Database:FindFirstChild("Custom")
            and ReplicatedSt.Database.Custom:FindFirstChild("Weapons")
        if not weapons then return nil end
        local exact = weapons:FindFirstChild(name)
        if exact then return exact end
        local wanted = tostring(name):lower():gsub("[%s%-%_%.]", "")
        for _, child in ipairs(weapons:GetChildren()) do
            if tostring(child.Name):lower():gsub("[%s%-%_%.]", "") == wanted then return child end
        end
        return nil
    end)
    return ok and mod or nil
end

function _readWeaponModuleSourceInfo(name)
    local mod = _weaponModule(name); if not mod then return nil end
    local info = {}
    for _, key in ipairs(HUD_ICON_KEYS) do
        local ok, val = pcall(function() return mod:GetAttribute(key) end)
        local a = ok and _assetString(val) or nil
        if a then info.Icon = a; break end
    end
    local okSrc, src = pcall(function() return mod.Source end)
    if okSrc and type(src) == "string" and src ~= "" then
        info.Team = src:match('Team%s*=%s*"([^"]+)"') or src:match("Team%s*=%s*'([^']+)'") or info.Team
        info.Slot = src:match('Slot%s*=%s*"([^"]+)"') or src:match("Slot%s*=%s*'([^']+)'") or info.Slot

        info.Icon = _assetString(src:match('%f[%w]Icon%s*=%s*"([^"]+)"') or src:match("%f[%w]Icon%s*=%s*'([^']+)'") or src:match('%f[%w]Icon%s*=%s*(%d[%d]+)') or info.Icon)
        info.ReverseIcon = _assetString(src:match('%f[%w]ReverseIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]ReverseIcon%s*=%s*'([^']+)'") or src:match('%f[%w]ReverseIcon%s*=%s*(%d[%d]+)') or info.ReverseIcon)

    end
    if info.Icon or info.ReverseIcon or info.Team or info.Slot then return info end
    return nil
end

function _readWeaponRuntimeInfo(name)

    if type(name) ~= "string" or name == "" then return nil end
    HUDSkin.requireCache = HUDSkin.requireCache or {}
    if HUDSkin.requireCache[name] ~= nil then return HUDSkin.requireCache[name] or nil end
    local mod = _weaponModule(name)
    if not (mod and mod:IsA("ModuleScript")) then return nil end
    local info = {}
    for _, key in ipairs(HUD_ICON_KEYS) do
        local okA, val = pcall(function() return mod:GetAttribute(key) end)
        local a = okA and _assetString(val) or nil
        if a then info.Icon = a; break end
    end
    local okSrc, src = pcall(function() return mod.Source end)
    if okSrc and type(src) == "string" and src ~= "" then
        info.Icon = info.Icon or _assetString(src:match('%f[%w]Icon%s*=%s*"([^"]+)"') or src:match("%f[%w]Icon%s*=%s*'([^']+)'") or src:match('%f[%w]Icon%s*=%s*(%d[%d]+)') or src:match('%f[%w]InventoryIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]InventoryIcon%s*=%s*'([^']+)'") or src:match('%f[%w]InventoryIcon%s*=%s*(%d[%d]+)') or src:match('%f[%w]DisplayIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]DisplayIcon%s*=%s*'([^']+)'") or src:match('%f[%w]DisplayIcon%s*=%s*(%d[%d]+)') or src:match('%f[%w]WeaponIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]WeaponIcon%s*=%s*'([^']+)'") or src:match('%f[%w]WeaponIcon%s*=%s*(%d[%d]+)') or src:match('%f[%w]HUDIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]HUDIcon%s*=%s*'([^']+)'") or src:match('%f[%w]HUDIcon%s*=%s*(%d[%d]+)') or src:match('%f[%w]SlotIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]SlotIcon%s*=%s*'([^']+)'") or src:match('%f[%w]SlotIcon%s*=%s*(%d[%d]+)') or info.Icon)
        info.ReverseIcon = info.ReverseIcon or _assetString(src:match('%f[%w]ReverseIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]ReverseIcon%s*=%s*'([^']+)'") or src:match('%f[%w]ReverseIcon%s*=%s*(%d[%d]+)') or src:match('%f[%w]BackIcon%s*=%s*"([^"]+)"') or src:match("%f[%w]BackIcon%s*=%s*'([^']+)'") or src:match('%f[%w]BackIcon%s*=%s*(%d[%d]+)') or info.ReverseIcon)

        info.Team = info.Team or src:match('Team%s*=%s*"([^"]+)"') or src:match("Team%s*=%s*'([^']+)'")
        info.Slot = info.Slot or src:match('Slot%s*=%s*"([^"]+)"') or src:match("Slot%s*=%s*'([^']+)'")
    end
    if info.Icon or info.ReverseIcon or info.Team or info.Slot then
        HUDSkin.requireCache[name] = info
        return info
    end
    return nil
end

