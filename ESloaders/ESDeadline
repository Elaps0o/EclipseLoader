function _ensureESPWeaponIcon(data)
    if data.WeaponIcon and data.WeaponIcon.Parent then return data.WeaponIcon end
    local gui = _ensureESPIconGui(); if not gui then return nil end
    local img = Instance.new("ImageLabel")
    img.BackgroundTransparency = 1
    img.BorderSizePixel = 0
    img.ScaleType = Enum.ScaleType.Fit
    pcall(function() img.ResampleMode = Enum.ResamplerMode.Pixelated end)
    img.Visible = false
    img.ZIndex = 100000
    img.ImageColor3 = Color3.fromRGB(255,255,255)
    img.ImageTransparency = 0
    img.Size = UDim2.fromOffset(24, 24)
    img.Parent = gui

    local guard = false
    local function reassert()
        if guard then return end
        guard = true
        _forceESPWeaponIconVisual(img)
        guard = false
    end
    local function reassertSoon()
        reassert()
        task.defer(reassert)
        task.delay(0.04, reassert)
        task.delay(0.12, reassert)
    end
    pcall(function() connectSignal(img:GetPropertyChangedSignal("ImageTransparency"):Connect(reassertSoon)) end)
    pcall(function() connectSignal(img:GetPropertyChangedSignal("ImageColor3"):Connect(reassertSoon)) end)
    pcall(function() connectSignal(img:GetPropertyChangedSignal("BackgroundTransparency"):Connect(reassertSoon)) end)
    pcall(function() connectSignal(img:GetPropertyChangedSignal("Visible"):Connect(reassertSoon)) end)
    pcall(function() connectSignal(img:GetPropertyChangedSignal("Image"):Connect(reassertSoon)) end)
    data.WeaponIcon = img
    return img
end

function _espIconAssetForWeapon(weaponName)
    if type(weaponName) ~= "string" or weaponName == "" then return nil end
    local clean = (_cleanHUDWeaponText and _cleanHUDWeaponText(weaponName)) or weaponName
    clean = tostring(clean):gsub("^%s+", ""):gsub("%s+$", "")
    _ESPWeaponIconCache = _ESPWeaponIconCache or {}
    if _ESPWeaponIconCache[clean] ~= nil then return _ESPWeaponIconCache[clean] or nil end
    local icon = nil
    local ok, res = pcall(_espResolvedWeaponIcon, clean)
    if ok and type(res) == "string" and res ~= "" then icon = res end
    if not icon then return nil end

    local id = _assetIdFromString(icon)
    local direct = id and ("rbxassetid://" .. id) or (_assetString(icon) or icon)
    _ESPWeaponIconCache[clean] = direct
    return direct
end

function _espDrawTag(data, L, R, T, cx, plr, dist, weaponName, B)
    local s = _espAnimScale()
    if s <= 0.001 then
        data.TagBg.Visible=false
        for _,l in pairs(data.TagBorder) do l.Visible=false end
        for _,l in pairs(data.TagGrad)   do l.Visible=false end
        data.TagAmmoBg.Visible=false; data.TagAmmoFill.Visible=false
        data.TagText.Visible=false
        if data.WeaponIcon then data.WeaponIcon.Visible=false end
        return 0
    end
    local hasWeapon = Config.ESP.WeaponName and weaponName and weaponName ~= ""
    local weaponIconAsset = hasWeapon and _espIconAssetForWeapon(weaponName) or nil

    if hasWeapon and not weaponIconAsset and data.LastWeaponIcon then
        weaponIconAsset = data.LastWeaponIcon
    end
    local showIcon = hasWeapon and weaponIconAsset ~= nil
    local baseW = math.max(170, math.min(250, (R - L) + 48))

    local ICON_BASE = 34
    local _wn = tostring(weaponName or "")
    local _wnLower = _wn:lower()
    local _isSniperW = SniperWeapons and SniperWeapons[_wn] == true
    local _isRifleW = (_wn == "AK-47" or _wn == "M4A1-S" or _wn == "M4A4" or _wn == "FAMAS" or _wn == "Galil AR" or _wn == "AUG" or _wn == "SG 553")
    local _isKnifeW = (KNIVES and KNIVES[_wn] == true) or _wnLower:find("knife", 1, true) ~= nil or _wnLower:find("bayonet", 1, true) ~= nil or _wnLower == "karambit"
    local ICON_SIZE
    if _isSniperW or _isRifleW then
        ICON_SIZE = math.floor(ICON_BASE * 1.45 + 0.5)
    elseif _isKnifeW then
        ICON_SIZE = math.floor(ICON_BASE * 1.32 + 0.5)
    else
        ICON_SIZE = ICON_BASE
    end
    local ICON_PAD  = 3

    local baseH = 24

    local width  = math.floor(baseW * (0.68 + 0.32 * math.min(1, s)))
    local height = math.floor(baseH * (0.68 + 0.32 * math.min(1, s)))
    local x  = math.floor(cx - width / 2)
    local y  = math.floor((B or (T + 120)) + 12)
    local trBase = 1 * math.min(1, s)

    local showBox = (Config.ESP.Name or Config.ESP.Distance) and true or false
    if showBox then
        data.TagBg.Size = Vector2.new(width, height)
        data.TagBg.Position = Vector2.new(x, y)
        data.TagBg.Filled = true; data.TagBg.Color = Color3.fromRGB(8,10,16)
        data.TagBg.Transparency = 0.40 * math.min(1, s); data.TagBg.Visible = true
        local tl, tr, bl, br = Vector2.new(x,y), Vector2.new(x+width,y), Vector2.new(x,y+height), Vector2.new(x+width,y+height)
        data.TagBorder[1].From, data.TagBorder[1].To = tl, tr
        data.TagBorder[2].From, data.TagBorder[2].To = tr, br
        data.TagBorder[3].From, data.TagBorder[3].To = br, bl
        data.TagBorder[4].From, data.TagBorder[4].To = bl, tl
        for _, l in ipairs(data.TagBorder) do l.Thickness = 1.4; l.Transparency = 0.45 * math.min(1,s); l.Color = Color3.fromRGB(120, 190, 255); l.Visible = true end

        local segs = ESP_TAG_GRAD_SEGS
        local segW = width / segs
        local a, b = ESP_TAG_GRAD_A, ESP_TAG_GRAD_B
        for i = 1, segs do
            local t = (i - 0.5) / segs
            local ln = data.TagGrad[i]
            ln.From = Vector2.new(x + (i-1)*segW, y + 1)
            ln.To   = Vector2.new(x + i*segW,      y + 1)
            ln.Color = Color3.new(a.R + (b.R-a.R)*t, a.G + (b.G-a.G)*t, a.B + (b.B-a.B)*t)
            ln.Thickness = 2; ln.Transparency = trBase; ln.Visible = true
        end
    else
        data.TagBg.Visible = false
        for _, l in ipairs(data.TagBorder) do l.Visible = false end
        for _, l in ipairs(data.TagGrad)   do l.Visible = false end
    end
    local nameParts = {}
    if Config.ESP.Name then table.insert(nameParts, plr.Name .. (_ECC_DEADLINE_RAW_TAG or "")) end
    if Config.ESP.Distance then table.insert(nameParts, math.floor(dist) .. "m") end
    local moneyStr = nil
    if Config.ESP.IdentifyMoney and _isWarmup and _isWarmup() then
        local m = tonumber(plr:GetAttribute("Money")) or tonumber(plr:GetAttribute("Cash"))
        if not m then
            local ls = plr:FindFirstChild("leaderstats")
            if ls then
                local v = ls:FindFirstChild("Money") or ls:FindFirstChild("Cash") or ls:FindFirstChild("$")
                if v then m = tonumber(v.Value) end
            end
        end
        if not m and plr.Character then
            m = tonumber(plr.Character:GetAttribute("Money")) or tonumber(plr.Character:GetAttribute("Cash"))
        end
        if m then
            moneyStr = "$" .. tostring(math.floor(m)):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
        end
    end
    _espHideAmmo(data)

    local lines = {}
    if #nameParts > 0 then table.insert(lines, table.concat(nameParts, "  •  ")) end
    data.TagText.Size = 12
    data.TagText.Text = table.concat(lines, "\n")

    local textY = math.floor(y + 6)
    if showIcon then
        local iconSize = ICON_SIZE
        local img = _ensureESPWeaponIcon(data)
        if img then

            if data.LastWeaponIcon ~= weaponIconAsset then
                img.Image = weaponIconAsset
                img.ImageRectOffset = Vector2.new(0,0)
                img.ImageRectSize = Vector2.new(0,0)
                data.LastWeaponIcon = weaponIconAsset
            end

            _forceESPWeaponIconVisual(img)
            img.Size = UDim2.fromOffset(iconSize, iconSize)

            local headTop = T or (y - 20)
            local iconX = math.floor(cx - iconSize / 2)
            local iconY = math.floor(headTop - iconSize - 8)
            img.Position = UDim2.fromOffset(iconX, iconY)
            img.Visible = true

            local now = tick()
            if not data.NextIconVisualFix or now >= data.NextIconVisualFix then
                data.NextIconVisualFix = now + 0.18
                task.defer(function() _forceESPWeaponIconVisual(img) end)
                task.delay(0.08, function() _forceESPWeaponIconVisual(img) end)
            end
        end
    elseif data.WeaponIcon then
        data.WeaponIcon.Visible = false
    end

    data.TagText.Position = Vector2.new(cx, textY)
    data.TagText.Color = Config.ESP.NameColor or Color3.fromRGB(240,240,245)
    data.TagText.Transparency = trBase
    data.TagText.Visible = #lines > 0

    if moneyStr then
        if not data.MoneyText then
