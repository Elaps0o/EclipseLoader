-- =====================================================
local MBox = MiscTab:AddLeftGroupbox("MOVEMENT", "zap")

-- Cache original humanoid values so we can restore them on toggle-off / respawn / unload.
local _speedMul = 2
local _speedActive = false
local _speedConn
local _origCache = {} -- [humanoid] = { WalkSpeed=..., }

local function _cacheHum(hum)
    if not hum or _origCache[hum] then return end
    _origCache[hum] = { WalkSpeed = hum.WalkSpeed }
end
local function _restoreAll()
    for hum, data in pairs(_origCache) do
        pcall(function() if hum and hum.Parent then hum.WalkSpeed = data.WalkSpeed end end)
    end
    _origCache = {}
end

local function _startSpeed()
    if _speedConn then return end
    _speedConn = RunService.Heartbeat:Connect(function(dt)
        if not _speedActive then return end
        local lc = _localCharacter(); if not lc then return end
        local hrp = lc:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local hum = lc:FindFirstChildOfClass("Humanoid"); if not hum then return end
        if hum.Health <= 0 then return end
        _cacheHum(hum)
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude < 0.05 then return end
        local extra = (hum.WalkSpeed or 16) * (_speedMul - 1) * dt
        hrp.CFrame = hrp.CFrame + moveDir * extra
    end)
end
local function _stopSpeed()
    if _speedConn then _speedConn:Disconnect(); _speedConn = nil end
    _speedActive = false
    _restoreAll()
end

MBox:AddToggle("misc_speed2x",{ Text="Speed 2x", Default=false, Callback=function(v)
    Config.Misc.Speed2x = v
    if v then _speedActive = true; _startSpeed()
    else _stopSpeed() end
end }):Addcker("speed2x_key",{ Default="G", SyncToggleState=true, Mode="Toggle", Text="Speed 2x" })

-- Re-cache on respawn (values already reset by engine)
-- Re-arm Speed 2x depois de morrer/respawnar. Limpa cache de humanoids mortos
-- e força re-cache pro humanoid novo pra evitar restaurar WalkSpeed 0.
LocalPlayer.CharacterAdded:Connect(function(c)
    _origCache = {}
    local hum = c:WaitForChild("Humanoid", 5)
    if hum then
        _cacheHum(hum)
        if Config.Misc.Speed2x then _speedActive = true; _startSpeed() end
    end
end)

