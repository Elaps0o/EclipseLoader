        if not (Config and Config.Sounds and Config.Sounds.Enabled) then return end
        local catName = snd.Parent and snd.Parent.Name or ""
        local weaponName = _weaponNameForSound(snd, catName)
        if catName == "Bullet" or not _isFireSound(catName, snd) then return end
        local inf = resolvePresetInfo(catName, weaponName)
        if not inf then return end
        if not EX.originalSoundIds[snd] then EX.originalSoundIds[snd] = { SoundId=snd.SoundId, Volume=snd.Volume, PlaybackSpeed=snd.PlaybackSpeed } end
        pcall(function()
            snd.SoundId = inf.Id
            snd.Volume = inf.Volume
            snd.PlaybackSpeed = inf.Pitch
        end)
    end

