                rec.iconImageRectOffset = (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ImageRectOffset or rec.iconImageRectOffset
                rec.iconImageRectSize = (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ImageRectSize or rec.iconImageRectSize
                rec.iconScaleType = (iconLbl:IsA("ImageLabel") or iconLbl:IsA("ImageButton")) and iconLbl.ScaleType or rec.iconScaleType
