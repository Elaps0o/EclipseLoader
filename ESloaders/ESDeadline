function _EclipseRepairActivePages(forceDeep)
    pcall(function()
        if not (_NLWindow and _NLWindow.Pages) then return end
        for _, page in pairs(_NLWindow.Pages) do
            if page.Active and page.Sections then
                pcall(function()
                    if page.Items and page.Items.Page and page.Window and page.Window.Items and page.Window.Items.Content then
                        page.Items.Page.Instance.Parent = page.Window.Items.Content.Instance
                        page.Items.Page.Instance.Visible = true
                    end
                end)

                local pageLooksEmpty = forceDeep and true or false
                if not pageLooksEmpty then
                    pageLooksEmpty = true
                    for _, sec0 in pairs(page.Sections) do
                        local content0 = sec0.Items and sec0.Items.Content and sec0.Items.Content.Instance
                        if content0 then
                            for _, d in _iter(content0:GetDescendants()) do
                                if d:IsA("GuiObject") and d.Visible then
                                    pageLooksEmpty = false
                                    break
                                end
                            end
                        end
                        if not pageLooksEmpty then break end
                    end
                end

                for _, sec in pairs(page.Sections) do
                    pcall(function()
                        if sec.Items and sec.Items.Section and sec.Page and sec.Page.ColumnsData and sec.Page.ColumnsData[sec.Side] then
                            sec.Items.Section.Instance.Parent = sec.Page.ColumnsData[sec.Side].Instance
                            sec.Items.Section.Instance.Visible = true
                        end
                        if sec.Items then
                            for _, key in _iter({ "Background", "Content" }) do
                                local item = sec.Items[key]
                                if item and item.Instance and item.Instance:IsA("GuiObject") then item.Instance.Visible = true end
                            end
                        end
                    end)

                    if pageLooksEmpty and sec.Elements then
                        for _, element in pairs(sec.Elements) do
                            pcall(function()
                                local items = element.Items
                                if type(items) ~= "table" then return end
                                for _, key in _iter({
                                    "Toggle", "Indicator", "Text", "Slider", "RealSlider", "Dropdown", "RealDropdown",
                                    "ArrowIcon", "Label", "Button", "Textbox", "Keybind", "Colorpicker"
                                }) do
                                    local item = items[key]
                                    local inst = item and item.Instance
                                    if typeof(inst) == "Instance" and inst:IsA("GuiObject") and inst:IsDescendantOf(sec.Items.Content.Instance) then
                                        inst.Visible = true
                                    end
                                end
                            end)
                        end
                    end

                    if sec.TweenElements then pcall(function() sec:TweenElements(true, true) end) end
                end
            end
        end
    end)
end

