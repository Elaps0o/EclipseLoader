    local function _attachAccessory(model, accessory)
        if not (model and accessory and accessory:IsA("Accessory")) then return false end
        local handle = accessory:FindFirstChild("Handle") or accessory:FindFirstChildWhichIsA("BasePart")
        if not handle then pcall(function() accessory:Destroy() end); return false end
        accessory.Parent = model
        for _, p in ipairs(accessory:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Anchored = false
                p.CanCollide = false
                p.CanQuery = false
                p.CanTouch = false
                p.Massless = true
            end
        end
        local target, hCFrame, targetCFrame = _findAccessoryAttachment(model, handle)
        if not target then
            target = model:FindFirstChild("Head") or model:FindFirstChild("Torso") or model.PrimaryPart
            hCFrame = CFrame.new()
            targetCFrame = CFrame.new(0, 0.55, 0)
        end
        if target then
            for _, old in ipairs(handle:GetChildren()) do
                if old:IsA("Weld") or old:IsA("WeldConstraint") or old:IsA("Motor6D") then
                    pcall(function() old:Destroy() end)
                end
            end
            local weld = Instance.new("Weld")
            weld.Name = "EclipseCPMAccessoryWeld"
            weld.Part0 = target
            weld.Part1 = handle
            weld.C0 = targetCFrame or CFrame.new()
            weld.C1 = hCFrame or CFrame.new()
            weld.Parent = handle
            return true
        end
        return false
    end

