local PenMaterialLimits = {
    [Enum.Material.Plastic]=7,[Enum.Material.SmoothPlastic]=7,[Enum.Material.Wood]=7,
    [Enum.Material.WoodPlanks]=7,[Enum.Material.Cardboard]=7,
}
local PenMaterialVariantLimits = { ["IndoorWall"]=0.25, ["Sandy Brick"]=0.25 }
local function _penMatLimit(mat) return PenMaterialLimits[mat] or 0.25 end

local function GetPenetrationStats(origin, direction, maxPen, ignoreList, targetRoot)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    pcall(function() params.CollisionGroup = "Bullet" end)
    local filter = ignoreList or { LocalPlayer.Character, Camera }
    params.FilterDescendantsInstances = filter
    local backParams = RaycastParams.new()
    backParams.FilterType = Enum.RaycastFilterType.Include
    pcall(function() backParams.CollisionGroup = "Bullet" end)
    local currentOrigin, currentDir = origin, direction
    local accMat, accVar = {}, {}
    local stats = { TotalThickness=0, Success=false, FailReason="Max Steps", EndPos=Vector3.zero }
    for _ = 1, 40 do
        if not currentOrigin or not currentDir then break end
        local result = Workspace:Raycast(currentOrigin, currentDir * 1000, params)
        if not result then
            if not targetRoot then stats.Success=true; stats.EndPos=currentOrigin+currentDir*1000
            else stats.FailReason="Void" end
            break
        end
        if not result.Instance or not result.Instance.Parent then stats.FailReason="Destroyed"; break end
        if targetRoot and result.Instance:IsDescendantOf(targetRoot) then
            stats.Success=true; stats.EndPos=result.Position; stats.FailReason="Hit"; return stats
        end
        table.insert(filter, result.Instance); params.FilterDescendantsInstances = filter
        local enterPos = result.Position
        local fakeEnd = enterPos + currentDir * 1000
        backParams.FilterDescendantsInstances = { result.Instance }
        local backRes = Workspace:Raycast(fakeEnd, enterPos - fakeEnd, backParams)
        local thickness, limit = 0.5, 0.25
        if not backRes then thickness = 5; stats.FailReason="Infinite/Block"
        else
            thickness = (enterPos - backRes.Position).Magnitude
            local variant = backRes.Instance and backRes.Instance.MaterialVariant or ""
            if variant ~= "" and PenMaterialVariantLimits[variant] then
                limit = PenMaterialVariantLimits[variant]
                accVar[variant] = (accVar[variant] or 0) + thickness
                if accVar[variant] > limit + maxPen then
                    stats.FailReason = string.format("Var:%s", variant); return stats
                end
            else
                local mat = backRes.Material
                limit = _penMatLimit(mat)
                accMat[mat] = (accMat[mat] or 0) + thickness
                if accMat[mat] > limit + maxPen then
                    stats.FailReason = string.format("%s", mat.Name); return stats
                end
            end
            currentOrigin = backRes.Position
        end
        stats.TotalThickness = stats.TotalThickness + thickness
    end
    return stats
end

