        if Config.Movement.AutoStrafe and spaceHeld and inAir then
                local move = hum.MoveDirection
                local look = Camera and Camera.CFrame.LookVector or Vector3.new(0,0,-1)
                local camFlat = Vector3.new(look.X, 0, look.Z)
                local inputFlat = (move and move.Magnitude > 0.05) and Vector3.new(move.X, 0, move.Z) or nil
                local flat = camFlat
                if camFlat.Magnitude < 0.05 then
                    local cv = root.AssemblyLinearVelocity
                    local horiz = Vector3.new(cv.X, 0, cv.Z)
                    flat = (horiz.Magnitude > 0.1) and horiz or Vector3.new()
                end
                if inputFlat and inputFlat.Magnitude > 0.05 and flat.Magnitude > 0.05 then

