function _EclipseHitPossible(part, allowWallbang)
    if not part or not Camera then return false, nil end
    if IsVisible(part) then return true, { Direct=true, Success=true, TotalThickness=0 } end
    if not allowWallbang then return false, nil end
    local origin = Camera.CFrame.Position
    local delta = part.Position - origin
