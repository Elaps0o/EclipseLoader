local function _pickServer()
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", game.PlaceId)
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if not ok or not body then return nil, "HTTP failed" end
    local ok2, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok2 or type(data) ~= "table" or type(data.data) ~= "table" then return nil, "Bad JSON" end
    local pool = {}
    for _, s in _iter(data.data) do
        if s.id ~= game.JobId and (s.playing or 0) < (s.maxPlayers or 99) then
            table.insert(pool, s)
        end
    end
    if #pool == 0 then return nil, "No servers" end
    local m = Config.ServerHop.Mode
    if m == "Lowest Ping"   then table.sort(pool, function(a,b) return (a.ping or 999) < (b.ping or 999) end)
    elseif m == "Most Players"  then table.sort(pool, function(a,b) return (a.playing or 0) > (b.playing or 0) end)
    elseif m == "Least Players" then table.sort(pool, function(a,b) return (a.playing or 0) < (b.playing or 0) end)
    else for i = #pool, 2, -1 do local j = math.random(i); pool[i], pool[j] = pool[j], pool[i] end end
    return pool[1]
end
