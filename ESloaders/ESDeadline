    do
        local _sel = Config.Skins.SelectedKnife
        local _hasAlt = (_sel == "Butterfly Knife") or (_sel == "Skeleton Knife") or (_sel == "Stiletto Knife")
        local _alt = nil
        if _hasAlt then
