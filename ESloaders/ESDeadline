                if not pageLooksEmpty then
                    pageLooksEmpty = true
                    for _, sec0 in pairs(page.Sections) do
                        local content0 = sec0.Items and sec0.Items.Content and sec0.Items.Content.Instance
                        if content0 then
                            for _, d in ipairs(content0:GetDescendants()) do
                                if d:IsA("GuiObject") and d.Visible then
                                    pageLooksEmpty = false
                                    break
                                end
                            end
                        end
                        if not pageLooksEmpty then break end
                    end
                end

                for _, sec in pairs(page.Sections) do
                    pcall(function()
                        if sec.Items and sec.Items.Section and sec.Page and sec.Page.ColumnsData and sec.Page.ColumnsData[sec.Side] then
                            sec.Items.Section.Instance.Parent = sec.Page.ColumnsData[sec.Side].Instance
