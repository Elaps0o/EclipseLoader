local function _serialize()
    local function clean(t)
        local o = {}
        for k, v in pairs(t) do
            if type(v) == "table" then o[k] = clean(v)
            elseif typeof(v) == "Color3" then o[k] = { _c3=true, r=v.R, g=v.G, b=v.B }
            elseif typeof(v) == "EnumItem" then o[k] = { _enum=true, n=tostring(v) }
            elseif type(v) == "number" or type(v) == "string" or type(v) == "boolean" then o[k] = v
            end
        end
        return o
    end
    local okE, s = pcall(function() return HttpService:JSONEncode(clean(Config)) end)
    return okE and s or "{}"
end
local function _deserialize(str)
    local ok, decoded = pcall(function() return HttpService:JSONDecode(str) end)
    if not ok or type(decoded) ~= "table" then return end
    local function apply(dst, src)
        for k, v in pairs(src) do
            if type(v) == "table" and v._c3 then dst[k] = Color3.new(v.r, v.g, v.b)
            elseif type(v) == "table" and v._enum then -- skip
            elseif type(v) == "table" and type(dst[k]) == "table" then apply(dst[k], v)
            elseif type(v) ~= "table" then dst[k] = v
            end
        end
    end
    apply(Config, decoded)
end
local function _listConfigs()
    local out = {}
    if listfiles then
        local ok, files = pcall(listfiles, CFG_FOLDER)
        if ok and files then
            for _, f in _iter(files) do
                local n = tostring(f):match("([^/\\]+)$")
                if n and n:sub(-5) == ".json" then out[#out+1] = n end
            end
        end
    end
    table.sort(out)
    return out
end
