    local function _sanitizeGeneratedModel(model, cfg, keepCharacterMesh)
        if not model then return nil end
        model.Name = "CPMRig"

        local hum = model:FindFirstChildOfClass("Humanoid")
        if hum then
            for _, acc in ipairs(hum:GetAccessories()) do pcall(function() acc:Destroy() end) end
        end
        for _, d in ipairs(model:GetDescendants()) do
            if d:IsA("Shirt") or d:IsA("Pants") or d:IsA("ShirtGraphic") or d:IsA("BodyColors") then
                pcall(function() d:Destroy() end)
            elseif d:IsA("CharacterMesh") and not keepCharacterMesh then
                pcall(function() d:Destroy() end)
            end
        end
        for _, d in ipairs(model:GetDescendants()) do
            if d:IsA("Script") or d:IsA("LocalScript") or d:IsA("ModuleScript") then
                pcall(function() d:Destroy() end)
            elseif d:IsA("BasePart") then
                pcall(function()
                    d.Anchored = false
                    d.CanCollide = false
                    d.CanQuery = false
                    d.CanTouch = false
                    d.Massless = true
                end)
            end
        end
        local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")
        if hrp and hrp:IsA("BasePart") then model.PrimaryPart = hrp end
        if hum then
            pcall(function()
                hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                hum.AutoRotate = false
                hum.PlatformStand = true
                hum.EvaluateStateMachine = false
            end)
        end
        pcall(function()
            local bc = Instance.new("BodyColors")
            bc.HeadColor3, bc.LeftArmColor3, bc.RightArmColor3 = cfg.skinColor, cfg.skinColor, cfg.skinColor
            bc.LeftLegColor3, bc.RightLegColor3, bc.TorsoColor3 = cfg.skinColor, cfg.skinColor, cfg.skinColor
            bc.Parent = model
        end)
        return model
    end

    local function _buildModel(name)
        local cfg = OUTFITS[name]; if not cfg then return nil end
        if _cache[name] then
            local ok, cl = pcall(function() return _cache[name]:Clone() end)
            if ok and cl then return cl end
        end

        local desc = _makeDescription(cfg)
        local model
        local ok, generated = pcall(function()
            return Players:CreateHumanoidModelFromDescription(desc, Enum.HumanoidRigType.R15)
        end)
        if ok and generated then
            model = _sanitizeGeneratedModel(generated, cfg, cfg.bodyType == "bundle")
        end
        if not model then return nil end

        _applyLoadedAssets(model, cfg)
        _paintBody(model, cfg.skinColor)

        do
            local SUB_JOINTS = {
                LeftElbow = true, RightElbow = true,
                LeftWrist = true, RightWrist = true,
                LeftKnee  = true, RightKnee  = true,
                LeftAnkle = true, RightAnkle = true,
            }
            for _, d in ipairs(model:GetDescendants()) do
                if d:IsA("Motor6D") and SUB_JOINTS[d.Name] and d.Part0 and d.Part1 then
                    local w = Instance.new("Weld")
                    w.Name  = d.Name .. "_EclipseRigid"
                    w.Part0 = d.Part0
                    w.Part1 = d.Part1
                    w.C0    = d.C0
                    w.C1    = d.C1
                    w.Parent = d.Parent
                    pcall(function() d:Destroy() end)
                end
            end
        end

        if cfg.hideDefaultHead or cfg.hideHead then
            for _, d in ipairs(model:GetDescendants()) do
                if d:IsA("BasePart") and d.Name == "Head" then
                    pcall(function()
                        d.Transparency = 0
                        d.LocalTransparencyModifier = 0
                        d.CanCollide = false
                    end)
                end
            end
        end

        _cache[name] = model:Clone()
        return model
    end

