do
    local Players    = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LP         = Players.LocalPlayer
    local TAG        = "EclipseGlassFX"

    local touched  = {}
    local outlines = {}
    local shells   = {}

    local function _snapshot(p)
        if touched[p] then return end
        touched[p] = {
            Transparency = p.Transparency,
            Material     = p.Material,
            Reflectance  = p.Reflectance,
            Color        = p.Color,
            CastShadow   = p.CastShadow,
        }
    end

    local function _ensureShell(part, color, trans, scale)
        local sh = shells[part]
        if not (sh and sh.Parent) then
            local ok, clone = pcall(function() return part:Clone() end)
            if not ok or not clone then return end
            for _, c in ipairs(clone:GetChildren()) do

                if c:IsA("SurfaceAppearance") or c:IsA("Decal") or c:IsA("Texture")
                   or c:IsA("Highlight") or c:IsA("PointLight") or c:IsA("SpotLight")
                   or c:IsA("Beam") or c:IsA("Trail") or c:IsA("Script") or c:IsA("LocalScript") then
                    pcall(function() c:Destroy() end)
                end
            end
            pcall(function()
                clone.Name          = "EclipseGlassShell"
                clone.Anchored      = false
                clone.CanCollide    = false
                clone.CanQuery      = false
                clone.CanTouch      = false
                clone.Massless      = true
                clone.CastShadow    = false
                clone.Material      = Enum.Material.SmoothPlastic
                clone.Reflectance   = 0
                clone.Color         = color
                clone.Transparency  = trans
                clone.LocalTransparencyModifier = 0
                clone.Size          = part.Size * (scale or 1.018)
                clone.CFrame        = part.CFrame
                clone.Parent        = part
                local w = Instance.new("WeldConstraint")
                w.Part0 = part; w.Part1 = clone; w.Parent = clone
            end)
            shells[part] = clone
        else
            pcall(function()
                sh.Transparency = trans
                sh.Color        = color
                sh.Material     = Enum.Material.SmoothPlastic
                sh.Reflectance  = 0
                sh.LocalTransparencyModifier = 0
                sh.Size         = part.Size * (scale or 1.018)
            end)
        end
    end

    local function _clearShell(part)
        local sh = shells[part]
        if sh then pcall(function() sh:Destroy() end); shells[part] = nil end
    end

    local function _restorePart(p)
        local s = touched[p]; if not s then return end
        pcall(function()
            p.Transparency = s.Transparency
            p.Material     = s.Material
            p.Reflectance  = s.Reflectance
            p.Color        = s.Color
            p.CastShadow   = s.CastShadow
        end)
        local h = outlines[p]
        if h then pcall(function() h:Destroy() end); outlines[p] = nil end
        _clearShell(p)
        touched[p] = nil
    end
    local function _clearOutlines()
        for part, h in pairs(outlines) do
            pcall(function() h:Destroy() end)
            outlines[part] = nil
        end
        for part, _ in pairs(shells) do _clearShell(part) end
    end
    local function _clearAll()
        for p, _ in pairs(touched) do _restorePart(p) end
        _clearOutlines()
        pcall(function() RunService:UnbindFromRenderStep("EclipseGlassHide") end)
    end
    _G.EclipseGlassFXClear = _clearAll

    local function _normName(name)
        return tostring(name or ""):lower()
    end

    local function _isHeadOrFace(inst)
        local p = inst
        while p and p ~= workspace do
            local n = _normName(p.Name)
            if n == "head" or n == "face" or n:find("hair", 1, true) or n:find("hat", 1, true) then
                return true
            end
            if p:IsA("Tool") then break end
            p = p.Parent
        end
        return false
    end

    local weaponWords = {
        weapon=true, weapons=true, gun=true, rifle=true, pistol=true, smg=true, shotgun=true, sniper=true,
        knife=true, blade=true, bayonet=true, karambit=true, butterfly=true, stiletto=true, skeleton=true,
        ak=true, ak47=true, m4=true, m4a1=true, m4a4=true, awp=true, aug=true, famas=true, galil=true, glock=true,
        usp=true, p2000=true, p250=true, tec=true, tec9=true, five=true, fiveseven=true, cz=true, cz75=true,
        deagle=true, revolver=true, r8=true, beretta=true, dualies=true, mac=true, mac10=true, mp=true, mp5=true,
        mp7=true, mp9=true, ump=true, ump45=true, p90=true, bizon=true, nova=true, mag=true, mag7=true,
        sawed=true, sawedoff=true, xm=true, xm1014=true, negev=true, m249=true, scar=true, scar20=true,
        g3sg1=true, ssg=true, ssg08=true, sg=true, sg553=true, taser=true, zeus=true, grenade=true,
        flash=true, smoke=true, molotov=true, incendiary=true, decoy=true, he=true, c4=true, bomb=true, defuser=true,
    }

    local weaponPartWords = {
        handle=true, barrel=true, magazine=true, clip=true, trigger=true, slide=true, grip=true,
        stock=true, scope=true, sight=true, silencer=true, suppressor=true, muzzle=true, bolt=true, hammer=true,
        receiver=true, rail=true, ammo=true, bullet=true, bullets=true, chamber=true, iron=true,
        safety=true, cylinder=true, drum=true, foregrip=true, laser=true, flashlight=true,
        pump=true, forend=true, buttstock=true, sling=true, cartridge=true, cocking=true,
        edge=true, guard=true, hilt=true, sheath=true, pommel=true, tang=true,
    }

    local bodyWords = {
        arm=true, arms=true, hand=true, hands=true, glove=true, gloves=true, sleeve=true, sleeves=true,
        torso=true, upper=true, lower=true, leg=true, foot=true, feet=true, body=true, character=true,
        humanoid=true, viewmodel=true, view=true,
    }
    local overlayWords = {
        glove=true, gloves=true, sleeve=true, sleeves=true, cloth=true, clothes=true, clothing=true,
        shirt=true, pants=true, jacket=true, vest=true, armor=true, armour=true, wrap=true, wraps=true,
        strap=true, straps=true, watch=true, wrist=true, wristband=true, overlay=true, cosmetic=true,
    }

    local function _hasWord(name, words)
        local n = _normName(name):gsub("[%p_]+", " ")
        for w in n:gmatch("%w+") do
            if words[w] then return true end
        end
        return false
    end

    local function _hasBodyHint(inst, stopAt)
        local p = inst
        while p and p ~= workspace and p ~= stopAt do
            if _hasWord(p.Name, bodyWords) then return true end
            p = p.Parent
        end
        return false
    end

    local function _hasOverlayHint(inst, stopAt)
        local p = inst
        while p and p ~= workspace and p ~= stopAt do
            if _hasWord(p.Name, overlayWords) then return true end
            p = p.Parent
        end
        return false
    end

    local function _hostHasBodyHint(host)
        if not host then return false end
        if _hasWord(host.Name, bodyWords) then return true end
        for _, d in ipairs(host:GetDescendants()) do
            if _hasWord(d.Name, bodyWords) then return true end
        end
        return false
    end

    local function _isHelperPart(part)
        local n = _normName(part.Name)
        if n == "humanoidrootpart" or n == "rootpart" or n == "root" then return true end
        if n:find("hitbox", 1, true) or n:find("hurtbox", 1, true) or n:find("collider", 1, true)
            or n:find("collision", 1, true) or n:find("bbox", 1, true) or n:find("bound", 1, true)
            or n:find("box", 1, true) or n:find("camera", 1, true) or n:find("aim", 1, true)
        then
            return true
        end

        local snap = touched[part]
        local origT = (snap and snap.Transparency) or part.Transparency
        if origT >= 0.98 and not part:FindFirstChildOfClass("SurfaceAppearance") and not part:FindFirstChildOfClass("SpecialMesh") then
            return true
        end
        local s = part.Size
        if s and ((s.X > 8 and s.Y > 8) or (s.Y > 7 and (s.X > 3 or s.Z > 3))) then
            return true
        end
        return false
    end

    local function _isWeaponDesc(part, stopAt)

        if _hasWord(part.Name, weaponPartWords) then return true end
        local a = part
        local hasBody = _hasBodyHint(part, stopAt)
        while a and a ~= workspace and a ~= stopAt do
            if _hasWord(a.Name, bodyWords) then
                hasBody = true
            end
            if a:IsA("Tool") then return true end
            if a:IsA("Model") then
                local nm = _normName(a.Name)
                if _hasWord(nm, weaponWords) then

                    return true
                end

                local h = a:FindFirstChild("Handle")
                if h and h:IsA("BasePart") and not hasBody then
                    return true
                end
            end
            a = a.Parent
        end
        return false
    end

    local function _collectHosts()
        local hosts = {}
        local ch = LP and LP.Character

        if ch and ch.Parent and not _G.EclipseCPMActive then
            hosts[#hosts + 1] = ch
        end
        for _, plr in ipairs(Players:GetPlayers()) do
            local char = plr.Character
            if char and char.Parent and char ~= ch then
                hosts[#hosts + 1] = char
            end
        end
        local cam = workspace.CurrentCamera
        if cam then
            for _, top in ipairs(cam:GetChildren()) do
                if top:IsA("Model") then

                    if _hostHasBodyHint(top) then hosts[#hosts + 1] = top end
                end
            end
        end
        return hosts
    end

    local function _insideClass(part, className)
        local p = part
        while p and p ~= workspace do
            if p:IsA(className) then return true end
            p = p.Parent
        end
        return false
    end

    local function _shouldHideOnlyGlassPart(part, host)
        if not (part and part:IsA("BasePart") and host and host.Parent) then return false end
        if part.Name == "EclipseGlassShell" or _isHeadOrFace(part) or _isHelperPart(part) then return false end
        if _insideClass(part, "Accessory") then return true end
        if _hasOverlayHint(part, host) then return true end
        if _isWeaponDesc(part, host) then return false end
        return false
    end

    local function _shouldGlassPart(part, host)
        if not (part and part:IsA("BasePart") and host and host.Parent) then return false end
        if part.Name == "EclipseGlassShell" then return false end
        if _isHeadOrFace(part) or _isHelperPart(part) then return false end
        if LP and LP.Character and host == LP.Character then
            if part:IsDescendantOf(LP.Character:FindFirstChildOfClass("Tool") or Instance.new("Folder")) then return false end
            if _insideClass(part, "Accessory") or _hasOverlayHint(part, host) then return false end
            return true
        end

        if _isWeaponDesc(part, host) then return false end
        if _hasOverlayHint(part, host) then return false end
        if not _hasBodyHint(part, host) then return false end
        return true
    end

    local function _ensureOutline(part, color)

        local hl = outlines[part]
        if not (hl and hl.Parent) then
            hl = Instance.new("Highlight")
            hl.Name = "EclipseGlassHL"
            hl.Adornee = part
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.FillTransparency = 0.55
            hl.OutlineTransparency = 0
            hl.Parent = part
            outlines[part] = hl
        end
        pcall(function()
            hl.Adornee = part
            hl.FillColor = color
            hl.OutlineColor = color
            hl.Enabled = true
        end)
    end

    connectSignal(RunService.Heartbeat:Connect(function()
        if not scriptRunning then return end
        local on = Config.Visuals.GlassFX
        if not on then
            if next(touched) or next(outlines) then _clearAll() end
            return
        end
        if not ES152.tick("GlassFX.scan", 0.25) then return end
        local col       = Config.Visuals.GlassFXColor   or Color3.fromRGB(85, 190, 255)

        local transShell = 0.5
        local transBody  = 1.0
        local shellScale = 1.04

        local lpChar    = LP and LP.Character

        local hosts = _collectHosts()
        local activeParts = {}
        for p, _ in pairs(touched) do
            local keep = false
            if p.Parent then
                for _, h in ipairs(hosts) do
                    if p == h or p:IsDescendantOf(h) then
                        if _shouldGlassPart(p, h) or _shouldHideOnlyGlassPart(p, h) then keep = true; activeParts[p] = true end
                        break
                    end
                end
            end
            if not keep then _restorePart(p) end
        end
        for p, h in pairs(outlines) do
            if not activeParts[p] and (not p.Parent or not touched[p]) then
                pcall(function() h:Destroy() end)
