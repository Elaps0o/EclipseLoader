function _findGloveSkinSource(gsr, side)
    if not gsr then return nil end
    local candidates = {
        side,
        side == "Left Arm" and "Left" or "Right",
        side == "Left Arm" and "L" or "R",
        side .. " Glove",
        "Glove",
    }
    for _, n in ipairs(candidates) do
        local src = gsr:FindFirstChild(n)
        if src then return src end
    end
    for _, d in ipairs(gsr:GetDescendants()) do
        local n = tostring(d.Name)
        if d:IsA("SurfaceAppearance") and (n == side or n:find(side == "Left Arm" and "Left" or "Right", 1, true)) then return d end
        if d:IsA("BasePart") and n == "Glove" then return d end
    end
    return nil
end

function _copyGloveSkinDirect(glove, source, sourceKey, gsr)
    if not (glove and glove:IsA("BasePart") and source) then return false end
    local visual = source
    if not visual:IsA("SurfaceAppearance") then
        local nested = visual:FindFirstChild("Glove", true)
        if nested and nested:IsA("BasePart") then visual = nested end
    end

    local surfaceList = {}
    if visual:IsA("SurfaceAppearance") then
        table.insert(surfaceList, visual)
    else
        for _, d in ipairs(visual:GetDescendants()) do
            if d:IsA("SurfaceAppearance") then table.insert(surfaceList, d) end
        end
    end
    if #surfaceList == 0 and gsr then
        for _, d in ipairs(gsr:GetChildren()) do
            if d:IsA("SurfaceAppearance") then table.insert(surfaceList, d) end
        end
    end

    pcall(_saveOriginalSA, glove)
    for _, old in ipairs(glove:GetChildren()) do
        if old:IsA("SurfaceAppearance") then old:Destroy() end
    end

    for _, sa in ipairs(surfaceList) do
        local c = sa:Clone()
        c.Name = "SurfaceAppearance"
        pcall(function()
            c:SetAttribute("EclipseSkinSurface", true)
            c:SetAttribute("EclipseSurfaceSource", sourceKey)
        end)
        c.Parent = glove
    end
    if visual:IsA("MeshPart") and glove:IsA("MeshPart") and visual.TextureID and visual.TextureID ~= "" then
        glove.TextureID = visual.TextureID
    end
    if visual:IsA("BasePart") then
        glove.Color = visual.Color
        glove.Material = visual.Material
    end
    return #surfaceList > 0 or visual:IsA("BasePart")
end

function _applyGloveSideDirect(glove, side, gloveSkin, gsr, directSurfaceApps, sourceKey)
    if glove:GetAttribute("EclipseSkinSource") == sourceKey and glove:GetAttribute("SkinApplied") == gloveSkin then return end
    _restoreGloveSurfaceOnly(glove, side)
