-- =====================================================
-- XENO TEAM CHECK (PlayerGui friendly-indicator scoring)
-- Detects the small colored indicators Deadline draws above teammates.
-- =====================================================
local _XenoTeam = {
    Friendlies      = {},   -- [model] = true
    Scores          = {},   -- [model] = int
    ConfirmedEnemy  = {},   -- [model] = true
    EnemyConfirms   = {},   -- [model] = int
    Indicators      = {},   -- Vector2 screen positions
    _lastScan       = 0,
}

local function _XT_ScanIndicators()
    _XenoTeam.Indicators = {}
    local pg = LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return end
    local count = 0
    for _, gui in _iter(pg:GetDescendants()) do
        if count >= 60 then break end
        if gui:IsA("GuiObject") and gui.Visible then
            local sz = gui.AbsoluteSize
            if sz.X > 0 and sz.Y > 0 and sz.X < 22 and sz.Y < 22 then
                local ok = false
                if gui:IsA("Frame") and gui.BackgroundTransparency < 0.9 then
                    local c = gui.BackgroundColor3
                    if c.G > 0.5 or c.B > 0.5 then ok = true end
                elseif gui:IsA("ImageLabel") and gui.ImageTransparency < 0.5 and gui.Image ~= "" then
                    ok = true
                end
                if ok then
                    local p = gui.AbsolutePosition
                    count = count + 1
                    _XenoTeam.Indicators[count] = Vector2.new(p.X + sz.X/2, p.Y + sz.Y/2)
                end
            end
        end
    end
end

local function _XT_UpdateStatus()
    local cam = Workspace.CurrentCamera; if not cam then return end
    local folder = _charFolder(); if not folder then return end
    for _, model in _iter(folder:GetChildren()) do
        if model:IsA("Model") and model.Name ~= LocalPlayer.Name then
            local hrp = model:FindFirstChild("humanoid_root_part") or model:FindFirstChild("HumanoidRootPart")
            if hrp then
                if _XenoTeam.ConfirmedEnemy[model] then
                    -- locked in as enemy
                else
                    local sp, on = cam:WorldToViewportPoint(hrp.Position)
                    if on and sp.Z > 0 then
                        local sp2 = Vector2.new(sp.X, sp.Y)
                        local found = false
                        for i = 1, #_XenoTeam.Indicators do
                            if (_XenoTeam.Indicators[i] - sp2).Magnitude < 130 then found = true; break end
                        end
                        local sc = _XenoTeam.Scores[model] or 0
                        local cf = _XenoTeam.EnemyConfirms[model] or 0
                        if found then sc = math.min(sc + 2, 8); cf = math.max(cf - 2, 0)
                        else          sc = math.max(sc - 1, 0); cf = cf + 2 end
                        _XenoTeam.Scores[model] = sc
                        _XenoTeam.EnemyConfirms[model] = cf
                        if sc >= 3 then _XenoTeam.Friendlies[model] = true
                        elseif cf >= 4 then _XenoTeam.Friendlies[model] = nil; _XenoTeam.ConfirmedEnemy[model] = true
                        elseif sc <= 0 then _XenoTeam.Friendlies[model] = nil end
                    end
                end
            end
        end
    end
    -- cleanup
    for m,_ in pairs(_XenoTeam.Friendlies)     do if not m.Parent then _XenoTeam.Friendlies[m]=nil end end
    for m,_ in pairs(_XenoTeam.ConfirmedEnemy) do if not m.Parent then _XenoTeam.ConfirmedEnemy[m]=nil end end
    for m,_ in pairs(_XenoTeam.Scores)         do if not m.Parent then _XenoTeam.Scores[m]=nil end end
    for m,_ in pairs(_XenoTeam.EnemyConfirms)  do if not m.Parent then _XenoTeam.EnemyConfirms[m]=nil end end
end

task.spawn(function()
    while task.wait(0.4) do
        if not scriptRunning then break end
        if Config.Global and Config.Global.TeamCheck then
            pcall(_XT_ScanIndicators)
            pcall(_XT_UpdateStatus)
        end
    end
end)

local function XT_IsFriendly(model) return _XenoTeam.Friendlies[model] == true end
local function XT_IsChecking(model) return not _XenoTeam.ConfirmedEnemy[model] and not _XenoTeam.Friendlies[model] end
local function XT_StatusColor(model)
    if _XenoTeam.ConfirmedEnemy[model] then return Color3.fromRGB(255,75,85) end
    if _XenoTeam.Friendlies[model]     then return Color3.fromRGB(80,180,255) end
    return Color3.fromRGB(150,150,150)
end
local function XT_StatusText(model)
    if _XenoTeam.ConfirmedEnemy[model] then return "ENEMY" end
    if _XenoTeam.Friendlies[model]     then return "FRIENDLY" end
    return "CHECKING"
end

-- Override isEnemyChar to consult xeno team when global team-check is on.
local _isEnemyBase = isEnemyChar
isEnemyChar = function(model)
    if not model or model.Name == LocalPlayer.Name then return false end
    if Config.Global and Config.Global.TeamCheck then
        if _XenoTeam.Friendlies[model] then return false end
        -- Also honor Players.Team when available
        local mine = LocalPlayer.Team
        local plr  = Players:FindFirstChild(model.Name)
        if mine and plr and plr.Team and plr.Team == mine then return false end
        return true
    end
    return _isEnemyBase(model)
end

