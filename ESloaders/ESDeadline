do
    local Players    = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LP         = Players.LocalPlayer
    local ATTR       = "EclipseDeadHL"

    local dead    = {}
    local tracked = {}
    local hooked  = {}

    local function _cleanup(char)
        dead[char]    = nil
        hooked[char]  = nil
        local h = tracked[char]
        if h then pcall(function() h:Destroy() end); tracked[char] = nil end
    end
    local function _cleanAll()
        for c, _ in pairs(tracked) do _cleanup(c) end
        for c, _ in pairs(dead)    do dead[c]    = nil end
        for c, _ in pairs(hooked)  do hooked[c]  = nil end
    end
    _G.EclipseDeadESPClear = _cleanAll

    local function _flagDead(char) if char then dead[char] = true end end

    local function _hookChar(char)
        if not char or hooked[char] then return end
        hooked[char] = true
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            if hum.Health <= 0 then _flagDead(char) end
            connectSignal(hum.Died:Connect(function() if scriptRunning then _flagDead(char) end end))
            connectSignal(hum.HealthChanged:Connect(function(h) if scriptRunning and h <= 0 then _flagDead(char) end end))
        end
    end

    local function _bindPlayer(plr)
        if plr == LP then return end
        if plr.Character then _hookChar(plr.Character) end
        connectSignal(plr.CharacterAdded:Connect(function(c)
            if not scriptRunning then return end

            for c2,_ in pairs(tracked) do
                if c2 ~= c and c2:IsDescendantOf(game) == false then _cleanup(c2) end
            end
            task.wait(0.2); _hookChar(c)
        end))
        connectSignal(plr.CharacterRemoving:Connect(function(c) if scriptRunning then _cleanup(c) end end))
    end
    for _, p in ipairs(Players:GetPlayers()) do _bindPlayer(p) end
    connectSignal(Players.PlayerAdded:Connect(function(p) if scriptRunning then _bindPlayer(p) end end))
    connectSignal(Players.PlayerRemoving:Connect(function(p)
        if p.Character then _cleanup(p.Character) end
    end))

    connectSignal(RunService.Heartbeat:Connect(function()
        if not scriptRunning then return end
        local on  = Config.Visuals.DeadESP
        local col = Config.Visuals.DeadESPColor or Color3.fromRGB(255,60,60)
        if not on then
            if next(tracked) then
                for c, h in pairs(tracked) do pcall(function() h:Destroy() end); tracked[c] = nil end
            end
            return
        end

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LP and plr.Character then
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health <= 0 then dead[plr.Character] = true end
                if not hooked[plr.Character] then _hookChar(plr.Character) end
            end
        end

        for char, _ in pairs(dead) do
            if char and char.Parent then
                local h = tracked[char]
                if not (h and h.Parent) then
                    h = Instance.new("Highlight")
                    h.Name = "EclipseDeadESP"
                    h:SetAttribute(ATTR, true)
                    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    h.FillTransparency = 0.4
                    h.OutlineTransparency = 0
                    h.Adornee = char
                    h.Parent  = char
                    tracked[char] = h
                end
                h.FillColor    = col
                h.OutlineColor = col
                h.Enabled      = true
            else
                _cleanup(char)
            end
        end
    end))
end

