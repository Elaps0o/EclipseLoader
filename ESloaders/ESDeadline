-- =====================================================
-- CHAR / TEAM RESOLUTION (Deadline-specific)
-- =====================================================
-- Team resolution priority:
--   1) game:GetService("Teams") -> Player.Team (real team object)
--   2) character model attribute "team" (numeric-string team id)
--   3) character model attribute "Team" / "teamId" / "TeamId"
local TeamsSvc = game:GetService("Teams")

local function _charTeam(model)
    if not model then return nil end
    -- Try player.Team first
    local plr = Players:FindFirstChild(model.Name)
    if plr and plr.Team then return "T:"..tostring(plr.Team.Name) end
    -- Try attributes (Deadline stores team id as attribute)
    for _, key in _iter({"team","Team","teamId","TeamId","team_id"}) do
        local ok, v = pcall(function() return model:GetAttribute(key) end)
        if ok and v ~= nil then return "A:"..tostring(v) end
    end
    return nil
end

local function _localCharacter()
    local f = _charFolder(); if not f then return nil end
    local c = LocalPlayer.Character
    if c and c.Parent == f then return c end
    for _, m in _iter(f:GetChildren()) do
        if m.Name == LocalPlayer.Name then return m end
    end
    return c
end

local function _localTeam()
    -- LocalPlayer.Team is the most reliable source
    if LocalPlayer.Team then return "T:"..tostring(LocalPlayer.Team.Name) end
    return _charTeam(_localCharacter())
end

local function _plrFromChar(model)
    return Players:FindFirstChild(model.Name)
end

local function isEnemyChar(model)
    if not model then return false end
    if model.Name == LocalPlayer.Name then return false end
    local mine = _localTeam()
    local his  = _charTeam(model)
    -- If we can resolve both and they match -> ally
    if mine and his and mine == his then return false end
    return true
end

-- Map friendly part names to actual Deadline part names (lowercase first — Deadline uses lowercase)
local PART_MAP = {
    Head  = { "head", "Head" },
    Neck  = { "neck", "Neck", "head", "Head" },
    Torso = { "torso", "Torso", "UpperTorso", "humanoid_root_part", "HumanoidRootPart" },
    Legs  = { "left_leg", "right_leg", "LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot" },
}
local function resolveTargetPart(model, wanted)
    local list = PART_MAP[wanted] or PART_MAP.Head
    for _, n in _iter(list) do
        local p = model:FindFirstChild(n)
        if p and p:IsA("BasePart") then return p end
    end
    return model:FindFirstChild("head") or model:FindFirstChild("Head")
        or model:FindFirstChild("humanoid_root_part") or model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChildWhichIsA("BasePart")
end

local function getCharParts(model)
    if not model or not model.Parent then return nil end
    local hum = model:FindFirstChildOfClass("Humanoid")
    -- Deadline uses lowercase part names
    local hrp = model:FindFirstChild("humanoid_root_part")
             or model:FindFirstChild("HumanoidRootPart")
             or model:FindFirstChild("torso")
             or model:FindFirstChild("Torso")
             or model:FindFirstChild("UpperTorso")
             or model:FindFirstChildWhichIsA("BasePart")
    local head = model:FindFirstChild("head") or model:FindFirstChild("Head") or hrp
    if not hrp then return nil end
    -- Deadline models often have no Humanoid; only skip if humanoid exists AND is dead
    if hum and hum.Health <= 0 and (Config.Global and Config.Global.IgnoreDead) then return nil end
    return hrp, hum, head
end

