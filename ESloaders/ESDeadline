    local function _loadAssetChildren(id)

        local function _filterInstances(list)
            local out = {}
            for _, v in ipairs(list or {}) do
                if typeof(v) == "Instance" then out[#out+1] = v end
            end
            return out
        end
        local ok, res = pcall(function()
            return game:GetObjects("rbxassetid://" .. tostring(id))
        end)
        if ok and typeof(res) == "table" then
            local kids = _filterInstances(res)
            if kids[1] then return kids end
        end
        local ok2, asset = pcall(function() return InsertService:LoadAsset(id) end)
        if ok2 and typeof(asset) == "Instance" then
            local kids = _filterInstances(asset:GetChildren())
            for _, k in ipairs(kids) do k.Parent = nil end
            pcall(function() asset:Destroy() end)
            return kids
        end
        return {}
    end

    local function _paintBody(model, color)
        local function _insideAccessory(inst)
            local a = inst and inst.Parent
            while a and a ~= model and a ~= workspace do
                if a:IsA("Accessory") then return true end
                a = a.Parent
            end
            return false
        end
        for _, p in ipairs(model:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" and not _insideAccessory(p) then
                pcall(function() p.Color = color end)
            end
        end
    end

    local function _csv(list)
        local t = {}
        for _, id in ipairs(list or {}) do t[#t+1] = tostring(id) end
        return table.concat(t, ",")
    end

    local function _mergeCsv(base, ids)
        if not ids or #ids == 0 then return base end
        local t = {}
        if base and base ~= "" then t[#t+1] = base end
        for _, id in ipairs(ids) do t[#t+1] = tostring(id) end
        return table.concat(t, ",")
    end

    local function _makeDescription(cfg)
        local desc = Instance.new("HumanoidDescription")

        local bundleData  = cfg.bodyBundle    and _fetchBundle(cfg.bodyBundle)    or nil
        local overlayData = cfg.overlayBundle and _fetchBundle(cfg.overlayBundle) or nil
        local headData    = cfg.headBundle    and _fetchBundle(cfg.headBundle)    or nil
        pcall(function()
            desc.HeadColor     = cfg.skinColor
            desc.LeftArmColor  = cfg.skinColor
            desc.RightArmColor = cfg.skinColor
            desc.LeftLegColor  = cfg.skinColor
            desc.RightLegColor = cfg.skinColor
            desc.TorsoColor    = cfg.skinColor
            if cfg.shirt then desc.Shirt = cfg.shirt end
            if cfg.pants then desc.Pants = cfg.pants end
            local function bundleAcc(field)
                local a = {}
                if bundleData and bundleData.accessories[field] then
                    for _, id in ipairs(bundleData.accessories[field]) do a[#a+1] = id end
                end
                if overlayData and overlayData.accessories[field] then
                    for _, id in ipairs(overlayData.accessories[field]) do a[#a+1] = id end
                end
                if headData and headData.accessories[field] then
                    for _, id in ipairs(headData.accessories[field]) do a[#a+1] = id end
                end
                return a
            end
            desc.HairAccessory      = _mergeCsv(_csv(cfg.hair),      bundleAcc("HairAccessory"))
            desc.HatAccessory       = _mergeCsv(_csv(cfg.hat),       bundleAcc("HatAccessory"))
            desc.FaceAccessory      = _mergeCsv(_csv(cfg.face),      bundleAcc("FaceAccessory"))
            desc.NeckAccessory      = _mergeCsv(_csv(cfg.neck),      bundleAcc("NeckAccessory"))
            desc.ShouldersAccessory = _mergeCsv(_csv(cfg.shoulders), bundleAcc("ShouldersAccessory"))
            desc.BackAccessory      = _mergeCsv(_csv(cfg.back),      bundleAcc("BackAccessory"))
            desc.WaistAccessory     = _mergeCsv(_csv(cfg.waist),     bundleAcc("WaistAccessory"))
            desc.FrontAccessory     = _mergeCsv(_csv(cfg.front),     bundleAcc("FrontAccessory"))
            local function _bodyAssetId(v)
                if typeof(v) == "table" then return v.asset or v.assetId or v.id or v[1] end
                return v
            end
            if cfg.bodyAssets then
                if cfg.bodyAssets.Head     then desc.Head     = _bodyAssetId(cfg.bodyAssets.Head) end
                if cfg.bodyAssets.Torso    then desc.Torso    = _bodyAssetId(cfg.bodyAssets.Torso) end
                if cfg.bodyAssets.RightArm then desc.RightArm = _bodyAssetId(cfg.bodyAssets.RightArm) end
                if cfg.bodyAssets.LeftArm  then desc.LeftArm  = _bodyAssetId(cfg.bodyAssets.LeftArm) end
                if cfg.bodyAssets.LeftLeg  then desc.LeftLeg  = _bodyAssetId(cfg.bodyAssets.LeftLeg) end
                if cfg.bodyAssets.RightLeg then desc.RightLeg = _bodyAssetId(cfg.bodyAssets.RightLeg) end
            end
            if cfg.bodyAssets and cfg.bodyAssets.Head then
                desc.Head = _bodyAssetId(cfg.bodyAssets.Head)
            end
            if bundleData then
                if bundleData.body.Torso    then desc.Torso    = bundleData.body.Torso end
                if bundleData.body.RightArm then desc.RightArm = bundleData.body.RightArm end
                if bundleData.body.LeftArm  then desc.LeftArm  = bundleData.body.LeftArm end
                if bundleData.body.LeftLeg  then desc.LeftLeg  = bundleData.body.LeftLeg end
                if bundleData.body.RightLeg then desc.RightLeg = bundleData.body.RightLeg end
                if bundleData.body.Head and not (headData and headData.body.Head) then
                    desc.Head = bundleData.body.Head
                end
            end
            if headData and headData.body.Head then desc.Head = headData.body.Head end

            local isBundle = (bundleData ~= nil) or (cfg.bodyType == "mickey")
            desc.HeightScale = cfg.heightScale or 1.00
            desc.WidthScale  = cfg.widthScale  or 1.00
            desc.DepthScale  = cfg.depthScale  or 1.00
            desc.HeadScale   = cfg.headScale   or 1.00
            desc.ProportionScale = 0.00
            desc.BodyTypeScale = cfg.bodyTypeScale or (isBundle and 1.00 or 0.00)
        end)
        return desc
    end

