function _applyPanelSavedPosition(name, frame)
    if not frame or type(name) ~= "string" then return end
    Config.UI = Config.UI or {}
    Config.UI.PanelPositions = Config.UI.PanelPositions or {}
    local saved = Config.UI.PanelPositions[name]
    if type(saved) == "table"
        and type(saved.XS) == "number" and type(saved.XO) == "number"
        and type(saved.YS) == "number" and type(saved.YO) == "number" then
        pcall(function()
            frame.Position = UDim2.new(saved.XS, saved.XO, saved.YS, saved.YO)
        end)
    end
end

function _findGuiChildByHint(root, hints)
    if not root or typeof(root) ~= "Instance" then return nil end
    local seen = {}
    local function walk(inst)
        if not inst or typeof(inst) ~= "Instance" or seen[inst] then return nil end
        seen[inst] = true
        if inst:IsA("GuiObject") then
            local name = tostring(inst.Name or "")
            local lname = string.lower(name)
            for _, hint in ipairs(hints or {}) do
                local h = tostring(hint or "")
                if h ~= "" and (name == h or lname:find(string.lower(h), 1, true)) then
                    return inst
                end
            end
        end
        for _, child in ipairs(inst:GetChildren()) do
            local found = walk(child)
            if found then return found end
        end
        return nil
    end
    return walk(root)
end

function _bindPanelPosition(name, frame)
    if not frame or type(name) ~= "string" then return end
    Config.UI = Config.UI or {}
    Config.UI.PanelPositions = Config.UI.PanelPositions or {}
    _EclipsePanelFrames[name] = frame
    _applyPanelSavedPosition(name, frame)

    pcall(function()
        connectSignal(frame:GetPropertyChangedSignal("Position"):Connect(function()
            if not scriptRunning then return end
            local p = frame.Position
            Config.UI.PanelPositions[name] = {
                XS = p.X.Scale, XO = p.X.Offset,
                YS = p.Y.Scale, YO = p.Y.Offset,
            }
        end))
    end)
end

function _tryBindNamedPanel(name, root, hints)
    local frame = _findGuiChildByHint(root, hints)
    if frame and frame:IsA("GuiObject") then
        _bindPanelPosition(name, frame)
        return frame
    end
    return nil
end

function _reapplyAllPanelPositions()
    for name, frame in pairs(_EclipsePanelFrames) do
        if frame and frame.Parent then
            _applyPanelSavedPosition(name, frame)
        end
    end
end

