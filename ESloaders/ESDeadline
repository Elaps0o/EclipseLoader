            for _, pl in ipairs(Players:GetPlayers()) do
                if pl ~= LocalPlayer then
                    local skip = (not _IS_DEATHMATCH) and Config.TeamCheck and IsAlly and IsAlly(pl)
                    if not skip then
                        local pch = pl.Character
                        local h   = pch and pch:FindFirstChildOfClass("Humanoid")
                        local hd  = pch and (pch:FindFirstChild("Head") or pch:FindFirstChild("HumanoidRootPart"))
                        if h and h.Health > 0 and hd then
                            local sp, on = Camera:WorldToViewportPoint(hd.Position)
                            if on and sp.Z > 0 then
                                local dx, dy = sp.X - cx, sp.Y - cy
                                if (dx*dx + dy*dy) <= (fov*fov) and IsVisible and IsVisible(hd) then
                                    enemyInFov = true; break
                                end
                            end
                        end
                    end
                end
            end
        end

        if isShooting or enemyInFov then
            local move = hum.MoveDirection
            local isMoving = move and move.Magnitude > 0
            local shouldStop = false
            if not isMoving then shouldStop = true end
            if isShooting then shouldStop = true end
            if HasOpt("Move Between Shots") and not isShooting and isMoving then
                shouldStop = false
            end
            local canStop = grounded or HasOpt("In Air")
            if HasOpt("On Land") and not grounded then canStop = false end
            if shouldStop and canStop then
                local vel = root.AssemblyLinearVelocity
                local horiz = Vector3.new(vel.X, 0, vel.Z)
                if horiz.Magnitude > 0.1 then
                    root.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
                    pcall(function() hum:MoveTo(root.Position) end)
                end
            end
        end
    end

    _doJBEB(char, hum, root)
end

function _doJBEB(char, hum, root)
    if not (Config.Movement.Jumpbug or Config.Movement.Edgebug) then return end
    local now = tick()
    local dt = now - _MV.JB_LastTick; if dt <= 0 then dt = 1/60 end
    _MV.JB_LastTick = now
    _jbebSetFilter(char)
    local vel = root.AssemblyLinearVelocity
    local pos = root.Position
    local vy = vel.Y
    local inAir = (hum.FloorMaterial == Enum.Material.Air)
    local onGround = _jbebGround(pos)
    if _MV.JBCooldown > 0 then _MV.JBCooldown = _MV.JBCooldown - dt end
    if _MV.EB_Active then
        if not Config.Movement.Edgebug then
            _MV.EB_Active = false
        elseif (onGround and vy <= 1) or not _jbebStillEdge(pos) or (tick() - _MV.EB_StartTime > 2.0) then
            _MV.EB_Active = false
        else
            root.AssemblyLinearVelocity = Vector3.new(vel.X * 0.995, 0, vel.Z * 0.995)
            return
        end
    end
    local grd = (onGround and vy <= 1) or not inAir
    if not grd then
        _MV.JBEB_WasAir = true; _MV.JBEB_LandedFrame = false
        if vy < -1 then _MV.JBEB_FallFrames = _MV.JBEB_FallFrames + 1 end
    end
    if grd and _MV.JBEB_WasAir then
        _MV.JBEB_LandedFrame = true; _MV.JBEB_WasAir = false
    elseif grd and not _MV.JBEB_WasAir then
        _MV.JBEB_LandedFrame = false
    end
    if Config.Movement.Jumpbug and _MV.JBEB_LandedFrame and _MV.JBCooldown <= 0
        and _MV.JBEB_FallFrames >= _MV.JB_MIN_FRAMES then
        local hSpeed = math.sqrt(vel.X * vel.X + vel.Z * vel.Z)
        local newH = math.min(hSpeed + _MV.JB_HORIZ_BOOST, 24.5)
        local newVY = vy + _MV.JB_VERT_BOOST
        if hSpeed > 0.5 then
            local dir = Vector3.new(vel.X, 0, vel.Z).Unit
            root.AssemblyLinearVelocity = Vector3.new(dir.X * newH, newVY, dir.Z * newH)
        else
            root.AssemblyLinearVelocity = Vector3.new(vel.X, newVY, vel.Z)
        end
        _MV.JBCooldown = 0.4; _MV.JBActive = true; _MV.JBEB_FallFrames = 0
        task.delay(0.2, function() _MV.JBActive = false end)
    end
    if grd and not _MV.JBEB_LandedFrame then _MV.JBEB_FallFrames = 0 end
    if Config.Movement.Edgebug and not grd and vy < -8
        and not _MV.EB_Active and not _MV.JBActive then
        if _jbebNearEdge(pos) then
            _MV.EB_Active = true; _MV.EB_StartTime = tick(); _MV.JBEB_FallFrames = 0
            root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
        end
    end
end

