function _applyNLPanelStyle(frame, opts)
    if not frame then return end
    opts = opts or {}
    local th     = (NLLib and NLLib.Theme) or {}
    local bg     = th["Section Background"]  or Color3.fromRGB(27, 25, 29)
    local border = Color3.fromRGB(0, 0, 0)
    local accent = th["Accent"]              or Color3.fromRGB(140, 90, 255)
    local grad   = th["AccentGradient"]      or Color3.fromRGB(70, 40, 160)

    frame.BackgroundColor3       = bg
    frame.BackgroundTransparency = opts.Transparency or 0.30
    frame.BorderSizePixel        = 0

    for _, ch in ipairs(frame:GetChildren()) do
        if ch.Name == "EclipseGlow" or ch.Name == "EclipseAccentBar"
        or ch.Name == "EclipsePanelGrad" then
            ch:Destroy()
        end
    end

    local corner = frame:FindFirstChildOfClass("UICorner") or Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(0, opts.Corner or 4)

    local stroke = frame:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke", frame)
    stroke.Color = border; stroke.Thickness = 1; stroke.Transparency = 0
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    if opts.AccentBar ~= false then
        local bar = Instance.new("Frame", frame)
        bar.Name = "EclipseAccentBar"; bar.BorderSizePixel = 0
        bar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        bar.Position = UDim2.fromOffset(0, 0)
        bar.Size = UDim2.new(1, 0, 0, 2)
        bar.ZIndex = (frame.ZIndex or 1) + 2
        Instance.new("UICorner", bar).CornerRadius = UDim.new(0, opts.Corner or 4)
        local bgr = Instance.new("UIGradient", bar)
        bgr.Name = "EclipsePanelGrad"
        bgr.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, accent),
            ColorSequenceKeypoint.new(1, grad),
        }
        pcall(function()
            if NLLib and bgr.AddToTheme then
                bgr:AddToTheme({ Color = function()
                    return ColorSequence.new{
                        ColorSequenceKeypoint.new(0, (NLLib.Theme and NLLib.Theme.Accent) or accent),
                        ColorSequenceKeypoint.new(1, (NLLib.Theme and NLLib.Theme.AccentGradient) or grad),
                    }
                end })
            end
        end)
    end
end

