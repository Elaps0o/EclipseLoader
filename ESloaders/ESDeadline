        pcall(function() Library:Notify({Title="Server Hop", Description=string.format("Teleport → %d players · %dms", s.playing or 0, s.ping or 0), Time=3}) end)
        pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, LocalPlayer) end)
        task.wait(4); SH_STATE.busy = false
    end)
end })
