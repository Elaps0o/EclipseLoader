function destroySmokeFolder(folder)
    if not folder or SmokeDestroyed[folder] then return end
    SmokeDestroyed[folder] = true
    local processed = 0
    for _, d in ipairs(folder:GetDescendants()) do
        processed = processed + 1
        if (processed % 18) == 0 then EclipseYield() end
        if d:IsA("ParticleEmitter") or d:IsA("Smoke") or d:IsA("Fire") or d:IsA("Beam") or d:IsA("Trail") then
            pcall(function() d.Enabled = false end)
        end
        if d:IsA("BasePart") then
            pcall(function() d.Transparency = 1 end)
            pcall(function() d.CanCollide = false end)
        end
    end
    pcall(function() folder:Destroy() end)
end

local function queueSmokeFolder(folder)
    if not folder or SmokeDestroyed[folder] or SmokeQueue[folder] then return end
    SmokeQueue[folder] = true
    if SmokeQueueRunning then return end
    SmokeQueueRunning = true
    task.spawn(function()
        while scriptRunning do
            local nextFolder = nil
            for f, _ in pairs(SmokeQueue) do
                nextFolder = f
                SmokeQueue[f] = nil
                break
            end
            if not nextFolder then break end
            if nextFolder.Parent and not SmokeDestroyed[nextFolder] then
                pcall(destroySmokeFolder, nextFolder)
            end
            EclipseYield()
        end
        SmokeQueueRunning = false
        if scriptRunning and next(SmokeQueue) then
            local pending = {}
            for f, _ in pairs(SmokeQueue) do
                pending[#pending + 1] = f
                SmokeQueue[f] = nil
            end
            for _, f in ipairs(pending) do
                queueSmokeFolder(f)
            end
        end
    end)
end

