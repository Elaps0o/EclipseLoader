local HealthGrad = {
    {threshold=0.00, color=Color3.fromRGB(200, 30, 40)},
    {threshold=0.50, color=Color3.fromRGB(235,170, 30)},
    {threshold=1.00, color=Color3.fromRGB( 60,200, 70)},
}
function GetHealthColor(pct)
    if Config and Config.ESP and typeof(Config.ESP.HealthColor) == "Color3" then
        return Config.ESP.HealthColor
    end
    pct = math.clamp(pct, 0, 1)
    for i = 2, #HealthGrad do
        local cur, prev = HealthGrad[i], HealthGrad[i-1]
        if pct <= cur.threshold then
            local t = (pct - prev.threshold) / (cur.threshold - prev.threshold)
            local a, b = prev.color, cur.color
            return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
        end
    end
    return HealthGrad[#HealthGrad].color
end

