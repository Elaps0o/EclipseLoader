    local function _killCharVisible(char)
        if not char then return false end
        local cam = Workspace.CurrentCamera
        if not cam then return false end
        local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
        if not root then return false end
        local camPos = cam.CFrame.Position
        if (camPos - root.Position).Magnitude > 500 then return false end
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local ex = { char }
        if LocalPlayer.Character then table.insert(ex, LocalPlayer.Character) end
        rp.FilterDescendantsInstances = ex
        rp.IgnoreWater = true

        local candidates = {
            "Head","UpperTorso","LowerTorso","Torso","HumanoidRootPart",
            "LeftUpperArm","RightUpperArm","LeftLowerArm","RightLowerArm",
            "LeftHand","RightHand","LeftUpperLeg","RightUpperLeg",
            "LeftFoot","RightFoot"
        }
        for _, name in ipairs(candidates) do
            local p = char:FindFirstChild(name)
            if p and p:IsA("BasePart") then
                local sp, onScreen = cam:WorldToViewportPoint(p.Position)
                if onScreen and sp.Z > 0 then
                    local dir = p.Position - camPos
                    local mag = dir.Magnitude
                    local hit = Workspace:Raycast(camPos, dir, rp)
                    if not hit or (hit.Position - camPos).Magnitude >= (mag - 1.5) then
                        return true
                    end
                end
            end
        end
        return false
    end

