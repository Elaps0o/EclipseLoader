function _hudColorLooksPulsed(col)
    return (not col) or (col.R >= 0.92 and col.G >= 0.92 and col.B >= 0.92)
end

function _hudDefaultIconTintForTeam(teamKey)
    if teamKey == "Terrorists" then return Color3.fromRGB(226, 132, 62) end
    if teamKey == "Counter-Terrorists" then return Color3.fromRGB(168, 188, 224) end
    return Color3.fromRGB(188, 196, 208)
end

function _hudDefaultNameTintForTeam(teamKey)
    if teamKey == "Terrorists" then return Color3.fromRGB(232, 145, 72) end
    if teamKey == "Counter-Terrorists" then return Color3.fromRGB(172, 194, 232) end
    return Color3.fromRGB(210, 216, 226)
end

function _hudColorTeamGuess(col)
    if not col or _hudColorLooksPulsed(col) then return nil end
    if col.R > 0.58 and col.G > 0.32 and col.G < 0.78 and col.B < 0.55 and col.R > col.B * 1.35 then return "Terrorists" end
    if col.B > 0.52 and col.R < 0.82 and col.B >= col.R * 1.08 then return "Counter-Terrorists" end
    return nil
end

function _hudTintAllowedForTeam(col, teamKey)
    local guessed = _hudColorTeamGuess(col)
    return guessed == nil or teamKey == nil or teamKey == "Unknown" or guessed == teamKey
end

function _hudIconLooksAnimating(slotFrame, iconLbl)
    if not (slotFrame and iconLbl) then return false end
    local sfSize = slotFrame.AbsoluteSize
    local absImg = iconLbl.AbsoluteSize
    if sfSize and absImg and sfSize.X > 0 and sfSize.Y > 0 then
        if absImg.X > sfSize.X * 1.05 or absImg.Y > sfSize.Y * 1.05 then return true end
    end
    local tr = tonumber(iconLbl.ImageTransparency) or 0
    if tr > 0.45 and _hudColorLooksPulsed(iconLbl.ImageColor3) then return true end
    return false
end

function _hudAcceptIconTint(col, slotFrame, iconLbl)
    if not col then return false end
    if _hudColorLooksPulsed(col) then return false end
    if iconLbl and _hudIconLooksAnimating(slotFrame, iconLbl) then return false end
    return true
end

function _hudSampleStableIconTint(excludeSlot, teamKey)
    teamKey = teamKey or _hudActiveTeamKey()
    local inv = _hudInventory and _hudInventory() or nil
    if not inv then return HUDSkin.teamIconTints[teamKey] end
    for _, slot in ipairs(_hudInventorySlots(inv)) do
        if slot ~= excludeSlot then
            for _, d in ipairs(slot:GetDescendants()) do
                if (d:IsA("ImageLabel") or d:IsA("ImageButton")) and d:GetAttribute("EclipseHUD") ~= true then
                    local img = tostring(d.Image or "")
                    local hasAsset = img:find("rbxasset", 1, true) or img:find("http", 1, true)
                    if hasAsset and d.Visible and (tonumber(d.ImageTransparency) or 0) < 0.6 and _hudAcceptIconTint(d.ImageColor3, slot, d) and _hudTintAllowedForTeam(d.ImageColor3, teamKey) then
                        HUDSkin.teamIconTints[teamKey] = d.ImageColor3
                        return d.ImageColor3
                    end
                end
            end
        end
    end
    return HUDSkin.teamIconTints[teamKey]
end

