                                local item = sec.Items[key]
                                if item and item.Instance and item.Instance:IsA("GuiObject") then item.Instance.Visible = true end
                            end
                        end
                    end)

                    if pageLooksEmpty and sec.Elements then
                        for _, element in pairs(sec.Elements) do
                            pcall(function()
                                local items = element.Items
                                if type(items) ~= "table" then return end
                                for _, key in ipairs({
                                    "Toggle", "Indicator", "Text", "Slider", "RealSlider", "Dropdown", "RealDropdown",
                                    "ArrowIcon", "Label", "Button", "Textbox", "Keybind", "Colorpicker"
