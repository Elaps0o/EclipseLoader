        if not root then return end
        pcall(function()
            connectSignal(root.DescendantAdded:Connect(function(d)
                if not d then return end
                local nm = tostring(d.Name or ""):lower()
                if nm:find("color") or nm:find("picker") or nm:find("holder") then
                    _bumpZ(d)

                    local sg = d:FindFirstAncestorOfClass("ScreenGui")
                    if sg then _bumpZ(sg) end
                end
            end))
        end)
    end
    task.spawn(function()
        local CoreGui = game:GetService("CoreGui")
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
