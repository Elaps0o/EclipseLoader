function _hookHUDInventory(inv)
    if HUDSkin.inventoryRef == inv then return end
    if HUDSkin.inventoryChildConn then pcall(function() HUDSkin.inventoryChildConn:Disconnect() end); HUDSkin.inventoryChildConn = nil end
    if HUDSkin.inventoryDescConn then pcall(function() HUDSkin.inventoryDescConn:Disconnect() end); HUDSkin.inventoryDescConn = nil end
    HUDSkin.inventoryRef = inv
    if not inv then return end
    HUDSkin.inventoryChildConn = inv.ChildAdded:Connect(function(child)
        _scheduleHUDApply(0.06)
    end)
    HUDSkin.inventoryDescConn = inv.DescendantAdded:Connect(function(d)
        local n = tostring(d.Name)
        if n == "WeaponName" or n == "Weapon" or n:find("Icon", 1, true) or d:IsA("ImageLabel") or d:IsA("ImageButton") or d:IsA("ViewportFrame") then
            _scheduleHUDApply(0.06)
        end
    end)
    table.insert(UnloadConnections, HUDSkin.inventoryChildConn)
    table.insert(UnloadConnections, HUDSkin.inventoryDescConn)
end

function _hudInventorySlots(inv)
    local out, seen = {}, {}
    local function add(slot)
        if slot and not seen[slot] and slot:FindFirstChild("Weapon") then
            seen[slot] = true; out[#out + 1] = slot
        end
    end
    for _, child in ipairs(inv:GetChildren()) do add(child) end
    for _, d in ipairs(inv:GetDescendants()) do add(d) end
    return out
end

