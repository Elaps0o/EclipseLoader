    task.spawn(function()
        for _, candidate in ipairs(candidates) do
            local tmp = Instance.new("ImageLabel")
            tmp.BackgroundTransparency = 1
            tmp.Image = candidate
            local finalStatus = "Unknown"
            local ok, err = pcall(function()
                ContentProvider:PreloadAsync({tmp}, function(_, status)
                    finalStatus = tostring(status):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end)
            if ok then
                pcall(function()
                    finalStatus = tostring(ContentProvider:GetAssetFetchStatus(candidate)):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end
            _hudDbg("preload", candidate, ok and finalStatus or tostring(err))
            pcall(function() tmp:Destroy() end)
        end
    end)
