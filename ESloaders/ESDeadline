    if type(obj) ~= "table" then return end

    local inst = rawget(obj, "Instance")
    if typeof(inst) == "Instance" and inst:IsA("GuiObject") then pcall(fn, inst) end

    local items = rawget(obj, "Items")
    if type(items) == "table" then
        for _, v in pairs(items) do _walkControlGui(v, fn, seen, depth + 1) end
    end

    local nl = rawget(obj, "_nl")
    if type(nl) == "table" then _walkControlGui(nl, fn, seen, depth + 1) end
end

local function _setControlVisible(nlObj, visible)
    local did = false
    pcall(function()
        if nlObj and type(nlObj.SetVisibility) == "function" then
            nlObj:SetVisibility(visible)
            did = true
        end
    end)
    if did then return end
    _walkControlGui(nlObj, function(gui) gui.Visible = visible and true or false end)
end

local function _setControlDisabled(nlObj, disabled)
    disabled = disabled and true or false
    _walkControlGui(nlObj, function(gui)
        pcall(function()
            if gui:IsA("GuiButton") then
                gui.Interactable = not disabled
                gui.AutoButtonColor = not disabled
            end
        end)
    end)

end

local _EclipseInlineCounts = setmetatable({}, { __mode = "k" })
local function _findNLToggleRow(nlToggle)
    local sec = nlToggle and rawget(nlToggle, "Section")
    local items = sec and rawget(sec, "Items")
    local content = items and items.Content and items.Content.Instance
    if not (typeof(content) == "Instance") then return nil, nil end
    local wanted = tostring((nlToggle and nlToggle.Name) or "")
    for _, d in ipairs(content:GetDescendants()) do
        if d:IsA("TextLabel") and d.Text == wanted then
            local row = d.Parent
            while row and row ~= content and not row:IsA("GuiButton") do row = row.Parent end
            if row and row ~= content then return row, d end
        end
    end
    return nil, nil
end

