                })
            end)
            local w
            w = {
                Type = "ColorPicker",
                Value = data.Default or Color3.new(1,1,1),
                _changed = {},
                SetValueRGB = function(self2, c)
                    if typeof(c) ~= "Color3" then return end
                    self2.Value = c
                    pcall(function() if cp then cp:Set(c) end end)
                    if data.Callback then pcall(data.Callback, c) end
                    for _, fn in _iter(self2._changed or {}) do pcall(fn, c) end
                end,
                SetValue    = function(self2, c)
                    if typeof(c) ~= "Color3" then return end
                    self2.Value = c
                    pcall(function() if cp then cp:Set(c) end end)
                    if data.Callback then pcall(data.Callback, c) end
                    for _, fn in _iter(self2._changed or {}) do pcall(fn, c) end
                end,
                SetVisible  = function(_, b) _setControlVisible(cp, b) end,
                SetDisabled = function(_, b) _setControlDisabled(cp, b) end,
                OnChanged   = function(self2, fn)
                    if type(fn) == "function" then
                        self2._changed = self2._changed or {}
                        self2._changed[#self2._changed + 1] = fn
                    end
                end,
