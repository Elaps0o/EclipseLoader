    local function _findAccessoryAttachment(model, handle)
        if not (model and handle) then return nil end
        for _, hAtt in ipairs(handle:GetChildren()) do
            if hAtt:IsA("Attachment") then
                for _, d in ipairs(model:GetDescendants()) do
                    if d:IsA("Attachment") and d.Name == hAtt.Name and d.Parent and d.Parent:IsA("BasePart") then
                        return d.Parent, hAtt.CFrame, d.CFrame
                    end
                end
            end
