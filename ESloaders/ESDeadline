        if ch:IsA("Frame") then ch:Destroy() end
    end
    local knife = Config.Skins.SelectedKnife or "Butterfly Knife"
    HUDSkin.infoCache[knife] = nil
    local data = _weaponInfo(knife) or HUD_KNIFE_ASSETS[knife]
    if not data then
        v.title.Text = "HUD ASSET VIEWER"
        v.status.Text = "No Icon/ReverseIcon found in dumps or runtime module for " .. tostring(knife)
        return
    end
    v.title.Text = "HUD ASSET VIEWER · " .. tostring(knife)
    v.status.Text = "Validating Icon assets. Confirm only if at least one card says success."
    local rows = {
        { label="Icon", asset=data.Icon },
        { label="Icon JPG", asset=_assetThumb(data.Icon) },
        { label="Small JPG", asset=_assetThumbSmall(data.Icon) },
        { label="Reverse", asset=data.ReverseIcon },
    }
    for i, row in ipairs(rows) do
        local card = Instance.new("Frame", v.list)
        card.Name = "Asset_" .. tostring(i); card.BackgroundColor3 = Color3.fromRGB(26,26,30); card.BorderSizePixel = 0; card.ZIndex = 203
        Instance.new("UICorner", card).CornerRadius = UDim.new(0, 4)
        local img = Instance.new("ImageLabel", card)
        img.Name = "Image"; img.BackgroundTransparency = 1; img.Position = UDim2.fromOffset(6, 4); img.Size = UDim2.new(1, -12, 0, 50)
        img.ScaleType = Enum.ScaleType.Fit; img.ImageColor3 = Color3.fromRGB(255,255,255); img.Image = row.asset or ""; img.ZIndex = 204
        local lbl = Instance.new("TextLabel", card)
        lbl.BackgroundTransparency = 1; lbl.Position = UDim2.fromOffset(4, 56); lbl.Size = UDim2.new(1, -8, 0, 20)
        lbl.Font = Enum.Font.Code; lbl.TextSize = 10; lbl.TextColor3 = Color3.fromRGB(190,190,200); lbl.TextXAlignment = Enum.TextXAlignment.Center; lbl.Text = row.label .. " · loading"; lbl.ZIndex = 204
        task.spawn(function()
            if not row.asset then
                if lbl and lbl.Parent then lbl.Text = row.label .. " · missing" end
                return
            end
            local finalStatus = "Unknown"
            local ok = pcall(function()
                ContentProvider:PreloadAsync({img}, function(_, status)
                    finalStatus = tostring(status):gsub("Enum.AssetFetchStatus%.", "")
                end)
            end)
            task.wait(0.2)
            local ready, loaded, fetchStatus = _imageCandidateReady(img, row.asset)
            if finalStatus ~= "Unknown" then fetchStatus = finalStatus end
            local text = "fail"
            if ready then text = "success" elseif ok and not _statusIsBad(fetchStatus) then text = tostring(fetchStatus):lower() end
            if lbl and lbl.Parent then lbl.Text = row.label .. " · " .. text end
            _hudDbg("viewer", knife, row.label, tostring(row.asset), "status=", tostring(fetchStatus), "loaded=", tostring(loaded))
        end)
    end
end

