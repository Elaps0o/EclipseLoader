    local function _findNeckMotor(char)
        if not char then return nil end
        local head = char:FindFirstChild("Head")
        if head then
            local m = head:FindFirstChild("Neck")
            if m and m:IsA("Motor6D") then return m end
        end
        for _, name in ipairs({ "Torso", "UpperTorso" }) do
            local t = char:FindFirstChild(name)
            if t then
                local m = t:FindFirstChild("Neck")
                if m and m:IsA("Motor6D") then return m end
            end
        end
        return nil
    end

    local function _setNeckPitch(char, deg)
        local m = _findNeckMotor(char)
        if not m then return end
        if NECK_C0[m] == nil then NECK_C0[m] = m.C0 end
        m.C0 = NECK_C0[m] * CFrame.Angles(math.rad(deg), 0, 0)
    end

    local function _restoreNeck(char)
        local m = _findNeckMotor(char)
        if not m then return end
        if NECK_C0[m] ~= nil then m.C0 = NECK_C0[m] end
    end

    connectSignal(RunS.Heartbeat:Connect(function()
        if not scriptRunning then return end
        if not (Config and Config.Misc and Config.Misc.AntiAim) then
            local char = LP and LP.Character
            if char then pcall(function() _restoreNeck(char) end) end
            return
        end
        local char = LP and LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health <= 0 then return end
        local cam   = workspace.CurrentCamera
        local camCF = cam and cam.CFrame
        local yaw   = tostring(Config.Misc.AntiAimYaw or "Forward")
        local spd   = math.rad(tonumber(Config.Misc.AntiAimSpeed) or 80)

        pcall(function()
            local pos = hrp.Position

            if yaw == "Freeze" then
                _restoreNeck(char)
                local st = _G.__EclipseAA or { mode = nil, yawRad = 0 }
                if st.mode ~= yaw then
                    local lookCF = camCF or hrp.CFrame
                    local lv = lookCF.LookVector
                    st.yawRad = math.atan2(-lv.X, -lv.Z)
                    st.mode = yaw
                    _G.__EclipseAA = st
                end
                hrp.CFrame = CFrame.new(pos) * CFrame.Angles(0, st.yawRad, 0)

            elseif yaw == "Follow" then

                _restoreNeck(char)
                local bestPl = _aaFollowTarget
                local bestOk = false
                if bestPl and bestPl.Parent and bestPl.Character then
                    local pch = bestPl.Character
                    local h   = pch and pch:FindFirstChildOfClass("Humanoid")
                    local hd  = pch and (pch:FindFirstChild("Head") or pch:FindFirstChild("HumanoidRootPart"))
                    bestOk = h and h.Health > 0 and hd ~= nil
                end
                if (not bestOk) or (tick() - _aaFollowLastScan) > ES152.adaptiveInterval(0.18, 2) then
                    _aaFollowLastScan = tick()
                    bestPl = nil
                    local bestDist = math.huge
                    for _, pl in ipairs(Players:GetPlayers()) do
                        if pl ~= LP then
                            local skip = false
                            if not _IS_DEATHMATCH and Config.TeamCheck and IsAlly and IsAlly(pl) then skip = true end
                            if not skip then
                                local pch = pl.Character
                                local h   = pch and pch:FindFirstChildOfClass("Humanoid")
                                local hd  = pch and (pch:FindFirstChild("Head") or pch:FindFirstChild("HumanoidRootPart"))
                                if h and h.Health > 0 and hd then
                                    local vis = IsVisible and IsVisible(hd)
                                    if vis then
                                        local d = (hd.Position - pos).Magnitude
                                        if d < bestDist then bestDist = d; bestPl = pl end
                                    end
                                end
                            end
                        end
                    end
                    _aaFollowTarget = bestPl
                end
                if bestPl and bestPl.Character then
                    local target = bestPl.Character:FindFirstChild("HumanoidRootPart")
                                or bestPl.Character:FindFirstChild("Head")
                    if target then
                        local dv = target.Position - pos
                        local ry = math.atan2(-dv.X, -dv.Z)
                        hrp.CFrame = CFrame.new(pos) * CFrame.Angles(0, ry, 0)
                        _G.__EclipseAA = { mode = yaw, yawRad = ry }
                    end
                else
                    local _, ry = hrp.CFrame:ToOrientation()
                    ry = ry + spd
                    hrp.CFrame = CFrame.new(pos) * CFrame.Angles(0, ry, 0)
                    _G.__EclipseAA = { mode = yaw, yawRad = ry }
                end

            else
                _restoreNeck(char)
                local _, ry = hrp.CFrame:ToOrientation()
                ry = ry + spd
                hrp.CFrame = CFrame.new(pos) * CFrame.Angles(0, ry, 0)
                _G.__EclipseAA = { mode = yaw, yawRad = ry }
            end

            if cam and camCF then cam.CFrame = camCF end
        end)
    end))
end)()
