function _uniformScale(inst, factor)
    if not inst or not factor or factor == 1 then return end
    local function _scaleBP(bp)
        local visualMeshes = {}
        for _, ch in ipairs(bp:GetChildren()) do
            if ch:IsA("SpecialMesh") or ch:IsA("BlockMesh") or ch:IsA("CylinderMesh") then
                table.insert(visualMeshes, ch)
            end
        end
        if #visualMeshes > 0 then
            for _, ch in ipairs(visualMeshes) do pcall(function() ch.Scale = ch.Scale * factor end) end
        else
            pcall(function() bp.Size = bp.Size * factor end)
        end
    end
    if inst:IsA("BasePart") then
        _scaleBP(inst)
    elseif inst:IsA("Model") or inst:IsA("Folder") then
        for _, d in ipairs(inst:GetDescendants()) do
            if d:IsA("BasePart") then _scaleBP(d) end
        end
    end
end

