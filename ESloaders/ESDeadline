function _ecfgEncode(v, seen)
    local tv = typeof(v)
    if tv == "Color3" then
        return { __eclipseType="Color3", r=math.floor(v.R * 255 + 0.5), g=math.floor(v.G * 255 + 0.5), b=math.floor(v.B * 255 + 0.5) }
    elseif tv == "EnumItem" then
        return { __eclipseType="EnumItem", enum=tostring(v.EnumType):gsub("^Enum%.", ""), name=v.Name }
    elseif type(v) == "table" then
        seen = seen or {}
        if seen[v] then return nil end
        seen[v] = true
        local out = {}
        for k, val in pairs(v) do
            local ek = (type(k) == "string" or type(k) == "number") and k or tostring(k)
            local ev = _ecfgEncode(val, seen)
            if ev ~= nil then out[ek] = ev end
        end
        seen[v] = nil
        return out
    elseif type(v) == "string" or type(v) == "number" or type(v) == "boolean" then
        return v
    end
    return nil
end

function _ecfgDecode(v)
    if type(v) ~= "table" then return v end
    if v.__eclipseType == "Color3" then
        return Color3.fromRGB(tonumber(v.r) or 255, tonumber(v.g) or 255, tonumber(v.b) or 255)
    elseif v.__eclipseType == "EnumItem" then
        local ok, item = pcall(function() return Enum[tostring(v.enum)][tostring(v.name)] end)
        if ok then return item end
        return tostring(v.name or "")
    end
    local out = {}
    for k, val in pairs(v) do out[k] = _ecfgDecode(val) end
    return out
end

function _ecfgMerge(dst, src)
    if type(dst) ~= "table" or type(src) ~= "table" then return end
    for k, v in pairs(src) do
        if type(v) == "table" and type(dst[k]) == "table" and not v.__eclipseType then
            _ecfgMerge(dst[k], v)
        else
            dst[k] = v
        end
    end
end

