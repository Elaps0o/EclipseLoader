        local inner = Instance.new("Frame", slot)
        inner.Name = "Gloss"
        inner.BackgroundColor3 = Color3.fromRGB(255,255,255)
        inner.BackgroundTransparency = 0.75
        inner.BorderSizePixel = 0
        inner.AnchorPoint = Vector2.new(0.5, 0)
        inner.Position = UDim2.new(0.5, 0, 0, 1)
        inner.Size = UDim2.new(1, -4, 0, 4)
        inner.ZIndex = slot.ZIndex + 2
        local ic = Instance.new("UICorner", inner); ic.CornerRadius = UDim.new(0, 3)
