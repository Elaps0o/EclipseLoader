local function isVisibleFromCamera(targetPart, ignoreModel)
    if not targetPart then return false end
    local cam = Workspace.CurrentCamera
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end
    local lc = _localCharacter(); if lc then table.insert(ignore, lc) end
    if ignoreModel then table.insert(ignore, ignoreModel) end
    params.FilterDescendantsInstances = ignore
    local dir = (targetPart.Position - cam.CFrame.Position)
    local r = Workspace:Raycast(cam.CFrame.Position, dir, params)
    if not r then return true end
    return r.Instance:IsDescendantOf(ignoreModel)
end

