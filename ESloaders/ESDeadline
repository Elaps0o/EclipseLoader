function _assetString(v)
    if typeof(v) == "Instance" then
        if v:IsA("StringValue") then v = v.Value
        elseif v:IsA("IntValue") or v:IsA("NumberValue") then v = v.Value
        elseif v:IsA("Decal") or v:IsA("Texture") then v = v.Texture
        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then v = v.Image
        else return nil end
    end
    if type(v) == "number" then return "rbxassetid://" .. tostring(v) end
    if type(v) ~= "string" or v == "" then return nil end
    v = v:gsub("^%s+", ""):gsub("%s+$", "")
    if v == "" then return nil end
    if v:match("^%d+$") then return "rbxassetid://" .. v end
    if v:match("^rbxthumb://") then return v end
    local id = v:match("rbxassetid://(%d+)") or v:match("[?&]id=(%d+)") or v:match("[?&]assetId=(%d+)") or v:match("/library/(%d+)") or v:match("/catalog/(%d+)")
    if id then return "rbxassetid://" .. id end
    return v
end

function _assetIdFromString(v)
    v = _assetString(v)
    if type(v) ~= "string" or v == "" then return nil end
    return v:match("rbxassetid://(%d+)") or v:match("[?&]id=(%d+)") or v:match("[?&]assetId=(%d+)") or v:match("^(%d+)$")
end

function _assetThumb(v)
