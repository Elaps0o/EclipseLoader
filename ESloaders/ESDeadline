function _aimRayHitsSmoke(from, to)
    local dbg = Workspace:FindFirstChild("Debris"); if not dbg then return false end
    local dir = to - from; local mag = dir.Magnitude; if mag <= 0.001 then return false end
    local u = dir / mag
    for _, folder in ipairs(dbg:GetChildren()) do
        if folder:IsA("Folder") and folder.Name:match("^VoxelSmoke_") and not (Config.Misc and Config.Misc.AntiSmoke) and not SmokeDestroyed[folder] then
            for _, vox in ipairs(folder:GetChildren()) do
                if vox:IsA("BasePart") and vox.Name == "SmokeVoxel" and vox.Transparency < 0.95 then
                    local half = vox.Size / 2
                    local mn, mx = vox.Position - half, vox.Position + half
                    local tmin, tmax = 0, mag
                    local ok = true
                    for _, axis in ipairs({"X","Y","Z"}) do
                        local o, d = from[axis], u[axis]
                        if math.abs(d) < 1e-4 then
                            if o < mn[axis] or o > mx[axis] then ok = false; break end
                        else
                            local inv = 1/d
                            local t1, t2 = (mn[axis]-o)*inv, (mx[axis]-o)*inv
                            if t2 < t1 then t1, t2 = t2, t1 end
                            if t1 > tmin then tmin = t1 end
                            if t2 < tmax then tmax = t2 end
                            if tmax < tmin then ok = false; break end
                        end
                    end
                    if ok and tmin >= 0 and tmin <= mag then return true end
                end
            end
        end
    end
    return false
end

