                    end
                end
            end
        end
    end)
end

local function wrapToggle(id, nlToggle, cbHolder)
    local function isLikelyToggle(obj)
        local t = typeof(obj)
        return obj ~= nil and (t == "table" or t == "Instance")
    end
    if not isLikelyToggle(nlToggle) then
        warn("[wrapToggle] invalid nlToggle for id", id, "type", typeof(nlToggle), type(nlToggle))
        return {
            Type="Toggle", Value=false, Disabled=true, Visible=false, _nl=nil, _changed={},
            SetValue=function() end, SetVisible=function() end,
            SetDisabled=function() end, OnChanged=function() end,
            AddColorPicker=function() return { Type="ColorPicker", Value=Color3.new(1,1,1), SetValue=function() end, SetVisible=function() end, SetDisabled=function() end, OnChanged=function() end } end,
            AddKeyPicker=function() return { Type="KeyPicker", Value=Enum.KeyCode.Unknown, SetValue=function() end, SetState=function() end, SetVisible=function() end, SetDisabled=function() end, OnChanged=function() end, OnClick=function() end } end,
        }
    end
    if type(cbHolder) ~= "table" then
        warn("[wrapToggle] cbHolder is not a table for id", id, "got", typeof(cbHolder), type(cbHolder))
        cbHolder = {}
    end
    local initVal = false
    local ok, rawVal = pcall(function()
        return nlToggle.Value
    end)
    if ok and rawVal ~= nil then
        initVal = rawVal
    end
    local self = {
        Type      = "Toggle",
        Value     = initVal and true or false,
        Disabled  = false,
        Visible   = true,
        _nl       = nlToggle,
        _changed  = {},
    }
    local function triggerChange(v)
        self._changed = self._changed or {}
        for _, fn in _iter(self._changed) do
            pcall(fn, v)
        end
    end
    local function syncFromNative(v)
        local bv = v and true or false
        if self.Value == bv then return false end
        self.Value = bv
        triggerChange(bv)
        return true
    end
    self.SetValue = function(_, v)
        local bv = v and true or false
        if self.Value == bv then return end

        self._setNativeFired = false
        self._nativeChangedDuringSet = false
        self._settingNative = true
        if type(nlToggle) == "table" and type(nlToggle.Set) == "function" then
            pcall(function() nlToggle:Set(bv) end)
        end
        self._settingNative = false

        if self._nativeChangedDuringSet then
            if self._extCb then pcall(self._extCb, bv) end
        elseif not self._setNativeFired then
            syncFromNative(bv)
            if self._extCb then pcall(self._extCb, bv) end
        end
        self._nativeChangedDuringSet = false
    end
    self.SetVisible = function(_, b)
        self.Visible = b and true or false
        pcall(_setControlVisible, nlToggle, self.Visible)
    end
    self.SetDisabled = function(_, b)
        self.Disabled = b and true or false
        pcall(_setControlDisabled, nlToggle, self.Disabled)
    end
    self.OnChanged = function(_, fn)
        if type(fn) ~= "function" then
            warn("[wrapToggle] OnChanged callback is not a function for id", id)
            return
        end
        self._changed = self._changed or {}
        self._changed[#self._changed + 1] = fn
    end
    if type(cbHolder) == "table" then
        cbHolder[#cbHolder + 1] = function(v)
            self._setNativeFired = true
            local changed = syncFromNative(v)
            if self._settingNative then
                self._nativeChangedDuringSet = changed
                return false
            end
            return changed
        end
    else
        warn("[wrapToggle] cbHolder is not a table when registering callback for id", id, "got", typeof(cbHolder), type(cbHolder))
    end

    local function resolveKey(k)
        if typeof(k) == "EnumItem" then return k end
        if type(k) ~= "string" or k == "" then return Enum.KeyCode.Unknown end
        local mouseMap = {
            MB1="MouseButton1", MB2="MouseButton2", MB3="MouseButton3",
            LMB="MouseButton1", RMB="MouseButton2", MMB="MouseButton3",
            MouseButton1="MouseButton1", MouseButton2="MouseButton2", MouseButton3="MouseButton3",
        }
        local mb = mouseMap[k]
        if mb then
            local ok, v = pcall(function() return Enum.UserInputType[mb] end)
            if ok and v then return v end
        end
        local ok, v = pcall(function() return Enum.KeyCode[k] end)
        if ok and v then return v end
        return Enum.KeyCode.Unknown
    end

    function self:AddColorPicker(cid, data)
        data = data or {}
        local cp, slot

        local w
        pcall(function()
            slot = _makeInlineSlot(nlToggle, "Color", data.Default or Color3.new(1,1,1))
            if slot and NLLib and type(NLLib.CreateColorpicker) == "function" then
                cp = NLLib:CreateColorpicker({
                    Parent   = { Instance = slot },
                    Parent2  = { Instance = slot },
                    Page     = rawget(nlToggle, "Page"),
                    Section  = rawget(nlToggle, "Section"),
                    Flag     = makeFlag(cid, "_col"),
                    Default  = data.Default or Color3.new(1,1,1),
                    Alpha    = data.Alpha or false,
                    Callback = function(c, a)
                        if w then w.Value = c end
                        pcall(function() if slot then slot.BackgroundColor3 = c end end)
                        if data.Callback then pcall(data.Callback, c, a) end
                    end,
                })
                task.defer(function()
                    pcall(function()

                        for _, d in _iter(slot:GetDescendants()) do
                            if d:IsA("TextButton") then
                                d.Size = UDim2.fromScale(1, 1)
                                d.Position = UDim2.fromScale(0, 0)
                                d.BackgroundTransparency = 1
                                d.Text = ""
                                d.AutoButtonColor = false
                                d.ZIndex = (slot.ZIndex or 2) + 10
                            elseif d:IsA("TextLabel") then
                                d.Visible = false
                            elseif d:IsA("ImageLabel") or d:IsA("ImageButton") then
                                d.Visible = false
                            elseif d:IsA("Frame") then

                                d.BackgroundTransparency = 1
                                for _, gc in _iter(d:GetChildren()) do
                                    if gc:IsA("UICorner") or gc:IsA("UIStroke") or gc:IsA("UIGradient") then
                                        pcall(function() gc:Destroy() end)
                                    end
                                end
                            end
                        end
                    end)
                end)

            elseif nlToggle and type(nlToggle.Colorpicker) == "function" then
                cp = nlToggle:Colorpicker({
                    Name     = data.Title or data.Text or "Color",
                    Flag     = makeFlag(cid, "_col"),
                    Default  = data.Default or Color3.new(1,1,1),
                    Callback = function(c) if data.Callback then pcall(data.Callback, c) end end,
                })
            end
        end)
        if slot and not cp then
            local palette = {
                data.Default or Color3.new(1,1,1), Color3.fromRGB(255,60,60), Color3.fromRGB(80,255,120),
                Color3.fromRGB(80,170,255), Color3.fromRGB(180,100,255), Color3.fromRGB(255,220,80), Color3.fromRGB(255,255,255),
            }
            local pi = 1
            connectSignal(slot.MouseButton1Click:Connect(function()
                if not scriptRunning then return end
                pi = (pi % #palette) + 1
                local c = palette[pi]
                w.Value = c
                slot.BackgroundColor3 = c
                if data.Callback then pcall(data.Callback, c) end
            end))
        end
        w = {
            Type      = "ColorPicker",
            Value     = data.Default or Color3.new(1,1,1),
            _changed  = {},
            SetValueRGB = function(self2, c)
                if type(c) ~= "userdata" and typeof(c) ~= "Color3" then return end
                self2.Value = c
                pcall(function() if cp then cp:Set(c) end end)
                pcall(function() if slot then slot.BackgroundColor3 = c end end)
                if data.Callback then pcall(data.Callback, c) end
                for _, fn in _iter(self2._changed or {}) do pcall(fn, c) end
            end,
            SetValue    = function(self2, c)
                if typeof(c) ~= "Color3" then return end
                self2.Value = c
                pcall(function() if cp then cp:Set(c) end end)
                pcall(function() if slot then slot.BackgroundColor3 = c end end)
                if data.Callback then pcall(data.Callback, c) end
                for _, fn in _iter(self2._changed or {}) do pcall(fn, c) end
            end,
            SetVisible  = function(_, b) if slot then slot.Visible = b and true or false else _setControlVisible(cp, b) end end,
            SetDisabled = function(_, b) _setControlDisabled(cp, b) end,
            OnChanged   = function(self2, fn)
                if type(fn) == "function" then
                    self2._changed = self2._changed or {}
                    self2._changed[#self2._changed + 1] = fn
                end
            end,
        }

        pcall(function() if slot and w.Value then slot.BackgroundColor3 = w.Value end end)
        registerEntry(Library.Options, cid, w)
        return self
    end

    function self:AddKeyPicker(kid, data)
        data = data or {}
        local defaultKey = resolveKey(data.Default)
        local w
        local mode = data.Mode or "Toggle"
        local slot, stroke = _makeInlineSlot(nlToggle, "Key", Color3.fromRGB(30, 28, 38))
        local picking = false
        local function keyText(k)
            if typeof(k) == "EnumItem" then
                local n = k.Name or tostring(k)
                return (n == "MouseButton1" and "MB1") or (n == "MouseButton2" and "MB2") or (n == "MouseButton3" and "MB3") or n
            end
            return tostring(k or "None")
        end
        local function setVisual(active)
            if not slot then return end
            slot.Text = picking and "..." or keyText(w and w.Value or defaultKey)
            slot.TextSize = 10; slot.Font = Enum.Font.GothamBold
            slot.TextColor3 = active and Color3.fromRGB(255,255,255) or Color3.fromRGB(220,215,240)
            slot.BackgroundColor3 = active and Color3.fromRGB(150, 100, 255) or Color3.fromRGB(34, 32, 44)
            if stroke then stroke.Color = active and Color3.fromRGB(210, 170, 255) or Color3.fromRGB(100, 85, 160) end
        end
        local function fireState(v)
            if not w then return end
            w.Toggled = v and true or false
            if data.SyncToggleState then

                if self and type(self.SetValue) == "function" then
                    pcall(function() self:SetValue(w.Toggled) end)
                end
            end
            if data.Callback then pcall(data.Callback, w.Toggled) end
            setVisual(w.Toggled)
        end
        w = {
            Type      = "KeyPicker",
            Text      = data.Text or tostring(kid or "Keybind"),
            Value     = defaultKey,
            Default   = defaultKey,
            Mode      = mode,
            SyncToggleState = data.SyncToggleState,
            Toggled   = false,
            GetState  = function() return w.Toggled == true end,
            SetValue  = function(_, key, mode)
                w.Value = resolveKey(key)
                if mode then w.Mode = mode end
                setVisual(w.Toggled)
            end,
            SetState = function(_, v)
                fireState(v and true or false)
            end,
            SetVisible  = function(_, b) if slot then slot.Visible = b and true or false end end,
            SetDisabled = function(_, b) if slot then slot.Active = not b end end,
            OnChanged = function() end,
            OnClick   = function() end,
        }
        if slot then
            connectSignal(slot.MouseButton1Click:Connect(function()
                if not scriptRunning then return end
                picking = true; setVisual(false)
            end))
        end
        local UIS = game:GetService("UserInputService")
        connectSignal(UIS.InputBegan:Connect(function(input, gp)
            if picking then
                picking = false
                local k = (input.UserInputType and input.UserInputType.Name:find("MouseButton")) and input.UserInputType or input.KeyCode
                if input.KeyCode == Enum.KeyCode.Backspace or input.KeyCode == Enum.KeyCode.Escape then k = Enum.KeyCode.Unknown end
                w.Value = k; setVisual(w.Toggled); return
            end
            if gp then return end
            local match = (input.KeyCode == w.Value) or (input.UserInputType == w.Value)
            if not match then return end
            if w.Mode == "Hold" then fireState(true)
            elseif w.Mode == "Always" then fireState(true)
            else fireState(not w.Toggled) end
        end))
        connectSignal(UIS.InputEnded:Connect(function(input)
            local match = (input.KeyCode == w.Value) or (input.UserInputType == w.Value)
            if match and w.Mode == "Hold" then fireState(false) end
        end))
        setVisual(false)
        registerEntry(Library.Options, kid, w)
        return self
    end
    return self
end

local function makeGroupbox(nlSection)
