local RECOIL_DEFAULTS = {
    aim_sway_recoil        = { min=0,  max=2,  value=0 },
    animation_weight       = { min=0,  max=5,  value=0 },
    camera_lag_recoil      = { min=-2, max=2,  value=0 },
    camera_recoil          = { min=0,  max=2,  value=0 },
    horizontal_recoil      = { min=0,  max=2,  value=0 },
    knockback              = { min=0,  max=5,  value=0 },
    progressive_fall_per_second = { min=0, max=1, value=0 },
    progressive_increment  = { min=0,  max=1,  value=0 },
    progressive_maximum    = { min=0,  max=5,  value=0 },
    progressive_minimum    = { min=0,  max=5,  value=0 },
    roll_recoil            = { min=0,  max=5,  value=0 },
    rotation_recoil        = { min=0,  max=2,  value=0 },
    sway_recoil            = { min=0,  max=10, value=0 },
    trait_continuity       = { min=0,  max=1,  value=0 },
    vertical_recoil        = { min=0,  max=2,  value=0 },
    weapon_roll_recoil     = { min=0,  max=5,  value=0 },
}

local RECOIL_TABLE
local function locateRecoil()
    if RECOIL_TABLE then return RECOIL_TABLE end
    local ok, gc = pcall(getgc, true); if not ok then return nil end
    for _, v in pairs(gc) do
        if type(v) == "table" then
            local rdv = rawget(v, "RECOIL_DEBUG_VALUES")
            if type(rdv) == "table" and rdv.aim_sway_recoil then RECOIL_TABLE = rdv; return rdv end
            -- Some builds have the values table directly
            if rawget(v, "aim_sway_recoil") and rawget(v, "horizontal_recoil") and rawget(v, "vertical_recoil") then
                RECOIL_TABLE = v; return v
            end
        end
    end
    return nil
end

RCSBox:AddToggle("rcs_enabled",{ Text="Enabled", Default=false, Callback=function(v)
    Config.RCS.Enabled = v
    local t = locateRecoil()
    if not t then Library:Notify({Title="RCS", Text="Recoil module not found. Enter a match first."}); return end
    if v then
        -- Aplica os defaults ÓTIMOS (zero recoil), preservando qualquer valor que o user tenha ajustado no slider.
        for k, cfg in pairs(RECOIL_DEFAULTS) do
            if t[k] then
                -- Salva o valor original do jogo (uma vez só) para poder restaurar depois.
                Config.RCS.Original = Config.RCS.Original or {}
                if Config.RCS.Original[k] == nil then Config.RCS.Original[k] = t[k].value end
                Config.RCS.Values[k] = Config.RCS.Values[k] or cfg.value
                t[k].value = Config.RCS.Values[k]
            end
        end
    else
        -- Restaura os valores originais do jogo (não os defaults zerados).
        local orig = Config.RCS.Original or {}
        for k, _ in pairs(RECOIL_DEFAULTS) do
            if t[k] and orig[k] ~= nil then t[k].value = orig[k] end
        end
    end
end })
for k, cfg in pairs(RECOIL_DEFAULTS) do
    RCSBox:AddSlider("rcs_"..k, {
        Text = k:gsub("_"," "):upper(),
