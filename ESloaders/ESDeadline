    local function _weldOverlay(ch, model)
        local hrp = ch:FindFirstChild("HumanoidRootPart"); if not hrp then return end

        pcall(function() model:PivotTo(hrp.CFrame) end)

        local function _isBodyPartName(n)
            return n == "Torso" or n == "Head" or n == "HumanoidRootPart"
                or n == "Left Arm" or n == "Right Arm"
                or n == "Left Leg" or n == "Right Leg"
                or n == "UpperTorso" or n == "LowerTorso"
                or n == "LeftUpperArm" or n == "LeftLowerArm" or n == "LeftHand"
                or n == "RightUpperArm" or n == "RightLowerArm" or n == "RightHand"
                or n == "LeftUpperLeg" or n == "LeftLowerLeg" or n == "LeftFoot"
                or n == "RightUpperLeg" or n == "RightLowerLeg" or n == "RightFoot"
        end

        local dHum = model:FindFirstChildOfClass("Humanoid")
        if dHum then
            pcall(function()
                dHum.PlatformStand      = true
                dHum.EvaluateStateMachine = false
                dHum.AutoRotate         = false
                dHum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            end)
            local anim = dHum:FindFirstChildOfClass("Animator")
            if anim then
                for _, t in ipairs(anim:GetPlayingAnimationTracks()) do pcall(function() t:Stop() end) end
            end
            local defaultAnim = model:FindFirstChild("Animate")
            if defaultAnim then pcall(function() defaultAnim:Destroy() end) end
        end

        model.Name = "EclipseCPMOverlay"
        model:SetAttribute("EclipseCPMOverlay", true)
        model.Parent = workspace

        local dummyRoot = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
            or model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")

        local syncParts = {}
        local sourceParts = {}
        for _, p in ipairs(ch:GetDescendants()) do
            if p:IsA("BasePart") then sourceParts[p.Name] = p end
        end
        local heightScale = tonumber(model:GetAttribute("EclipseCPMHeightScale")) or 1.0
        local function _offsetFor(dummyName, target)
            local tn = target and target.Name or ""
            local o
            if dummyName == tn then return CFrame.new() end
            if dummyName == "Torso" and tn == "UpperTorso" then o = Vector3.new(0, -0.35, 0)
            elseif dummyName == "UpperTorso" and tn == "Torso" then o = Vector3.new(0, 0.45, 0)
            elseif dummyName == "LowerTorso" and tn == "Torso" then o = Vector3.new(0, -0.45, 0)
            elseif dummyName:find("UpperArm") and tn:find(" Arm") then o = Vector3.new(0, 0.35, 0)
            elseif dummyName:find("LowerArm") and tn:find(" Arm") then o = Vector3.new(0, -0.25, 0)
            elseif dummyName:find("Hand") and tn:find(" Arm") then o = Vector3.new(0, -0.85, 0)
            elseif dummyName:find("UpperLeg") and tn:find(" Leg") then o = Vector3.new(0, 0.35, 0)
            elseif dummyName:find("LowerLeg") and tn:find(" Leg") then o = Vector3.new(0, -0.25, 0)
            elseif dummyName:find("Foot") and tn:find(" Leg") then o = Vector3.new(0, -0.85, 0)
            elseif (dummyName == "Left Arm" or dummyName == "Right Arm") and tn:find("UpperArm") then
                o = Vector3.new(0, -0.50, 0)
            elseif (dummyName == "Left Leg" or dummyName == "Right Leg") and tn:find("UpperLeg") then
                o = Vector3.new(0, -0.50, 0)
            end
            if o then return CFrame.new(o * heightScale) end
            return CFrame.new()
        end

        local function _firstPart(names)
            for _, n in ipairs(names or {}) do
                local p = sourceParts[n] or (ch and ch:FindFirstChild(n))
                if p and p:IsA("BasePart") and p.Parent then return p end
            end
            return nil
        end

        local function _blendCF(a, b, alpha)
            if a and b then return a.CFrame:Lerp(b.CFrame, alpha or 0.5) end
            if a then return a.CFrame end
            if b then return b.CFrame end
            return nil
        end

        local function _targetCFrameFor(dummyName)
            local exact = sourceParts[dummyName]
            if exact and exact.Parent then return exact.CFrame, nil end

            if dummyName == "Torso" then
                local upper = _firstPart({ "UpperTorso", "Torso" })
                local lower = _firstPart({ "LowerTorso", "Torso" })
                return _blendCF(upper, lower, 0.35), nil
            elseif dummyName == "Left Arm" then
                local p = _firstPart({ "LeftUpperArm", "LeftLowerArm", "LeftHand", "Left Arm" })
                return p and p.CFrame, p
            elseif dummyName == "Right Arm" then
                local p = _firstPart({ "RightUpperArm", "RightLowerArm", "RightHand", "Right Arm" })
                return p and p.CFrame, p
            elseif dummyName == "Left Leg" then
                local p = _firstPart({ "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "Left Leg" })
                return p and p.CFrame, p
            elseif dummyName == "Right Leg" then
                local p = _firstPart({ "RightUpperLeg", "RightLowerLeg", "RightFoot", "Right Leg" })
                return p and p.CFrame, p
            end

            local target = _lpLimb(ch, dummyName) or hrp
            return target and target.CFrame, target
        end

        for _, p in ipairs(model:GetDescendants()) do
            if p:IsA("BasePart") and not _isAccessoryPart(p) then
                p.Anchored, p.CanCollide, p.CanQuery, p.CanTouch, p.Massless = true, false, false, false, true
                if _isBodyPartName(p.Name) then
                    local _, target = _targetCFrameFor(p.Name)
                    syncParts[#syncParts + 1] = { part = p, name = p.Name, offset = _offsetFor(p.Name, target) }
                else
                    syncParts[#syncParts + 1] = { part = p, name = "HumanoidRootPart", offset = CFrame.new() }
                end
            elseif p:IsA("BasePart") then
                p.CanCollide, p.CanQuery, p.CanTouch, p.Massless = false, false, false, true
            end
        end

        local function _syncPose()
            if not (scriptRunning and _cpmActive and _overlay == model and ch and ch.Parent) then return end
            for _, item in ipairs(syncParts) do
                local part = item.part
                if part and part.Parent then
                    local cf = _targetCFrameFor(item.name)
                    if cf then
                        part.CFrame = cf * (item.offset or CFrame.new())
                        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end

        for _, d in ipairs(model:GetDescendants()) do
            if d:IsA("Animator") or d:IsA("AnimationController") then
                pcall(function() d:Destroy() end)
            end
        end
        local dHum = model:FindFirstChildOfClass("Humanoid")
        if dHum then pcall(function() dHum.EvaluateStateMachine = false end) end

        _syncPose()
        if _syncConn then pcall(function() _syncConn:Disconnect() end) end
        _syncConn = connectSignal(RunService.RenderStepped:Connect(function()
            pcall(_syncPose)
        end))
    end

