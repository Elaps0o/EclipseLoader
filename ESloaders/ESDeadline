        local dist = (cam.CFrame.Position - hrp.Position).Magnitude
        if dist > 500 then return false, dist end
        local _, onScreen = cam:WorldToViewportPoint(hrp.Position)
        if not onScreen then return false, dist end
        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local ex = { model }
        if LocalPlayer.Character then table.insert(ex, LocalPlayer.Character) end
        rp.FilterDescendantsInstances = ex
        rp.IgnoreWater = true
        local dir = hrp.Position - cam.CFrame.Position
        local hit = Workspace:Raycast(cam.CFrame.Position, dir, rp)
        if hit and (hit.Position - cam.CFrame.Position).Magnitude < (dist - 2) then
            return false, dist
        end
        return true, dist
    end

