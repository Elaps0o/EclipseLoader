        local function scan(v, depth)
            if origin and finish then return end
            if depth > 3 then return end
            local tv = typeof(v)
            if tv == "Vector3" then
                if not origin then origin = v elseif not finish and (v - origin).Magnitude > 0.5 then finish = v end
            elseif type(v) == "table" then
                local o = rawget(v, "Origin") or rawget(v, "origin") or rawget(v, "Start") or rawget(v, "start")
                local h = rawget(v, "HitPosition") or rawget(v, "Position") or rawget(v, "EndPosition") or rawget(v, "End") or rawget(v, "Hit")
                local d = rawget(v, "Direction") or rawget(v, "direction")
                if typeof(o) == "Vector3" then origin = origin or o end
                if typeof(h) == "Vector3" then finish = finish or h end
                if origin and not finish and typeof(d) == "Vector3" and d.Magnitude > 0.001 then finish = origin + d.Unit * 450 end
                if not (origin and finish) then
                    local hits = rawget(v, "Hits") or rawget(v, "hits") or rawget(v, "Bullets") or rawget(v, "bullets")
                    if type(hits) == "table" then
                        for i = 1, math.min(#hits, 4) do scan(hits[i], depth + 1) end
