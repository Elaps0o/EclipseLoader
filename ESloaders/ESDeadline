local WeatherPart, WeatherEmitter = nil, nil
function UpdateWeather(t)
    if t ~= "None" and t ~= "Rain" and t ~= "Snow" and t ~= "Aurora" then t = "None" end
    Config.World.Weather = t
    if WeatherPart then pcall(function() WeatherPart:Destroy() end); WeatherPart=nil end
    WeatherEmitter = nil
    if t == "None" then return end
    WeatherPart = Instance.new("Part")
    WeatherPart.Name="Deadline_Weather"; WeatherPart.Size=Vector3.new(100,1,100)
    WeatherPart.Transparency=1; WeatherPart.Anchored=true; WeatherPart.CanCollide=false
    local cam = Workspace.CurrentCamera
    if cam then WeatherPart.CFrame = cam.CFrame * CFrame.new(0,30,0) end
    WeatherPart.Parent = Workspace
    WeatherEmitter = Instance.new("ParticleEmitter", WeatherPart)
    WeatherEmitter.EmissionDirection = Enum.NormalId.Bottom
    if t == "Rain" then
        WeatherEmitter.Texture="rbxassetid://241868005"; WeatherEmitter.Rate=300

        WeatherEmitter.Color=ColorSequence.new(Color3.fromRGB(120,255,255), Color3.fromRGB(150,240,255))
        WeatherEmitter.LightEmission=1; WeatherEmitter.LightInfluence=0
        WeatherEmitter.Size=NumberSequence.new(2.2,4.5); WeatherEmitter.Lifetime=NumberRange.new(2,2.5)
        WeatherEmitter.Speed=NumberRange.new(80,100); WeatherEmitter.Acceleration=Vector3.new(0,-50,0)
        WeatherEmitter.Transparency=NumberSequence.new(0.2,0.4)
    elseif t == "Snow" then
        WeatherEmitter.Texture="rbxassetid://99851851"; WeatherEmitter.Rate=90
        WeatherEmitter.Color=ColorSequence.new(Color3.fromRGB(255,255,255))
        WeatherEmitter.LightEmission=1; WeatherEmitter.LightInfluence=0
        WeatherEmitter.Size=NumberSequence.new(0.25,0.35); WeatherEmitter.Speed=NumberRange.new(30,30)
        WeatherEmitter.Lifetime=NumberRange.new(5,10); WeatherEmitter.SpreadAngle=Vector2.new(50,50)
    elseif t == "Aurora" then
        WeatherEmitter.Texture="rbxassetid://243098098"; WeatherEmitter.Rate=80
        WeatherEmitter.Color=ColorSequence.new({
            ColorSequenceKeypoint.new(0.00, Color3.fromRGB(80,255,170)),
            ColorSequenceKeypoint.new(0.50, Color3.fromRGB(90,220,255)),
            ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255,130,220)),
        })
        WeatherEmitter.LightEmission=1; WeatherEmitter.LightInfluence=0
        WeatherEmitter.Size=NumberSequence.new(0.2,2.4)
        WeatherEmitter.Transparency=NumberSequence.new(0.35)
        WeatherEmitter.Lifetime=NumberRange.new(5,9); WeatherEmitter.Speed=NumberRange.new(2,5)
        WeatherEmitter.SpreadAngle=Vector2.new(180,180); WeatherEmitter.Acceleration=Vector3.new(0,-1,0)
    end
    local sp = math.clamp(tonumber(Config.World.WeatherSpeed) or 0, 0, 5)
    local mult = 1 + sp
    if WeatherPart and mult ~= 1 then
        for _, em in _iter(WeatherPart:GetChildren()) do
            if em:IsA("ParticleEmitter") then
                pcall(function()
                    em.Rate = em.Rate * mult
                    em.Speed = NumberRange.new(em.Speed.Min * mult, em.Speed.Max * mult)
                end)
            end
        end
    end
end
