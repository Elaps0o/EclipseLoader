do
    local Lighting = game:GetService("Lighting")
    local _nmEffect
    local function _ensureNMEffect()
        if _nmEffect and _nmEffect.Parent then return _nmEffect end
        for _, ch in ipairs(Lighting:GetChildren()) do
            if ch.Name == "EclipseNightMode" and ch:IsA("ColorCorrectionEffect") then _nmEffect = ch; break end
        end
        if not _nmEffect then
            _nmEffect = Instance.new("ColorCorrectionEffect")
            _nmEffect.Name = "EclipseNightMode"
            _nmEffect.Parent = Lighting
        end
        _nmEffect.TintColor = Color3.fromRGB(205, 185, 235)
        _nmEffect.Brightness = -0.06
        _nmEffect.Contrast = 0.04
        _nmEffect.Saturation = -0.03
        return _nmEffect
    end
    local TweenService = game:GetService("TweenService")
    local _nmTween
    local _nmToken = 0
    local NM_TARGET = { TintColor = Color3.fromRGB(126,96,176), Brightness = -0.20, Contrast = 0.10, Saturation = -0.10 }
    local NM_OFF    = { TintColor = Color3.fromRGB(255,255,255), Brightness = 0,     Contrast = 0,    Saturation = 0 }
    local function _applyNightMode(on)
        local e = _ensureNMEffect()
        _nmToken = _nmToken + 1
        local myToken = _nmToken
        if _nmTween then pcall(function() _nmTween:Pause() end); _nmTween = nil end
        e.Enabled = true
        local target = on and NM_TARGET or NM_OFF
        local dur = on and 0.9 or 0.7
        _nmTween = TweenService:Create(e, TweenInfo.new(dur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), target)
        _nmTween:Play()
        if not on then
            task.delay(dur + 0.05, function()
                if myToken == _nmToken and _nmEffect then _nmEffect.Enabled = false end
            end)
        end
    end

    _EclipseApplyNightMode = _applyNightMode
    task.spawn(function()
        while scriptRunning do
            task.wait(1.25)
            if Config.Misc and Config.Misc.NightMode then
                local e = _ensureNMEffect()
                local needs = (not e.Enabled)
                    or ((e.TintColor.R - NM_TARGET.TintColor.R)^2 + (e.TintColor.G - NM_TARGET.TintColor.G)^2 + (e.TintColor.B - NM_TARGET.TintColor.B)^2 > 0.002)
                    or math.abs((e.Brightness or 0) - NM_TARGET.Brightness) > 0.03
                if needs then pcall(_applyNightMode, true) end
            end
        end
    end)
    connectSignal(LocalPlayer.CharacterAdded:Connect(function()
        task.delay(0.35, function()
            if scriptRunning and Config.Misc and Config.Misc.NightMode then pcall(_applyNightMode, true) end
        end)
    end))
    connectSignal(Lighting.ChildRemoved:Connect(function(ch)
        if ch == _nmEffect or ch.Name == "EclipseNightMode" then
            _nmEffect = nil
            task.delay(0.1, function()
                if scriptRunning and Config.Misc and Config.Misc.NightMode then pcall(_applyNightMode, true) end
            end)
        end
    end))
end

