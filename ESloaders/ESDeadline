    local stateGrounded = (floorMat ~= nil and floorMat ~= Enum.Material.Air)
                      and hstate ~= Enum.HumanoidStateType.Jumping
                      and hstate ~= Enum.HumanoidStateType.Freefall

    local rayGrounded = false
    do
        _MV.ASF_RAY.FilterDescendantsInstances = { char }
        local down = Workspace:Raycast(root.Position, Vector3.new(0,-4.5,0), _MV.ASF_RAY)
        if down then rayGrounded = true end
    end
    local cvY_check = root.AssemblyLinearVelocity.Y
    local grounded  = stateGrounded or (rayGrounded and cvY_check <= 0.5)
    local inAir     = not grounded

    if Config.Movement.BunnyHop and spaceHeld then
        if grounded and tick() - _MV.lastBhop > 0.05 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            _MV.lastBhop = tick()
            pcall(function()
                local cv = root.AssemblyLinearVelocity
                local horiz = Vector3.new(cv.X, 0, cv.Z)
                local look = Camera and Camera.CFrame.LookVector or Vector3.new(0,0,-1)
                local camFlat = Vector3.new(look.X, 0, look.Z)
                local move = hum.MoveDirection
                local desired = (move and move.Magnitude > 0.05) and Vector3.new(move.X,0,move.Z) or camFlat
                if desired.Magnitude > 0.05 then desired = desired.Unit end
                if horiz.Magnitude > 4 then
                    local boosted = horiz:Lerp(desired * math.max(horiz.Magnitude, 18), 0.35)
                    local boost = boosted.Unit * math.min(boosted.Magnitude * 0.22, 9)
                    root.AssemblyLinearVelocity = Vector3.new(cv.X + boost.X, cv.Y, cv.Z + boost.Z)
                elseif desired.Magnitude > 0.05 then
