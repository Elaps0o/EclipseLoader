function _TW_ApplyAllCameraSkins()
    if _TW_ApplyDebounce then
        _TW_ApplyPending = true
        return
    end
    local now = tick()
    if (now - (_TW_LastApplyAt or 0)) < (_TW_MinApplyInterval or 0.85) then
        if not _TW_ApplyPending then
            _TW_ApplyPending = true
            task.delay(_TW_MinApplyInterval or 0.85, function()
                if not scriptRunning then return end
                if _TW_ApplyPending then
                    _TW_ApplyPending = false
                    pcall(_TW_ApplyAllCameraSkins)
                end
            end)
        end
        return
    end
    _TW_LastApplyAt = now
    _TW_ApplyDebounce = true
    task.spawn(function()
        task.wait(0.2)
        pcall(function()
            if Config.Skins.SkinChangerEnabled and IsAlive() then
                pcall(_applySelectedGloveSkin)
                local cam = workspace.CurrentCamera
                if cam then
                    local processed = 0
                    for _, obj in ipairs(cam:GetChildren()) do
                        if obj:IsA("Model") then
                            processed = processed + 1
                            local nm = obj.Name
                            if nm == "CT Knife" or nm == "T Knife" or nm == "Knife" then

                                pcall(_applyWeaponSkinCore, obj, nil)
                            else
                                local sn = Config.Skins.SelectedSkins[nm]
                                if sn and sn ~= "" and sn ~= "Vanilla" and sn ~= "Default" and sn ~= "None" then
                                    pcall(applyWeaponSkin, obj, sn)
                                end
                            end
                            if processed % 3 == 0 then EclipseYield() end
                        end
                    end
                end

                task.wait(0.15)
                pcall(_applySelectedGloveSkin)
            end
        end)
        _TW_ApplyDebounce = false
        if _TW_ApplyPending then
            _TW_ApplyPending = false
            task.delay(_TW_MinApplyInterval or 0.85, function()
                if scriptRunning then pcall(_TW_ApplyAllCameraSkins) end
            end)
        end
    end)
end

