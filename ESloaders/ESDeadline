function _espDrawArrow(data, root)
    local arrow = ensureESPArrow(data)
    if not arrow then return end
    local vs = Camera.ViewportSize
    local cx, cy = vs.X/2, vs.Y/2
    local sp = Camera:WorldToViewportPoint(root.Position)
    local sx, sy, behind = sp.X, sp.Y, (sp.Z <= 0)
    if behind then

        sx = vs.X - sx
        sy = vs.Y - sy
    end
    local dx, dy = sx - cx, sy - cy
    if dx == 0 and dy == 0 then dx = 0.0001 end
    local onScreen = (not behind) and sx >= 0 and sx <= vs.X and sy >= 0 and sy <= vs.Y
    if onScreen then
        arrow.Visible = false
        return
    end
    local ang = math.atan2(dy, dx)
    local rad = math.min(cx, cy) - 80
    local tipX = cx + math.cos(ang) * rad
    local tipY = cy + math.sin(ang) * rad
    local size = 12
    local fx, fy = math.cos(ang), math.sin(ang)
    local perpX, perpY = -fy, fx
    local baseX = tipX - fx * size * 1.8
    local baseY = tipY - fy * size * 1.8
    arrow.PointA = Vector2.new(tipX, tipY)
    arrow.PointB = Vector2.new(baseX + perpX*size, baseY + perpY*size)
    arrow.PointC = Vector2.new(baseX - perpX*size, baseY - perpY*size)
    arrow.Color = Config.ESP.ArrowsColor
    arrow.Filled = true
    arrow.Transparency = 1
    arrow.Visible = true
end

function _espDrawCornerBox(data, plr, L, R, T, B, cW, cH)
    local col
    if Config.ESP.VisibleCheck and not IsAlly(plr) then
        local ch = plr.Character
        local head = ch and (ch:FindFirstChild("Head") or ch:FindFirstChild("HumanoidRootPart"))
        local vis = head and IsVisible(head)
        col = vis and Config.ESP.VisibleBoxColor or Config.ESP.InvisibleBoxColor
    else
        col = IsAlly(plr) and Config.ESP.AllyBoxColor or Config.ESP.BoxColor
    end
    if typeof(col) ~= "Color3" then col = Color3.fromRGB(230, 45, 55) end

    local style   = tostring(Config.ESP.CornerBoxStyle or "Corner")
    local ln      = data.CornerLines
    local glow    = data.BoxGlow
    local glowOff = 1
    local shadow  = Color3.fromRGB(0, 0, 0)

    local function setLn(idx, thick, trans, from, to, c)
        ln[idx].Thickness   = thick
        ln[idx].Transparency= trans
        ln[idx].From        = from
        ln[idx].To          = to
        ln[idx].Color       = c
        ln[idx].Visible     = true
    end
    local function setGlow(idx, thick, trans, from, to, c, vis)
        glow[idx].Thickness   = thick
        glow[idx].Transparency= trans
        glow[idx].From        = from
        glow[idx].To          = to
        glow[idx].Color       = c
        glow[idx].Visible     = vis and true or false
    end

    if style == "Full" then
        setLn(1, 1.6, 1, Vector2.new(L,T), Vector2.new(R,T), col)
        setLn(2, 1.6, 1, Vector2.new(L,B), Vector2.new(R,B), col)
        setLn(3, 1.6, 1, Vector2.new(L,T), Vector2.new(L,B), col)
        setLn(4, 1.6, 1, Vector2.new(R,T), Vector2.new(R,B), col)
        for i = 5, 8 do ln[i].Visible = false end
        setGlow(1, 3, 0.72, Vector2.new(L-glowOff,T-glowOff), Vector2.new(R+glowOff,T-glowOff), shadow, true)
        setGlow(2, 3, 0.72, Vector2.new(L-glowOff,B+glowOff), Vector2.new(R+glowOff,B+glowOff), shadow, true)
        setGlow(3, 3, 0.72, Vector2.new(L-glowOff,T-glowOff), Vector2.new(L-glowOff,B+glowOff), shadow, true)
        setGlow(4, 3, 0.72, Vector2.new(R+glowOff,T-glowOff), Vector2.new(R+glowOff,B+glowOff), shadow, true)
        for i = 5, 8 do glow[i].Visible = false end
    elseif style == "Outline" then
        setLn(1, 1, 1, Vector2.new(L,T), Vector2.new(R,T), col)
        setLn(2, 1, 1, Vector2.new(L,B), Vector2.new(R,B), col)
