end

killESP = function(model)
    local s = ESPCache[model]; if not s then return end
    pcall(function() s.box:Remove() end)
    pcall(function() s.boxOut:Remove() end)
    for _,ln in _iter(s.corners) do pcall(function() ln:Remove() end) end
    pcall(function() s.name:Remove() end)
    pcall(function() s.dist:Remove() end)
    pcall(function() s.hp:Remove() end)
    pcall(function() s.hpBg:Remove() end)
    pcall(function() s.tracer:Remove() end)
    if s.arrow then pcall(function() s.arrow:Remove() end) end
    if s.chams then pcall(function() s.chams:Destroy() end) end
    ESPCache[model] = nil
end

-- Cleanup: iterate cache (not folder). Kills ESPs for models that left workspace.
task.spawn(function()
    while task.wait(0.5) do
        if not scriptRunning then break end
        for model,_ in pairs(ESPCache) do
            if not model or not model.Parent then killESP(model) end
        end
    end
end)

local function _drawCorner(lines, i1, i2, x1, y1, x2, y2, color)
    lines[i1].From = Vector2.new(x1, y1); lines[i1].To = Vector2.new(x2, y1); lines[i1].Color = color; lines[i1].Visible = true
    lines[i2].From = Vector2.new(x1, y1); lines[i2].To = Vector2.new(x1, y2); lines[i2].Color = color; lines[i2].Visible = true
end

RunService.RenderStepped:Connect(function()
    if not scriptRunning then return end
    if not Config.ESP.Enabled or not (Config.Global and Config.Global.Enabled) then
        for _,set in pairs(ESPCache) do _hideSet(set) end
        return
    end
    local folder = _charFolder(); if not folder then return end
    local cam = Workspace.CurrentCamera; if not cam then return end
    local viewport = cam.ViewportSize
    local camPos = cam.CFrame.Position

    -- Track live models this frame so we can hide anything stale
    local seen = {}

    for _, model in _iter(folder:GetChildren()) do
        if model.Name ~= LocalPlayer.Name and model:IsA("Model") then
            seen[model] = true
            local enemy = isEnemyChar(model)
            local hrp, hum, head = getCharParts(model)
            local set = ESPCache[model]

            local show = true
            if Config.ESP.TeamCheck and not enemy then show = false end
            if not hrp then show = false end
            if hrp and (hrp.Position - camPos).Magnitude > Config.ESP.MaxDistance then show = false end

            if not show then
                if set then _hideSet(set) end
            else
                set = set or makeESP(model)
                local top = head or hrp
                local topPos, onTop = worldToScreen(top.Position + Vector3.new(0, 0.8, 0))
                local botPos, onBot = worldToScreen(hrp.Position - Vector3.new(0, 3, 0))
                if not (onTop or onBot) then
                    -- off-screen: hide the on-screen elements but optionally show arrow
                    set.box.Visible=false; set.boxOut.Visible=false
                    for _,ln in _iter(set.corners) do ln.Visible=false end
                    set.name.Visible=false; set.dist.Visible=false
                    set.hp.Visible=false; set.hpBg.Visible=false
                    set.tracer.Visible=false
                    if set.chams then set.chams.Enabled=false end
                    if Config.ESP.Arrows and set.arrow then
                        local cx, cy = viewport.X/2, viewport.Y/2
                        local camCF = cam.CFrame
                        local toTarget = (hrp.Position - camPos)
                        if toTarget.Magnitude < 0.01 then toTarget = camCF.LookVector end
                        toTarget = toTarget.Unit
                        local right = camCF.RightVector
                        local up    = camCF.UpVector
                        local look  = camCF.LookVector
                        local dx =  toTarget:Dot(right)
                        local dy = -toTarget:Dot(up)
                        local fwd =  toTarget:Dot(look)
                        -- Se o alvo está atrás da câmera, inverte o vetor projetado
                        -- para que a seta aponte para trás do jogador corretamente.
                        if fwd < 0 then dx = -dx; dy = -dy end
                        local mag = math.sqrt(dx*dx + dy*dy)
                        if mag < 1e-4 then mag = 1e-4 end
                        dx, dy = dx/mag, dy/mag
                        local rad = math.min(cx, cy) - 80
                        local tipX = cx + dx * rad
                        local tipY = cy + dy * rad
                        local asize = 14
                        local perpX, perpY = -dy, dx
                        local baseX = tipX - dx * asize * 1.8
                        local baseY = tipY - dy * asize * 1.8
                        set.arrow.PointA = Vector2.new(tipX, tipY)
                        set.arrow.PointB = Vector2.new(baseX + perpX*asize, baseY + perpY*asize)
                        set.arrow.PointC = Vector2.new(baseX - perpX*asize, baseY - perpY*asize)
                        set.arrow.Color = Config.ESP.ArrowsColor
                        set.arrow.Filled = true; set.arrow.Transparency = 1; set.arrow.Visible = true
                    elseif set.arrow then set.arrow.Visible=false end
                else
                    if set.arrow then set.arrow.Visible=false end
                    local h = math.abs(topPos.Y - botPos.Y)
                    local w = h * 0.55
                    local x = (topPos.X + botPos.X)/2 - w/2
                    local y = math.min(topPos.Y, botPos.Y)
                    local size = Vector2.new(w, h)
                    local pos  = Vector2.new(x, y)
                    local baseColor = Config.ESP.BoxColor
                    if Config.ESP.UseTeamColors then baseColor = enemy and Config.ESP.EnemyColor or Config.ESP.AllyColor end
                    local boxColor = baseColor

                    if Config.ESP.Box then
                        if Config.ESP.BoxStyle == "Corner" then
                            set.box.Visible=false; set.boxOut.Visible=false
                            local clx = math.min(10, w*0.3); local cly = math.min(10, h*0.2)
                            local x2 = x + w; local y2 = y + h
                            _drawCorner(set.corners, 1, 2, x,       y,      x+clx,  y+cly, boxColor)
                            _drawCorner(set.corners, 3, 4, x2-clx,  y,      x2,     y+cly, boxColor)
                            set.corners[3].From=Vector2.new(x2-clx,y); set.corners[3].To=Vector2.new(x2,y)
                            set.corners[4].From=Vector2.new(x2,y);     set.corners[4].To=Vector2.new(x2,y+cly)
                            _drawCorner(set.corners, 5, 6, x,       y2-cly, x+clx,  y2,    boxColor)
                            set.corners[5].From=Vector2.new(x,y2);     set.corners[5].To=Vector2.new(x+clx,y2)
                            set.corners[6].From=Vector2.new(x,y2-cly); set.corners[6].To=Vector2.new(x,y2)
                            set.corners[7].From=Vector2.new(x2-clx,y2);set.corners[7].To=Vector2.new(x2,y2)
                            set.corners[8].From=Vector2.new(x2,y2-cly);set.corners[8].To=Vector2.new(x2,y2)
                            set.corners[7].Color=boxColor; set.corners[7].Visible=true
                            set.corners[8].Color=boxColor; set.corners[8].Visible=true
                        else
                            for _,ln in _iter(set.corners) do ln.Visible=false end
                            set.boxOut.Size=size; set.boxOut.Position=pos; set.boxOut.Visible=true
                            set.box.Size=size;    set.box.Position=pos;    set.box.Color=boxColor; set.box.Visible=true
                        end
                    else
                        set.box.Visible=false; set.boxOut.Visible=false
                        for _,ln in _iter(set.corners) do ln.Visible=false end
                    end

                    set.name.Visible=false

                    if Config.ESP.Distance then
                        local d = math.floor((camPos - hrp.Position).Magnitude)
                        set.dist.Position=Vector2.new(x + w/2, y + h + 2)
                        set.dist.Text=("[%dm]"):format(d); set.dist.Color=Color3.fromRGB(200,200,200); set.dist.Visible=true
                    else set.dist.Visible=false end

                    -- Health drawing removed per user request
                    set.hp.Visible=false; set.hpBg.Visible=false

                    if Config.ESP.Tracer then
                        set.tracer.From = Vector2.new(viewport.X/2, viewport.Y)
                        set.tracer.To   = Vector2.new(x + w/2, y + h)
                        set.tracer.Color = boxColor
                        set.tracer.Visible = true
                    else set.tracer.Visible = false end

                    if Config.ESP.Chams then
                        if not set.chams then
                            local hl = Instance.new("Highlight")
                            hl.FillTransparency = 0.55
                            hl.OutlineTransparency = 0
                            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            hl.Adornee = model
                            hl.Parent = model
                            set.chams = hl
                        end
                        set.chams.Enabled = true
                        set.chams.FillColor    = boxColor
                        set.chams.OutlineColor = boxColor
                    elseif set.chams then set.chams.Enabled = false end
                end
            end
        end
    end

    -- Hide/kill any cached ESP whose model isn't in the folder this frame
    for model, set in pairs(ESPCache) do
        if not seen[model] then killESP(model) end
    end
end)

