function GetCharacter(plr)
    if not plr then return nil end
    local char = plr.Character
    if char and char.Parent and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")) then
        return char
    end

    local chars = Characters or Workspace:FindFirstChild("Characters")
    if chars then
        Characters = chars
        local direct = chars:FindFirstChild(plr.Name)
        if direct and direct.Parent then return direct end
        for _, folder in ipairs(chars:GetChildren()) do
            local found = folder:FindFirstChild(plr.Name)
            if found and found.Parent then return found end
        end
    end
    return char
end
function IsAlly(plr)
    if _IS_DEATHMATCH then return false end
    if not plr or plr == LocalPlayer then return false end

    local hook = rawget(getgenv(), "_DL_IsTeammate")
    if type(hook) == "function" then
        local ok, res = pcall(hook, plr)
        if ok and type(res) == "boolean" then return res end
    end

    local Characters = Workspace:FindFirstChild("Characters")
    if not Characters then return false end
    local tFolder  = Characters:FindFirstChild("Terrorists")
    local ctFolder = Characters:FindFirstChild("Counter-Terrorists")
    local localTeam
    if tFolder and tFolder:FindFirstChild(LocalPlayer.Name) then
        localTeam = "T"
    elseif ctFolder and ctFolder:FindFirstChild(LocalPlayer.Name) then
        localTeam = "CT"
    else
        return false
    end
    if localTeam == "T" then
        return tFolder and tFolder:FindFirstChild(plr.Name) ~= nil
    else
        return ctFolder and ctFolder:FindFirstChild(plr.Name) ~= nil
    end
end
function IsEnemy(plr)
    if plr == LocalPlayer or not GetCharacter(plr) then return false end
    if _IS_DEATHMATCH then return true end
    if Config.TeamCheck then return not IsAlly(plr) end
    return true
end

function IsVisible(part)
    if not part then return false end
    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin)
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = { GetCharacter(LocalPlayer) }
    local r = Workspace:Raycast(origin, dir, rp)
    if r then return r.Instance:IsDescendantOf(part.Parent) end
    return true
end
