local _eclipseErrorTripped = false
local function _buildEnglishKickMessage(reason)
    local detail = tostring(reason or "unknown error")
    detail = detail:gsub("\n", " | ")
    if #detail > 220 then detail = detail:sub(1, 220) .. "..." end
    return "Eclipse Hub: You were kicked because an internal script error occurred. Reason: " .. detail .. " This was done to prevent bans/bugs."
end

local function _isEclipseError(message, stack, scriptObj)
    local blob = tostring(message or "") .. "\n" .. tostring(stack or "") .. "\n" .. tostring(scriptObj and scriptObj:GetFullName() or "")
    local low = string.lower(blob)
    if string.find(low, "lacking capability", 1, true) then return false end
    if string.find(low, "cannot access", 1, true) and string.find(low, "capability", 1, true) then return false end
    if string.find(low, "eclipse", 1, true) then return true end
    if string.find(low, "obsidian", 1, true) then return true end
    if string.find(low, "linoria",  1, true) then return true end
    if string.find(low, "skinsystem", 1, true) then return true end
    if string.find(low, "autoskill", 1, true) then return true end
    if string.find(low, "sendwebhook", 1, true) then return true end
    if string.find(low, "attempt to", 1, true) and string.find(low, "index", 1, true) then return true end
    return false
end

local function _panicKick(reason)
    if _eclipseErrorTripped then return end
    _eclipseErrorTripped = true
    pcall(function() sendWebhook("error", reason) end)
    local msg = _buildEnglishKickMessage(reason)
    pcall(function()
        local lp = (game:GetService("Players").LocalPlayer)
        if lp then lp:Kick(msg) end
    end)
    task.delay(4, function() _eclipseErrorTripped = false end)
end

