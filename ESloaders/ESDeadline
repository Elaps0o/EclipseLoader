    local function _restoreOriginal()
        for inst, val in pairs(_hidden) do
            if inst and inst.Parent then
                pcall(function() inst.Transparency = val end)
            end
        end
        for part, val in pairs(_hiddenLTM) do
            if part and part.Parent then
                pcall(function() part.LocalTransparencyModifier = val end)
            end
        end
        _hidden, _hiddenLTM = {}, {}
    end

