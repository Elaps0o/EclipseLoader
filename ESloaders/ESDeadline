    local function _applyLoadedAssets(model, cfg)
        local hum = model:FindFirstChildOfClass("Humanoid")

        for _, id in ipairs(cfg.clothing or {}) do
            for _, obj in ipairs(_loadAssetChildren(id)) do
                if obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic") then
                    local old = model:FindFirstChildOfClass(obj.ClassName)
                    if old then pcall(function() old:Destroy() end) end
                    obj.Parent = model
                elseif obj:IsA("Accessory") then
                    _attachAccessory(model, obj)
                elseif obj:IsA("Folder") or obj:IsA("Model") then
                    for _, sub in ipairs(obj:GetDescendants()) do
                        if sub:IsA("Shirt") or sub:IsA("Pants") or sub:IsA("ShirtGraphic") then
                            local old = model:FindFirstChildOfClass(sub.ClassName)
                            if old then pcall(function() old:Destroy() end) end
                            sub.Parent = model
                        elseif sub:IsA("Accessory") then
                            _attachAccessory(model, sub)
                        end
                    end
                    pcall(function() obj:Destroy() end)
                else
                    pcall(function() obj:Destroy() end)
                end
            end
        end

        local existing = {}
        for _, a in ipairs(model:GetDescendants()) do
            if a:IsA("Accessory") then existing[tostring(a.Name)] = true end
        end
        for _, id in ipairs(cfg.accessories or {}) do
            local added = false
            for _, obj in ipairs(_loadAssetChildren(id)) do
                if obj:IsA("Accessory") then
                    added = true
                    _attachAccessory(model, obj)
                elseif obj:IsA("Model") or obj:IsA("Folder") then
                    for _, sub in ipairs(obj:GetChildren()) do
                        if sub:IsA("Accessory") then
                            added = true
                            _attachAccessory(model, sub)
                        end
                    end
                    pcall(function() obj:Destroy() end)
                else
                    pcall(function() obj:Destroy() end)
                end
            end
            if not added then pcall(function() warn("[Eclipse CPM] asset failed: " .. tostring(id)) end) end
        end
    end

