                sh.Reflectance = 0
                sh.LocalTransparencyModifier = 0
                if sh:IsA("MeshPart") and sh.TextureID ~= "" then
                    sh.TextureID = ""
                end
                sh.Size = part.Size * (scale or 1.010)
            end)
        end
    end

    local function _syncWHShells(model, rec, color, inten)
        rec.shells = rec.shells or {}
        local a = math.clamp(inten or 1, 0.2, 3.0)
        local shellT = math.clamp(0.88 - a * 0.18, 0.55, 0.94)

        local scale  = 1.003 + math.clamp(a - 1, 0, 2) * 0.0015
        local eligible, seen = {}, {}
        for _, part in ipairs(model:GetDescendants()) do
            if _isWHPart(part, model) then
                eligible[part] = true
                seen[part] = true
                _ensureWHShell(rec, part, color, shellT, scale)
            end
        end

        for _, d in ipairs(model:GetDescendants()) do
            if d:IsA("BasePart")
               and (d:GetAttribute("EclipseWHShell") or d.Name == "EclipseWHShell") then
                local host = d.Parent
                if not (host and eligible[host]) then
                    pcall(function() d:Destroy() end)
                elseif rec.shells[host] and rec.shells[host] ~= d then
                    pcall(function() d:Destroy() end)
                end
            end
        end
        for part, shell in pairs(rec.shells) do
            if not seen[part] or not part.Parent then
                if shell then pcall(function() shell:Destroy() end) end
                rec.shells[part] = nil
            end
        end
    end

    local function _ensureHighlight(model, color, inten)
        if not model or not model.Parent then return end
        local rec = _highlights[model]
        if not rec then
            rec = {}

            rec.light = nil
            rec.lightHost = nil
            _highlights[model] = rec
        end
        local mixed = _whModelMixed(model)
        if mixed then

            if rec.fill then pcall(function() rec.fill:Destroy() end); rec.fill = nil end
            if rec.rim  then pcall(function() rec.rim:Destroy()  end); rec.rim  = nil end
        else
            if not (rec.rim and rec.rim.Parent) then
                rec.rim = Instance.new("Highlight")
                rec.rim.Name = "EclipseWHRim"
                rec.rim.Adornee = model
                rec.rim.DepthMode = Enum.HighlightDepthMode.Occluded
                rec.rim.Parent = model
            end
            if not (rec.fill and rec.fill.Parent) then
                rec.fill = Instance.new("Highlight")
                rec.fill.Name = "EclipseWH"
                rec.fill.Adornee = model

                rec.fill.DepthMode = Enum.HighlightDepthMode.Occluded
                rec.fill.Parent = model
            end
        end
        local a = math.clamp((inten or 1), 0.2, 3.0)

        local fillT = math.clamp(0.62 - a * 0.22, 0.08, 0.78)
        local outT  = math.clamp(0.22 - a * 0.18, 0.00, 0.40)
        local rimFT = math.clamp(0.78 - a * 0.22, 0.18, 0.88)
        local rimOT = math.clamp(0.42 - a * 0.30, 0.00, 0.70)
        if rec.fill and rec.rim then
            pcall(function()
                rec.fill.FillColor           = color
                rec.fill.OutlineColor        = color
                rec.fill.FillTransparency    = fillT
                rec.fill.OutlineTransparency = outT
                rec.rim.FillColor            = color
                rec.rim.OutlineColor         = color
                rec.rim.FillTransparency     = rimFT
                rec.rim.OutlineTransparency  = rimOT
            end)
        end
        _syncWHShells(model, rec, color, a)
    end

    connectSignal(RunS.Heartbeat:Connect(ES152.guard("WH.sync", function()
        if not scriptRunning then return end
        if not Config.Misc.WeaponHighlight then
            if next(_highlights) then _clearAll() end
            return
        end
        local lpChar = LocalPlayer and LocalPlayer.Character
        local hum = lpChar and lpChar:FindFirstChildOfClass("Humanoid")
        if not (lpChar and hum and hum.Health > 0 and workspace.CurrentCamera) then
            if next(_highlights) then _clearAll() end
            return
        end

        if not ES152.tick("WH.sync", 0.15) then return end
        local list = _collectVMWeapons()
        local active = {}
        for _, m in ipairs(list) do active[m] = true end
        for m,_ in pairs(_highlights) do
            if not active[m] or not m.Parent then _clearOne(m) end
        end
        local inten = tonumber(Config.Misc.WeaponHighlightIntensity) or 1.0
        if inten < 0.2 then inten = 0.2 end
        local col = Config.Misc.WeaponHighlightColor or Color3.fromRGB(0, 170, 255)
        for _, m in ipairs(list) do _ensureHighlight(m, col, inten) end
    end)))

end


