                        snd.SoundId = data.SoundId or snd.SoundId
                        snd.Volume = data.Volume or snd.Volume
                        snd.PlaybackSpeed = data.PlaybackSpeed or snd.PlaybackSpeed
                    else
                        snd.SoundId = data
                    end
                end)
                return
            end
            local inf = resolvePresetInfo(catName, weaponName)
            if inf then
                pcall(function()
                    snd.SoundId = inf.Id
                    snd.Volume = inf.Volume
                    snd.PlaybackSpeed = inf.Pitch
