                local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                local vis = head and IsVisible(head)
                chamsCol = vis and Config.ESP.VisibleChamsColor or Config.ESP.InvisibleChamsColor
            end

            hl.FillColor           = chamsCol
            hl.OutlineColor        = chamsCol
            hl.FillTransparency    = baseFillT
            hl.OutlineTransparency = math.max(0.02, baseOutT)

            local lt = ChamsLT[plr]
            if not lt or not lt.Parent then
                if lt then pcall(function() lt:Destroy() end) end
