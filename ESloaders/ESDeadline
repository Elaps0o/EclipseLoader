    _G.EclipseInstallSilentBypass = function()
        if installed then return true end
        installed = true
        local ok, err = pcall(function()
        local hookfn = hookfunction or (oth and oth.hook) or hookfunc
        assert(hookfn, "executor missing hookfunction/oth.hook")
        assert(getgc, "executor missing getgc")
        assert(rawget, "executor missing rawget")

        local Players     = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local Workspace   = game:GetService("Workspace")
        local RunService  = game:GetService("RunService")

        local _tsTarget = nil

        local function _tsClosestHead()
            local cam = Workspace.CurrentCamera
            if not cam then return nil end
            local myTeam = LocalPlayer:GetAttribute("Team")
            local lchar  = LocalPlayer.Character
            if not lchar or not lchar:FindFirstChild("Head") then return nil end
            local best, bestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer then
                    local char = v.Character
                    if char and not char:GetAttribute("Dead")
                       and v:GetAttribute("Team") ~= myTeam then
                        local head = char:FindFirstChild("Head")
                        if head then
                            local sp, on = cam:WorldToViewportPoint(head.Position)
                            if on then
                                local d = (Vector2.new(sp.X, sp.Y) - cam.ViewportSize/2).Magnitude
                                if d < bestDist then
                                    bestDist = d
                                    best = head
                                end
                            end
                        end
                    end
                end
            end
            return best
        end

        connectSignal(RunService.RenderStepped:Connect(function()
            if not scriptRunning then return end
            if Config and Config.Misc and Config.Misc.SilentAim then
                _tsTarget = _tsClosestHead()
            else
                _tsTarget = nil
            end
        end))

        for _, v in next, getgc(true) do
            if type(v) == "table" and rawget(v, "cast") then
                local _old
                _old = hookfn(v.cast, function(...)
                    local args = {...}
                    if scriptRunning and Config and Config.Misc and Config.Misc.SilentAim
                       and args[2] and typeof(args[2]) == "Vector3" and _tsTarget then
                        local origin = args[1]
                        args[2] = (_tsTarget.Position - origin)
                    end
                    return _old(unpack(args))
                end)
            end
        end
        end)
        if not ok then
            installed = false
            warn("[Eclipse] Silent bypass skipped: "..tostring(err))
        end
        return ok
    end
end

