-- TRIGGER BOT (Xeno-style per-part screen check)
-- =====================================================
local _trigLast = 0
local TRIG_PARTS = { "head", "torso", "humanoid_root_part" }
task.spawn(function()
    while task.wait(0.02) do
        if not scriptRunning then break end
        local doRun = Config.Trigger.Enabled and Config.Global and Config.Global.Enabled
        if doRun and (tick() - _trigLast >= Config.Trigger.Delay) then
            local cam = Workspace.CurrentCamera
            local folder = _charFolder()
            if cam and folder then
                local mousePos = getMouseDrawingPos()
                local inset = Vector2.new(0,0); pcall(function() inset = GuiService:GetGuiInset() end)
                local mouseVP = mousePos - inset
                local fov = Config.Trigger.FOV or 25
                local lc = _localCharacter()
                local fired = false
                for _, model in _iter(folder:GetChildren()) do
                    if fired then break end
                    if model:IsA("Model") and model ~= lc and model.Name ~= LocalPlayer.Name
                       and not (Config.Trigger.TeamCheck and not isEnemyChar(model)) then
                        for _, pn in _iter(TRIG_PARTS) do
                            local p = model:FindFirstChild(pn)
                            if p and p:IsA("BasePart") then
                                local sp, on = cam:WorldToViewportPoint(p.Position)
                                local dxs = (Config.Trigger.Spread or 0)
                                local jitter = dxs > 0 and Vector2.new((math.random()*2-1)*dxs, (math.random()*2-1)*dxs) or Vector2.new(0,0)
                                if on and sp.Z > 0 and (Vector2.new(sp.X, sp.Y) - mouseVP + jitter).Magnitude < fov then
                                    local params = RaycastParams.new()
                                    params.FilterType = Enum.RaycastFilterType.Exclude
                                    local ig = {}
                                    if LocalPlayer.Character then table.insert(ig, LocalPlayer.Character) end
                                    if lc then table.insert(ig, lc) end
                                    params.FilterDescendantsInstances = ig
                                    local dir = p.Position - cam.CFrame.Position
                                    local r = Workspace:Raycast(cam.CFrame.Position, dir, params)
                                    local wallOk = (not r) or r.Instance:IsDescendantOf(model)
                                    local hcRoll = math.random(1,100) <= (Config.Trigger.HitChance or 100)
                                    if wallOk and hcRoll then
                                        _trigLast = tick()
                                        fired = true
                                        pcall(function()
                                            if _EclipseIsMobile and _EclipseMobileFire then
                                                _EclipseMobileFire()
                                            else
                                                mouse1press(); task.wait(0.03); mouse1release()
                                            end
                                        end)
                                        break
                                    end
                                end
                            end

                        end
                    end
                end
            end
        end
    end
end)

